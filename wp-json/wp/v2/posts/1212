{"id":1212,"date":"2026-03-28T21:53:35","date_gmt":"2026-03-28T12:53:35","guid":{"rendered":"https:\/\/shootsense.com\/?p=1212"},"modified":"2026-06-12T14:19:32","modified_gmt":"2026-06-12T05:19:32","slug":"%ea%b4%80%ea%b4%91%ea%b0%9d%ec%9d%b4-%ec%a0%81%ec%96%b4-%ed%98%84%ec%a7%80%ec%9d%98-%ec%86%8d%eb%8f%84%eb%a5%bc-%eb%8a%90%eb%82%80-%ec%95%84%eb%a5%b4%ed%83%80","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ea%b4%80%ea%b4%91%ea%b0%9d%ec%9d%b4-%ec%a0%81%ec%96%b4-%ed%98%84%ec%a7%80%ec%9d%98-%ec%86%8d%eb%8f%84%eb%a5%bc-%eb%8a%90%eb%82%80-%ec%95%84%eb%a5%b4%ed%83%80\/","title":{"rendered":"\uadf8\ub9ac\uc2a4 \uc544\ub974\ud0c0 \ud63c\uc790 \uc5ec\ud589: \uad00\uad11\uac1d\uc774 \uc801\uc740 \ub3c4\uc2dc\ub97c \uc548\uc815\uc801\uc73c\ub85c \uac77\ub294 \ubc95"},"content":{"rendered":"\n<p>\uc544\ub974\ud0c0\ub294 \uadf8\ub9ac\uc2a4 \uc5ec\ud589\uc5d0\uc11c \uac00\uc7a5 \uba3c\uc800 \ub5a0\uc62c\ub9ac\ub294 \ub3c4\uc2dc\ub294 \uc544\ub2c8\ub2e4. \uadf8\ub798\uc11c \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uad00\uad11\uac1d \ud750\ub984\ubcf4\ub2e4 \ud604\uc9c0\uc758 \uc18d\ub3c4\uc5d0 \ub9de\ucdb0 \uac78\uc744 \uc218 \uc788\uace0, \uc77c\uc815\ub3c4 \ube44\uad50\uc801 \ucc28\ubd84\ud558\uac8c \uad6c\uc131\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uadf8\ub9ac\uc2a4 \uc544\ub974\ud0c0\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c\ud55c \uac10\uc0c1\uc774\ub098 \ucd94\ucc9c \ubaa9\ub85d\uc774 \uc544\ub2c8\ub77c \uad50\ud1b5, \uc219\uc18c, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \ud558\ub8e8\ub97c \uc124\uacc4\ud558\ub294 \ub370 \ucd08\uc810\uc744 \ub454\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uadf8\ub9ac\uc2a4 \uc544\ub974\ud0c0 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\uc544\ub974\ud0c0\ub294 \uc720\uba85 \uba85\uc18c\ub97c \ubab0\uc544\ubcf4\ub294 \ub3c4\uc2dc\uac00 \uc544\ub2c8\ub77c \uc2dc\ub0b4\uc640 \uc8fc\ubcc0 \uc0dd\ud65c\uad8c\uc744 \uae30\uc900\uc73c\ub85c \uccb4\ub958\uac10\uc744 \ubcf4\ub294 \uacf3\uc774\ub2e4. \uad50\ud1b5\ud3b8\uacfc \uc219\uc18c \uc704\uce58\ub97c \uba3c\uc800 \uc815\ud558\uba74 \ud558\ub8e8 \ub610\ub294 1\ubc15 \uc77c\uc815\uc73c\ub85c \uc548\uc815\uc801\uc73c\ub85c \ubcfc \uc218 \uc788\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \uc911\uc694\ud55c \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uadf8\ub9ac\uc2a4 \uc18c\ub3c4\uc2dc \uc0b0\ucc45, \ud604\uc9c0 \uc0dd\ud65c\uad8c \uad00\ucc30, \uc870\uc6a9\ud55c 1\ubc15 \uc77c\uc815<\/td><td>\ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \uc870\uc6a9\ud55c \uc2dc\uac04\uc744 \uc2e4\ud328\ub85c \ubcf4\uc9c0 \uc54a\ub294\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\ubc84\uc2a4 \uc774\ub3d9, \ud130\ubbf8\ub110 \uc704\uce58, \ub2e4\uc74c \ub3c4\uc2dc \uc5f0\uacb0\ud3b8 \ud655\uc778<\/td><td>\ud63c\uc790 \uc774\ub3d9\ud560 \ub54c\ub294 \ud658\uc2b9\uacfc \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc9c1\uc811 \uad00\ub9ac\ud574\uc57c \ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ud558\ub8e8 \ub610\ub294 1\ubc15 \uad8c\uc7a5, \uc774\ub3d9 \uc911\uac04 \uac70\uc810\uc73c\ub85c\ub3c4 \uac80\ud1a0 \uac00\ub2a5<\/td><td>\ub3c4\ucc29 \uc2dc\uac04\uacfc \uc2dd\uc0ac \uc2dc\uac04\uc5d0 \ub530\ub77c \uccb4\uac10 \ub9cc\uc871\ub3c4\uac00 \ud06c\uac8c \ubc14\ub010\ub2e4<\/td><\/tr><tr><td>\ud575\uc2ec \ubcc0\uc218<\/td><td>\ubc84\uc2a4 \uc2dc\uac04\ud45c, \ud55c\ub0ae \ub354\uc704, \uc2dd\ub2f9 \uc601\uc5c5 \uc2dc\uac04, \uc800\ub141 \uc774\ub3d9<\/td><td>\uc791\uc740 \ubaa9\uc801\uc9c0\ub294 \ub0a0\uc528, \ud734\ubb34, \uad50\ud1b5 \uac04\uaca9\uc758 \uc601\ud5a5\uc774 \ud06c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc544\ub974\ud0c0\uac00 \ud63c\uc790\uc5d0\uac8c \ud3b8\uc548\ud55c \uc774\uc720<\/h2>\n\n\n\n<p>\uc544\ub974\ud0c0\ub294 \uad00\uad11\uac1d\uc744 \ub530\ub77c \uc6c0\uc9c1\uc774\ub294 \uc555\ubc15\uc774 \uc801\uc5b4 \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \uc790\uae30 \uc18d\ub3c4\ub85c \uac77\uae30 \uc88b\ub2e4. \ub300\uc2e0 \uc815\ubcf4\uac00 \ub9ce\uc9c0 \uc54a\uc740 \ub3c4\uc2dc\uc774\ubbc0\ub85c \uad50\ud1b5\uacfc \uc219\uc18c\ub97c \ubbf8\ub9ac \ud655\uc778\ud574\uc57c \uc77c\uc815\uc774 \ud754\ub4e4\ub9ac\uc9c0 \uc54a\ub294\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uad00\uad11\uc9c0\uc758 \uc720\uba85\ub3c4\ubcf4\ub2e4 \ud63c\uc790 \uc788\uc5b4\ub3c4 \uc2dc\uac04\uc774 \uc790\uc5f0\uc2a4\ub7fd\uac8c \ud750\ub974\ub294\uc9c0\uac00 \ub354 \uc911\uc694\ud558\ub2e4. \uc0ac\ub78c\uc774 \ub9ce\uc9c0 \uc54a\uc740 \ubaa9\uc801\uc9c0\ub294 \uacc4\ud68d\uc774 \uc57d\ud558\uba74 \uc2ec\uc2ec\ud574\uc9c0\uc9c0\ub9cc, \uae30\uc900\uc810\uc744 \uc7a1\uc73c\uba74 \uc624\ud788\ub824 \ud3b8\uc548\ud55c \uccb4\ub958\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc84\uc2a4 \uc2dc\uac04\ud45c\uac00 \uc77c\uc815\uc758 \uc911\uc2ec\uc774 \ub418\ub294 \ub3c4\uc2dc<\/h2>\n\n\n\n<p>\uc544\ub974\ud0c0\ub294 \ub300\ub3c4\uc2dc\ucc98\ub7fc \uad50\ud1b5 \uc120\ud0dd\uc9c0\uac00 \ub9ce\uc9c0 \uc54a\uc744 \uc218 \uc788\ub2e4. \ub3c4\ucc29 \ud130\ubbf8\ub110\uacfc \uc219\uc18c \uac70\ub9ac, \ub2e4\uc74c \ubaa9\uc801\uc9c0\ub85c \uac00\ub294 \ubc84\uc2a4 \uc2dc\uac04\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uad6c\uac04<\/th><th>\uba3c\uc800 \ud655\uc778\ud560 \uac83<\/th><th>\ud604\uc7a5 \ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ucd9c\ubc1c \uc804<\/td><td>\uacf5\uc2dd \uad50\ud1b5\ud3b8\uacfc \ub9c8\uc9c0\ub9c9 \ubcf5\uadc0 \uc2dc\uac04<\/td><td>\ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \uc801\uc73c\uba74 \uc77c\uc815 \uc804\uccb4\ub97c \uc55e\ub2f9\uae34\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \uc815\ub958\uc7a5, \uc219\uc18c, \uc911\uc2ec \uac70\ub9ac \uc704\uce58<\/td><td>\uae38\uc744 \uc783\uc5c8\uc744 \ub54c \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\ub0ae \uc2dc\uac04<\/td><td>\ub300\ud45c \uc0b0\ucc45 \uad6c\uac04\uacfc \uc2dd\uc0ac \ud6c4\ubcf4<\/td><td>\uac00\uc7a5 \ubc1d\uace0 \uc774\ub3d9\ud558\uae30 \uc26c\uc6b4 \uc2dc\uac04\uc5d0 \ud575\uc2ec \uad6c\uac04\uc744 \ubcf8\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4 \ud6c4\ubc18<\/td><td>\uc778\uc801, \uc870\uba85, \ub2e4\uc74c \uc774\ub3d9\ud3b8<\/td><td>\ud63c\uc790\ub77c\uba74 \ud574\uc9c0\uae30 \uc804 \ubcf5\uadc0 \ud750\ub984\uc744 \ud655\uc815\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ud55c\ub0ae \ub354\uc704\ub97c \ud53c\ud558\ub294 \uac77\uae30 \ubc29\uc2dd<\/h2>\n\n\n\n<p>\uc2dc\ub0b4 \uc911\uc2ec\ubd80\uc640 \uc219\uc18c \uc8fc\ubcc0\uc744 \uae30\uc900\uc73c\ub85c \ub3d9\uc120\uc744 \uc881\uac8c \uc7a1\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ud55c\ub0ae\uc5d0\ub294 \ub354\uc704\uac00 \ubd80\ub2f4\ub420 \uc218 \uc788\uc73c\ubbc0\ub85c \uc624\uc804\uacfc \ub2a6\uc740 \uc624\ud6c4\uc5d0 \uac77\uace0, \ub0ae\uc5d0\ub294 \uc2dd\uc0ac\uc640 \ud734\uc2dd\uc744 \ub123\ub294 \ubc29\uc2dd\uc774 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<p>\uc5ec\ub7ec \uc9c0\uc810\uc744 \ube60\ub974\uac8c \uc5f0\uacb0\ud558\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \uc911\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \uc815\ud574 \ubc18\ubcf5\ud574\uc11c \uac77\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\ub2e4. \ud63c\uc790\ub77c\uba74 \uc77c\uc815\uc744 \ub113\ud788\ub294 \uac83\ubcf4\ub2e4 \uc904\uc77c \uc218 \uc788\ub294 \uad6c\uc870\ub97c \ub9cc\ub4dc\ub294 \uac83\uc774 \ub354 \uc911\uc694\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud130\ubbf8\ub110\uacfc \uc911\uc2ec\ubd80 \uc0ac\uc774 \uc219\uc18c\uac00 \uc720\ub9ac\ud55c \uc774\uc720<\/h2>\n\n\n\n<p>1\ubc15\uc744 \ud55c\ub2e4\uba74 \ud130\ubbf8\ub110\uacfc \uc911\uc2ec\ubd80 \uc0ac\uc774\uc758 \uc811\uadfc\uc131\uc744 \uc6b0\uc120\ud55c\ub2e4. \ub108\ubb34 \uc678\uacfd\uc758 \uc219\uc18c\ub294 \uac00\uaca9\uc774 \uc88b\uc544\ub3c4 \uc2dd\uc0ac\uc640 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \uac00\uaca9\ubcf4\ub2e4 \ubcf5\uadc0 \ub3d9\uc120\uacfc \uc2dd\uc0ac \uc811\uadfc\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc870\uc6a9\ud55c \uc678\uacfd \uc219\uc18c\uac00 \ub9e4\ub825\uc801\uc73c\ub85c \ubcf4\uc5ec\ub3c4 \ubc24 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud558\uba74 \ud63c\uc790 \uc5ec\ud589\uc758 \ud53c\ub85c\uac00 \ud06c\uac8c \ub298\uc5b4\ub09c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc791\uc740 \ub3c4\uc2dc\uc5d0\uc11c \uc2dd\uc0ac \uacf5\ubc31\uc744 \uc904\uc774\ub294 \ubc95<\/h2>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc911\uc2ec\ubd80\uc5d0\uc11c \ud574\uacb0\ud558\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4. \uadf8\ub9ac\uc2a4 \uc18c\ub3c4\uc2dc\ub294 \ub2a6\uc740 \uc2dd\uc0ac \ubb38\ud654\uac00 \uc788\uc744 \uc218 \uc788\uc73c\ubbc0\ub85c \ud63c\uc790\ub77c\uba74 \uc810\uc2ec\uacfc \uc800\ub141 \uc0ac\uc774 \uacf5\ubc31\uc744 \ub300\ube44\ud574 \uac04\ub2e8\ud55c \uac04\uc2dd\uc744 \uc900\ube44\ud558\ub294 \uac83\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub3c4\uc2dc\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc218\ubcf4\ub2e4 \uc601\uc5c5 \uc2dc\uac04\uacfc \uc26c\ub294 \ub0a0 \ud655\uc778\uc774 \uc911\uc694\ud558\ub2e4. \ud63c\uc790\ub77c\uba74 \uae34 \ub300\uae30\ub97c \ud53c\ud558\uae30 \uc704\ud574 \uc810\uc2ec \ud6c4\ubcf4\uc640 \uc26c\uc5b4\uac08 \uc7a5\uc18c\ub97c \ub530\ub85c \ud655\ubcf4\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc870\uc6a9\ud55c \ub3c4\uc2dc\uc5d0\uc11c \ud53c\ub85c\uac00 \uc313\uc774\ub294 \uc21c\uac04<\/h2>\n\n\n\n<p>\uad00\uad11\uac1d\uc774 \uc801\ub2e4\ub294 \uc810\uc740 \uc870\uc6a9\ud558\ub2e4\ub294 \uc7a5\uc810\uacfc \uc815\ubcf4 \ubd80\uc871\uc774\ub77c\ub294 \ub2e8\uc810\uc744 \ub3d9\uc2dc\uc5d0 \ub9cc\ub4e0\ub2e4. \ub2a6\uc740 \uc2dc\uac04 \uc678\uacfd \uc774\ub3d9\uc744 \uc904\uc774\uace0, \uc219\uc18c \uc8fc\ubcc0\uc758 \ubc1d\uc740 \uae38\uacfc \uc911\uc2ec \uac70\ub9ac\ub97c \uae30\uc900\uc73c\ub85c \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc758 \uc548\uc804\uc740 \uc704\ud5d8\ud55c \uc7a5\uc18c\ub97c \ud53c\ud558\ub294 \uac83\ub9cc\uc774 \uc544\ub2c8\ub77c, \ud53c\uace4\ud574\uc84c\uc744 \ub54c \ubc14\ub85c \uc77c\uc815\uc744 \uc904\uc77c \uc218 \uc788\ub294 \uad6c\uc870\ub97c \ub9cc\ub4dc\ub294 \uac83\uc774\ub2e4. \uc911\uc2ec \uac70\ub9ac\uc640 \uad50\ud1b5 \uac70\uc810\uc744 \uacc4\uc18d \uc758\uc2dd\ud558\uba74 \ud604\uc7a5 \ud310\ub2e8\uc774 \uc26c\uc6cc\uc9c4\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc544\ub974\ud0c0\uc5d0\uc11c 1\ubc15\uc744 \ud560 \uac00\uce58\uac00 \uc0dd\uae30\ub294 \ub54c<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \ubc84\uc2a4 \uc774\ub3d9\uacfc \uc219\ubc15\ube44 \uc911\uc2ec\uc73c\ub85c \uacc4\uc0b0\ud55c\ub2e4. \ub300\ud615 \uad00\uad11\uc9c0\ubcf4\ub2e4 \uc18c\ube44 \uc555\ubc15\uc740 \ub0ae\uc744 \uc218 \uc788\uc9c0\ub9cc, \uc774\ub3d9 \uc120\ud0dd\uc9c0\uac00 \uc801\uc73c\uba74 \uc2dc\uac04 \ube44\uc6a9\uc774 \ucee4\uc9c4\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uc774\ub3d9 \ubc29\uc2dd\uacfc \uc219\uc18c \uc704\uce58\uc5d0\uc11c \ub354 \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \ub2f9\uc77c\uce58\uae30\ub294 \ube44\uc6a9\uc774 \ub0ae\uc9c0\ub9cc \uccb4\ub958 \uc2dc\uac04\uc774 \uc9e7\uace0, 1\ubc15\uc740 \ube44\uc6a9\uc774 \ub298\uc9c0\ub9cc \uac00\uc7a5 \uc870\uc6a9\ud55c \uc2dc\uac04\ub300\ub97c \ubcfc \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc544\ub974\ud0c0\ub97c \uc9c0\ub098\uac00\ub294 \ub3c4\uc2dc\ub85c\ub9cc \uc4f0\ub294 \uc2e4\uc218<\/h2>\n\n\n\n<p>\uc544\ub974\ud0c0\ub97c \ub2e8\uc21c\ud788 \uc9c0\ub098\uac00\ub294 \ub3c4\uc2dc\ub85c\ub9cc \ubcf4\uace0 \ub3c4\ucc29 \ub2f9\uc77c \ub2a6\uac8c \ub4e4\uc5b4\uc624\ub294 \uc77c\uc815\uc740 \ud53c\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ucd5c\uc18c\ud55c \ub0ae \uc2dc\uac04 \uc0b0\ucc45\uc744 \ud655\ubcf4\ud574\uc57c \ub3c4\uc2dc\uc758 \uc7a5\uc810\uc774 \ubcf4\uc778\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud604\uc9c0\uc758 \uc18d\ub3c4\ub97c \uc5ec\ud589\uc73c\ub85c \ubc1b\uc544\ub4e4\uc774\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\uadf8\ub9ac\uc2a4\uc758 \uc720\uba85 \uc12c\uc774\ub098 \ub300\ub3c4\uc2dc\ubcf4\ub2e4 \uc870\uc6a9\ud55c \ub0b4\ub959 \ub3c4\uc2dc\uc758 \ubd84\uc704\uae30\ub97c \ubcf4\uace0 \uc2f6\uc740 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \uad00\uad11\uac1d\uc774 \uc801\uc740 \uc7a5\uc18c\uc5d0\uc11c\ub3c4 \ud3b8\ud558\uac8c \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub294 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc544\ub974\ud0c0 \uccb4\ub958\ub97c \uacb0\uc815\ud558\ub294 \uae30\uc900<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\uc544\ub974\ud0c0\ucc98\ub7fc \uc870\uc6a9\ud55c \ub3c4\uc2dc\uc5d0\uc11c \uc77c\uc815\uc774 \ub354 \uc911\uc694\ud574\uc9c0\ub294 \uc774\uc720<\/h2>\n<p>\uad00\uad11\uac1d\uc774 \ub9ce\uc740 \ub3c4\uc2dc\uc5d0\uc11c\ub294 \uc815\ubcf4\uac00 \ubd80\uc871\ud574\ub3c4 \ud750\ub984\uc5d0 \uc62c\ub77c\ud0c0\uae30 \uc27d\uc9c0\ub9cc, \uc544\ub974\ud0c0\ucc98\ub7fc \uc870\uc6a9\ud55c \ub3c4\uc2dc\ub294 \uc2a4\uc2a4\ub85c \uad6c\uc870\ub97c \ub9cc\ub4e4\uc5b4\uc57c \ud569\ub2c8\ub2e4. \ubc84\uc2a4 \uc2dc\uac04\ud45c, \uc2dd\uc0ac \uac00\ub2a5 \uc2dc\uac04, \uac77\uae30 \uc88b\uc740 \uad6c\uac04\uacfc \ud53c\uace4\ud574\uc9c0\ub294 \uad6c\uac04\uc744 \ubcf8\uc778\uc774 \uc815\ub9ac\ud558\uc9c0 \uc54a\uc73c\uba74 \ud558\ub8e8\uac00 \uc27d\uac8c \ub290\uc2a8\ud574\uc9d1\ub2c8\ub2e4. \uadf8\ub798\uc11c \uc544\ub974\ud0c0\uc758 \ub9cc\uc871\ub3c4\ub294 \ubcfc\uac70\ub9ac \uc218\ubcf4\ub2e4 \uc6b4\uc601\uc758 \uc815\ub3c8\ub3c4\uc5d0 \uac00\uae5d\uc2b5\ub2c8\ub2e4. \uc870\uc6a9\ud55c \ub3c4\uc2dc\uc77c\uc218\ub85d \uc5ec\ud589\uc790\ub294 \ub354 \ub2a5\ub3d9\uc801\uc73c\ub85c \uae30\uc900\uc744 \uc138\uc6cc\uc57c \ud569\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc544\ub974\ud0c0\ub97c \uc9e7\uac8c \ub4e4\ub97c \ub54c\uc640 1\ubc15\ud560 \ub54c \ud310\ub2e8\uc774 \ub2ec\ub77c\uc9c0\ub294 \uc9c0\uc810<\/h2>\n<p>\uc9e7\uac8c \ub4e4\ub97c \uacbd\uc6b0\uc5d0\ub294 \uc911\uc2ec\ubd80 \uc0b0\ucc45\uacfc \uc2dd\uc0ac, \ub2e4\uc74c \uc774\ub3d9 \uc5f0\uacb0\ub9cc \ub9e4\ub044\ub7fd\uac8c \uc774\uc5b4\uc838\ub3c4 \ucda9\ubd84\ud558\uc9c0\ub9cc, 1\ubc15\uc774 \ub418\uba74 \uc800\ub141\uacfc \uc544\uce68\uc758 \ub9ac\ub4ec\uae4c\uc9c0 \ud568\uaed8 \ud3c9\uac00\ud574\uc57c \ud569\ub2c8\ub2e4. \uc219\uc18c \uc704\uce58\uac00 \uc5b4\uc911\uac04\ud558\uac70\ub098 \uc57c\uac04 \ub3d9\uc120\uc774 \uc560\ub9e4\ud558\uba74, \ub3c4\uc2dc \uc790\uccb4\uac00 \uc870\uc6a9\ud55c \ub9cc\ud07c \ubd88\ud3b8\uc774 \ub354 \ud06c\uac8c \ub290\uaef4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \ub9ac\ub4ec\uc774 \ub9de\ub294 \uc0ac\ub78c\uc5d0\uac8c\ub294 \uc18c\ub3c4\uc2dc \ud2b9\uc720\uc758 \uc548\uc815\uac10\uc774 \uac15\uc810\uc774 \ub429\ub2c8\ub2e4. \uacb0\uad6d \uc544\ub974\ud0c0\ub294 \ud654\ub824\ud568\ubcf4\ub2e4 \uccb4\ub958 \uad6c\uc870\uc758 \uc815\uc9c1\ud568\uc73c\ub85c \ud3c9\uac00\ud574\uc57c \ud558\ub294 \uacf3\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc544\ub974\ud0c0\uc5d0\uc11c \uc2e4\uc81c\ub85c \uc911\uc694\ud55c \uc2dc\uac04\ub300<\/h2>\n\n\n\n<p>\uc774 \ub3c4\uc2dc\uc758 \uc7a5\uc810\uc740 \ud55c\ub0ae\ubcf4\ub2e4 \uc624\uc804\uacfc \ub2a6\uc740 \uc624\ud6c4\uc5d0 \ub354 \uc798 \ub4dc\ub7ec\ub09c\ub2e4. \uadf8\ub798\uc11c \uc9e7\uac8c \ub4e4\ub974\ub354\ub77c\ub3c4 \uac00\uc7a5 \ub354\uc6b4 \uc2dc\uac04\uc744 \uc774\ub3d9\uc73c\ub85c \uc4f0\uc9c0 \uc54a\uace0, \uac77\uae30 \uc88b\uc740 \uc2dc\uac04\ub300\ub97c \ub3c4\uc2dc \uc911\uc2ec \uad6c\uac04\uc5d0 \ub0a8\uaca8\ub450\ub294 \ud3b8\uc774 \ud6e8\uc52c \ub0ab\ub2e4.<\/p>\n\n\n\n\n\n<p>\uadf8\ub9ac\uc2a4 \uc544\ub974\ud0c0\ub294 \ud654\ub824\ud55c \ubaa9\uc801\uc9c0\ub294 \uc544\ub2c8\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \ud604\uc9c0\uc758 \uc18d\ub3c4\ub97c \ub290\ub07c\uae30 \uc88b\uc740 \uc18c\ub3c4\uc2dc\ub2e4. \ubc84\uc2a4 \uc2dc\uac04\uacfc \uc219\uc18c \uc704\uce58, \ud55c\ub0ae \ub354\uc704\ub9cc \uad00\ub9ac\ud558\uba74 \uc548\uc815\uc801\uc778 \uccb4\ub958\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uadf8\ub9ac\uc2a4 \uc544\ub974\ud0c0 \ud63c\uc790 \uc5ec\ud589\uc744 \uc704\ud55c \uad50\ud1b5, \uc219\uc18c, \uc2dd\uc0ac, \uc2dc\ub0b4 \uc0b0\ucc45, \uc548\uc804\uacfc \uccb4\ub958 \uc2dc\uac04 \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc2e4\uc804 \uac00\uc774\ub4dc.<\/p>\n","protected":false},"author":1,"featured_media":1213,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-m