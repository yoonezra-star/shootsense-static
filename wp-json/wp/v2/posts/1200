{"id":1200,"date":"2026-03-23T21:25:41","date_gmt":"2026-03-23T12:25:41","guid":{"rendered":"https:\/\/shootsense.com\/?p=1200"},"modified":"2026-06-12T14:06:20","modified_gmt":"2026-06-12T05:06:20","slug":"%eb%8b%a4%ec%8b%9c-%ea%b0%80%ea%b3%a0-%ec%8b%b6%eb%8b%a4%eb%8a%94-%ec%83%9d%ea%b0%81%ec%9d%b4-%eb%93%a0-%ec%9d%b4%ec%9c%a0-%ec%97%86%eb%8a%94-%ed%9e%88%eb%8b%a4%ed%9b%84%eb%a3%a8%ec%b9%b4%ec%99%80","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%eb%8b%a4%ec%8b%9c-%ea%b0%80%ea%b3%a0-%ec%8b%b6%eb%8b%a4%eb%8a%94-%ec%83%9d%ea%b0%81%ec%9d%b4-%eb%93%a0-%ec%9d%b4%ec%9c%a0-%ec%97%86%eb%8a%94-%ed%9e%88%eb%8b%a4%ed%9b%84%eb%a3%a8%ec%b9%b4%ec%99%80\/","title":{"rendered":"\uc77c\ubcf8 \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640 \ud63c\uc790 \uc5ec\ud589: \ub2e4\uc2dc \uac00\uace0 \uc2f6\uc5b4\uc9c0\ub294 \uc870\uc6a9\ud55c \ub9c8\uc744 \uae30\uc900"},"content":{"rendered":"\n<p>\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub294 \uac15\ud55c \uc774\uc720 \ud558\ub098\ub85c \uc124\uba85\ud558\uae30\ubcf4\ub2e4, \uac77\uace0 \ub09c \ub4a4 \ub2e4\uc2dc \ub5a0\uc624\ub974\ub294 \uc870\uc6a9\ud55c \ub9c8\uc744\uc5d0 \uac00\uae5d\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uba85\uc18c\ubcf4\ub2e4 \uc774\ub3d9\uacfc \uccb4\ub958 \ub9ac\ub4ec\uc744 \uc5b4\ub5bb\uac8c \uc7a1\ub294\uc9c0\uac00 \ub9cc\uc871\ub3c4\ub97c \uacb0\uc815\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc77c\ubcf8 \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc815\ubcf4\ud615 \uac00\uc774\ub4dc\ub2e4. \uac10\uc0c1\ubcf4\ub2e4 \uad50\ud1b5, \ub3c4\ubcf4 \ub3d9\uc120, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc911\uc2ec\uc73c\ub85c \uc2e4\uc81c \uc77c\uc815\uc744 \uc9e4 \uc218 \uc788\uac8c \uad6c\uc131\ud588\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc77c\ubcf8 \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub294 \ub2e4\uce74\uc57c\ub9c8\uc640 \ud568\uaed8 \ubb36\uae30 \uc27d\uc9c0\ub9cc, \ub108\ubb34 \uc9e7\uac8c \uc9c0\ub098\uac00\uba74 \uc7a5\uc810\uc774 \uc57d\ud574\uc9c4\ub2e4. \uc5ed\uacfc \uc218\ub85c, \uc870\uc6a9\ud55c \uac70\ub9ac\uc758 \ub3d9\uc120\uc744 \ub2e8\uc21c\ud558\uac8c \uc7a1\uc544 \ucc9c\ucc9c\ud788 \ubcf4\ub294 \uac83\uc774 \uc88b\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \ubcf4\ub294 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uc77c\ubcf8 \uc18c\ub3c4\uc2dc \uc0b0\ucc45, \uc218\ub85c\uc640 \uc624\ub798\ub41c \uac70\ub9ac, \uc870\uc6a9\ud55c \ubc18\ub098\uc808 \uccb4\ub958<\/td><td>\ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \uc870\uc6a9\ud55c \ub3c4\uc2dc\ub97c \uc2ec\uc2ec\ud558\ub2e4\uace0 \uc624\ud574\ud558\uc9c0 \uc54a\ub294\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\ub2e4\uce74\uc57c\ub9c8\uad8c \uc5f4\ucc28\u00b7\ubc84\uc2a4 \uc2dc\uac04\uacfc \ubcf5\uadc0\ud3b8 \ud655\uc778<\/td><td>\uc9c0\ubc29 \uc5ec\ud589\uc740 \ud658\uc2b9, \ub9c9\ucc28, \ub3c4\ubcf4 \ubcf5\uadc0 \uc2dc\uac04\uc774 \uc77c\uc815 \uc804\uccb4\ub97c \uc88c\uc6b0\ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ubc18\ub098\uc808 \uac00\ub2a5, \uc5ec\uc720 \uc788\uac8c \ubcf4\ub824\uba74 1\ubc15 \ub610\ub294 \uae34 \ud558\ub8e8<\/td><td>\ubc18\ub098\uc808\uc778\uc9c0 1\ubc15\uc778\uc9c0\uc5d0 \ub530\ub77c \uc219\uc18c\uc640 \uc2dd\uc0ac \uc804\ub7b5\uc774 \ub2ec\ub77c\uc9c4\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\uc5f4\ucc28 \uac04\uaca9, \uaca8\uc6b8 \ub0a0\uc528, \uc2dd\ub2f9 \uc601\uc5c5\uc77c, \uc800\ub141 \uc778\uc801<\/td><td>\ub0a0\uc528, \ud63c\uc7a1, \uc5b8\uc5b4, \uacb0\uc81c \ubc29\uc2dd\uc774 \ud604\uc7a5 \ud53c\ub85c\ub3c4\ub97c \ubc14\uafbc\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\uac00 \ud63c\uc790\uc5d0\uac8c \ud3b8\ud55c \uc774\uc720<\/h2>\n\n\n\n<p>\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub294 \ud63c\uc790\uc11c \uac77\ub294 \uc18d\ub3c4\uac00 \uc798 \ub9de\ub294 \uacf3\uc774\ub2e4. \uad00\uad11\uac1d \ud750\ub984\uc774 \uac15\ud558\uc9c0 \uc54a\uc544 \uc218\ub85c\uc640 \uace8\ubaa9, \uc5ed \uc8fc\ubcc0\uc744 \uc790\uae30 \ub9ac\ub4ec\uc73c\ub85c \ubcfc \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uba85\uc18c \uac1c\uc218\ubcf4\ub2e4 \uc7a5\uc18c\uac00 \uc8fc\ub294 \ub9ac\ub4ec\uc774 \uc911\uc694\ud558\ub2e4. \uc774\ub3d9\uacfc \uc2dd\uc0ac, \ud734\uc2dd\uc758 \uae30\uc900\ub9cc \uc7a1\uc73c\uba74 \uc870\uc6a9\ud55c \ubaa9\uc801\uc9c0\ub3c4 \ucda9\ubd84\ud788 \ubc00\ub3c4 \uc788\ub294 \ud558\ub8e8\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uce74\uc57c\ub9c8 \uc77c\uc815\uacfc \ubd84\ub9ac\ud574\uc11c \ubcf4\ub294 \ubc95<\/h2>\n\n\n\n<p>\uc811\uadfc\uc740 \uc5b4\ub835\uc9c0 \uc54a\uc9c0\ub9cc \uc5f4\ucc28 \uac04\uaca9\uacfc \ubcf5\uadc0 \uc2dc\uac04\uc744 \ud655\uc778\ud574\uc57c \ud55c\ub2e4. \ub2e4\uce74\uc57c\ub9c8\uc640 \ud568\uaed8 \ubcfc \uacbd\uc6b0 \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\uc5d0 \ub0a8\uae38 \uc2dc\uac04\uc744 \uba3c\uc800 \uc815\ud558\uc9c0 \uc54a\uc73c\uba74 \ub2e8\uc21c \uacbd\uc720\uc9c0\uac00 \ub418\uae30 \uc27d\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc2dc\uac04\ub300<\/th><th>\uc6b0\uc120 \ud589\ub3d9<\/th><th>\ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \uc815\ub958\uc7a5, \uc219\uc18c, \uc911\uc2ec \uac70\ub9ac \ud655\uc778<\/td><td>\ub3cc\uc544\uac08 \uae30\uc900\uc810\uc744 \uba3c\uc800 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\uc624\uc804<\/td><td>\ud575\uc2ec \uc0b0\ucc45 \uad6c\uac04 \uba3c\uc800 \ubcf4\uae30<\/td><td>\uac00\uc7a5 \uccb4\ub825\uc774 \uc88b\uace0 \uae38\uc774 \ubc1d\uc744 \ub54c \uc911\uc694\ud55c \uad6c\uac04\uc744 \uac77\ub294\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4<\/td><td>\uc2dd\uc0ac\uc640 \ud734\uc2dd, \ubcf4\uc870 \ub3d9\uc120 \ubc30\uce58<\/td><td>\ubb34\ub9ac\ud55c \ud655\uc7a5\ubcf4\ub2e4 \ucee8\ub514\uc158 \uc720\uc9c0\uac00 \uc6b0\uc120\uc774\ub2e4<\/td><\/tr><tr><td>\ud574\uc9c8 \ubb34\ub835<\/td><td>\uc219\uc18c \ub610\ub294 \ucd9c\ubc1c\uc9c0 \ubc29\ud5a5\uc73c\ub85c \ubcf5\uadc0<\/td><td>\ud63c\uc790\ub77c\uba74 \uc57c\uac04 \uc678\uacfd \uc774\ub3d9\uc744 \uc904\uc778\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc218\ub85c\uc640 \uace8\ubaa9\uc744 \ubc18\ubcf5\ud574\uc11c \uac77\ub294 \ubc29\uc2dd<\/h2>\n\n\n\n<p>\ub3d9\uc120\uc740 \uc5ed\uc5d0\uc11c \uc2dc\uc791\ud574 \uc218\ub85c\uc640 \uc911\uc2ec \uac70\ub9ac\ub85c \uc774\uc5b4\uc9c0\ub294 \ucd95\uc744 \uc7a1\uc73c\uba74 \ucda9\ubd84\ud558\ub2e4. \uc678\uacfd\uae4c\uc9c0 \ud06c\uac8c \ub113\ud788\uae30\ubcf4\ub2e4 \uac19\uc740 \uad6c\uac04\uc744 \uc2dc\uac04\ub300\ubcc4\ub85c \ucc9c\ucc9c\ud788 \uac77\ub294 \ubc29\uc2dd\uc774 \ub354 \uc798 \ub9de\ub294\ub2e4.<\/p>\n\n\n\n<p>\ucc98\uc74c \ubc29\ubb38\uc774\ub77c\uba74 \ub3d9\uc120\uc744 \ud06c\uac8c \ub113\ud788\uae30\ubcf4\ub2e4 \uc911\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \ubc18\ubcf5\ud574\uc11c \uac77\ub294 \ud3b8\uc774 \ub0ab\ub2e4. \ud63c\uc790\uc77c \ub54c\ub294 \uc77c\uc815\uc774 \ub2e8\uc21c\ud560\uc218\ub85d \uae38\uc744 \uc783\uac70\ub098 \ubcf5\uadc0 \uc2dc\uac04\uc744 \ub193\uce60 \uac00\ub2a5\uc131\uc774 \uc904\uc5b4\ub4e0\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc18\ub098\uc808\uacfc 1\ubc15\uc758 \ucc28\uc774\uac00 \uc0dd\uae30\ub294 \uc9c0\uc810<\/h2>\n\n\n\n<p>\ub2f9\uc77c\uce58\uae30\ub3c4 \uac00\ub2a5\ud558\uc9c0\ub9cc 1\ubc15\uc744 \ud558\uba74 \uc870\uc6a9\ud55c \uc800\ub141\uacfc \uc544\uce68\uc744 \ubcfc \uc218 \uc788\ub2e4. \uc219\uc18c\ub294 \uc5ed \uc811\uadfc\uc131\uacfc \uc2dd\uc0ac \uac00\ub2a5 \ubc94\uc704\ub97c \ud568\uaed8 \ubcf4\ub294 \uac83\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \uc804\ub9dd\ubcf4\ub2e4 \uc811\uadfc\uc131\uacfc \uc2dd\uc0ac \uac00\ub2a5\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc678\uacfd \uc219\uc18c\uac00 \uc88b\uc544 \ubcf4\uc5ec\ub3c4 \ubc24\uc5d0 \ub3cc\uc544\uac00\uae30 \uc5b4\ub835\uac70\ub098 \uc8fc\ubcc0 \uc2dd\ub2f9\uc774 \ub2eb\ud788\uba74 \ud63c\uc790 \uc5ec\ud589\uc758 \ubd80\ub2f4\uc774 \ucee4\uc9c4\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc18c\ub3c4\uc2dc \uc601\uc5c5\uc77c\uc815\uc5d0 \ub9de\ucdb0 \uc2dd\uc0ac \uc7a1\uae30<\/h2>\n\n\n\n<p>\uc810\uc2ec\uc740 \uc911\uc2ec\ubd80\uc5d0\uc11c \ud574\uacb0\ud558\uace0, \uc800\ub141\uae4c\uc9c0 \uba38\ubb38\ub2e4\uba74 \uc219\uc18c \uc8fc\ubcc0 \uc2dd\ub2f9 \uc601\uc5c5 \uc2dc\uac04\uc744 \ubbf8\ub9ac \ud655\uc778\ud574\uc57c \ud55c\ub2e4. \uc9c0\ubc29 \uc18c\ub3c4\uc2dc\ub294 \uc26c\ub294 \ub0a0\uc774 \uc77c\uc815\uc5d0 \uc9c1\uc811 \uc601\ud5a5\uc744 \uc900\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub3c4\uc2dc\ub098 \uad00\uad11\uc9c0 \uc678\uacfd\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc218\ubcf4\ub2e4 \uc2e4\uc81c \uc601\uc5c5 \uc2dc\uac04\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \uc810\uc2ec \ud6c4\ubcf4\ub97c \uba3c\uc800 \uc815\ud558\uace0, \uc800\ub141\uc740 \uc219\uc18c\uc5d0\uc11c \uac78\uc5b4\uac08 \uc218 \uc788\ub294 \ubc94\uc704\ub85c \uc881\ud788\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uaca8\uc6b8\ucca0\uacfc \uc800\ub141 \uc2dc\uac04\uc5d0 \uc870\uc2ec\ud560 \uac83<\/h2>\n\n\n\n<p>\uce58\uc548\ubcf4\ub2e4 \ub0a0\uc528\uc640 \uc57c\uac04 \uc774\ub3d9\uc774 \ubcc0\uc218\ub2e4. \uaca8\uc6b8\uc5d0\ub294 \uae38\uc774 \ubbf8\ub044\ub7ec\uc6b8 \uc218 \uc788\uace0, \ub2a6\uc740 \uc2dc\uac04\uc5d0\ub294 \uc778\uc801\uc774 \uc904 \uc218 \uc788\uc73c\ubbc0\ub85c \uc5ed\uacfc \uc219\uc18c \ubc29\ud5a5\uc744 \uacc4\uc18d \uc758\uc2dd\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc758 \uc548\uc804\uc740 \ub300\ub2e8\ud55c \uc7a5\ube44\ubcf4\ub2e4 \uc77c\uc815\uc758 \uc5ec\ubc31\uc5d0\uc11c \ub098\uc628\ub2e4. \uae38\uc774 \ubcf5\uc7a1\ud558\uac70\ub098 \uc5b8\uc5b4 \uc7a5\ubcbd\uc774 \uc788\ub294 \uc9c0\uc5ed\uc77c\uc218\ub85d \ub0ae \uc2dc\uac04\uc5d0 \ud575\uc2ec \uad6c\uac04\uc744 \ubcf4\uace0, \uc800\ub141\uc5d0\ub294 \ub3d9\uc120\uc744 \uc904\uc774\ub294 \ubc29\uc2dd\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uccb4\ub958\uac10\uc744 \uc0b4\ub9ac\ub294 \ucd5c\uc18c \uc2dc\uac04<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc655\ubcf5 \uad50\ud1b5\ube44\uc640 \uc219\ubc15 \uc5ec\ubd80\uc5d0 \ub530\ub77c \ub2ec\ub77c\uc9c4\ub2e4. \ub2f9\uc77c\uce58\uae30\ub294 \uac00\ubccd\uc9c0\ub9cc \uccb4\ub958\uac10\uc740 \uc57d\ud558\uace0, 1\ubc15\uc740 \ube44\uc6a9\uc774 \ub298\uc9c0\ub9cc \uc7a5\uc18c\uc758 \ub9ac\ub4ec\uc744 \ub354 \uc798 \ub290\ub084 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uad50\ud1b5\uacfc \uc219\uc18c \uc704\uce58\uc5d0\uc11c \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \ub2f9\uc77c\uce58\uae30\ub294 \ube44\uc6a9\uc774 \ub0ae\uc9c0\ub9cc \uccb4\ub958 \uc2dc\uac04\uc774 \uc9e7\uace0, 1\ubc15\uc740 \ube44\uc6a9\uc774 \ub298\uc9c0\ub9cc \uc870\uc6a9\ud55c \uc2dc\uac04\ub300\ub97c \ud655\ubcf4\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub97c \uacbd\uc720\uc9c0\ub85c\ub9cc \uc4f0\ub294 \uc2e4\uc218<\/h2>\n\n\n\n<p>\ub2e4\uce74\uc57c\ub9c8, \uc2dc\ub77c\uce74\uc640\uace0, \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub97c \ubaa8\ub450 \ud558\ub8e8\uc5d0 \ubb34\ub9ac\ud558\uac8c \ubb36\ub294 \ubc29\uc2dd\uc740 \ud53c\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \uc774\ub3d9\ub9cc \ub9ce\uc544\uc9c0\uace0 \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\uc758 \uc870\uc6a9\ud55c \uc7a5\uc810\uc774 \uc0ac\ub77c\uc9c4\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc774\uc720\ubcf4\ub2e4 \ubd84\uc704\uae30\ub85c \ub0a8\ub294 \uc7a5\uc18c\ub97c \uc88b\uc544\ud558\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\uc77c\ubcf8 \uc9c0\ubc29 \uc18c\ub3c4\uc2dc\uc758 \uc870\uc6a9\ud55c \uac70\ub9ac\uc640 \ub290\ub9b0 \uc0b0\ucc45\uc744 \uc88b\uc544\ud558\ub294 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \ud2b9\ubcc4\ud55c \ubaa9\uc801 \uc5c6\uc774\ub3c4 \uc798 \uac77\ub294 \uc0ac\ub78c\uc5d0\uac8c \ud2b9\ud788 \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub97c \ub2e4\uc2dc \ucc3e\uace0 \uc2f6\uc740 \uc774\uc720<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub97c \uc870\uc6a9\ud55c \uacf3\uc73c\ub85c\ub9cc \ubcf4\uba74 \ub193\uce58\uae30 \uc26c\uc6b4 \ubd80\ubd84<\/h2>\n<p>\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub294 \uc870\uc6a9\ud558\ub2e4\ub294 \uc778\uc0c1\ub9cc\uc73c\ub85c \uc124\uba85\ud558\uae30 \uc26c\uc6b4 \uacf3\uc774\uc9c0\ub9cc, \uc2e4\uc81c\ub85c\ub294 \ubc18\ubcf5\ud574\uc11c \uac77\ub294 \uad6c\uc870\uac00 \uc5bc\ub9c8\ub098 \ud3b8\uc548\ud55c\uc9c0\uc5d0 \ub530\ub77c \ud3c9\uac00\uac00 \uac08\ub9bd\ub2c8\ub2e4. \uace8\ubaa9\uacfc \uc218\ub85c, \uc5ed \uc8fc\ubcc0\uc744 \ub2e4\uc2dc \uc9c0\ub098\ub3c4 \uc9c0\ub8e8\ud558\uc9c0 \uc54a\uc740\uc9c0, \uc26c\ub294 \uc2dc\uac04\uacfc \uc2dd\uc0ac \uc2dc\uac04\uc774 \uc5b5\uc9c0\ub85c \uc774\uc5b4\uc9c0\uc9c0 \uc54a\ub294\uc9c0\uac00 \uc911\uc694\ud569\ub2c8\ub2e4. \uc989, \ub2e8\uc21c\ud788 \u201c\ud55c\uc801\ud558\ub2e4\u201d\ub294 \ub9d0\ub85c\ub294 \ubd80\uc871\ud558\uace0, \uac19\uc740 \ubc18\uacbd\uc744 \uc5ec\ub7ec \ubc88 \ub3cc\uc544\ub3c4 \ub9ac\ub4ec\uc774 \uae68\uc9c0\uc9c0 \uc54a\ub294\uc9c0\uae4c\uc9c0 \ubd10\uc57c \uc774\uacf3\uc758 \uc7a5\uc810\uc774 \uc81c\ub300\ub85c \ubcf4\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\uc5d0\uc11c \uc7ac\ubc29\ubb38 \uc758\uc0ac\uac00 \uc0dd\uae30\ub294 \uc0ac\ub78c\uc758 \uacf5\ud1b5\uc810<\/h2>\n<p>\uc774\uacf3\uc744 \ub2e4\uc2dc \ucc3e\uace0 \uc2f6\ub2e4\uace0 \ub290\ub07c\ub294 \uc0ac\ub78c\ub4e4\uc740 \ubcf4\ud1b5 \uac15\ud55c \uc0ac\uac74\ubcf4\ub2e4 \uc794\uc794\ud55c \uc644\uc131\ub3c4\ub97c \ub192\uac8c \ud3c9\uac00\ud569\ub2c8\ub2e4. \uc720\uba85\ud55c \ud3ec\uc778\ud2b8\ub97c \ub9ce\uc774 \ucc0d\uc9c0 \uc54a\uc544\ub3c4 \ud558\ub8e8\uac00 \uc815\ub3c8\ub418\uc5b4 \uc788\uc5c8\uace0, \ubcf5\uadc0\uc640 \ud734\uc2dd, \uc2dd\uc0ac\uac00 \ubaa8\ub450 \ubb34\ub9ac \uc5c6\uc774 \uc774\uc5b4\uc84c\ub2e4\ub294 \uac10\uac01\uc774 \ub0a8\ub294 \uacbd\uc6b0\uac00 \ub9ce\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \uc9e7\uc740 \uc2dc\uac04 \uc548\uc5d0 \uac15\ud55c \uc778\uc0c1\uc744 \uc6d0\ud55c\ub2e4\uba74 \uc7ac\ubc29\ubb38 \uc758\uc0ac\uae4c\uc9c0 \uc774\uc5b4\uc9c0\uae30 \uc5b4\ub835\uc2b5\ub2c8\ub2e4. \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\uc758 \ub9e4\ub825\uc740 \ud654\uc81c\uc131\uc774 \uc544\ub2c8\ub77c \uc548\uc815\uc801\uc778 \uccb4\ub958\uac10\uc5d0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\uc5d0\uc11c \ub9cc\uc871\ub3c4\uac00 \uac08\ub9ac\ub294 \uacb0\uc815<\/h2>\n\n\n\n<p>\uc774 \ub9c8\uc744\uc758 \ub9cc\uc871\ub3c4\ub294 \uc5b4\ub514\ub97c \ub354 \ubcf4\ub290\ub0d0\ubcf4\ub2e4 \uc5bc\ub9c8\ub098 \ucc9c\ucc9c\ud788 \ubcf4\ub290\ub0d0\uc5d0\uc11c \uac08\ub9b0\ub2e4. \ubc18\ub098\uc808\ub9cc \uc368\ub3c4 \uc88b\uc9c0\ub9cc, \ub2e4\uc74c \uc5f4\ucc28 \uc2dc\uac04\uc5d0 \ucad3\uae30\uae30 \uc2dc\uc791\ud558\uba74 \uc774\uacf3\uc758 \uc7a5\uc810\uc740 \uac70\uc758 \uc0ac\ub77c\uc9c4\ub2e4.<\/p>\n\n\n\n\n\n<p>\uc77c\ubcf8 \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640\ub294 \uc774\uc720\ub97c \uc124\uba85\ud558\uae30 \uc5b4\ub824\uc6cc\ub3c4 \ub2e4\uc2dc \ub5a0\uc624\ub974\ub294 \ub9c8\uc744\uc774\ub2e4. \ubcf5\uadc0\ud3b8\uacfc \uc2dd\uc0ac \uc2dc\uac04\uc744 \uba3c\uc800 \uc7a1\uace0 \ub3d9\uc120\uc744 \uc881\ud788\uba74 \ud63c\uc790\uc11c\ub3c4 \ub9cc\uc871\ub3c4 \ub192\uc740 \ud558\ub8e8\uac00 \ub41c\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc77c\ubcf8 \ud788\ub2e4\ud6c4\ub8e8\uce74\uc640 \ud63c\uc790 \uc5