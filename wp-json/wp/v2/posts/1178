{"id":1178,"date":"2026-03-10T22:40:07","date_gmt":"2026-03-10T13:40:07","guid":{"rendered":"https:\/\/shootsense.com\/?p=1178"},"modified":"2026-06-12T14:06:18","modified_gmt":"2026-06-12T05:06:18","slug":"%ec%95%84%eb%ac%b4-%ec%82%ac%ec%a7%84%eb%8f%84-%eb%82%a8%ea%b8%b0%ec%a7%80-%ec%95%8a%ec%95%98%ec%a7%80%eb%a7%8c-%ea%b8%b0%ec%96%b5%ec%97%90-%eb%82%a8%ec%9d%80-%ec%83%a4%ed%97%88","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%95%84%eb%ac%b4-%ec%82%ac%ec%a7%84%eb%8f%84-%eb%82%a8%ea%b8%b0%ec%a7%80-%ec%95%8a%ec%95%98%ec%a7%80%eb%a7%8c-%ea%b8%b0%ec%96%b5%ec%97%90-%eb%82%a8%ec%9d%80-%ec%83%a4%ed%97%88\/","title":{"rendered":"\uc911\uad6d \uc0e4\ud5c8 \ud63c\uc790 \uc5ec\ud589: \uc0ac\uc9c4\ubcf4\ub2e4 \uae30\uc5b5\uc5d0 \ub0a8\ub294 \uace0\uc6d0 \ub9c8\uc744 \uae30\uc900"},"content":{"rendered":"\n<p>\uc0e4\ud5c8\ub294 \uc0ac\uc9c4\uc744 \ub9ce\uc774 \ub0a8\uae30\uc9c0 \uc54a\uc544\ub3c4 \uae30\uc5b5\uc5d0 \uc624\ub798 \ub0a8\uc744 \uc218 \uc788\ub294 \uace0\uc6d0 \ub9c8\uc744\uc774\ub2e4. \ud558\uc9c0\ub9cc \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ubd84\uc704\uae30\ubcf4\ub2e4 \uace0\ub3c4, \ub0a0\uc528, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac \uac00\ub2a5\uc131\uc744 \uba3c\uc800 \ud310\ub2e8\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc911\uad6d \uc0e4\ud5c8\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c \uac10\uc0c1\uc774 \uc544\ub2c8\ub77c \uad50\ud1b5, \uc219\uc18c, \uc2dd\uc0ac, \ub0a0\uc528, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \ud558\ub8e8\ub97c \uc124\uacc4\ud558\ub294 \ub370 \ucd08\uc810\uc744 \ub454\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc911\uad6d \uc0e4\ud5c8 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\uc0e4\ud5c8\ub294 \uc870\uc6a9\ud55c \uccb4\ub958\uc640 \uace0\uc6d0 \ud2b9\uc720\uc758 \ubd84\uc704\uae30\uac00 \uc7a5\uc810\uc774\uc9c0\ub9cc, \uc774\ub3d9\uacfc \ucee8\ub514\uc158 \uad00\ub9ac\uac00 \uc911\uc694\ud558\ub2e4. \ub3c4\ucc29\uc77c\uc5d0\ub294 \ubb34\ub9ac\ud558\uc9c0 \uc54a\uace0 \uc219\uc18c \uc8fc\ubcc0\uc744 \ud655\uc778\ud558\ub294 \uc815\ub3c4\ub85c \uc2dc\uc791\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \ubcf4\ub294 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uace0\uc6d0 \ub9c8\uc744 \uccb4\ub958, \uc870\uc6a9\ud55c \uc0b0\ucc45, \uc9c0\uc5ed \ubd84\uc704\uae30 \uad00\ucc30<\/td><td>\uc0ac\uc9c4\ubcf4\ub2e4 \uccb4\ub958 \ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \ub9cc\uc871\ub3c4\uac00 \uc548\uc815\ub41c\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\ubc84\uc2a4 \uc774\ub3d9, \ub3c4\ucc29 \uc2dc\uac04, \uc219\uc18c \uc811\uadfc\uc131\uacfc \ud53d\uc5c5 \uc5ec\ubd80 \ud655\uc778<\/td><td>\uc678\uacfd\u00b7\uc0b0\uc545 \uc9c0\uc5ed\uc740 \ubcf5\uadc0 \uc218\ub2e8\uc774 \uace7 \uc548\uc804 \uae30\uc900\uc774\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ucd5c\uc18c 1\ubc15, \uace0\ub3c4\uc640 \uc774\ub3d9 \ud53c\ub85c\ub97c \uace0\ub824\ud558\uba74 2\ubc15\uc774 \uc548\uc815\uc801<\/td><td>\ub3c4\ucc29\uc77c\uacfc \ud65c\ub3d9\uc77c\uc744 \ubd84\ub9ac\ud574\uc57c \ud53c\ub85c \ub204\uc801\uc744 \uc904\uc77c \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\uace0\ub3c4 \ud53c\ub85c, \ub0a0\uc528, \uc2dd\uc0ac \uc120\ud0dd\uc9c0, \ud1b5\uc2e0\uacfc \uc5b8\uc5b4 \uc7a5\ubcbd<\/td><td>\ub0a0\uc528, \uae38 \uc0c1\ud0dc, \uc778\uc801, \uc2dd\uc0ac \uac00\ub2a5\uc131\uc774 \uc77c\uc815\uc744 \ubc14\uafbc\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uace0\uc6d0 \ub9c8\uc744\uc774 \ud63c\uc790\uc5d0\uac8c \ub9de\ub294 \uc870\uac74<\/h2>\n\n\n\n<p>\uc0e4\ud5c8\ub294 \ud63c\uc790 \uc870\uc6a9\ud788 \uba38\ubb3c\uba70 \uc7a5\uc18c\uc758 \ubd84\uc704\uae30\ub97c \ub290\ub07c\uae30 \uc88b\uc740 \uacf3\uc774\ub2e4. \ub2e4\ub9cc \uace0\uc6d0 \uc9c0\uc5ed\uc774\ubbc0\ub85c \ucee8\ub514\uc158\uc744 \uacfc\uc2e0\ud558\uc9c0 \uc54a\uace0 \ucc9c\ucc9c\ud788 \uc6c0\uc9c1\uc5ec\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uba4b\uc9c4 \uc7a5\uba74\ubcf4\ub2e4 \ud604\uc7a5\uc5d0\uc11c \ubd88\uc548\ud558\uc9c0 \uc54a\uc740 \uad6c\uc870\uac00 \uba3c\uc800\ub2e4. \uc219\uc18c\uc640 \uc2dd\uc0ac, \ubcf5\uadc0 \uae30\uc900\uc774 \uc815\ub9ac\ub418\uc5b4 \uc788\uc73c\uba74 \uc870\uc6a9\ud55c \uc7a5\uc18c\ub3c4 \ucda9\ubd84\ud788 \uc758\ubbf8 \uc788\ub294 \uccb4\ub958\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\ub3c4 \uc801\uc751\uc744 \uc704\ud55c \uccab\ub0a0 \ud310\ub2e8<\/h2>\n\n\n\n<p>\ub3c4\ucc29 \uad50\ud1b5\ud3b8\uc740 \uc2dc\uac04\uacfc \ub3c4\ucc29 \uc704\uce58\ub97c \uc815\ud655\ud788 \ud655\uc778\ud574\uc57c \ud55c\ub2e4. \ub2a6\uc740 \ub3c4\ucc29\uc740 \uc219\uc18c \ucc3e\uae30\uc640 \uc2dd\uc0ac \ubb38\uc81c\uac00 \uacb9\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c \uac00\ub2a5\ud55c \ud55c \ubc1d\uc740 \uc2dc\uac04\uc5d0 \ub4e4\uc5b4\uac00\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc0c1\ud669<\/th><th>\uc704\ud5d8 \uc2e0\ud638<\/th><th>\uad8c\uc7a5 \ub300\uc751<\/th><\/tr><\/thead><tbody><tr><td>\ub2a6\uc740 \ub3c4\ucc29<\/td><td>\uc219\uc18c \uc704\uce58\ub97c \ucc3e\uae30 \uc5b4\ub835\uac70\ub098 \ucc28\ub7c9 \ud638\ucd9c\uc774 \ubd88\uc548\uc815\ud558\ub2e4<\/td><td>\ubc1d\uc740 \uc2dc\uac04 \uccb4\ud06c\uc778\uc744 \uc6b0\uc120\ud558\uace0 \ud53d\uc5c5\uc744 \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\ub0a0\uc528 \ubcc0\ud654<\/td><td>\ube44, \uc548\uac1c, \ubbf8\ub044\ub7ec\uc6b4 \uae38\ub85c \ubcf4\ud589 \uc2dc\uac04\uc774 \ub298\uc5b4\ub09c\ub2e4<\/td><td>\uc678\uacfd \ub3d9\uc120\uc744 \uc904\uc774\uace0 \uc219\uc18c \uc8fc\ubcc0 \uccb4\ub958\ub85c \ubc14\uafbc\ub2e4<\/td><\/tr><tr><td>\uc2dd\uc0ac \uacf5\ubc31<\/td><td>\uc8fc\ubcc0 \uc2dd\ub2f9\uc774 \ub2eb\ud788\uac70\ub098 \uba40\ub2e4<\/td><td>\ub3c4\ucc29 \uc804\uc5d0 \ubb3c, \uac04\uc2dd, \uc219\uc18c \uc2dd\uc0ac \uc5ec\ubd80\ub97c \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\ud1b5\uc2e0 \ubd88\uc548\uc815<\/td><td>\uc9c0\ub3c4\uc640 \ud638\ucd9c \uc11c\ube44\uc2a4\uac00 \ub2a6\uac8c \uc791\ub3d9\ud55c\ub2e4<\/td><td>\uc624\ud504\ub77c\uc778 \uc9c0\ub3c4\uc640 \uc219\uc18c \uc8fc\uc18c\ub97c \uc800\uc7a5\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ub9ce\uc774 \ubcf4\ub294 \ub300\uc2e0 \ubab8\uc744 \ub0a8\uae30\ub294 \ubc30\uce58<\/h2>\n\n\n\n<p>\uccab\ub0a0\uc740 \uc219\uc18c \uc8fc\ubcc0\uacfc \uc911\uc2ec \uac70\ub9ac \ud655\uc778, \ub458\uc9f8 \ub0a0\uc740 \uac00\uae4c\uc6b4 \uc0b0\ucc45 \uad6c\uac04 \uc911\uc2ec\uc73c\ub85c \uc7a1\ub294 \uac83\uc774 \uc548\uc804\ud558\ub2e4. \uace0\ub3c4\uc5d0 \uc801\uc751\ud558\uae30 \uc804\uc5d0\ub294 \uae34 \ub3c4\ubcf4 \uc77c\uc815\uc744 \ub123\uc9c0 \uc54a\ub294\ub2e4.<\/p>\n\n\n\n<p>\uc77c\uc815\uc740 \ub113\uac8c \ud655\uc7a5\ud558\uae30\ubcf4\ub2e4 \uc219\uc18c\uc640 \uc911\uc2ec \uad6c\uac04\uc744 \uae30\uc900\uc73c\ub85c \uc904\uc77c \uc218 \uc788\uac8c \uc7a1\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ud63c\uc790\ub77c\uba74 \u201c\ub354 \ubcf4\ub294 \uac83\u201d\ubcf4\ub2e4 \u201c\ubb34\ub9ac\ud558\uc9c0 \uc54a\uace0 \ub3cc\uc544\uc624\ub294 \uac83\u201d\uc774 \uc77c\uc815 \ud488\uc9c8\uc744 \uc88c\uc6b0\ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0e4\ud5c8\uc5d0\uc11c \uc219\uc18c \uc704\uce58\ubcf4\ub2e4 \uc911\uc694\ud55c \uac83<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \uc911\uc2ec \uac70\ub9ac\uc640 \uc2dd\uc0ac \uac00\ub2a5 \uad6c\uc5ed\uc5d0\uc11c \ub108\ubb34 \uba40\uc9c0 \uc54a\uc740 \uacf3\uc774 \uc88b\ub2e4. \uc804\ub9dd\ubcf4\ub2e4 \ub09c\ubc29, \uc628\uc218, \uccb4\ud06c\uc778, \uc8fc\ubcc0 \uc2dd\ub2f9 \uc811\uadfc\uc131\uc744 \uc6b0\uc120\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc678\uacfd \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \ud63c\uc790\uc5d0\uac8c\ub294 \uc2dd\uc0ac\uc640 \uc57c\uac04 \uc774\ub3d9\uc774 \ubcc0\uc218\ub2e4. \uc219\uc18c\ub97c \uace0\ub97c \ub54c\ub294 \uc804\ub9dd\ubcf4\ub2e4 \uccb4\ud06c\uc778 \uc2dc\uac04, \ud53d\uc5c5 \uac00\ub2a5 \uc5ec\ubd80, \uc8fc\ubcc0 \uc2dd\uc0ac \uac00\ub2a5\uc131\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uc6d0 \uc9c0\uc5ed\uc5d0\uc11c \uc2dd\uc0ac\ub97c \ubbf8\ub8e8\uba74 \uc548 \ub418\ub294 \uc774\uc720<\/h2>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc911\uc2ec\ubd80\uc5d0\uc11c \ud574\uacb0\ud558\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4. \uace0\uc6d0 \uc9c0\uc5ed\uc5d0\uc11c\ub294 \ucee8\ub514\uc158\uc774 \ud754\ub4e4\ub9b4 \uc218 \uc788\uc73c\ubbc0\ub85c \uc2dd\uc0ac\ub97c \uac70\ub974\uc9c0 \ub9d0\uace0 \ubb3c\uacfc \uac04\uc2dd\uc744 \uc900\ube44\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc77c\uc815\uc758 \ubcf4\uc870\uac00 \uc544\ub2c8\ub77c \uc548\uc804 \uae30\uc900\uc774\ub2e4. \uc2dd\uc0ac \uc2dc\uac04\uc774 \ubc00\ub9ac\uba74 \ud53c\ub85c\uc640 \ud310\ub2e8 \uc2e4\uc218\uac00 \ud568\uaed8 \ub298\uc5b4\ub098\ubbc0\ub85c, \ud63c\uc790\ub77c\uba74 \ub2a6\uc740 \uc2dc\uac04\uae4c\uc9c0 \uc2dd\uc0ac\ub97c \ubbf8\ub8e8\uc9c0 \uc54a\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uce58\uc548\ubcf4\ub2e4 \ucee8\ub514\uc158\uc774 \ubcc0\uc218\uc778 \uad6c\uac04<\/h2>\n\n\n\n<p>\uc0e4\ud5c8\uc758 \ub9ac\uc2a4\ud06c\ub294 \uce58\uc548\ubcf4\ub2e4 \uace0\ub3c4\uc640 \ub0a0\uc528, \uc5b8\uc5b4 \uc7a5\ubcbd\uc5d0\uc11c \uc628\ub2e4. \ubab8\uc774 \ubb34\uac81\uac70\ub098 \ub450\ud1b5\uc774 \uc788\uc73c\uba74 \uc678\uacfd \uc0b0\ucc45\uc744 \uc904\uc774\uace0 \uc219\uc18c\uc5d0\uc11c \uc26c\ub294 \ud3b8\uc774 \ub9de\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \uac00\uc7a5 \ud53c\ud574\uc57c \ud560 \uc870\ud569\uc740 \ud53c\ub85c, \uc5b4\ub450\uc6b4 \uae38, \ubd88\ud655\uc2e4\ud55c \ubcf5\uadc0 \uc218\ub2e8\uc774 \ub3d9\uc2dc\uc5d0 \uc0dd\uae30\ub294 \uc0c1\ud669\uc774\ub2e4. \uc14b \uc911 \ud558\ub098\ub77c\ub3c4 \ubcf4\uc774\uba74 \uadf8\ub0a0\uc758 \uc77c\uc815\uc740 \uc904\uc774\ub294 \uac83\uc774 \ub9de\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub09c\ubc29\uacfc \uc704\uce58\uc5d0 \ub3c8\uc744 \uc368\uc57c \ud558\ub294 \uacbd\uc6b0<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc219\uc18c \uc218\uc900\uacfc \uc774\ub3d9 \ubc29\uc2dd\uc5d0 \ub530\ub77c \ub2ec\ub77c\uc9c4\ub2e4. \uc800\ub834\ud55c \uc219\uc18c\ubcf4\ub2e4 \ub09c\ubc29\uacfc \uc704\uce58\uac00 \uc548\uc815\uc801\uc778 \uc219\uc18c\uac00 \ud63c\uc790 \uc5ec\ud589\uc5d0\ub294 \ub354 \ub098\uc740 \uc120\ud0dd\uc77c \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc219\ubc15\ube44\ub9cc \ube44\uad50\ud558\uba74 \ud310\ub2e8\uc774 \ud2c0\uc5b4\uc9c8 \uc218 \uc788\ub2e4. \uc678\uacfd \uc774\ub3d9\ube44, \ud53d\uc5c5 \ube44\uc6a9, \uc2dd\uc0ac \ud3ec\ud568 \uc5ec\ubd80, \ub0a0\uc528 \ub54c\ubb38\uc5d0 \uc0dd\uae30\ub294 \ub300\uccb4 \uad50\ud1b5\ube44\uae4c\uc9c0 \ud568\uaed8 \ubd10\uc57c \uc2e4\uc81c \ube44\uc6a9\uc774 \ubcf4\uc778\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0e4\ud5c8\uc5d0\uc11c \ud754\ud55c \uacfc\uc2e0 \ud328\ud134<\/h2>\n\n\n\n<p>\ub3c4\ucc29 \ub2f9\uc77c\uc5d0 \uae34 \uc0b0\ucc45\uc774\ub098 \uc678\uacfd \uc774\ub3d9\uc744 \ub123\ub294 \uc77c\uc815\uc740 \ud53c\ud574\uc57c \ud55c\ub2e4. \uc0ac\uc9c4\uc744 \ub0a8\uae30\ub824\ub294 \uc695\uc2ec\ubcf4\ub2e4 \ubab8 \uc0c1\ud0dc \ud655\uc778\uc774 \uba3c\uc800\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc870\uc6a9\ud55c \uccb4\ub958\ub97c \uae30\uc5b5\uc73c\ub85c \ub0a8\uae30\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\ud654\ub824\ud55c \uc0ac\uc9c4\ubcf4\ub2e4 \uc870\uc6a9\ud55c \uace0\uc6d0 \ub9c8\uc744\uc758 \ubd84\uc704\uae30\ub97c \uc624\ub798 \uae30\uc5b5\ud558\uace0 \uc2f6\uc740 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \ucc9c\ucc9c\ud788 \uac77\uace0 \uc26c\ub294 \uc5ec\ud589\uc744 \ubc1b\uc544\ub4e4\uc77c \uc218 \uc788\ub294 \uc0ac\ub78c\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0e4\ud5c8\ub97c \uc624\ub798 \uae30\uc5b5\ud558\uac8c \ub9cc\ub4dc\ub294 \uc774\uc720<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\uc0e4\ud5c8\uc5d0\uc11c \uc77c\uc815\uc744 \uc904\uc774\ub294 \ud310\ub2e8\uc774 \uc624\ud788\ub824 \uc815\ud655\ud55c \uc774\uc720<\/h2>\n<p>\uc0e4\ud5c8\ub294 \uace0\ub3c4\uc640 \uae30\uc628, \uc774\ub3d9 \uc18d\ub3c4\uac00 \ub3d9\uc2dc\uc5d0 \uc791\uc6a9\ud558\ub294 \uc9c0\uc5ed\uc774\ub77c\uc11c \uc77c\uc815\uc744 \uc904\uc774\ub294 \ud310\ub2e8\uc774 \uc18c\uadf9\uc801\uc778 \uc120\ud0dd\uc774 \uc544\ub2c8\ub77c \ud604\uc2e4\uc801\uc778 \ucd5c\uc801\ud654\uac00 \ub429\ub2c8\ub2e4. \ud3c9\uc9c0 \ub3c4\uc2dc\ucc98\ub7fc \uc774\ub3d9\ub7c9\uc744 \uae30\uc900\uc73c\ub85c \ud558\ub8e8\ub97c \uc124\uacc4\ud558\uba74 \uc911\uac04\ubd80\ud130 \uccb4\ub825 \uc800\ud558\uac00 \ub204\uc801\ub418\uace0, \uc774\ud6c4\uc758 \uac10\uc0c1\uacfc \ud310\ub2e8\uae4c\uc9c0 \ud750\ub824\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \ucc98\uc74c\ubd80\ud130 \uc774\ub3d9\ub7c9\uc744 \ub0ae\ucdb0 \ub450\uba74 \uc219\uc18c \ubcf5\uadc0, \uc2dd\uc0ac, \uc7ac\uc815\ube44 \uc2dc\uac04\uc774 \ubaa8\ub450 \uc548\uc815\uc801\uc73c\ub85c \uc5f0\uacb0\ub418\uba74\uc11c \uc804\uccb4 \uccb4\ub958 \uacbd\ud5d8\uc774 \ud6e8\uc52c \uc120\uba85\ud574\uc9d1\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc0e4\ud5c8\uc5d0\uc11c \uae30\uc5b5\uc5d0 \ub0a8\ub294 \uccb4\ub958\ub97c \ub9cc\ub4dc\ub294 \uc2e4\uc81c \ubcc0\uc218<\/h2>\n<p>\uc0e4\ud5c8\uc758 \uc778\uc0c1\uc740 \uc0ac\uc9c4 \ud55c \uc7a5\ubcf4\ub2e4 \ubab8 \uc0c1\ud0dc\uc640 \uccb4\ub958 \ub9ac\ub4ec\uc5d0\uc11c \ub354 \ud06c\uac8c \uac08\ub9bd\ub2c8\ub2e4. \uace0\ub3c4 \uc801\uc751\uc774 \ubb34\ub09c\ud588\ub294\uc9c0, \ub09c\ubc29\uacfc \uc628\uc218 \uac19\uc740 \uc219\uc18c \uc870\uac74\uc774 \uae30\ubcf8 \uc774\uc0c1\uc778\uc9c0, \ud574\uac00 \uc9c4 \ub4a4 \ubb34\ub9ac\ud55c \uc774\ub3d9\uc744 \ud53c\ud588\ub294\uc9c0 \uac19\uc740 \uc694\uc18c\uac00 \uc804\uccb4 \ub9cc\uc871\ub3c4\ub97c \uc88c\uc6b0\ud569\ub2c8\ub2e4. \uacb0\uad6d \uc0e4\ud5c8\ub97c \uc88b\uac8c \uae30\uc5b5\ud558\ub294 \uc0ac\ub78c\uc740 \ud2b9\ubcc4\ud55c \uc7a5\uba74\uc744 \ub9ce\uc774 \ubcf8 \uc0ac\ub78c\uc774 \uc544\ub2c8\ub77c, \ubab8\uc744 \uc9c0\ud0a4\uba74\uc11c \uc870\uc6a9\ud55c \ud750\ub984\uc744 \uc720\uc9c0\ud55c \uc0ac\ub78c\uc778 \uacbd\uc6b0\uac00 \ub9ce\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc0e4\ud5c8\uc5d0\uc11c \uc0ac\uc9c4\ubcf4\ub2e4 \uba3c\uc800 \ud3ec\uae30\ud574\uc57c \ud558\ub294 \uc695\uc2ec<\/h2>\n\n\n\n<p>\uc774 \uc9c0\uc5ed\uc5d0\uc11c\ub294 \uba40\ub9ac \uac77\ub294 \uc695\uc2ec\uacfc \ub3c4\ucc29 \ub2f9\uc77c \ubc14\ub85c \ubd84\uc704\uae30\ub97c \ub2e4 \ubcf4\ub824\ub294 \ub9c8\uc74c\uc744 \uba3c\uc800 \uc904\uc5ec\uc57c \ud55c\ub2e4. \ubab8 \uc0c1\ud0dc\uac00 \uc870\uae08\ub9cc \ud754\ub4e4\ub824\ub3c4 \uac19\uc740 \ud48d\uacbd\uc774 \uc804\ud600 \ub2e4\ub978 \uacbd\ud5d8\uc73c\ub85c \ubc14\ub00c\uae30 \ub54c\ubb38\uc5d0, \uc18d\ub3c4\ub97c \ub2a6\ucd94\ub294 \uac83\uc774 \uc624\ud788\ub824 \uc5ec\ud589\uc758 \ubc00\ub3c4\ub97c \ub192\uc778\ub2e4.<\/p>\n\n\n\n\n\n<p>\uc911\uad6d \uc0e4\ud5c8\ub294 \uc0ac\uc9c4\ubcf4\ub2e4 \uae30\uc5b5\uc5d0 \ub0a8\uc744 \uc218 \uc788\ub294 \ubaa9\uc801\uc9c0\uc9c0\ub9cc, \ud63c\uc790\ub77c\uba74 \uc900\ube44\uac00 \ud544\uc694\ud558\ub2e4. \uace0\ub3c4, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac, \ub3c4\ucc29 \uc2dc\uac04\uc744 \uba3c\uc800 \uad00\ub9ac\ud558\uba74 \uc548\uc815\uc801\uc778 \uccb4\ub958\uac00 \ub41c\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc911\uad6d \uc0e4\ud5c8 \ud63c\uc790 \uc5ec\ud589\uc744 \uc704\ud55c \uace0\uc6d0 \uc801\uc751, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac, \uc774\ub3d9, \ub0a0\uc528\uc640 \uc548\uc804 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc2e4\uc804 \uac00\uc7