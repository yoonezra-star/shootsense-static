{"id":724,"date":"2025-06-10T16:45:58","date_gmt":"2025-06-10T07:45:58","guid":{"rendered":"https:\/\/shootsense.com\/?p=724"},"modified":"2026-06-12T14:19:29","modified_gmt":"2026-06-12T05:19:29","slug":"honja-yeohaeng-social-activity","status":"publish","type":"post","link":"https:\/\/shootsense.com\/honja-yeohaeng-social-activity\/","title":{"rendered":"\ud63c\uc790 \uc5ec\ud589 \uc911 \uc0ac\ub78c\ub4e4\uacfc \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc5b4\uc6b8\ub9ac\ub294 \ubc95"},"content":{"rendered":"\n<p>\ud63c\uc790 \uc5ec\ud589\uc740 \ubc18\ub4dc\uc2dc \ud63c\uc790\ub9cc \uc788\uc5b4\uc57c \ud558\ub294 \uc5ec\ud589\uc774 \uc544\ub2d9\ub2c8\ub2e4. \ud544\uc694\ud560 \ub54c\ub294 \uc0ac\ub78c\ub4e4\uacfc \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc5b4\uc6b8\ub9b4 \uc218 \uc788\uace0, \ub2e4\uc2dc \ud63c\uc790\ub9cc\uc758 \uc2dc\uac04\uc73c\ub85c \ub3cc\uc544\uc62c \uc218\ub3c4 \uc788\uc2b5\ub2c8\ub2e4. \uc911\uc694\ud55c \uac83\uc740 \ubb34\ub9ac\ud574\uc11c \uce5c\ud574\uc9c0\ub824\ub294 \uac83\uc774 \uc544\ub2c8\ub77c \uc548\uc804\ud558\uace0 \ubd80\ub2f4\uc774 \ub0ae\uc740 \ubc29\uc2dd\uc73c\ub85c \uad50\ub958\ud558\ub294 \uac83\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ud63c\uc790 \uc5ec\ud589 \uc911 \uc0ac\ub78c\ub4e4\uacfc \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc5b4\uc6b8\ub9ac\ub294 \ubc29\ubc95\uc744 \uc815\ub9ac\ud569\ub2c8\ub2e4. \uac8c\uc2a4\ud2b8\ud558\uc6b0\uc2a4, \ud22c\uc5b4, \ud074\ub798\uc2a4, \uce74\ud398, \uc2dc\uc7a5\ucc98\ub7fc \uc0c1\ud669\ubcc4\ub85c \uc5b4\ub5a4 \uad50\ub958\uac00 \ubd80\ub2f4\uc774 \uc801\uc740\uc9c0, \uc5b4\ub5a4 \uacbd\uc6b0\uc5d0\ub294 \uac70\ub9ac\ub97c \ub450\ub294 \uac83\uc774 \uc88b\uc740\uc9c0 \ud310\ub2e8 \uae30\uc900\uc744 \uc81c\uc2dc\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"social-first-rule\">\ud63c\uc790 \uc5ec\ud589\uc758 \uad50\ub958\ub294 \uc120\ud0dd\uc774\uc5b4\uc57c \ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \uc0ac\ub78c\uc744 \ub9cc\ub098\ub294 \uac83\uc740 \uc88b\uc740 \uacbd\ud5d8\uc774 \ub420 \uc218 \uc788\uc9c0\ub9cc, \ubc18\ub4dc\uc2dc \ud574\uc57c \ud558\ub294 \uacfc\uc81c\ub294 \uc544\ub2d9\ub2c8\ub2e4. \uc678\ub85c\uc6c0\uc744 \uc5c6\uc560\uae30 \uc704\ud574 \ubb34\ub9ac\ud558\uac8c \ub300\ud654\ub97c \uc774\uc5b4\uac00\uba74 \uc624\ud788\ub824 \ud53c\ub85c\uac00 \ucee4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uad50\ub958\ub294 \ub0b4 \ucee8\ub514\uc158\uacfc \uc548\uc804 \uae30\uc900 \uc548\uc5d0\uc11c \uc120\ud0dd\ud558\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uad50\ub958 \ubc29\uc2dd<\/th><th>\ubd80\ub2f4 \uc815\ub3c4<\/th><th>\ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\uc77c\uc77c \ud22c\uc5b4<\/td><td>\ub0ae\uc74c<\/td><td>\uc2dc\uac04\uacfc \uc5ed\ud560\uc774 \uc815\ud574\uc838 \uc788\uc5b4 \ucd08\ubcf4\uc790\uc5d0\uac8c \ud3b8\ud568<\/td><\/tr><tr><td>\ud074\ub798\uc2a4\u00b7\uccb4\ud5d8<\/td><td>\ub0ae\uc74c<\/td><td>\ud65c\ub3d9 \uc911\uc2ec\uc774\ub77c \ub300\ud654 \ubd80\ub2f4\uc774 \uc801\uc74c<\/td><\/tr><tr><td>\uac8c\uc2a4\ud2b8\ud558\uc6b0\uc2a4<\/td><td>\uc911\uac04<\/td><td>\ubd84\uc704\uae30\uc5d0 \ub530\ub77c \uad50\ub958\uc640 \ud53c\ub85c\uac00 \ubaa8\ub450 \uac00\ub2a5<\/td><\/tr><tr><td>\uc989\ud765 \ub9cc\ub0a8<\/td><td>\ub192\uc74c<\/td><td>\uc7a5\uc18c, \uc2dc\uac04, \uc74c\uc8fc \uc5ec\ubd80\ub97c \uc2e0\uc911\ud788 \ud310\ub2e8<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"social-safe-space\">\uad50\ub958\ub294 \uacf5\uac1c\ub41c \uc7a5\uc18c\uc640 \ub0ae \uc2dc\uac04\ub300\uac00 \uae30\uc900\uc785\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\ucc98\uc74c \ub9cc\ub09c \uc0ac\ub78c\uacfc \uc5b4\uc6b8\ub9b4 \ub54c\ub294 \uc7a5\uc18c\uc640 \uc2dc\uac04\ub300\uac00 \uc911\uc694\ud569\ub2c8\ub2e4. \uacf5\uac1c\ub41c \uc7a5\uc18c, \ub0ae \uc2dc\uac04\ub300, \uc774\ub3d9\uc774 \uc26c\uc6b4 \uacf3, \uc219\uc18c\uc640 \ub108\ubb34 \uba40\uc9c0 \uc54a\uc740 \uacf3\uc774 \uc548\uc804\ud569\ub2c8\ub2e4. \ub2a6\uc740 \ubc24, \uc678\uc9c4 \uc7a5\uc18c, \uacfc\ud55c \uc74c\uc8fc, \uc219\uc18c \uc704\uce58 \uacf5\uc720\ub294 \ud53c\ud558\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc0ac\ub78c\uc744 \ub9cc\ub098\ub294 \uc77c\uc774 \uc990\uac81\ub354\ub77c\ub3c4 \uc219\uc18c \ubcf5\uadc0 \ub3d9\uc120\uc740 \ub530\ub85c \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4. \ubc24 \uadc0\uac00 \uae30\uc900\uc740 <a href=\"https:\/\/shootsense.com\/honja-sukso-anjeon-checklist\/\">\ud63c\uc790 \uc219\uc18c\uc5d0\uc11c \uc548\uc804\ud558\uac8c \uba38\ubb34\ub294 \ud301<\/a>\uacfc \uc5f0\uacb0\ud574 \uc0dd\uac01\ud558\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"social-tour-class\">\ucd08\ubcf4\uc790\uc5d0\uac8c\ub294 \ud22c\uc5b4\uc640 \ud074\ub798\uc2a4\uac00 \uac00\uc7a5 \ubd80\ub2f4\uc774 \ub0ae\uc2b5\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc77c\uc77c \ud22c\uc5b4\ub098 \ucfe0\ud0b9 \ud074\ub798\uc2a4, \uc6cc\ud0b9 \ud22c\uc5b4, \uacf5\uc608 \uccb4\ud5d8\ucc98\ub7fc \ubaa9\uc801\uc774 \ubd84\uba85\ud55c \ud65c\ub3d9\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \uc0ac\ub78c\uc744 \ub9cc\ub098\uae30 \uc88b\uc740 \ubc29\uc2dd\uc785\ub2c8\ub2e4. \ub300\ud654\ub97c \uacc4\uc18d \uc774\uc5b4\uac00\uc9c0 \uc54a\uc544\ub3c4 \ud65c\ub3d9 \uc790\uccb4\uac00 \uc911\uc2ec\uc774 \ub418\uae30 \ub54c\ubb38\uc5d0 \ubd80\ub2f4\uc774 \uc801\uc2b5\ub2c8\ub2e4. \ub05d\ub098\ub294 \uc2dc\uac04\uacfc \uc7a5\uc18c\uac00 \uc815\ud574\uc838 \uc788\ub2e4\ub294 \uc810\ub3c4 \uc548\uc804\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud65c\ub3d9<\/th><th>\uc7a5\uc810<\/th><th>\ud655\uc778\ud560 \uc810<\/th><\/tr><\/thead><tbody><tr><td>\uc6cc\ud0b9 \ud22c\uc5b4<\/td><td>\ub3c4\uc2dc \uc774\ud574\uc640 \uad50\ub958\ub97c \ub3d9\uc2dc\uc5d0 \uc5bb\uc74c<\/td><td>\uc885\ub8cc \uc704\uce58\uc640 \uadc0\uac00 \ubc29\ubc95<\/td><\/tr><tr><td>\ucfe0\ud0b9 \ud074\ub798\uc2a4<\/td><td>\uc2dd\uc0ac\uc640 \uccb4\ud5d8\uc744 \ud568\uaed8 \ud574\uacb0<\/td><td>\uc5b8\uc5b4, \uc2dc\uac04, \ucde8\uc18c \uaddc\uc815<\/td><\/tr><tr><td>\uc18c\uaddc\ubaa8 \ud22c\uc5b4<\/td><td>\uc774\ub3d9 \ubd80\ub2f4\uc774 \uc904\uc5b4\ub4e6<\/td><td>\uc9d1\ud569 \uc7a5\uc18c\uc640 \uc885\ub8cc \uc2dc\uac04<\/td><\/tr><tr><td>\uac8c\uc2a4\ud2b8\ud558\uc6b0\uc2a4 \uc774\ubca4\ud2b8<\/td><td>\uc219\uc18c \uc548\uc5d0\uc11c \uad50\ub958 \uac00\ub2a5<\/td><td>\uc18c\uc74c, \uc74c\uc8fc \ubd84\uc704\uae30, \uac1c\uc778 \uacf5\uac04<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"social-boundary\">\ub300\ud654\ubcf4\ub2e4 \uacbd\uacc4 \uc124\uc815\uc774 \uba3c\uc800\uc785\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589 \uc911 \uc0ac\ub78c\ub4e4\uacfc \uc5b4\uc6b8\ub9b4 \ub54c\ub294 \uce5c\uc808\ud568\uacfc \uacbd\uacc4 \uc124\uc815\uc744 \ud568\uaed8 \uac00\uc838\uac00\uc57c \ud569\ub2c8\ub2e4. \uc219\uc18c \uc704\uce58, \uc138\ubd80 \uc77c\uc815, \ud63c\uc790 \uba38\ubb34\ub294 \ubc29 \ubc88\ud638, \uc5ec\uad8c\uc774\ub098 \uacb0\uc81c \uc815\ubcf4\ub294 \uacf5\uc720\ud558\uc9c0 \uc54a\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4. \ubd88\ud3b8\ud55c \uc81c\uc548\uc774 \uc788\uc73c\uba74 \uc774\uc720\ub97c \uae38\uac8c \uc124\uba85\ud558\uc9c0 \uc54a\uace0 \uac70\uc808\ud574\ub3c4 \ub429\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uacbd\uacc4 \uc124\uc815\uc740 \ubb34\ub840\ud568\uc774 \uc544\ub2c8\ub77c \uc548\uc804 \uae30\uc900\uc785\ub2c8\ub2e4. \ud2b9\ud788 \ud574\uc678\ub098 \ub0af\uc120 \uc9c0\uc5ed\uc5d0\uc11c\ub294 \uacf5\uac1c\ub41c \uc7a5\uc18c\uc5d0\uc11c \uc9e7\uac8c \uad50\ub958\ud558\uace0, \uc774\ud6c4 \uc77c\uc815\uc740 \uc2a4\uc2a4\ub85c \uacb0\uc815\ud558\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"social-alone-time\">\ud63c\uc790 \uc788\ub294 \uc2dc\uac04\ub3c4 \uc77c\uc815\uc5d0 \ud3ec\ud568\ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc0ac\ub78c\uc744 \ub9cc\ub09c \ub4a4\uc5d0\ub294 \ud63c\uc790 \ud68c\ubcf5\ud560 \uc2dc\uac04\uc774 \ud544\uc694\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uacc4\uc18d \ub300\ud654\ud558\uace0 \uc6c0\uc9c1\uc774\uba74 \uc5ec\ud589\uc774 \uc990\uac70\uc6cc\ub3c4 \ud53c\ub85c\uac00 \uc313\uc785\ub2c8\ub2e4. \ud22c\uc5b4\ub098 \ubaa8\uc784 \ub2e4\uc74c\uc5d0\ub294 \uce74\ud398, \uc219\uc18c, \uc9e7\uc740 \uc0b0\ucc45\ucc98\ub7fc \ud63c\uc790 \uc815\ub9ac\ud558\ub294 \uc2dc\uac04\uc744 \ub123\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc678\ub85c\uc6c0\uacfc \uad50\ub958 \uc695\uad6c\uac00 \ud5f7\uac08\ub9b4 \ub54c\ub294 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-gamjeong-gwanri\/\">\ud63c\uc790 \uc5ec\ud589 \uc911 \uc678\ub85c\uc6c0\uacfc \uac10\uc815 \uad00\ub9ac<\/a>\ub97c \uae30\uc900\uc73c\ub85c \ubab8 \uc0c1\ud0dc\uc640 \uac10\uc815 \uc0c1\ud0dc\ub97c \uba3c\uc800 \ubd84\ub9ac\ud574 \ubcf4\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"social-avoid\">\uc0ac\ub78c\ub4e4\uacfc \uc5b4\uc6b8\ub9b4 \ub54c \ud53c\ud574\uc57c \ud560 \uc0c1\ud669<\/h2>\n\n\n\n<ul class=\"wp-block-list\"><li>\ucc98\uc74c \ub9cc\ub09c \uc0ac\ub78c\uc5d0\uac8c \uc219\uc18c \uc704\uce58\ub098 \ubc29 \ubc88\ud638\ub97c \uc54c\ub824\uc8fc\ub294 \uac83<\/li><li>\ub2a6\uc740 \ubc24 \uc678\uc9c4 \uc7a5\uc18c\ub85c \uc989\ud765 \uc774\ub3d9\ud558\ub294 \uac83<\/li><li>\ucee8\ub514\uc158\uc774 \ub098\uc05c\ub370 \ubaa8\uc784\uc744 \uc5b5\uc9c0\ub85c \uc774\uc5b4\uac00\ub294 \uac83<\/li><li>\uc220\uc790\ub9ac \ubd84\uc704\uae30\uc5d0 \ud729\uc4f8\ub824 \uadc0\uac00 \uacc4\ud68d\uc744 \ub193\uce58\ub294 \uac83<\/li><\/ul>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"social-checklist\">\uad50\ub958 \uc804 \uccb4\ud06c\ub9ac\uc2a4\ud2b8<\/h2>\n\n\n\n<ul class=\"wp-block-list\"><li>\uc7a5\uc18c\uac00 \uacf5\uac1c\ub41c \uacf3\uc778\uc9c0 \ud655\uc778\ud569\ub2c8\ub2e4.<\/li><li>\uc885\ub8cc \uc2dc\uac04\uacfc \uc219\uc18c \ubcf5\uadc0 \ubc29\ubc95\uc744 \ud655\uc778\ud569\ub2c8\ub2e4.<\/li><li>\uc219\uc18c \uc704\uce58\uc640 \uc138\ubd80 \uc77c\uc815\uc740 \uacf5\uc720\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/li><li>\ubd88\ud3b8\ud558\uba74 \ubc14\ub85c \ube60\uc9c8 \uc218 \uc788\ub294 \uc774\uc720\uc640 \ub3d9\uc120\uc744 \uc900\ube44\ud569\ub2c8\ub2e4.<\/li><li>\uad50\ub958 \ud6c4 \ud63c\uc790 \uc274 \uc2dc\uac04\uc744 \ub0a8\uaca8 \ub461\ub2c8\ub2e4.<\/li><\/ul>\n\n\n\n<h2 class=\"wp-block-heading\">\uad50\ub958 \uc804\uc5d0 \uacf5\uc2dd\uc801\uc73c\ub85c \ud655\uc778\ud558\uac70\ub098 \ubd84\uba85\ud788 \ud574\ub458 \uac83<\/h2>\n<p>\uc0ac\ub78c\ub4e4\uacfc \uc5b4\uc6b8\ub9ac\ub294 \uc0c1\ud669\uc740 \uac10\uc815 \ubb38\uc81c\ucc98\ub7fc \ubcf4\uc774\uc9c0\ub9cc \uc2e4\uc81c\ub85c\ub294 \uc7a5\uc18c\uc640 \uc6b4\uc601 \ubc29\uc2dd\uc774 \uc911\uc694\ud569\ub2c8\ub2e4. \ud22c\uc5b4\ub098 \ud074\ub798\uc2a4, \ud589\uc0ac\uc5d0 \ucc38\uc5ec\ud560 \ub54c\ub294 \uc8fc\ucd5c \uc8fc\uccb4, \ucde8\uc18c \uaddc\uc815, \ubaa8\uc784 \uc7a5\uc18c, \uc885\ub8cc \uc2dc\uac04, \uadc0\uac00 \ubc29\ubc95\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4. \ub0af\uc120 \uc0ac\ub78c\uacfc\uc758 \uad50\ub958\ub294 \u201c\ubd84\uc704\uae30\u201d\ubcf4\ub2e4 \u201c\uc5b8\uc81c \ub05d\ub098\uace0 \uc5b4\ub5bb\uac8c \ub3cc\uc544\uc624\ub290\ub0d0\u201d\uac00 \uc548\uc804\uc5d0 \ub354 \uc9c1\uc811\uc801\uc778 \uc601\ud5a5\uc744 \uc90d\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc774 \uae00\ub9cc\uc73c\ub85c \ud574\uacb0\ub418\uc9c0 \uc54a\ub294 \uc0c1\ud669<\/h2>\n<p>\uad50\ub958\uac00 \ubd88\ud3b8\ud55c \uc774\uc720\uac00 \ub2e8\uc21c \uc5b4\uc0c9\ud568\uc774 \uc544\ub2c8\ub77c \uac15\ud55c \ubd88\uc548, \uacf5\ud3ec, \uacfc\uac70\uc758 \uc88b\uc9c0 \uc54a\uc740 \uacbd\ud5d8\uacfc \uc5f0\uacb0\ub418\uc5b4 \uc788\ub2e4\uba74 \uc5ec\ud589 \ud301\ub9cc\uc73c\ub85c \ud574\uacb0\ub418\uc9c0 \uc54a\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774 \uacbd\uc6b0\uc5d0\ub294 \uc77c\uc815\uc744 \uc904\uc774\uace0 \uc548\uc804\ud55c \uacf5\uac1c \uc7a5\uc18c \uc704\uc8fc\ub85c \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \uc88b\uc73c\uba70, \ud544\uc694\ud558\uba74 \uc8fc\ubcc0 \uc2e0\ub8b0 \uac00\ub2a5\ud55c \uc0ac\ub78c\uc774\ub098 \uc804\ubb38 \uc9c0\uc6d0 \uccb4\uacc4\uc758 \ub3c4\uc6c0\uc744 \ubc1b\ub294 \uc120\ud0dd\ub3c4 \uace0\ub824\ud574\uc57c \ud569\ub2c8\ub2e4. \uc774 \uad6c\ubd84\uc744 \ud574 \ub450\uba74 \u201c\uc5b5\uc9c0\ub85c \uc5b4\uc6b8\ub824\uc57c \ud55c\ub2e4\u201d\ub294 \uc555\ubc15\uc744 \uc904\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ud63c\uc790 \uc5ec\ud589 \uc911 \uad50\ub958\uac00 \ubd80\ub2f4\uc73c\ub85c \ubc14\ub00c\ub294 \uacbd\uacc4\uc120<\/h2>\n<p>\uc0ac\ub78c\ub4e4\uacfc \uc5b4\uc6b8\ub9ac\ub294 \uc77c\uc740 \uc5ec\ud589\uc758 \ud655\uc7a5\uc774 \ub420 \uc218\ub3c4 \uc788\uc9c0\ub9cc, \uae30\uc900\uc774 \uc5c6\uc73c\uba74 \uae08\ubc29 \ud53c\ub85c\uc640 \ubd88\uc548\uc73c\ub85c \ubc14\ub014 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788 \uc0c1\ub300\uc758 \ud638\uc758\uc640 \ubcf8\uc778\uc758 \ubd88\ud3b8\ud568\uc774 \ub3d9\uc2dc\uc5d0 \ub290\uaef4\uc9c8 \ub54c, \ucd08\ubcf4\uc790\ub294 \uac70\uc808 \ud0c0\uc774\ubc0d\uc744 \ub193\uce58\uae30 \uc27d\uc2b5\ub2c8\ub2e4. \uadf8\ub798\uc11c \uad50\ub958\ub294 \ub9ce\uc774 \ud558\ub294 \uac83\ubcf4\ub2e4 \uc911\ub2e8\ud560 \uc218 \uc788\ub294 \uad6c\uc870 \uc548\uc5d0\uc11c \uc2dc\uc791\ud558\ub294 \ud3b8\uc774 \ub0ab\uc2b5\ub2c8\ub2e4. \uacf5\uac1c\ub41c \uc7a5\uc18c, \uc815\ud574\uc9c4 \uc885\ub8cc \uc2dc\uc810, \ub0b4 \uc219\uc18c\uc640 \ub3d9\uc120\uc774 \ub4dc\ub7ec\ub098\uc9c0 \uc54a\ub294 \uc870\uac74\uc774 \uc720\uc9c0\ub420 \ub54c\ub9cc \uad50\ub958\uac00 \uc5ec\ud589 \ud488\uc9c8\uc744 \ub192\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc790\uc5f0\uc2a4\ub7fd\uac8c \uc5b4\uc6b8\ub9b0\ub2e4\ub294 \ub9d0\uc774 \uc2e4\uc81c\ub85c \ub73b\ud558\ub294 \uac83<\/h2>\n<p>\uc5ec\ud589\uc5d0\uc11c \uc790\uc5f0\uc2a4\ub7ec\uc6b4 \uad50\ub958\ub294 \ub9d0\uc744 \uc798\ud558\ub294 \ub2a5\ub825\ubcf4\ub2e4, \uc0c1\ud669\uc744 \uc548\uc804\ud558\uac8c \uc77d\uace0 \uc801\uc808\ud55c \uac70\ub9ac\uac10\uc744 \uc720\uc9c0\ud558\ub294 \ud310\ub2e8\uc5d0 \uac00\uae5d\uc2b5\ub2c8\ub2e4. \uc5b5\uc9c0\ub85c \uce5c\ud574\uc9c0\ub824 \ud558\uac70\ub098, \ubc18\ub300\ub85c \ub108\ubb34 \uacbd\uc9c1\ub418\uac8c \uad74 \ud544\uc694\ub3c4 \uc5c6\uc2b5\ub2c8\ub2e4. \uc9e7\uac8c \uc774\uc57c\uae30\ud558\uace0 \ub05d\ub0bc \uc218 \uc788\ub294 \uc5ec\uc9c0\ub97c \ub0a8\uaca8\ub450\ub294 \ucabd\uc774 \uc624\ud788\ub824 \ud3b8\uc548\ud55c \ub9cc\ub0a8\uc73c\ub85c \uc774\uc5b4\uc9c8 \uac00\ub2a5\uc131\uc774 \ud07d\ub2c8\ub2e4. \uc774 \uae00\uc758 \ud575\uc2ec\uc740 \uc0ac\uad50 \uae30\uc220\uc774 \uc544\ub2c8\ub77c, \ud63c\uc790 \uc5ec\ud589\uc790\uc758 \uc548\uc804\uacfc \uc790\uc728\uc131\uc744 \ud574\uce58\uc9c0 \uc54a\ub294 \uad50\ub958 \ubc29\uc2dd\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\" id=\"social-faq\">\uc0ac\ub78c\ub4e4\uacfc \uc5b4\uc6b8\ub9b4 \ub54c \uc790\uc8fc \ub9c9\ud788\ub294 \uc9c8\ubb38<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">Q1. \ud63c\uc790 \uc5ec\ud589 \uc911 \uc0ac\ub78c\uc744 \uaf2d \ub9cc\ub098\uc57c \ud558\ub098\uc694?<\/h3>\n\n\n<p>\uc544\ub2d9\ub2c8\ub2e4. \uad50\ub958\ub294 \uc120\ud0dd\uc785\ub2c8\ub2e4. \ud63c\uc790 \uc788\ub294 \uc2dc\uac04\uc774 \ud3b8\ud558\ub2e4\uba74 \uadf8 \uc790\uccb4\ub85c \uc88b\uc740 \uc5ec\ud589\uc785\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q2. \ucd08\ubcf4\uc790\uc5d0\uac8c \uac00\uc7a5 \ubd80\ub2f4\uc774 \uc801\uc740 \uad50\ub958 \ubc29\uc2dd\uc740 \ubb34\uc5c7\uc778\uac00\uc694?<\/h3>\n\n\n<p>\uc77c\uc77c \ud22c\uc5b4, \uc6cc\ud0b9 \ud22c\uc5b4, \ud074\ub798\uc2a4\ucc98\ub7fc \uc2dc\uac04\uacfc \uc7a5\uc18c, \ud65c\ub3d9 \ubaa9\uc801\uc774 \uc815\ud574\uc9c4 \ubc29\uc2dd\uc774 \ubd80\ub2f4\uc774 \uc801\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q3. \uac8c\uc2a4\ud2b8\ud558\uc6b0\uc2a4\ub294 \uc0ac\ub78c \ub9cc\ub098\uae30 \uc88b\uc740\uac00\uc694?<\/h3>\n\n\n<p>\uc88b\uc744 \uc218 \uc788\uc9c0\ub9cc \uc219\uc18c \ubd84\uc704\uae30\uc5d0 \ub530\ub77c \ud53c\ub85c\uac00 \uc0dd\uae38 \uc218\ub3c4 \uc788\uc2b5\ub2c8\ub2e4. \uc18c\uc74c, \uc74c\uc8fc \ubd84\uc704\uae30, \uac1c\uc778 \uacf5\uac04 \ud6c4\uae30\ub97c \ud568\uaed8 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q4. \ubd88\ud3b8\ud55c \uc81c\uc548\uc744 \ubc1b\uc73c\uba74 \uc5b4\ub5bb\uac8c \ud558\ub098\uc694?<\/h3>\n\n\n<p>\uc774\uc720\ub97c \uae38\uac8c \uc124\uba85\ud558\uc9c0 \uc54a\uc544\ub3c4 \ub429\ub2c8\ub2e4. \uc77c\uc815\uc774 \uc788\ub2e4, \uc26c\uc5b4\uc57c \ud55c\ub2e4, \uc219\uc18c\ub85c \ub3cc\uc544\uac00\uc57c \ud55c\ub2e4\uace0 \ub9d0\ud558\uace0 \uacf5\uac1c\ub41c \uc7a5\uc18c\ub85c \uc774\ub3d9\ud558\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ud63c\uc790 \uc5ec\ud589 \uc911 \uad50\ub958\ub294 \uc120\ud0dd\uc785\ub2c8\ub2e4. \uacf5\uac1c\ub41c \uc7a5\uc18c, \ub0ae \uc2dc\uac04\ub300, \uba85\ud655\ud55c \ud65c\ub3d9, \uc219\uc18c \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \uc0ac\ub78c\ub4e4\uacfc \uc548\uc804\ud558\uac8c \uc5b4\uc6b8\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"disabled","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"ba