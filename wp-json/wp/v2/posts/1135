{"id":1135,"date":"2026-03-06T18:31:54","date_gmt":"2026-03-06T09:31:54","guid":{"rendered":"https:\/\/shootsense.com\/?p=1135"},"modified":"2026-06-12T14:10:22","modified_gmt":"2026-06-12T05:10:22","slug":"%ec%a7%80%eb%8f%84%ec%97%90-%eb%b3%84%ed%91%9c%ea%b0%80-%ec%97%86%eb%8a%94-%ea%b3%b3%ec%97%90%ec%84%9c-%eb%b3%b4%eb%82%b8-%eb%af%b8%ec%95%bc%eb%a7%88%ec%9d%98-%ec%8b%9c%ea%b0%84","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%a7%80%eb%8f%84%ec%97%90-%eb%b3%84%ed%91%9c%ea%b0%80-%ec%97%86%eb%8a%94-%ea%b3%b3%ec%97%90%ec%84%9c-%eb%b3%b4%eb%82%b8-%eb%af%b8%ec%95%bc%eb%a7%88%ec%9d%98-%ec%8b%9c%ea%b0%84\/","title":{"rendered":"\uc77c\ubcf8 \ubbf8\uc57c\ub9c8 \ud63c\uc790 \uc5ec\ud589: \uc9c0\ub3c4 \ubcc4\ud45c\ubcf4\ub2e4 \ub9c8\uc744\uc758 \uc2dc\uac04 \ubcf4\ub294 \ubc95"},"content":{"rendered":"\n<p>\ubbf8\uc57c\ub9c8\ub294 \uc9c0\ub3c4\uc5d0 \ubcc4\ud45c\uac00 \ub9ce\uc740 \uc7a5\uc18c\ub77c\uae30\ubcf4\ub2e4 \ub9c8\uc744\uc758 \uc2dc\uac04\uacfc \ud48d\uacbd\uc744 \ucc9c\ucc9c\ud788 \ubcf4\ub294 \uacf3\uc774\ub2e4. \uadf8\ub798\uc11c \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uad50\ud1b5 \uc2dc\uac04\uc744 \uc815\ud655\ud788 \uc7a1\uace0, \ud604\uc7a5\uc5d0\uc11c\ub294 \uc18d\ub3c4\ub97c \ub0ae\ucd94\ub294 \ubc29\uc2dd\uc774 \uc798 \ub9de\ub294\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc77c\ubcf8 \ubbf8\uc57c\ub9c8\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc815\ubcf4\ud615 \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c \uac10\uc0c1\ubcf4\ub2e4 \uad50\ud1b5, \uccb4\ub958 \uc2dc\uac04, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \uc2e4\uc81c \uc77c\uc815\uc744 \uc9e4 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud588\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc77c\ubcf8 \ubbf8\uc57c\ub9c8 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\ubbf8\uc57c\ub9c8\ub294 \uc811\uadfc\uc131\uacfc \uccb4\ub958\uac10\uc758 \uade0\ud615\uc774 \ud575\uc2ec\uc774\ub2e4. \ubc84\uc2a4 \uc2dc\uac04\uc774 \uc77c\uc815\uc758 \ubf08\ub300\uac00 \ub418\ubbc0\ub85c, \uba3c\uc800 \uc624\uac00\ub294 \ud3b8\uc744 \uace0\uc815\ud55c \ub4a4 \ub9c8\uc744 \uc548\uc5d0\uc11c \uac78\uc744 \ubc94\uc704\ub97c \uc815\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud655\uc778 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uc804\ud1b5 \uac00\uc625 \ub9c8\uc744 \uc0b0\ucc45, \uc870\uc6a9\ud55c \uc790\uc5f0 \ud48d\uacbd, \ub290\ub9b0 \ubc18\ub098\uc808 \uccb4\ub958<\/td><td>\ubaa9\uc801\uc774 \ubaa8\ud638\ud558\uba74 \uc870\uc6a9\ud55c \uc7a5\uc18c\ub97c \ubcfc\uac70\ub9ac \ubd80\uc871\uc73c\ub85c \uc624\ud574\ud558\uae30 \uc27d\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\uad50\ud1a0\uad8c \ucd9c\ubc1c \ub300\uc911\uad50\ud1b5\uacfc \uc9c0\uc5ed \ubc84\uc2a4 \uc2dc\uac04 \ud655\uc778<\/td><td>\uc77c\ubcf8 \uc9c0\ubc29 \uc5ec\ud589\uc740 \ub9c9\ucc28\uc640 \ud658\uc2b9 \uc2dc\uac04\uc774 \uc77c\uc815 \uc804\uccb4\ub97c \uc88c\uc6b0\ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ub2f9\uc77c\uce58\uae30\ub3c4 \uac00\ub2a5\ud558\uc9c0\ub9cc \uc774\ub3d9 \uc2dc\uac04\uc744 \ud3ec\ud568\ud574 \ud558\ub8e8 \ub2e8\uc704\ub85c \uacc4\uc0b0<\/td><td>\uc9e7\uac8c \ubcfc\uc9c0, \ubc18\ub098\uc808 \uba38\ubb3c\uc9c0, 1\ubc15\ud560\uc9c0\uc5d0 \ub530\ub77c \ub9cc\uc871\ub3c4\uac00 \ub2ec\ub77c\uc9c4\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\ubc84\uc2a4 \uac04\uaca9, \uaca8\uc6b8 \ub0a0\uc528, \uc2dd\ub2f9 \ud734\ubb34, \ud1b5\uc2e0 \uc0c1\ud0dc<\/td><td>\ub0a0\uc528, \uc601\uc5c5\uc77c, \uad50\ud1b5 \uac04\uaca9\uc744 \ud655\uc778\ud574\uc57c \ud604\uc7a5 \uc2a4\ud2b8\ub808\uc2a4\uac00 \uc904\uc5b4\ub4e0\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\ub294 \uc18d\ub3c4\ub97c \ub2a6\ucd9c\uc218\ub85d \ud63c\ud589 \ub9cc\uc871\ub3c4\uac00 \uc624\ub978\ub2e4<\/h2>\n\n\n\n<p>\ubbf8\uc57c\ub9c8\ub294 \ud63c\uc790 \uc870\uc6a9\ud788 \uac77\ub294 \uc5ec\ud589\uc5d0 \uc801\ud569\ud558\ub2e4. \uc18c\ub9ac\uc640 \ud48d\uacbd\uc774 \ud070 \ube44\uc911\uc744 \ucc28\uc9c0\ud558\uae30 \ub54c\ubb38\uc5d0 \ub3d9\ud589\uc790\uc640 \ube60\ub974\uac8c \uc6c0\uc9c1\uc774\ub294 \uac83\ubcf4\ub2e4 \ud63c\uc790 \ucc9c\ucc9c\ud788 \ubcf4\ub294 \ubc29\uc2dd\uc774 \ub354 \uc790\uc5f0\uc2a4\ub7fd\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc720\uba85\ub3c4\ubcf4\ub2e4 \uccb4\ub958 \uc548\uc815\uc131\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \uc0ac\ub78c\uc774 \uc801\uc740 \uacf3\uc740 \uc2ec\uc2ec\ud560 \uc218 \uc788\uc9c0\ub9cc, \ub3d9\uc120\uc774 \ub2e8\uc21c\ud558\uace0 \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc774 \uba85\ud655\ud558\uba74 \uc624\ud788\ub824 \ud63c\uc790 \uac77\uae30 \ud3b8\ud55c \ubaa9\uc801\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\ub294 \ubcf5\uadc0 \uad50\ud1b5\uc744 \uba3c\uc800 \ud655\uc815\ud574\uc57c \uc548\uc815\uc801\uc774\ub2e4<\/h2>\n\n\n\n<p>\ubbf8\uc57c\ub9c8\ub294 \uad50\ud1b5\ud3b8\uc744 \uc989\ud765\uc801\uc73c\ub85c \ubc14\uafb8\uae30 \uc5b4\ub824\uc6b4 \ud3b8\uc774\ub2e4. \uc9c0\uc5ed \ubc84\uc2a4 \uc2dc\uac04\uacfc \ud658\uc2b9 \uc9c0\uc810\uc744 \uba3c\uc800 \ud655\uc778\ud558\uace0, \ub3cc\uc544\uc624\ub294 \ud3b8\uc744 \ub193\ucce4\uc744 \ub54c \ub300\uc548\uc774 \uc788\ub294\uc9c0\ub3c4 \uc219\uc18c\ub098 \uc548\ub0b4 \uc815\ubcf4\ub97c \ud1b5\ud574 \uc810\uac80\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc900\ube44 \ub2e8\uacc4<\/th><th>\ud655\uc778\ud560 \ub0b4\uc6a9<\/th><th>\ud63c\uc790 \uc5ec\ud589 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\uc804\ub0a0<\/td><td>\uacf5\uc2dd \uad50\ud1b5 \uc2dc\uac04\ud45c\uc640 \ubcf5\uadc0\ud3b8<\/td><td>\ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \uc801\uc73c\uba74 \uc624\uc804 \ucd9c\ubc1c\ub85c \uace0\uc815\ud55c\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \ubc84\uc2a4 \uc815\ub958\uc7a5, \uc548\ub0b4\uc18c \uc704\uce58<\/td><td>\uae38\uc744 \uc783\uc5c8\uc744 \ub54c \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\uc810\uc2ec \uc804\ud6c4<\/td><td>\uc2dd\ub2f9 \uc601\uc5c5 \uc5ec\ubd80\uc640 \ud734\uc2dd \uc7a5\uc18c<\/td><td>\uc791\uc740 \ub9c8\uc744\uc740 \uc601\uc5c5 \uc2dc\uac04\uc774 \uc9e7\uac70\ub098 \uc26c\ub294 \ub0a0\uc774 \uc788\uc744 \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4 \ud6c4\ubc18<\/td><td>\uc870\uba85, \uc778\uc801, \uc219\uc18c \ub610\ub294 \ucd9c\ubc1c\uc9c0 \ubc29\ud5a5<\/td><td>\ud63c\uc790\ub77c\uba74 \ud574\uc9c0\uae30 \uc804 \ubcf5\uadc0 \ud750\ub984\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8 \ub3d9\uc120\uc740 \ubc84\uc2a4 \uc2dc\uac04\ud45c \uae30\uc900\uc73c\ub85c \uc9dc\uc57c \ud55c\ub2e4<\/h2>\n\n\n\n<p>\ub9c8\uc744 \uc548\uc5d0\uc11c\ub294 \uc911\uc2ec \uad6c\uc5ed\uc744 \uae30\uc900\uc73c\ub85c \uc6d0\ud615\uc5d0 \uac00\uae5d\uac8c \uac77\ub294 \ud3b8\uc774 \uc88b\ub2e4. \uc678\uacfd \uae38\uae4c\uc9c0 \ub113\ud788\uba74 \ud48d\uacbd\uc740 \ub298\uc9c0\ub9cc \ubcf5\uadc0 \uc2dc\uac04\uc774 \ubd88\uc548\ud574\uc9c8 \uc218 \uc788\uc5b4 \uccab \ubc29\ubb38\uc774\ub77c\uba74 \ud575\uc2ec \ub9c8\uc744 \uad6c\uac04\uc5d0 \uc9d1\uc911\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc77c\ubcf8 \uc9c0\ubc29 \uc18c\ub3c4\uc2dc\ub294 \uc5ec\ub7ec \uc9c0\uc810\uc744 \ube60\ub974\uac8c \ucc0d\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \ud55c \ubc29\ud5a5\uc73c\ub85c \uac77\uace0 \ub2e4\uc2dc \ub3cc\uc544\uc624\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\ub2e4. \uc5ed\uc774\ub098 \uc815\ub958\uc7a5, \uc548\ub0b4\uc18c, \uc219\uc18c\ub97c \uae30\uc900\uc810\uc73c\ub85c \uc0bc\uc73c\uba74 \ud604\uc7a5\uc5d0\uc11c \uc77c\uc815\uc744 \uc904\uc774\uae30\ub3c4 \uc27d\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8 \uc219\uc18c\ub294 1\ubc15 \uac00\uce58\ubcf4\ub2e4 \ubcf5\uadc0 \ub09c\ub3c4\ub97c \uba3c\uc800 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>1\ubc15\uc744 \ud558\uba74 \uc544\uce68\uacfc \uc800\ub141\uc758 \uc870\uc6a9\ud55c \uc2dc\uac04\uc744 \ubcfc \uc218 \uc788\uc9c0\ub9cc, \uc219\uc18c \uc218\uc640 \uc2dd\uc0ac \uc120\ud0dd\uc9c0\ub294 \uc81c\ud55c\ub420 \uc218 \uc788\ub2e4. \ub2f9\uc77c\uce58\uae30\ub77c\uba74 \uad50\ud1a0\ub098 \uc778\uadfc \ub3c4\uc2dc\ub97c \ubca0\uc774\uc2a4\ub85c \uc7a1\uace0 \ubc84\uc2a4 \uc2dc\uac04\uc5d0 \ub9de\ucd94\ub294 \ubc29\uc2dd\uc774 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \ubd84\uc704\uae30\ubcf4\ub2e4 \uc811\uadfc\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc678\uacfd \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \uc800\ub141 \uc2dd\uc0ac\uc640 \uccb4\ud06c\uc778, \uc9d0 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud560 \uc218 \uc788\uc73c\ubbc0\ub85c \ud63c\uc790\ub77c\uba74 \uad50\ud1b5 \uac70\uc810\uacfc \uc2dd\uc0ac \uac00\ub2a5 \uad6c\uc5ed \uc0ac\uc774\uac00 \uac00\uc7a5 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\ub294 \uc2dd\uc0ac \uac04\uaca9\ubcf4\ub2e4 \uccb4\ub825 \uc548\ubc30\uac00 \uc911\uc694\ud558\ub2e4<\/h2>\n\n\n\n<p>\uc2dd\ub2f9\uc740 \uc601\uc5c5\uc77c\uacfc \uc2dc\uac04\uc774 \ubcc0\uc218\ub2e4. \ub9c8\uc744 \uc548 \uc2dd\uc0ac\ub9cc \ubbff\uae30\ubcf4\ub2e4 \ucd9c\ubc1c \uc804 \uac04\uc2dd\uacfc \ubb3c\uc744 \uc900\ube44\ud558\uace0, \uc810\uc2ec \uac00\ub2a5 \uc2dc\uac04\uc744 \uc77c\uc815 \uac00\uc6b4\ub370\uc5d0 \ubc30\uce58\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub9c8\uc744\uc5d0\uc11c\ub294 \ub9db\uc9d1\ubcf4\ub2e4 \uc601\uc5c5\uc77c\uacfc \uc601\uc5c5 \uc2dc\uac04\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \uc810\uc2ec \ud6c4\ubcf4\ub97c 2\uacf3 \uc774\uc0c1 \ub450\uace0, \uc2dd\ub2f9\uc774 \ub2eb\ud614\uc744 \ub54c\ub97c \ub300\ube44\ud574 \ud3b8\uc758\uc810\uc774\ub098 \uac04\ub2e8\ud55c \uac04\uc2dd \ud655\ubcf4 \uc5ec\ubd80\ub97c \ud655\uc778\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\ub294 \ud574 \uc9c0\uae30 \uc804 \ubcf5\uadc0\uc640 \uccb4\uc628 \uc720\uc9c0\uac00 \uc911\uc694\ud558\ub2e4<\/h2>\n\n\n\n<p>\ubbf8\uc57c\ub9c8\uc758 \uc704\ud5d8\uc740 \uce58\uc548\ubcf4\ub2e4 \ub0a0\uc528\uc640 \uad50\ud1b5 \uacf5\ubc31\uc5d0\uc11c \uc628\ub2e4. \uaca8\uc6b8\uc774\ub098 \ube44 \uc624\ub294 \ub0a0\uc5d0\ub294 \ubcf4\ud589 \uc2dc\uac04\uc774 \ub298\uc5b4\ub098\uace0 \uccb4\uac10 \ud53c\ub85c\uac00 \ucee4\uc9c0\ubbc0\ub85c, \uc0ac\uc9c4 \uc695\uc2ec\ubcf4\ub2e4 \uccb4\uc628\uacfc \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc6b0\uc120\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc0ac\ub78c\uc774 \uc801\uc740 \uae38\uc774 \ud56d\uc0c1 \uc704\ud5d8\ud558\ub2e4\ub294 \ub73b\uc740 \uc544\ub2c8\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ub2a6\uc740 \uc2dc\uac04\uacfc \uc678\uc9c4 \uae38\uc744 \ub3d9\uc2dc\uc5d0 \ub9cc\ub4e4\uc9c0 \uc54a\ub294 \uac83\uc774 \uc6d0\uce59\uc774\ub2e4. \uc0ac\uc9c4\uc744 \ub354 \ucc0d\uae30\ubcf4\ub2e4 \ubcf5\uadc0\uac00 \uc26c\uc6b4 \uc2dc\uac04\ub300\uc5d0 \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \uacb0\uacfc\uc801\uc73c\ub85c \uc5ec\ud589 \ub9cc\uc871\ub3c4\ub97c \ub192\uc778\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\uc5d0\uc11c\ub294 \uad50\ud1b5\ubcf4\ub2e4 \uccb4\ub958 \uc2dc\uac04\uc744 \uba3c\uc800 \uacc4\uc0b0\ud55c\ub2e4<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \ub300\uc911\uad50\ud1b5 \uc870\ud569\uacfc \uc219\ubc15 \uc5ec\ubd80\uc5d0 \ub530\ub77c \ub2ec\ub77c\uc9c4\ub2e4. \ub2f9\uc77c \uc5ec\ud589\uc740 \ube44\uad50\uc801 \uac00\ubccd\uc9c0\ub9cc \uc774\ub3d9 \uc2dc\uac04\uc774 \uae38\uc5b4 \ud558\ub8e8 \uc804\uccb4\ub97c \uc4f0\ub294 \ube44\uc6a9\uc73c\ub85c \uacc4\uc0b0\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uad50\ud1b5\uacfc \uc219\ubc15\uc5d0\uc11c \ucc28\uc774\uac00 \ub09c\ub2e4. \ub2f9\uc77c\uce58\uae30\ub77c\uba74 \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc783\uc9c0 \uc54a\ub294 \uad50\ud1b5\ud3b8\uc774 \uc911\uc694\ud558\uace0, 1\ubc15\uc774\ub77c\uba74 \uc219\uc18c \uc704\uce58\uac00 \ub2e4\uc74c \ub0a0 \uc774\ub3d9\uae4c\uc9c0 \uc601\ud5a5\uc744 \uc900\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\uc758 \ub290\ub9b0 \ud750\ub984\uc774 \ub9de\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\uad00\uad11 \ud3ec\uc778\ud2b8\ub97c \ub9ce\uc774 \ucc0d\uae30\ubcf4\ub2e4 \ud55c \ub9c8\uc744\uc744 \ucc9c\ucc9c\ud788 \ubcf4\ub294 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \uc77c\ubcf8 \uc9c0\ubc29\uc758 \uc870\uc6a9\ud55c \uc0dd\ud65c \ud48d\uacbd\uc744 \ubcf4\uace0 \uc2f6\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ud2b9\ud788 \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\uc5d0\uc11c \ub0a0\uc528\uc640 \uad50\ud1b5\uc744 \uac19\uc774 \ubd10\uc57c \ud558\ub294 \uc774\uc720<\/h2>\n<p>\ubbf8\uc57c\ub9c8\ub294 \ud48d\uacbd\ub9cc \ubcf4\uace0 \uacb0\uc815\ud558\uba74 \uc2e4\uc81c \ud604\uc7a5 \ub09c\ub3c4\ub97c \ub193\uce58\uae30 \uc27d\uc2b5\ub2c8\ub2e4. \ubc84\uc2a4 \uac04\uaca9\uc774 \uae34 \uc9c0\uc5ed\uc5d0\uc11c\ub294 \ube44\ub098 \uae30\uc628 \ubcc0\ud654\uac00 \ubc14\ub85c \uc77c\uc815 \uc804\uccb4\uc5d0 \uc601\ud5a5\uc744 \uc8fc\uae30 \ub54c\ubb38\uc5d0, \ub0a0\uc528\uc640 \uad50\ud1b5\uc744 \ubd84\ub9ac\ud574\uc11c \ubcfc \uc218 \uc5c6\uc2b5\ub2c8\ub2e4. \ub9d1\uc740 \ub0a0\uc774\ub77c\ub3c4 \ubcf5\uadc0 \uc2dc\uac04\uc774 \uc560\ub9e4\ud558\uba74 \uccb4\ub958 \ub9cc\uc871\ub3c4\uac00 \ub5a8\uc5b4\uc9c0\uace0, \ud750\ub9b0 \ub0a0\uc774\ub77c\ub3c4 \ub300\uae30\uc640 \uc774\ub3d9 \uad6c\uc870\uac00 \uc548\uc815\uc801\uc774\uba74 \uc624\ud788\ub824 \ub354 \ud3b8\ud55c \ud558\ub8e8\uac00 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub798\uc11c \ubbf8\uc57c\ub9c8\ub294 \ud48d\uacbd \uac10\uc0c1\ubcf4\ub2e4 \uc870\uac74 \uc870\ud569\uc774 \ub354 \uc911\uc694\ud55c \ubaa9\uc801\uc9c0\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\uc5d0\uc11c 1\ubc15 \uc120\ud0dd\uc774 \uacfc\ud55c\uc9c0 \uc544\ub2cc\uc9c0 \ud310\ub2e8\ud558\ub294 \uae30\uc900<\/h2>\n<p>1\ubc15\uc774 \uacfc\ud558\uc9c0 \uc54a\uc73c\ub824\uba74 \ub2a6\uc740 \ubcf5\uadc0 \ubd80\ub2f4\uc744 \uc904\uc774\ub294 \ud6a8\uacfc\uac00 \ubd84\uba85\ud574\uc57c \ud569\ub2c8\ub2e4. \ubc18\ub300\ub85c \ub2f9\uc77c\ub85c\ub3c4 \ucda9\ubd84\ud788 \uc5ec\uc720 \uc788\uac8c \uc655\ubcf5 \uac00\ub2a5\ud558\uace0, \uc219\uc18c\ub97c \ucd94\uac00\ud574\ub3c4 \uccb4\ub958 \ub0b4\uc6a9\uc774 \ud06c\uac8c \ub2ec\ub77c\uc9c0\uc9c0 \uc54a\ub294\ub2e4\uba74 1\ubc15\uc740 \ube44\uc6a9\ub9cc \ub298\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc219\uc18c \uc790\uccb4 \uacbd\ud5d8, \uc800\ub141 \uc774\ud6c4\uc758 \uc548\uc815\uac10, \ub2e4\uc74c \ub0a0 \ucd9c\ubc1c \ud3b8\uc758\uae4c\uc9c0 \ud569\uccd0 \uac00\uce58\uac00 \uc0dd\uae30\ub294\uc9c0 \ubd10\uc57c \ud569\ub2c8\ub2e4. \ubbf8\uc57c\ub9c8\ub294 \ubb34\uc870\uac74 \uc219\ubc15\uc774 \ub2f5\uc778 \uacf3\uc774 \uc544\ub2c8\ub77c \uc774\ub3d9 \ubd80\ub2f4\uacfc \uccb4\ub958 \uac10\uac01\uc758 \uade0\ud615\uc73c\ub85c \uacb0\uc815\ud574\uc57c \ud558\ub294 \uacf3\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ubbf8\uc57c\ub9c8\uc758 \uc2dc\uac04\uc740 \ubcc4\ud45c\ubcf4\ub2e4 \uccb4\ub958\uac10\uc774 \uc911\uc694\ud558\ub2e4<\/h2>\n\n\n\n<p>\uc77c\ubcf8 \ubbf8\uc57c\ub9c8\ub294 \ubcc4\ud45c \ub9ce\uc740 \uad00\uad11\uc9c0\uac00 \uc544\ub2c8\ub77c, \uc2dc\uac04\uc744 \ub0ae\ucdb0\uc57c \uac00\uce58\uac00 \ubcf4\uc774\ub294 \ub9c8\uc744\uc774\ub2e4. \ubc84\uc2a4 \uc2dc\uac04\uacfc \uc2dd\uc0ac \uac00\ub2a5 \uc5ec\ubd80\ub9cc \uba3c\uc800 \uace0\uc815\ud558\uba74 \ud63c\uc790\uc11c\ub3c4 \ucda9\ubd84\ud788 \uc548\uc815\uc801\uc778 \ud558\ub8e8\ub97c \ub9cc\ub4e4 \uc218 \uc788\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc77c\ubcf8 \ubbf8\uc57c\ub9c8 \ud63c\uc790 \uc5ec\ud589\uc744 \uc900\ube44\ud560 \ub54c \ud544\uc694\ud55c \ubc84\uc2a4 \uc2dc\uac04, \ub9c8\uc744 \uc0b0\ucc45, \uc219\uc18c, \uc2dd\uc0ac, \uc548\uc804 \uae30\uc900\uc744 \uc815\ub9ac\ud588\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":1136,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"tablet":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"mobile":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""}},"ast-content-b