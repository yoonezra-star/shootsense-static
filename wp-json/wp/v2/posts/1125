{"id":1125,"date":"2026-03-12T12:44:00","date_gmt":"2026-03-12T03:44:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1125"},"modified":"2026-06-12T14:24:12","modified_gmt":"2026-06-12T05:24:12","slug":"%eb%9e%9c%eb%93%9c%eb%a7%88%ed%81%ac-%ec%97%86%ec%9d%b4-%ea%b8%b0%ec%96%b5%ec%97%90-%eb%82%a8%ec%9d%80-%eb%a3%a8%ec%95%99%eb%82%a8%ed%83%80%ec%9d%98-%ed%95%98%eb%a3%a8","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%eb%9e%9c%eb%93%9c%eb%a7%88%ed%81%ac-%ec%97%86%ec%9d%b4-%ea%b8%b0%ec%96%b5%ec%97%90-%eb%82%a8%ec%9d%80-%eb%a3%a8%ec%95%99%eb%82%a8%ed%83%80%ec%9d%98-%ed%95%98%eb%a3%a8\/","title":{"rendered":"\ub77c\uc624\uc2a4 \ub8e8\uc559\ub0a8\ud0c0 \ud63c\uc790 \uc5ec\ud589: \ub79c\ub4dc\ub9c8\ud06c\ubcf4\ub2e4 \uc790\uc5f0\uacfc \uc0dd\ud65c \ub9ac\ub4ec\uc744 \ubcf4\ub294 \ubc95"},"content":{"rendered":"\n<p>\ub8e8\uc559\ub0a8\ud0c0\ub294 \uac15\ud55c \ub79c\ub4dc\ub9c8\ud06c \ud558\ub098\ub85c \uae30\uc5b5\ub418\ub294 \ub3c4\uc2dc\ub294 \uc544\ub2c8\ub2e4. \ub300\uc2e0 \ubd81\ubd80 \ub77c\uc624\uc2a4\uc758 \uc790\uc5f0, \ub290\ub9b0 \uac70\ub9ac, \uc9c0\uc5ed \uc0dd\ud65c \ub9ac\ub4ec\uc744 \uac00\uae4c\uc774 \ubcf4\uae30 \uc88b\uc740 \uac70\uc810\uc5d0 \uac00\uae5d\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ub77c\uc624\uc2a4 \ub8e8\uc559\ub0a8\ud0c0\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \u201c\ubcfc\uac70\ub9ac \ubaa9\ub85d\u201d\uc774 \uc544\ub2c8\ub77c \uc2e4\uc81c \uc77c\uc815 \ud310\ub2e8 \uae30\uc900\uc73c\ub85c \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \uad50\ud1b5, \uccb4\ub958 \uc2dc\uac04, \uc2dd\uc0ac, \uc219\uc18c, \ubcf5\uadc0 \ub3d9\uc120\uc744 \ud568\uaed8 \ubd10\uc57c \uc7a5\uc18c\uc758 \uc7a5\uc810\uacfc \ud55c\uacc4\ub97c \uc815\ud655\ud788 \ud310\ub2e8\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub77c\uc624\uc2a4 \ub8e8\uc559\ub0a8\ud0c0 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\ub8e8\uc559\ub0a8\ud0c0\ub294 \ubaa9\uc801\uc744 \uba85\ud655\ud788 \ud574\uc57c \ub9cc\uc871\ub3c4\uac00 \uc62c\ub77c\uac04\ub2e4. \ud2b8\ub808\ud0b9\uc774\ub098 \uc790\uc5f0 \ud65c\ub3d9\uc744 \ud560 \uac83\uc778\uc9c0, \uc870\uc6a9\ud55c \uccb4\ub958\ub97c \ud560 \uac83\uc778\uc9c0\uc5d0 \ub530\ub77c \uc219\uc18c \uc704\uce58\uc640 \ud558\ub8e8 \ub3d9\uc120\uc774 \ub2ec\ub77c\uc9c4\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \ubcf4\ub294 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\uc5ec\ud589 \ubaa9\uc801<\/td><td>\uc790\uc5f0 \ud65c\ub3d9, \ubd81\ubd80 \ub77c\uc624\uc2a4 \uccb4\ub958, \ub290\ub9b0 \ub3c4\uc2dc \uc0b0\ucc45<\/td><td>\ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \ubcfc\uac70\ub9ac \ubd80\uc871\uc744 \uc2e4\ud328\ub85c \uc624\ud574\ud558\uc9c0 \uc54a\ub294\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ub09c\ub3c4<\/td><td>\ubc84\uc2a4, \ubc34, \ud604\uc9c0 \ud22c\uc5b4 \uc774\ub3d9\uc744 \uc0ac\uc804\uc5d0 \ud655\uc778<\/td><td>\ud63c\uc790 \uc774\ub3d9 \uc2dc \ud658\uc2b9, \ub300\uae30, \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc9c1\uc811 \uad00\ub9ac\ud574\uc57c \ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uae38\uc774<\/td><td>\ucd5c\uc18c 1\ubc15, \uc790\uc5f0 \ud65c\ub3d9\uae4c\uc9c0 \ud3ec\ud568\ud558\uba74 2\ubc15 \uc774\uc0c1 \uad8c\uc7a5<\/td><td>\ubc18\ub098\uc808, \ud558\ub8e8, 1\ubc15 \uc911 \uc5b4\ub5a4 \ubc29\uc2dd\uc774 \ub9de\ub294\uc9c0 \uba3c\uc800 \uc815\ud55c\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\ub3c4\ub85c \uc774\ub3d9 \uc2dc\uac04, \uc6b0\uae30, \ud22c\uc5b4 \uc6b4\uc601 \uc5ec\ubd80, \ud1b5\uc2e0\uacfc \ud604\uae08 \uc900\ube44<\/td><td>\uc791\uc740 \ubaa9\uc801\uc9c0\ub294 \ub0a0\uc528\uc640 \uc601\uc5c5 \uc2dc\uac04 \ubcc0\ud654\uc758 \uc601\ud5a5\uc774 \ud06c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\ub294 \uc870\uc6a9\ud55c \ubc18\ubcf5\uc744 \uc88b\uc544\ud560 \ub54c \ub9de\ub294\ub2e4<\/h2>\n\n\n\n<p>\ub8e8\uc559\ub0a8\ud0c0\ub294 \ud63c\uc790 \uc870\uc6a9\ud788 \uba38\ubb3c\uae30 \uc88b\uc9c0\ub9cc, \uc790\uc5f0 \ud65c\ub3d9\uc740 \ud63c\uc790 \uc989\ud765\uc801\uc73c\ub85c \uc6c0\uc9c1\uc774\uae30\ubcf4\ub2e4 \ud604\uc9c0 \uc6b4\uc601\uc790\uc640 \uc548\uc804 \uc870\uac74\uc744 \ud655\uc778\ud558\ub294 \ud3b8\uc774 \ub9de\ub2e4. \ub3c4\uc2dc \uc548\uc5d0\uc11c\ub294 \ub290\ub9b0 \ub9ac\ub4ec\uc774 \uc7a5\uc810\uc774\uace0, \uc678\uacfd \ud65c\ub3d9\uc5d0\uc11c\ub294 \uc900\ube44\uc131\uc774 \uc911\uc694\ud558\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc740 \ubaa9\uc801\uc9c0\uac00 \uc720\uba85\ud55c\uc9c0\ubcf4\ub2e4 \ud63c\uc790 \uc788\ub294 \uc2dc\uac04\uc774 \uc790\uc5f0\uc2a4\ub7ec\uc6b4\uc9c0\uac00 \ub354 \uc911\uc694\ud558\ub2e4. \uc9c0\ub098\uce58\uac8c \uad00\uad11\uac1d \uc911\uc2ec\uc73c\ub85c \uc124\uacc4\ub41c \uc7a5\uc18c\ub294 \ud63c\uc790\uc77c \ub54c \uc18c\ube44 \uc18d\ub3c4\uac00 \ube68\ub77c\uc9c0\uc9c0\ub9cc, \uc0dd\ud65c\uad8c\uacfc \uc0b0\ucc45\uad8c\uc774 \ub0a8\uc544 \uc788\ub294 \uc7a5\uc18c\ub294 \uc77c\uc815\uc758 \ube48 \uacf5\uac04\uc744 \ud3b8\ud558\uac8c \ubc1b\uc544\ub4e4\uc77c \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0 \ub3d9\uc120\uc740 \ub113\uac8c \ub3cc\uc9c0 \ub9d0\uace0 \uc0dd\ud65c \ubc18\uacbd\uc73c\ub85c \uc7a1\ub294\ub2e4<\/h2>\n\n\n\n<p>\uccab\ub0a0\uc740 \ub3c4\ucc29, \uc219\uc18c \uccb4\ud06c\uc778, \uc911\uc2ec \uac70\ub9ac\uc640 \uc2dd\uc0ac \uc9c0\uc810 \ud655\uc778\uc5d0 \uc9d1\uc911\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \uc790\uc5f0 \ud65c\ub3d9\uc774\ub098 \uc678\uacfd \uc774\ub3d9\uc740 \ub2e4\uc74c \ub0a0 \uc624\uc804\ubd80\ud130 \uc2dc\uc791\ud574\uc57c \ub0a0\uc528\uc640 \uccb4\ub825 \ubcc0\uc218\ub97c \uad00\ub9ac\ud558\uae30 \uc27d\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc2dc\uac04\ub300<\/th><th>\ucd94\ucc9c \ud589\ub3d9<\/th><th>\ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\ubcf5\uadc0\ud3b8\uacfc \uae30\uc900 \uc9c0\uc810 \ud655\uc778<\/td><td>\uc815\ub958\uc7a5, \uc219\uc18c, \uc911\uc2ec \uac70\ub9ac \uc911 \ud558\ub098\ub97c \uae30\uc900\uc810\uc73c\ub85c \uc7a1\ub294\ub2e4<\/td><\/tr><tr><td>\uc624\uc804 \ub610\ub294 \ub0ae<\/td><td>\ub300\ud45c \ub3d9\uc120 \uba3c\uc800 \uac77\uae30<\/td><td>\uccb4\ub825\uacfc \ub0a0\uc528\uac00 \uc88b\uc744 \ub54c \uac00\uc7a5 \uc911\uc694\ud55c \uad6c\uac04\uc744 \ubcf8\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4<\/td><td>\uc2dd\uc0ac\uc640 \ud734\uc2dd \ubc30\uce58<\/td><td>\uc791\uc740 \ub3c4\uc2dc\uc77c\uc218\ub85d \ube0c\ub808\uc774\ud06c \ud0c0\uc784\uacfc \ub9c8\uac10 \uc2dc\uac04\uc774 \ubcc0\uc218\ub2e4<\/td><\/tr><tr><td>\ud574\uc9c8 \ubb34\ub835<\/td><td>\uc219\uc18c \ub610\ub294 \ucd9c\ubc1c\uc9c0\ub85c \uc774\ub3d9<\/td><td>\ud63c\uc790\ub77c\uba74 \ud48d\uacbd\ubcf4\ub2e4 \ubcf5\uadc0 \uc548\uc815\uc131\uc744 \uc6b0\uc120\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\ub294 \uc774\ub3d9 \ud3b8\uc218\ubcf4\ub2e4 \ubcf5\uadc0 \uac00\ub2a5 \uc2dc\uac04\uc744 \ud655\uc778\ud55c\ub2e4<\/h2>\n\n\n\n<p>\ub77c\uc624\uc2a4 \ubd81\ubd80 \uc774\ub3d9\uc740 \uc608\uc0c1\ubcf4\ub2e4 \uc2dc\uac04\uc774 \uae38\uc5b4\uc9c8 \uc218 \uc788\ub2e4. \ub3c4\ucc29 \ub2f9\uc77c\uc5d0 \ube61\ube61\ud55c \ud65c\ub3d9\uc744 \ub123\uc9c0 \ub9d0\uace0, \ub2e4\uc74c \ubaa9\uc801\uc9c0 \uc774\ub3d9\ud3b8\ub3c4 \uc219\uc18c\ub098 \ud130\ubbf8\ub110\uc5d0\uc11c \uc7ac\ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uad50\ud1b5 \uc815\ubcf4\ub294 \uacc4\uc808\uacfc \uc694\uc77c\uc5d0 \ub530\ub77c \ubc14\ub014 \uc218 \uc788\uc73c\ubbc0\ub85c, \ucd9c\ubc1c \uc804\uc5d0\ub294 \uacf5\uc2dd \uc6b4\ud589 \uc815\ubcf4\uc640 \uc219\uc18c \uc548\ub0b4\ub97c \ubc18\ub4dc\uc2dc \ud568\uaed8 \ud655\uc778\ud574\uc57c \ud55c\ub2e4. \ud2b9\ud788 \uc791\uc740 \ub3c4\uc2dc\ub098 \uad6d\uacbd \uc778\uadfc \uc9c0\uc5ed\uc740 \uc9c0\ub3c4 \uc571\uc758 \uc608\uc0c1 \uc2dc\uac04\ub9cc\uc73c\ub85c \ud310\ub2e8\ud558\uba74 \ub300\uae30 \uc2dc\uac04\uc774 \uae38\uc5b4\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0 \uc219\uc18c\ub294 \uc774\ub3d9\ubcf4\ub2e4 \uc870\uc6a9\ud55c \uccb4\ub958\uac10\uc744 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \uc911\uc2ec \uac70\ub9ac\uc640 \ud22c\uc5b4 \uc0ac\ubb34\uc18c \uc811\uadfc\uc131\uc744 \uae30\uc900\uc73c\ub85c \uace0\ub974\ub294 \uac83\uc774 \uc88b\ub2e4. \ub108\ubb34 \uc678\uacfd\uc774\uba74 \uc870\uc6a9\ud558\uc9c0\ub9cc \uc2dd\uc0ac\uc640 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud558\uace0, \uc790\uc5f0 \ud65c\ub3d9 \ucd9c\ubc1c \uc2dc\uac04\uc744 \ub9de\ucd94\uae30 \uc5b4\ub824\uc6b8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790\ub77c\uba74 \uc804\ub9dd\uc774\ub098 \uac00\uaca9\ub9cc \ubcf4\uace0 \uc678\uacfd \uc219\uc18c\ub97c \uace0\ub974\ub294 \uac83\uc740 \uc2e0\uc911\ud574\uc57c \ud55c\ub2e4. \ubc24\uc5d0 \uac78\uc5b4\uc11c \ub3cc\uc544\uc62c \uc218 \uc788\ub294\uc9c0, \uc2dd\ub2f9\uacfc \ud3b8\uc758\uc2dc\uc124\uc774 \uc2e4\uc81c \uc6b4\uc601 \uc911\uc778\uc9c0, \uccb4\ud06c\uc778 \uc2dc\uac04\uc774 \ub3c4\ucc29 \uc2dc\uac04\uacfc \ub9de\ub294\uc9c0\ub97c \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\ub294 \uc2dd\uc0ac\ubcf4\ub2e4 \ub9ac\ub4ec \ud68c\ubcf5\uc774 \ub354 \uc911\uc694\ud558\ub2e4<\/h2>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc911\uc2ec \uac70\ub9ac \uc8fc\ubcc0\uc5d0\uc11c \ud574\uacb0\ud558\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4. \ub2a6\uc740 \uc2dc\uac04 \uc120\ud0dd\uc9c0\uac00 \uc904 \uc218 \uc788\uc73c\ubbc0\ub85c \ub3c4\ucc29 \ub2f9\uc77c\uc5d0\ub294 \uc219\uc18c \uadfc\ucc98 \uc2dd\uc0ac \uac00\ub2a5 \uc5ec\ubd80\ub97c \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ubaa9\uc801\uc9c0\ub294 \u201c\ub9db\uc9d1\u201d\ubcf4\ub2e4 \u201c\uba39\uc744 \uc218 \uc788\ub294 \uc2dc\uac04\u201d\uc774 \uc911\uc694\ud558\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc790\ub294 \ub300\uae30\uc640 \uc774\ub3d9\uc744 \ud63c\uc790 \uac10\ub2f9\ud574\uc57c \ud558\ubbc0\ub85c, \uc2dd\ub2f9 \ud6c4\ubcf4\ub97c 2\uacf3 \uc774\uc0c1 \ub450\uace0 \uac04\ub2e8\ud55c \ubb3c\uacfc \uac04\uc2dd\uc744 \uc900\ube44\ud558\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\ub294 \uc608\uc0b0\ubcf4\ub2e4 \uccb4\ub958 \uc18d\ub3c4\ub97c \uba3c\uc800 \uc815\ud558\ub294 \ud3b8\uc774 \ub0ab\ub2e4<\/h2>\n\n\n\n<p>\ub8e8\uc559\ub0a8\ud0c0 \uc608\uc0b0\uc740 \uc219\ubc15\ubcf4\ub2e4 \uc774\ub3d9\uacfc \ud65c\ub3d9 \ube44\uc6a9\uc5d0\uc11c \ucc28\uc774\uac00 \ub09c\ub2e4. \uc790\uc5f0 \ud65c\ub3d9\uc744 \ub123\uc744 \uacbd\uc6b0 \uac00\uaca9\ub9cc \ubcf4\uc9c0 \ub9d0\uace0 \ud3ec\ud568 \uc0ac\ud56d, \uc774\ub3d9 \ubc29\uc2dd, \uac00\uc774\ub4dc \uc5ec\ubd80, \uc548\uc804 \uae30\uc900\uc744 \ud568\uaed8 \ube44\uad50\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc \ud558\ub098\ubcf4\ub2e4 \uc774\ub3d9 \ubc29\uc2dd, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac \uc120\ud0dd\uc5d0\uc11c \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \ubb34\ub9ac\ud558\uac8c \ube44\uc6a9\uc744 \ub0ae\ucd94\uba74 \ubcf5\uadc0 \uc2dc\uac04\uc774 \ub098\ube60\uc9c0\uace0, \ubc18\ub300\ub85c \uc774\ub3d9 \ud3b8\uc758\ub97c \uacfc\ud558\uac8c \uc0ac\uba74 \uc791\uc740 \ubaa9\uc801\uc9c0\uc758 \uc7a5\uc810\uc778 \ub290\ub9b0 \uccb4\ub958\uac10\uc774 \uc904\uc5b4\ub4e4 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\uc5d0\uc11c \ud53c\ud574\uc57c \ud560 \uc695\uc2ec \ub9ce\uc740 \uc77c\uc815<\/h2>\n\n\n\n<p>\ub3c4\ucc29 \ub2f9\uc77c\uc5d0 \ubc14\ub85c \uc678\uacfd \ud65c\ub3d9\uc744 \ub123\uac70\ub098, \ub2e4\uc74c \uc774\ub3d9\uc77c \uc544\uce68\uc5d0 \ubb34\ub9ac\ud55c \ud22c\uc5b4\ub97c \ub123\ub294 \uc77c\uc815\uc740 \ud53c\ud558\ub294 \uac83\uc774 \uc88b\ub2e4. \uc774\ub3d9 \uc2dc\uac04\uc774 \uae38\uace0 \ubcc0\uc218\ub3c4 \ub9ce\uc544 \uc5ec\uc720 \uc2dc\uac04\uc774 \uc548\uc804\uc7a5\uce58\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<p>\ud2b9\ud788 \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \u201c\uac04 \uae40\uc5d0 \ud558\ub098 \ub354\u201d\uac00 \uc27d\uac8c \ud53c\ub85c\ub85c \ubc14\ub010\ub2e4. \uc774\ub3d9\uc774 \uae38\uac70\ub098 \uc120\ud0dd\uc9c0\uac00 \uc801\uc740 \uc9c0\uc5ed\uc77c\uc218\ub85d \ud575\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \uc81c\ub300\ub85c \uac77\uace0, \ub098\uba38\uc9c0\ub294 \ud604\uc7a5 \ucee8\ub514\uc158\uc5d0 \ub530\ub77c \uc904\uc774\ub294 \ubc29\uc2dd\uc774 \ub0ab\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\ub97c \uc88b\uc544\ud560 \uc5ec\ud589\uc790 \uc131\ud5a5<\/h2>\n\n\n\n<p>\ub77c\uc624\uc2a4\uc758 \uc720\uba85 \uad00\uad11\uc9c0\ub9cc \ube60\ub974\uac8c \ubcf4\ub294 \uc5ec\ud589\ubcf4\ub2e4, \ubd81\ubd80 \uc9c0\uc5ed\uc758 \uc790\uc5f0\uacfc \uc0dd\ud65c \ub9ac\ub4ec\uc744 \ucc9c\ucc9c\ud788 \ubcf4\uace0 \uc2f6\uc740 \uc0ac\ub78c\uc5d0\uac8c \ub9de\ub294\ub2e4. \ud63c\uc790\ub77c\ub3c4 \uc900\ube44\ub97c \uaf3c\uaf3c\ud788 \ud558\ub294 \uc5ec\ud589\uc790\ub77c\uba74 \ub9cc\uc871\ub3c4\uac00 \ub192\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\uc5d0\uc11c \uc77c\uc815\uc774 \ub290\uc2a8\ud574 \ubcf4\uc5ec\ub3c4 \uad1c\ucc2e\uc740 \uc774\uc720<\/h2>\n<p>\ub8e8\uc559\ub0a8\ud0c0\ub294 \ub208\uc5d0 \ub744\ub294 \ub79c\ub4dc\ub9c8\ud06c\uac00 \uc801\uae30 \ub54c\ubb38\uc5d0 \uc77c\uc815\uc774 \ube44\uc5b4 \ubcf4\uc778\ub2e4\ub294 \uc778\uc0c1\uc744 \uc8fc\uae30 \uc27d\uc2b5\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \uc774 \uc9c0\uc5ed\uc758 \ub9cc\uc871\ub3c4\ub294 \uc77c\uc815 \ubc00\ub3c4\uac00 \uc544\ub2c8\ub77c, \uc0dd\ud65c \ubc18\uacbd \uc548\uc5d0\uc11c \uae34\uc7a5\uc744 \uc5bc\ub9c8\ub098 \ub0ae\ucd9c \uc218 \uc788\ub294\uc9c0\uc5d0 \ub354 \uac00\uae5d\uc2b5\ub2c8\ub2e4. \ube60\ub974\uac8c \uc774\ub3d9\ud558\uba70 \uc131\uacfc\ub97c \uc313\ub294 \ubc29\uc2dd\uc740 \uc624\ud788\ub824 \uc774 \ub3c4\uc2dc\uc758 \uc7a5\uc810\uc744 \uc9c0\uc6cc \ubc84\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub8e8\uc559\ub0a8\ud0c0\ub294 \ub290\uc2a8\ud568\uc774 \ubd80\uc871\ud568\uc774 \uc544\ub2c8\ub77c, \uc758\ub3c4\ub41c \uccb4\ub958 \ubc29\uc2dd\uc73c\ub85c \ubc1b\uc544\ub4e4\uc77c \ub54c \uac00\uce58\uac00 \uc0b4\uc544\ub0a9\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\uc5d0\uc11c \ud558\ub8e8 \uc774\uc0c1 \uba38\ubb3c \uac00\uce58\uac00 \uc0dd\uae30\ub294 \ud310\ub2e8 \uae30\uc900<\/h2>\n<p>\uc219\ubc15\uc744 \ub298\ub9b4\uc9c0 \ub9d0\uc9c0\ub294 \uad00\uad11 \ud3ec\uc778\ud2b8 \uac1c\uc218\ubcf4\ub2e4 \uccb4\ub958 \ub9ac\ub4ec\uc774 \ud68c\ubcf5\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294\uc9c0\ub85c \ud310\ub2e8\ud574\uc57c \ud569\ub2c8\ub2e4. \uccab\ub0a0\ubd80\ud130 \uc870\uc6a9\ud55c \uc219\uc18c, \ubc18\ubcf5 \uac00\ub2a5\ud55c \uc2dd\uc0ac, \ubb34\ub9ac \uc5c6\ub294 \uc0b0\ucc45 \ubc18\uacbd\uc774 \ub9de\uc544\ub5a8\uc5b4\uc9c0\uba74 1\ubc15 \uc774\uc0c1\uc774 \uaf64 \uc548\uc815\uc801\uc73c\ub85c \uc774\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \uc774\ub3d9 \uc5f0\uacb0\uc774 \uc560\ub9e4\ud558\uac70\ub098 \uc0dd\ud65c \ub9ac\ub4ec\uc774 \ub9de\uc9c0 \uc54a\uc73c\uba74, \uc624\ub798 \uba38\ubb3c\uc218\ub85d \ub2e8\uc870\ub85c\uc6c0\uc774 \ub354 \ud06c\uac8c \ub290\uaef4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub8e8\uc559\ub0a8\ud0c0\ub294 \u201c\ubb58 \ub354 \ubcfc\uae4c\u201d\ubcf4\ub2e4 \u201c\uc774 \ub9ac\ub4ec\uc744 \ub354 \uc774\uc5b4\uac08 \uac00\uce58\uac00 \uc788\ub098\u201d\ub97c \ubb3b\ub294 \ucabd\uc774 \uc815\ud655\ud569\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub8e8\uc559\ub0a8\ud0c0\ub294 \uc18d\ub3c4 \uc870\uc808\uc774 \ub9cc\uc871\ub3c4\ub97c \uc88c\uc6b0\ud55c\ub2e4<\/h2>\n\n\n\n<p>\ub77c\uc624\uc2a4 \ub8e8\uc559\ub0a8\ud0c0\ub294 \ub79c\ub4dc\ub9c8\ud06c\uac00 \uc801\ub2e4\ub294 \uc774\uc720\ub85c \ub0ae\uac8c \ubcfc \ubaa9\uc801\uc9c0\uac00 \uc544\ub2c8\ub2e4. \uc790\uc5f0 \ud65c\ub3d9\uacfc \ub3c4\uc2dc \uccb4\ub958\ub97c \ubd84\ub9ac\ud574 \uacc4\ud68d\ud558\uace0, \uad50\ud1b5\uacfc \uc219\uc18c \uc704\uce58\ub97c \uba3c\uc800 \ud655\uc815\ud558\uba74 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ucda9\ubd84\ud788 \uc758\ubbf8 \uc788\ub294 \uac70\uc810\uc774 \ub41c\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ub77c\uc624\uc2a4 \ub8e8\uc559\ub0a8\ud0c0 \ud63c\uc790 \uc5ec\ud589\uc744 \uc900\ube44\ud560 \ub54c \ud544\uc694\ud55c \uc774\ub3d9, \uc219\uc18c \uc704\uce58, \uc790\uc5f0 \ud65c\ub3d9, \uc2dd\uc0ac, \uc548\uc804 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc2e4\uc804 \uac00\uc774\ub4dc.<\/p>\n","protected":false},"author":1,"featured_media":1126,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"tablet":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","back