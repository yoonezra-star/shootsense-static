{"id":1216,"date":"2026-03-27T09:51:00","date_gmt":"2026-03-27T00:51:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1216"},"modified":"2026-06-12T14:24:15","modified_gmt":"2026-06-12T05:24:15","slug":"%ed%98%84%ec%a7%80%ec%9d%b8%ec%9d%98-%ec%9d%bc%ec%83%81%ec%97%90-%ec%84%9e%ec%97%ac-%ec%9e%88%eb%8d%98-%ed%83%9c%ea%b5%ad-%eb%b6%81%eb%b6%80%ec%9d%98-%ed%8c%8c%ec%9d%b4pai%ec%9d%98-%ec%8b%9c","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ed%98%84%ec%a7%80%ec%9d%b8%ec%9d%98-%ec%9d%bc%ec%83%81%ec%97%90-%ec%84%9e%ec%97%ac-%ec%9e%88%eb%8d%98-%ed%83%9c%ea%b5%ad-%eb%b6%81%eb%b6%80%ec%9d%98-%ed%8c%8c%ec%9d%b4pai%ec%9d%98-%ec%8b%9c\/","title":{"rendered":"\ud604\uc9c0\uc778\uc758 \uc77c\uc0c1\uc5d0 \uc11e\uc5ec \uc788\ub358 \ud0dc\uad6d \ubd81\ubd80\uc758 \ud30c\uc774(Pai)\uc758 \uc2dc\uac04"},"content":{"rendered":"\n<p>\ud0dc\uad6d \ubd81\ubd80\uc758 \ud30c\uc774(Pai)\ub294 \ube60\ub974\uac8c \uad00\uad11\uc9c0\ub97c \ucc0d\uace0 \uc774\ub3d9\ud558\ub294 \ub3c4\uc2dc\ub77c\uae30\ubcf4\ub2e4 \uba70\uce60 \uba38\ubb3c\uba70 \uc0dd\ud65c \uc18d\ub3c4\ub97c \ub9de\ucdb0 \ubcf4\ub294 \uacf3\uc5d0 \uac00\uae5d\uc2b5\ub2c8\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c\ub294 \uc7a5\uc810\uc774 \ubd84\uba85\ud569\ub2c8\ub2e4. \uc774\ub3d9 \ubc18\uacbd\uc774 \ube44\uad50\uc801 \uc791\uace0, \uce74\ud398\uc640 \uc219\uc18c \uc120\ud0dd\uc9c0\uac00 \ub9ce\uc73c\uba70, \ud63c\uc790 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uae30 \uc27d\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc \uc0b0\uc545 \ub3c4\ub85c \uc774\ub3d9, \ubc24\uae38, \uc624\ud1a0\ubc14\uc774 \uc774\uc6a9, \uc678\uacfd \uc219\uc18c \uc120\ud0dd\uc740 \uc2e0\uc911\ud558\uac8c \ud310\ub2e8\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ud30c\uc774\ub97c \uac10\uc131\uc801\uc778 \uc5ec\ud589\uc9c0\ub85c\ub9cc \uc18c\uac1c\ud558\uc9c0 \uc54a\uace0, \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \uc2e4\uc81c\ub85c \uba38\ubb3c \ub54c \ud544\uc694\ud55c \uae30\uc900\uc744 \uc815\ub9ac\ud569\ub2c8\ub2e4. \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac, \uc0b0\ucc45, \uad50\ud1b5, \uc678\uacfd \uc774\ub3d9, \uac10\uc815 \uad00\ub9ac\uae4c\uc9c0 \ud568\uaed8 \ubd10\uc57c \ud30c\uc774\uc758 \ub290\ub9b0 \ubd84\uc704\uae30\ub97c \uc548\uc804\ud558\uac8c \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"pai-fit\">\ud30c\uc774\ub294 \ube60\ub978 \uc77c\uc815\ubcf4\ub2e4 \uccb4\ub958\ud615 \ud63c\ud589\uc5d0 \ub9de\uc2b5\ub2c8\ub2e4<\/h2>\n\n\n<p>\ud30c\uc774\ub294 \ud558\ub8e8\uc5d0 \ub9ce\uc740 \uba85\uc18c\ub97c \ubcf4\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \uc219\uc18c \uc8fc\ubcc0\uc5d0\uc11c \ubc18\ubcf5 \uac00\ub2a5\ud55c \ub8e8\ud2f4\uc744 \ub9cc\ub4dc\ub294 \uc5ec\ud589\uc5d0 \uc798 \ub9de\uc2b5\ub2c8\ub2e4. \uc544\uce68\uc5d0\ub294 \uce74\ud398\ub098 \uc2dc\uc7a5, \ub0ae\uc5d0\ub294 \uc9e7\uc740 \uc0b0\ucc45, \uc624\ud6c4\uc5d0\ub294 \uc219\uc18c\ub098 \uc870\uc6a9\ud55c \uc7a5\uc18c\uc5d0\uc11c \uc26c\ub294 \uc2dd\uc73c\ub85c \uc6c0\uc9c1\uc774\uba74 \ud53c\ub85c\uac00 \uc801\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \uc9e7\uc740 \uc77c\uc815\uc5d0 \uc678\uacfd \uc804\ub9dd\ub300\uc640 \ud3ed\ud3ec, \uce74\ud398, \uc57c\uc2dc\uc7a5\uae4c\uc9c0 \ubaa8\ub450 \ub123\uc73c\uba74 \uc774\ub3d9 \ud53c\ub85c\uac00 \ucee4\uc9d1\ub2c8\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc5ec\ud589\uc790 \uc720\ud615<\/th><th>\ud30c\uc774\uc5d0\uc11c \ub9de\ub294 \ubc29\uc2dd<\/th><th>\uc8fc\uc758\ud560 \uc810<\/th><\/tr><\/thead><tbody><tr><td>\ub290\ub9b0 \uc5ec\ud589 \uc120\ud638<\/td><td>\uc219\uc18c \uc8fc\ubcc0 \uce74\ud398, \uc2dc\uc7a5, \uc0b0\ucc45 \uc911\uc2ec<\/td><td>\uc77c\uc815\uc744 \ube44\uc6cc \ub450\ub294 \ub370 \uc775\uc219\ud574\uc57c \ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>\ucd08\ubcf4 \ud63c\ud589<\/td><td>\uc911\uc2ec\uc9c0 \uc219\uc18c\uc640 \ub0ae \uc2dc\uac04 \uc774\ub3d9<\/td><td>\ubc24 \uc678\uacfd \uc774\ub3d9\uc740 \uc904\uc774\ub294 \ud3b8\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uc624\ud1a0\ubc14\uc774 \uc774\uc6a9 \uc608\uc815<\/td><td>\uc9e7\uc740 \uad6c\uac04\ubd80\ud130 \ud655\uc778<\/td><td>\uc6b4\uc804 \uacbd\ud5d8, \ubcf4\ud5d8, \ub3c4\ub85c \uc0c1\ud0dc\ub97c \ubd10\uc57c \ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uc0ac\uc9c4 \uc911\uc2ec \uc5ec\ud589<\/td><td>\uc804\ub9dd\ub300\ub098 \uc678\uacfd \ud55c \uacf3\ub9cc \uc120\ud0dd<\/td><td>\uc5ec\ub7ec \uc678\uacfd \uc9c0\uc810\uc744 \ud558\ub8e8\uc5d0 \ubb36\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"pai-stay\">\uc219\uc18c\ub294 \uc911\uc2ec\uc9c0 \uc811\uadfc\uc131\uacfc \ubc24 \uadc0\uac00\ub97c \uba3c\uc800 \ubd05\ub2c8\ub2e4<\/h2>\n\n\n<p>\ud30c\uc774 \uc219\uc18c\ub294 \uc911\uc2ec\uc9c0\uc5d0 \uac00\uae4c\uc6b4 \uacf3\uacfc \uc870\uc6a9\ud55c \uc678\uacfd \uc219\uc18c\ub85c \ub098\ub269\ub2c8\ub2e4. \uc678\uacfd \uc219\uc18c\ub294 \ubd84\uc704\uae30\uac00 \uc88b\uc744 \uc218 \uc788\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589 \ucd08\ubcf4\uc790\ub77c\uba74 \ubc24\uc5d0 \uc2dd\uc0ac \ud6c4 \ub3cc\uc544\uc624\ub294 \uae38\uacfc \uc774\ub3d9 \uc218\ub2e8\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4. \uc911\uc2ec\uc9c0 \uc219\uc18c\ub294 \uc18c\uc74c\uc774 \uc788\uc744 \uc218 \uc788\uc9c0\ub9cc \uc2dd\uc0ac\uc640 \uce74\ud398, \uc57c\uc2dc\uc7a5 \uc811\uadfc\uc774 \uc27d\ub2e4\ub294 \uc7a5\uc810\uc774 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n<p>\uc219\uc18c \ud6c4\uae30\ub294 \ud3c9\uc810\ubcf4\ub2e4 \u201c\uac78\uc5b4\uc11c \ub2e4\ub2d0 \uc218 \uc788\ub294\uc9c0\u201d, \u201c\ubc24\uc5d0 \ub3cc\uc544\uc624\uae30 \uad1c\ucc2e\uc740\uc9c0\u201d, \u201c\uc18c\uc74c\uc774 \uc2ec\ud55c\uc9c0\u201d, \u201c\uc9c1\uc6d0 \uc751\ub300\uac00 \ube60\ub978\uc9c0\u201d\ub97c \ubd10\uc57c \ud569\ub2c8\ub2e4. \uc138\ubd80 \uae30\uc900\uc740 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-sukso-goreuneun-beop\/\">\ud63c\uc790 \uc5ec\ud589 \uc219\uc18c \uace0\ub974\ub294 \ubc95<\/a>\uacfc \uc5f0\uacb0\ud574 \ud655\uc778\ud558\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"pai-day\">\ud30c\uc774\uc5d0\uc11c \ud558\ub8e8\ub97c \ubcf4\ub0b4\ub294 \uae30\uc900<\/h2>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc2dc\uac04\ub300<\/th><th>\uad8c\uc7a5 \ud589\ub3d9<\/th><th>\ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\uc544\uce68<\/td><td>\uc219\uc18c \uc8fc\ubcc0 \uce74\ud398, \uc2dc\uc7a5, \uc0b0\ucc45<\/td><td>\ub0a0\uc528\uc640 \ucee8\ub514\uc158\uc744 \uba3c\uc800 \ud655\uc778\ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>\ub0ae<\/td><td>\uc678\uacfd \ud55c \uacf3 \ub610\ub294 \ud734\uc2dd<\/td><td>\uc774\ub3d9 \uc218\ub2e8\uacfc \ubcf5\uadc0 \uc2dc\uac04\uc744 \uba85\ud655\ud788 \ub461\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uc800\ub141<\/td><td>\uc911\uc2ec\uc9c0 \uc2dd\uc0ac, \uc57c\uc2dc\uc7a5<\/td><td>\uc219\uc18c \ubcf5\uadc0 \uae38\uc744 \ubbf8\ub9ac \ud655\uc778\ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>\ubc24<\/td><td>\uc219\uc18c \uac00\uae4c\uc6b4 \uacf3\uc5d0\uc11c \ub9c8\ubb34\ub9ac<\/td><td>\uc0c8\ub85c\uc6b4 \uc678\uacfd \ub3d9\uc120\uc744 \ub9cc\ub4e4\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"pai-transport\">\uc624\ud1a0\ubc14\uc774\uc640 \uc678\uacfd \uc774\ub3d9\uc740 \ubcc4\ub3c4 \uae30\uc900\uc774 \ud544\uc694\ud569\ub2c8\ub2e4<\/h2>\n\n\n<p>\ud30c\uc774\uc5d0\uc11c\ub294 \uc624\ud1a0\ubc14\uc774\ub97c \uc774\uc6a9\ud558\ub294 \uc5ec\ud589\uc790\uac00 \ub9ce\uc9c0\ub9cc, \ubaa8\ub4e0 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294 \uc120\ud0dd\uc740 \uc544\ub2d9\ub2c8\ub2e4. \uc6b4\uc804 \uacbd\ud5d8\uc774 \ubd80\uc871\ud558\uac70\ub098 \ubcf4\ud5d8 \uc870\uac74\uc744 \ubaa8\ub978\ub2e4\uba74 \ubb34\ub9ac\ud558\uc9c0 \uc54a\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4. \uc678\uacfd \uba85\uc18c\ub97c \uac00\uc57c \ud55c\ub2e4\uba74 \ud22c\uc5b4, \ud0dd\uc2dc, \uc219\uc18c \ubb38\uc758 \uac19\uc740 \ub300\uccb4 \uc218\ub2e8\uc744 \uba3c\uc800 \ud655\uc778\ud558\uc138\uc694.<\/p>\n\n\n<p>\uc0b0\uc545 \ub3c4\ub85c\uc640 \ub0a0\uc528\ub294 \uc774\ub3d9 \ub09c\uc774\ub3c4\ub97c \ubc14\uafc9\ub2c8\ub2e4. \ube44\uac00 \uc624\uac70\ub098 \ubab8 \uc0c1\ud0dc\uac00 \uc88b\uc9c0 \uc54a\uc740 \ub0a0\uc5d0\ub294 \uc678\uacfd \uc774\ub3d9\uc744 \uc904\uc774\uace0 \uc911\uc2ec\uc9c0 \uc911\uc2ec\uc73c\ub85c \uba38\ubb34\ub294 \uac83\uc774 \uc548\uc804\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"pai-meal\">\uc2dd\uc0ac\ub294 \ubc18\ubcf5 \uac00\ub2a5\ud55c \uacf3\uc744 \uc815\ud558\uba74 \ud3b8\ud569\ub2c8\ub2e4<\/h2>\n\n\n<p>\ud30c\uc774\uc5d0\uc11c\ub294 \uce74\ud398, \uac04\ub2e8\ud55c \uc2dd\ub2f9, \uc57c\uc2dc\uc7a5\ucc98\ub7fc \ud63c\uc790 \uc774\uc6a9\ud558\uae30 \uc26c\uc6b4 \uc120\ud0dd\uc9c0\uac00 \uc788\uc2b5\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \ud53c\uace4\ud55c \ub0a0\uc5d0\ub294 \uc0c8\ub85c\uc6b4 \uc2dd\ub2f9\uc744 \ucc3e\ub294 \uac83\ub3c4 \ubd80\ub2f4\uc774 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc219\uc18c \uac00\uae4c\uc6b4 \uc2dd\ub2f9\uc774\ub098 \uce74\ud398\ub97c \ud558\ub098 \uc815\ud574 \ub450\uba74 \ud558\ub8e8 \ud310\ub2e8\uc774 \uc904\uc5b4\ub4ed\ub2c8\ub2e4. \ud63c\ubc25 \uae30\uc900\uc740 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-sikdang-goreuneun-beop\/\">\ud63c\uc790 \uc5ec\ud589 \uc911 \uc2dd\ub2f9 \uace0\ub974\ub294 \ubc95<\/a>\uc744 \ucc38\uace0\ud558\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"pai-avoid\">\ud30c\uc774\uc5d0\uc11c \ud53c\ud574\uc57c \ud560 \uc77c\uc815<\/h2>\n\n\n<ul class=\"wp-block-list\"><li>\ub3c4\ucc29 \uccab\ub0a0 \ubc14\ub85c \uc678\uacfd \uba85\uc18c\ub97c \uc5ec\ub7ec \uacf3 \ub123\ub294 \uc77c\uc815<\/li><li>\uc6b4\uc804 \uacbd\ud5d8 \uc5c6\uc774 \uc624\ud1a0\ubc14\uc774\ub97c \ubb34\ub9ac\ud558\uac8c \uc774\uc6a9\ud558\ub294 \uac83<\/li><li>\ubc24 \ub2a6\uac8c \uc678\uacfd \uc219\uc18c\ub85c \ud63c\uc790 \ub3cc\uc544\uac00\ub294 \uc77c\uc815<\/li><li>\uc2ec\uc2ec\ud568\uc744 \ub9cc\ud68c\ud558\ub824\uace0 \uacc4\uc18d \uba3c \uacf3\uc744 \ucd94\uac00\ud558\ub294 \uac83<\/li><\/ul>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"pai-checklist\">\ud30c\uc774 \ud63c\uc790 \uc5ec\ud589 \uccb4\ud06c\ub9ac\uc2a4\ud2b8<\/h2>\n\n\n<ul class=\"wp-block-list\"><li>\uc219\uc18c\uc5d0\uc11c \uc911\uc2ec\uc9c0\uae4c\uc9c0 \uac78\uc5b4\uac08 \uc218 \uc788\ub294\uc9c0 \ud655\uc778\ud569\ub2c8\ub2e4.<\/li><li>\uc678\uacfd \uc774\ub3d9\uc740 \ud558\ub8e8\uc5d0 \ud55c \uacf3\ub9cc \uc7a1\uc2b5\ub2c8\ub2e4.<\/li><li>\uc624\ud1a0\ubc14\uc774 \uc774\uc6a9 \uc804 \ubcf4\ud5d8\uacfc \uc6b4\uc804 \uacbd\ud5d8\uc744 \ud604\uc2e4\uc801\uc73c\ub85c \ubd05\ub2c8\ub2e4.<\/li><li>\ubc18\ubcf5\ud574\uc11c \uc774\uc6a9\ud560 \uce74\ud398\ub098 \uc2dd\ub2f9\uc744 \ud558\ub098 \uc815\ud569\ub2c8\ub2e4.<\/li><li>\ube44 \uc624\ub294 \ub0a0\uc5d0\ub294 \uc678\uacfd\ubcf4\ub2e4 \uc911\uc2ec\uc9c0 \ub8e8\ud2f4\uc73c\ub85c \ubc14\uafc9\ub2c8\ub2e4.<\/li><\/ul>\n<!-- \/wp:post-content -->\n\n<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">\ud30c\uc774\uc5d0\uc11c\ub294 \ubb34\uc5c7\uc744 \uc0ac\uc804\uc5d0 \ub2e4\uc2dc \ud655\uc778\ud574\uc57c \ud558\ub294\uac00<\/h2>\n<p>\ud30c\uc774\ub294 \ubd84\uc704\uae30\ub9cc \ubcf4\uba74 \uac00\ubccd\uac8c \uba38\ubb3c\uae30 \uc26c\uc6b4 \uacf3\ucc98\ub7fc \ubcf4\uc774\uc9c0\ub9cc, \uc2e4\uc81c\ub85c\ub294 \uc219\uc18c \uc704\uce58\uc640 \uc678\uacfd \uc774\ub3d9 \uc218\ub2e8, \ub2a6\uc740 \uc2dc\uac04 \uadc0\uac00 \uac00\ub2a5 \uc5ec\ubd80\ub97c \ubd84\ub9ac\ud574\uc11c \ubd10\uc57c \ud569\ub2c8\ub2e4. \uc624\ud1a0\ubc14\uc774\ub97c \uc774\uc6a9\ud558\ub294 \uc5ec\ud589\uc790\uac00 \ub9ce\ub2e4\uace0 \ud574\uc11c \ubaa8\ub4e0 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uac83\uc740 \uc544\ub2c8\ubbc0\ub85c, \uc6b4\uc804 \uacbd\ud5d8\uacfc \ubcf4\ud5d8 \uc870\uac74, \ub300\uccb4 \uc774\ub3d9 \uc218\ub2e8\uc744 \uba3c\uc800 \ud655\uc778\ud558\ub294 \ud3b8\uc774 \uc548\uc804\ud569\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ud30c\uc774\uc5d0\uc11c \uc77c\uc815 \ub9cc\uc871\ub3c4\uac00 \uac08\ub9ac\ub294 \ud3ec\uc778\ud2b8<\/h2>\n<p>\ud30c\uc774\ub294 \ub290\ub9b0 \ubd84\uc704\uae30\ub97c \uc88b\uc544\ud558\uba74 \uc624\ub798 \uba38\ubb34\ub97c\uc218\ub85d \uc7a5\uc810\uc774 \ucee4\uc9c0\uc9c0\ub9cc, \uc774\ub3d9 \uac15\ub3c4\uc640 \uc989\uac01\uc801\uc778 \uc790\uadf9\uc744 \uc6d0\ud558\ub294 \uc0ac\ub78c\uc5d0\uac8c\ub294 \uc624\ud788\ub824 \ub9ac\ub4ec\uc774 \ub298\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub530\ub77c\uc11c \ud30c\uc774\uc5d0\uc11c\ub294 \uba85\uc18c \uc218\ubcf4\ub2e4 \u201c\ub0b4\uac00 \uc9c0\uae08 \uc26c\ub7ec \uc654\ub294\uc9c0, \uc6c0\uc9c1\uc774\ub7ec \uc654\ub294\uc9c0\u201d\ub97c \uba3c\uc800 \uc815\ud558\ub294 \uac83\uc774 \ud6e8\uc52c \uc911\uc694\ud569\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ud30c\uc774\uc5d0\uc11c \uc790\uc720\ub85c\uc6b4 \ubd84\uc704\uae30\uc640 \ubb34\uacc4\ud68d\uc740 \uac19\uc740 \ub9d0\uc774 \uc544\ub2d9\ub2c8\ub2e4<\/h2>\n<p>\ud30c\uc774\ub294 \ub290\uc2a8\ud558\uace0 \uc790\uc720\ub85c\uc6b4 \uc5ec\ud589\uc9c0\ub85c \uc54c\ub824\uc838 \uc788\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uadf8 \ubd84\uc704\uae30\ub97c \uadf8\ub300\ub85c \ubb34\uacc4\ud68d\uc73c\ub85c \ubc1b\uc544\ub4e4\uc774\uba74 \uc624\ud788\ub824 \ud53c\ub85c\uac00 \ucee4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc219\uc18c \uc704\uce58, \ubc24 \uadc0\uac00, \uc678\uacfd \uc774\ub3d9 \uc218\ub2e8\ucc98\ub7fc \uae30\ubcf8 \uad6c\uc870\ub97c \uba3c\uc800 \uc7a1\uc544\uc57c \uc790\uc720\ub85c\uc6c0\uc774 \uc7a5\uc810\uc73c\ub85c \ub0a8\uc2b5\ub2c8\ub2e4. \ud2b9\ud788 \uc624\ud1a0\ubc14\uc774\ub098 \uc678\uacfd \uc774\ub3d9\uc774 \uc5bd\ud788\ub294 \uc21c\uac04\ubd80\ud130\ub294 \ud310\ub2e8 \uae30\uc900\uc774 \ud6e8\uc52c \uc2e4\ubb34\uc801\uc73c\ub85c \ubc14\ub01d\ub2c8\ub2e4. \ud30c\uc774\uc758 \uc5ec\uc720\ub294 \uc900\ube44\uac00 \ub418\uc5b4 \uc788\uc744 \ub54c\ub9cc \ud3b8\uc548\ud558\uac8c \uc791\ub3d9\ud569\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ud30c\uc774\uc5d0\uc11c \ub9cc\uc871\ub3c4\uac00 \uac08\ub9ac\ub294 \ud575\uc2ec\uc740 \uc678\uacfd \uc774\ub3d9 \uad00\ub9ac\uc785\ub2c8\ub2e4<\/h2>\n<p>\uc911\uc2ec\uc9c0 \uc548\uc5d0\uc11c\ub9cc \uba38\ubb3c\uba74 \ube44\uad50\uc801 \ub2e8\uc21c\ud558\uc9c0\ub9cc, \uc678\uacfd\uc73c\ub85c \ub098\uac00\uae30 \uc2dc\uc791\ud558\uba74 \uc77c\uc815 \ub09c\ub3c4\uc640 \ud53c\ub85c\ub3c4\uac00 \ub3d9\uc2dc\uc5d0 \uc62c\ub77c\uac11\ub2c8\ub2e4. \uadf8\ub798\uc11c \ud30c\uc774\ub294 \uc219\uc18c\uc640 \uc2dd\uc0ac\ubcf4\ub2e4\ub3c4 \uc678\uacfd \uc774\ub3d9\uc744 \uc5b4\ub5a4 \ubc29\uc2dd\uc73c\ub85c \ud1b5\uc81c\ud560\uc9c0\uc5d0\uc11c \ud3c9\uac00\uac00 \ud06c\uac8c \uac08\ub9bd\ub2c8\ub2e4. \uc695\uc2ec\uc744 \uc904\uc774\uace0 \uc911\uc2ec\uc9c0 \uccb4\ub958\ub97c \uc720\uc9c0\ud558\uba74 \uaf64 \ud3b8\ud55c \uc5ec\ud589\uc9c0\uac00 \ub420 \uc218 \uc788\uc9c0\ub9cc, \uc774\ub3d9 \uc218\ub2e8\uc5d0 \ub300\ud55c \uae30\uc900 \uc5c6\uc774 \ud655\uc7a5\ud558\uba74 \ub9cc\uc871\ub3c4\uac00 \uae09\uaca9\ud788 \ud754\ub4e4\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud30c\uc774 \uae00\uc758 \ud575\uc2ec\uc740 \uac10\uc131\uc774 \uc544\ub2c8\ub77c \uc774\ub3d9 \uacbd\uacc4\uc120 \uc124\uc815\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\" id=\"pai-faq\">\ud30c\uc774\uc5d0\uc11c \uc790\uc8fc \ud5f7\uac08\ub9ac\ub294 \ud310\ub2e8<\/h2>\n<!-- \/wp:heading -->\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Q1. \ud30c\uc774\ub294 \ud63c\uc790 \uc5ec\ud589\ud558\uae30 \uc88b\uc740\uac00\uc694?<\/h3>\n<!-- \/wp:heading -->\n<!-- wp:paragraph -->\n<p>\ub290\ub9b0 \uccb4\ub958\ub97c \uc88b\uc544\ud55c\ub2e4\uba74 \uc88b\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc \uc678\uacfd \uc774\ub3d9\uacfc \ubc24 \uadc0\uac00 \uae30\uc900\uc740 \ubbf8\ub9ac \uc815\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n<!-- \/wp:paragraph -->\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Q2. \ud30c\uc774\uc5d0\uc11c \uc624\ud1a0\ubc14\uc774\ub97c \uaf2d \ube4c\ub824\uc57c \ud558\ub098\uc694?<\/h3>\n<!-- \/wp:heading -->\n<!-- wp:paragraph -->\n<p>\uaf2d \ud544\uc694\ud558\uc9c0\ub294 \uc54a\uc2b5\ub2c8\ub2e4. \uc6b4\uc804 \uacbd\ud5d8\uc774 \ubd80\uc871\ud558\uba74 \ud22c\uc5b4\ub098 \ud0dd\uc2dc, \uc911\uc2ec\uc9c0 \uccb4\ub958 \ubc29\uc2dd\uc774 \ub354 \uc548\uc804\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n<!-- \/wp:paragraph -->\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Q3. \uc219\uc18c\ub294 \uc911\uc2ec\uc9c0\uac00 \uc88b\ub098\uc694?<\/h3>\n<!-- \/wp:heading -->\n<!-- wp:paragraph -->\n<p>\ucd08\ubcf4 \ud63c\ud589\uc774\ub77c\uba74 \uc911\uc2ec\uc9c0 \uc811\uadfc\uc131\uc774 \uc88b\uc740 \uc219\uc18c\uac00 \ud3b8\ud569\ub2c8\ub2e4. \uc678\uacfd \uc219\uc18c\ub294 \ubcf5\uadc0 \uc218\ub2e8\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n<!-- \/wp:paragraph -->\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Q4. \ud30c\uc774\ub294 \uba70\uce60 \uba38\ubb34\ub294 \uac83\uc774 \uc88b\ub098\uc694?<\/h3>\n<!-- \/wp:heading -->\n<!-- wp:paragraph -->\n<p>\ucc98\uc74c\uc774\ub77c\uba74 2\ubc15 \uc815\ub3c4\uac00 \ubb34\ub09c\ud569\ub2c8\ub2e4. \ub290\ub9b0 \ubd84\uc704\uae30\uac00 \ub9de\ub294\ub2e4\uba74 \ub354 \uba38\ubb3c\ub7ec\ub3c4 \uc88b\uc9c0\ub9cc \uc774\ub3d9 \uc695\uc2ec\uc740 \uc904\uc774\ub294 \ud3b8\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n<!-- \/wp:paragraph -->","protected":false},"excerpt":{"rendered":"<p>\ud30c\uc774(Pai)\ub294 \ube60\ub978 \uad00\uad11\ubcf4\ub2e4 \ub290\ub9b0 \uccb4\ub958\uc5d0 \ub9de\ub294 \ub3c4\uc2dc\uc785\ub2c8\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc790\ub294 \uc219\uc18c \uc704\uce58, \ubc24 \uadc0\uac00, \uc678\uacfd \uc774\ub3d9, \uc624\ud1a0\ubc14\uc774 \uae30\uc900\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":1217,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","a