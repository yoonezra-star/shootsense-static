{"id":1197,"date":"2026-03-21T09:10:00","date_gmt":"2026-03-21T00:10:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1197"},"modified":"2026-06-12T14:15:42","modified_gmt":"2026-06-12T05:15:42","slug":"honja-lushan-yeohaeng","status":"publish","type":"post","link":"https:\/\/shootsense.com\/honja-lushan-yeohaeng\/","title":{"rendered":"\uc911\uad6d \ub8e8\uc0b0 \ud63c\uc790 \uc5ec\ud589: \uac10\uc815\ubcf4\ub2e4 \uacc4\ud68d\uc774 \ud544\uc694\ud55c \uc0b0\uc545 \uc77c\uc815 \uae30\uc900"},"content":{"rendered":"\n<p>\ub8e8\uc0b0\uc740 \ud48d\uacbd\uc774 \uac15\ud55c \ub9cc\ud07c \uac10\uc815\uc774 \uc55e\uc11c\uae30 \uc26c\uc6b4 \uc0b0\uc545 \uc5ec\ud589\uc9c0\ub2e4. \uadf8\ub7ec\ub098 \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uac10\ub3d9\ubcf4\ub2e4 \uba3c\uc800 \uad50\ud1b5, \uc219\uc18c, \ub0a0\uc528, \ub3c4\ubcf4 \ub3d9\uc120\uc744 \ud604\uc2e4\uc801\uc73c\ub85c \uacc4\uc0b0\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc911\uad6d \ub8e8\uc0b0\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc815\ubcf4\ud615 \uac00\uc774\ub4dc\ub2e4. \uac10\uc0c1\ubcf4\ub2e4 \uad50\ud1b5, \ub3c4\ubcf4 \ub3d9\uc120, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc911\uc2ec\uc73c\ub85c \uc2e4\uc81c \uc77c\uc815\uc744 \uc9e4 \uc218 \uc788\uac8c \uad6c\uc131\ud588\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc911\uad6d \ub8e8\uc0b0 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\ub8e8\uc0b0\uc740 \uc0b0\uc545 \uc9c0\uc5ed \ud2b9\uc131\uc0c1 \ub0a0\uc528\uc640 \uc774\ub3d9 \ubc29\uc2dd\uc774 \uc77c\uc815 \ud488\uc9c8\uc744 \uc88c\uc6b0\ud55c\ub2e4. \ucc98\uc74c \ubc29\ubb38\uc774\ub77c\uba74 \uc219\uc18c\ub97c \uae30\uc900\uc73c\ub85c \ub3d9\uc120\uc744 \uc881\ud788\uace0, \ud575\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \uc548\uc815\uc801\uc73c\ub85c \ubcf4\ub294 \ubc29\uc2dd\uc774 \ub9de\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \ubcf4\ub294 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uc0b0\uc545 \ud48d\uacbd, \uc5ed\uc0ac\uc801 \ud734\uc591\uc9c0 \ubd84\uc704\uae30, \uac77\uae30 \uc911\uc2ec 1\ubc15 \uc774\uc0c1 \uc77c\uc815<\/td><td>\ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \uc870\uc6a9\ud55c \ub3c4\uc2dc\ub97c \uc2ec\uc2ec\ud558\ub2e4\uace0 \uc624\ud574\ud558\uc9c0 \uc54a\ub294\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\uae30\ucc28\uc5ed\u00b7\ubc84\uc2a4\u00b7\uc0b0 \uc704 \uc774\ub3d9\uc218\ub2e8\uacfc \uc219\uc18c \uc811\uadfc\uc131 \ud655\uc778<\/td><td>\uc9c0\ubc29 \uc5ec\ud589\uc740 \ud658\uc2b9, \ub9c9\ucc28, \ub3c4\ubcf4 \ubcf5\uadc0 \uc2dc\uac04\uc774 \uc77c\uc815 \uc804\uccb4\ub97c \uc88c\uc6b0\ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ucd5c\uc18c 1\ubc15, \ub0a0\uc528 \ubcc0\uc218\uae4c\uc9c0 \uace0\ub824\ud558\uba74 2\ubc15\uc774 \uc548\uc815\uc801<\/td><td>\ubc18\ub098\uc808\uc778\uc9c0 1\ubc15\uc778\uc9c0\uc5d0 \ub530\ub77c \uc219\uc18c\uc640 \uc2dd\uc0ac \uc804\ub7b5\uc774 \ub2ec\ub77c\uc9c4\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\uc548\uac1c, \ube44, \uc0b0\uae38 \ud53c\ub85c, \ub0b4\ubd80 \uc774\ub3d9, \uc219\uc18c \uc704\uce58<\/td><td>\ub0a0\uc528, \ud63c\uc7a1, \uc5b8\uc5b4, \uacb0\uc81c \ubc29\uc2dd\uc774 \ud604\uc7a5 \ud53c\ub85c\ub3c4\ub97c \ubc14\uafbc\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc0b0\uc5d0\uc11c \uac10\uc815\ubcf4\ub2e4 \uae30\uc900\uc774 \ud544\uc694\ud55c \uc774\uc720<\/h2>\n\n\n\n<p>\ub8e8\uc0b0\uc740 \ud63c\uc790\uc11c \ud48d\uacbd\uacfc \uac10\uc815\uc744 \uae4a\uac8c \ub290\ub07c\uae30 \uc88b\uc740 \uacf3\uc774\uc9c0\ub9cc, \uacc4\ud68d \uc5c6\uc774 \uc6c0\uc9c1\uc774\uba74 \ud53c\ub85c\uac00 \ube60\ub974\uac8c \ub204\uc801\ub41c\ub2e4. \uc0b0\uc545 \uc9c0\uc5ed\uc5d0\uc11c\ub294 \uc774\ub3d9 \ubc94\uc704\ub97c \uc904\uc774\ub294 \uac83\uc774 \uc624\ud788\ub824 \ub9cc\uc871\ub3c4\ub97c \ub192\uc778\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uba85\uc18c \uac1c\uc218\ubcf4\ub2e4 \uc7a5\uc18c\uac00 \uc8fc\ub294 \ub9ac\ub4ec\uc774 \uc911\uc694\ud558\ub2e4. \uc774\ub3d9\uacfc \uc2dd\uc0ac, \ud734\uc2dd\uc758 \uae30\uc900\ub9cc \uc7a1\uc73c\uba74 \uc870\uc6a9\ud55c \ubaa9\uc801\uc9c0\ub3c4 \ucda9\ubd84\ud788 \ubc00\ub3c4 \uc788\ub294 \ud558\ub8e8\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0b0 \uc544\ub798 \ub3c4\ucc29\uacfc \uc0b0 \uc704 \uc219\uc18c\ub97c \ubd84\ub9ac\ud574 \ubcf4\uae30<\/h2>\n\n\n\n<p>\ub8e8\uc0b0\uc740 \ub3c4\ucc29 \uc9c0\uc810\uacfc \uc2e4\uc81c \uc219\uc18c \uc704\uce58 \uc0ac\uc774 \uc774\ub3d9\uc744 \ud655\uc778\ud574\uc57c \ud55c\ub2e4. \uc0b0 \uc544\ub798\uc5d0\uc11c \uc0b0 \uc704\ub85c \uc774\ub3d9\ud558\ub294 \uc2dc\uac04, \ub0b4\ubd80 \uad50\ud1b5, \ub9c8\uc9c0\ub9c9 \ubcf5\uadc0 \uac00\ub2a5 \uc2dc\uac04\uc744 \ud568\uaed8 \ubd10\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc2dc\uac04\ub300<\/th><th>\uc6b0\uc120 \ud589\ub3d9<\/th><th>\ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \uc815\ub958\uc7a5, \uc219\uc18c, \uc911\uc2ec \uac70\ub9ac \ud655\uc778<\/td><td>\ub3cc\uc544\uac08 \uae30\uc900\uc810\uc744 \uba3c\uc800 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\uc624\uc804<\/td><td>\ud575\uc2ec \uc0b0\ucc45 \uad6c\uac04 \uba3c\uc800 \ubcf4\uae30<\/td><td>\uac00\uc7a5 \uccb4\ub825\uc774 \uc88b\uace0 \uae38\uc774 \ubc1d\uc744 \ub54c \uc911\uc694\ud55c \uad6c\uac04\uc744 \uac77\ub294\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4<\/td><td>\uc2dd\uc0ac\uc640 \ud734\uc2dd, \ubcf4\uc870 \ub3d9\uc120 \ubc30\uce58<\/td><td>\ubb34\ub9ac\ud55c \ud655\uc7a5\ubcf4\ub2e4 \ucee8\ub514\uc158 \uc720\uc9c0\uac00 \uc6b0\uc120\uc774\ub2e4<\/td><\/tr><tr><td>\ud574\uc9c8 \ubb34\ub835<\/td><td>\uc219\uc18c \ub610\ub294 \ucd9c\ubc1c\uc9c0 \ubc29\ud5a5\uc73c\ub85c \ubcf5\uadc0<\/td><td>\ud63c\uc790\ub77c\uba74 \uc57c\uac04 \uc678\uacfd \uc774\ub3d9\uc744 \uc904\uc778\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc804\ub9dd\ubcf4\ub2e4 \ubcf5\uadc0\ub97c \ub0a8\uae30\ub294 \ud558\ub8e8 \uad6c\uc131<\/h2>\n\n\n\n<p>\uccab\ub0a0\uc740 \uc219\uc18c \uccb4\ud06c\uc778\uacfc \uac00\uae4c\uc6b4 \uc0b0\ucc45 \uad6c\uac04\ub9cc \ubcf4\uace0, \ub458\uc9f8 \ub0a0 \uc624\uc804\uc5d0 \ud575\uc2ec \uc804\ub9dd\uc774\ub098 \uc0b0\ucc45 \ucf54\uc2a4\ub97c \ub123\ub294 \ubc29\uc2dd\uc774 \uc548\uc804\ud558\ub2e4. \uc548\uac1c\uac00 \uc2ec\ud558\uba74 \ubb34\ub9ac\ud558\uac8c \uba40\ub9ac \uac00\uc9c0 \ub9d0\uace0 \uc2e4\ub0b4 \ud734\uc2dd\uc774\ub098 \uac00\uae4c\uc6b4 \uad6c\uac04\uc73c\ub85c \uc870\uc815\ud55c\ub2e4.<\/p>\n\n\n\n<p>\ucc98\uc74c \ubc29\ubb38\uc774\ub77c\uba74 \ub3d9\uc120\uc744 \ud06c\uac8c \ub113\ud788\uae30\ubcf4\ub2e4 \uc911\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \ubc18\ubcf5\ud574\uc11c \uac77\ub294 \ud3b8\uc774 \ub0ab\ub2e4. \ud63c\uc790\uc77c \ub54c\ub294 \uc77c\uc815\uc774 \ub2e8\uc21c\ud560\uc218\ub85d \uae38\uc744 \uc783\uac70\ub098 \ubcf5\uadc0 \uc2dc\uac04\uc744 \ub193\uce60 \uac00\ub2a5\uc131\uc774 \uc904\uc5b4\ub4e0\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uac1c \ub080 \ub0a0 \ub354 \uc911\uc694\ud55c \uc219\uc18c \uc704\uce58<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \uc0b0 \uc704 \uc911\uc2ec \uad6c\uc5ed\uacfc \uc2dd\uc0ac \uc811\uadfc\uc131\uc744 \uae30\uc900\uc73c\ub85c \uace0\ub974\ub294 \uac83\uc774 \uc88b\ub2e4. \uc804\ub9dd\ub9cc \ubcf4\uace0 \uc678\uc9c4 \uacf3\uc744 \uace0\ub974\uba74 \ube44\ub098 \uc548\uac1c\uac00 \uc788\uc744 \ub54c \uc774\ub3d9\uc774 \ub9e4\uc6b0 \ubd88\ud3b8\ud574\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \uc804\ub9dd\ubcf4\ub2e4 \uc811\uadfc\uc131\uacfc \uc2dd\uc0ac \uac00\ub2a5\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc678\uacfd \uc219\uc18c\uac00 \uc88b\uc544 \ubcf4\uc5ec\ub3c4 \ubc24\uc5d0 \ub3cc\uc544\uac00\uae30 \uc5b4\ub835\uac70\ub098 \uc8fc\ubcc0 \uc2dd\ub2f9\uc774 \ub2eb\ud788\uba74 \ud63c\uc790 \uc5ec\ud589\uc758 \ubd80\ub2f4\uc774 \ucee4\uc9c4\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0b0 \uc704 \uc2dd\uc0ac \uacf5\ubc31\uc744 \ud53c\ud558\ub294 \ubc95<\/h2>\n\n\n\n<p>\uc0b0\uc545 \uad00\uad11\uc9c0\ub294 \uc2dd\uc0ac \uc120\ud0dd\uc9c0\uac00 \uc704\uce58\uc5d0 \ub530\ub77c \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \uc219\uc18c \uc8fc\ubcc0 \uc2dd\ub2f9\uacfc \uc601\uc5c5 \uc2dc\uac04\uc744 \uba3c\uc800 \ud655\uc778\ud558\uace0, \ub0a0\uc528\uac00 \ub098\uc060 \ub54c \uc774\ub3d9 \uc5c6\uc774 \uba39\uc744 \uc218 \uc788\ub294 \ub300\uc548\uc744 \ud655\ubcf4\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub3c4\uc2dc\ub098 \uad00\uad11\uc9c0 \uc678\uacfd\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc218\ubcf4\ub2e4 \uc2e4\uc81c \uc601\uc5c5 \uc2dc\uac04\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \uc810\uc2ec \ud6c4\ubcf4\ub97c \uba3c\uc800 \uc815\ud558\uace0, \uc800\ub141\uc740 \uc219\uc18c\uc5d0\uc11c \uac78\uc5b4\uac08 \uc218 \uc788\ub294 \ubc94\uc704\ub85c \uc881\ud788\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubbf8\ub044\ub7ec\uc6b4 \uae38\uc5d0\uc11c \uc77c\uc815\uc774 \ubb34\ub108\uc9c0\ub294 \ubc29\uc2dd<\/h2>\n\n\n\n<p>\ub8e8\uc0b0\uc758 \ub9ac\uc2a4\ud06c\ub294 \uce58\uc548\ubcf4\ub2e4 \ub0a0\uc528\uc640 \ubcf4\ud589 \ud53c\ub85c\ub2e4. \ud63c\uc790\ub77c\uba74 \ube44 \uc624\ub294 \ub0a0 \uae34 \uc0b0\ucc45 \ucf54\uc2a4\ub97c \ud53c\ud558\uace0, \uae38\uc774 \ubbf8\ub044\ub7ec\uc6b8 \ub54c\ub294 \uc804\ub9dd \uc695\uc2ec\ubcf4\ub2e4 \ubcf5\uadc0\ub97c \uc6b0\uc120\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc758 \uc548\uc804\uc740 \ub300\ub2e8\ud55c \uc7a5\ube44\ubcf4\ub2e4 \uc77c\uc815\uc758 \uc5ec\ubc31\uc5d0\uc11c \ub098\uc628\ub2e4. \uae38\uc774 \ubcf5\uc7a1\ud558\uac70\ub098 \uc5b8\uc5b4 \uc7a5\ubcbd\uc774 \uc788\ub294 \uc9c0\uc5ed\uc77c\uc218\ub85d \ub0ae \uc2dc\uac04\uc5d0 \ud575\uc2ec \uad6c\uac04\uc744 \ubcf4\uace0, \uc800\ub141\uc5d0\ub294 \ub3d9\uc120\uc744 \uc904\uc774\ub294 \ubc29\uc2dd\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">1\ubc15\uc744 \ub298\ub9b4\uc9c0 \uc774\ub3d9\ube44\ub97c \uc544\ub084\uc9c0 \ud310\ub2e8<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc0b0 \uc704 \uc219\ubc15, \ub0b4\ubd80 \uc774\ub3d9, \uc785\uc7a5\u00b7\uad50\ud1b5 \ube44\uc6a9\uc5d0\uc11c \ub2ec\ub77c\uc9c4\ub2e4. 1\ubc15\uc744 \uc544\ub07c\uae30\ubcf4\ub2e4 \ub0a0\uc528\uc640 \uccb4\ub825 \ud68c\ubcf5 \uc2dc\uac04\uc744 \ud655\ubcf4\ud558\ub294 \uac83\uc774 \uc804\uccb4 \ub9cc\uc871\ub3c4\uc5d0 \ub354 \ub3c4\uc6c0\uc774 \ub420 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uad50\ud1b5\uacfc \uc219\uc18c \uc704\uce58\uc5d0\uc11c \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \ub2f9\uc77c\uce58\uae30\ub294 \ube44\uc6a9\uc774 \ub0ae\uc9c0\ub9cc \uccb4\ub958 \uc2dc\uac04\uc774 \uc9e7\uace0, 1\ubc15\uc740 \ube44\uc6a9\uc774 \ub298\uc9c0\ub9cc \uc870\uc6a9\ud55c \uc2dc\uac04\ub300\ub97c \ud655\ubcf4\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc0b0\uc5d0\uc11c \uac00\uc7a5 \ud754\ud55c \uacfc\uc695 \ud328\ud134<\/h2>\n\n\n\n<p>\ud558\ub8e8\uc5d0 \ub8e8\uc0b0\uc758 \uc5ec\ub7ec \ucf54\uc2a4\ub97c \ubaa8\ub450 \ubcf4\ub824\ub294 \uc77c\uc815\uc740 \ud53c\ud574\uc57c \ud55c\ub2e4. \uc0b0\uc545 \uc9c0\uc5ed\uc740 \uc9c0\ub3c4\uc0c1 \uac70\ub9ac\uac00 \uc9e7\uc544 \ubcf4\uc5ec\ub3c4 \uc2e4\uc81c \uc774\ub3d9 \ud53c\ub85c\uac00 \ucee4\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud48d\uacbd\uc744 \ubcf4\ub418 \uc77c\uc815\uc740 \uc904\uc77c \uc218 \uc788\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\uac15\ud55c \uc790\uc5f0 \ud48d\uacbd\uacfc \uc870\uc6a9\ud55c \uc0b0\uc545 \uccb4\ub958\ub97c \uc6d0\ud558\ub294 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \ub2e8, \ud63c\uc790\ub77c\uba74 \uac10\uc815\uc801\uc73c\ub85c \ub04c\ub9ac\ub294 \ub300\ub85c \uc6c0\uc9c1\uc774\uae30\ubcf4\ub2e4 \ub0a0\uc528\uc640 \uccb4\ub825\uc744 \uae30\uc900\uc73c\ub85c \ud310\ub2e8\ud558\ub294 \uc0ac\ub78c\uc774 \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc0b0 \uc77c\uc815\uc740 \uc900\ube44 \uc218\uc900\uc774 \uacb0\ub860\uc744 \ubc14\uafbc\ub2e4<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\ub8e8\uc0b0\uc5d0\uc11c \uc0b0\uc545 \ud48d\uacbd\ubcf4\ub2e4 \uc6b4\uc601 \uae30\uc900\uc774 \uc55e\uc11c\uc57c \ud558\ub294 \uc774\uc720<\/h2>\n<p>\ub8e8\uc0b0\uc740 \uc0ac\uc9c4\uc0c1 \uc778\uc0c1\uc774 \uac15\ud55c \uc9c0\uc5ed\uc774\uc9c0\ub9cc, \uc2e4\uc81c \uc5ec\ud589\uc5d0\uc11c\ub294 \ud48d\uacbd\ubcf4\ub2e4 \uc6b4\uc601 \uae30\uc900\uc774 \uba3c\uc800\uc5ec\uc57c \ub9cc\uc871\ub3c4\uac00 \uc62c\ub77c\uac11\ub2c8\ub2e4. \uace0\ub3c4, \uc548\uac1c, \ubbf8\ub044\ub7ec\uc6b4 \uae38, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac \uacf5\ubc31\uc774 \ub3d9\uc2dc\uc5d0 \uc791\ub3d9\ud558\uae30 \ub54c\ubb38\uc5d0, \ub9c9\uc5f0\ud55c \uae30\ub300\ub9cc\uc73c\ub85c\ub294 \ud558\ub8e8\uac00 \uc27d\uac8c \ubb34\ub108\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788 \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ubcf5\uadc0 \uc5ec\uc720\uc640 \ucee8\ub514\uc158 \uad00\ub9ac\uac00 \uc870\uae08\ub9cc \uc5b4\uae0b\ub098\ub3c4 \uc804\uccb4 \uccb4\ub958\uac00 \ud53c\ub85c \uc911\uc2ec\uc73c\ub85c \ubc14\ub01d\ub2c8\ub2e4. \uadf8\ub798\uc11c \ub8e8\uc0b0\uc740 \uac10\ud0c4\ubcf4\ub2e4 \uc900\ube44\uac00 \uba3c\uc800\uc778 \ub300\ud45c\uc801\uc778 \uc0b0\uc545 \uc77c\uc815\ud615 \uc5ec\ud589\uc9c0\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub8e8\uc0b0\uc5d0\uc11c 1\ubc15 \uc774\uc0c1 \uba38\ubb3c\uc9c0 \uacb0\uc815\ud560 \ub54c \ubd10\uc57c \ud560 \ud575\uc2ec<\/h2>\n<p>\uc219\ubc15\uc744 \ub298\ub9b4\uc9c0 \ub9d0\uc9c0\ub294 \ud48d\uacbd \ub9cc\uc871\ub3c4\ubcf4\ub2e4 \uc6b4\uc601 \uc548\uc815\uc131\uc774 \uacc4\uc18d \uc720\uc9c0\ub418\ub294\uc9c0\ub85c \ud310\ub2e8\ud558\ub294 \ud3b8\uc774 \ub9de\uc2b5\ub2c8\ub2e4. \uccab\ub0a0\uc5d0 \uc774\ubbf8 \uc774\ub3d9\uacfc \uc2dd\uc0ac, \uc219\uc18c \uc811\uadfc\uc5d0\uc11c \ud53c\ub85c\uac00 \ud06c\uac8c \uc313\uc600\ub2e4\uba74 \ud558\ub8e8\ub97c \ub354 \ub298\ub824\ub3c4 \ud68c\ubcf5\ubcf4\ub2e4 \ubd80\ub2f4\uc774 \ucee4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \ub0a0\uc528 \ubcc0\uc218 \uc548\uc5d0\uc11c\ub3c4 \uc77c\uc815 \uc870\uc815\uc774 \uac00\ub2a5\ud558\uace0, \uc219\uc18c \uc704\uce58\uac00 \uc7ac\uc815\ube44\uc5d0 \uc720\ub9ac\ud558\ub2e4\uba74 1\ubc15 \uc774\uc0c1\uc774 \uc624\ud788\ub824 \ub354 \uc548\uc815\uc801\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub8e8\uc0b0\uc740 \uc624\ub798 \uba38\ubb38\ub2e4\uace0 \ubb34\uc870\uac74 \uc88b\uc544\uc9c0\ub294 \uacf3\uc774 \uc544\ub2c8\ub77c, \uad6c\uc870\uac00 \ubc84\ud2f8 \uc218 \uc788\uc744 \ub54c\ub9cc \uac00\uce58\uac00 \ucee4\uc9c0\ub294 \uacf3\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub8e8\uc0b0\uc5d0\uc11c \uc2e4\uc81c\ub85c \uba3c\uc800 \ud3ec\uae30\ud574\uc57c \ud558\ub294 \uac83<\/h2>\n\n\n\n<p>\uba3c\uc800 \ud3ec\uae30\ud574\uc57c \ud558\ub294 \uac83\uc740 \u201c\ub9ce\uc774 \ubcf4\uba74 \ub9cc\uc871\ub3c4\uac00 \uc62c\ub77c\uac04\ub2e4\u201d\ub294 \uc0dd\uac01\uc774\ub2e4. \ub8e8\uc0b0\uc740 \uad6c\uac04 \uc218\ub97c \ub298\ub9b4\uc218\ub85d \uac10\ub3d9\uc774 \ucee4\uc9c0\uae30\ubcf4\ub2e4 \ud53c\ub85c\uac00 \uc55e\uc11c\uae30 \uc26c\uc6cc\uc11c, \ud575\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \ub0a8\uae30\uace0 \ub098\uba38\uc9c0\ub97c \ube44\uc6cc\ub450\ub294 \ucabd\uc774 \ud6e8\uc52c \ub0ab\ub2e4.<\/p>\n\n\n\n\n\n<p>\uc911\uad6d \ub8e8\uc0b0\uc740 \uac10\uc815\uc774 \uc55e\uc11c\uae30 \uc26c\uc6b4 \ubaa9\uc801\uc9c0\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uacc4\ud68d\uc774 \uba3c\uc800\ub2e4. \uc219\uc18c \uc704\uce58, \ub0b4\ubd80 \uc774\ub3d9, \ub0a0\uc528 \ub300\uc751\uc744 \ud655\uc815\ud558\uba74 \uc0b0\uc545 \uc5ec\ud589\uc758 \ubd80\ub2f4\uc744 \uc904\uc774\uace0 \ud48d\uacbd\uc5d0 \uc9d1\uc911\ud560 \uc218 \uc788\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc911\uad6d \ub8e8\uc0b0 \ud63c\uc790 \uc5ec\ud589\uc744 \uc900\ube44\ud560 \ub54c \ud544\uc694\ud55c \uad50\ud1b5, \uc219\uc18c, \uc0b0\uc545 \ub3d9\uc120, \ub0a0\uc528, \uc2dd\uc0ac\uc640 \uc548\uc804 \uae30\uc900\uc744 \uc815\ub9ac\ud588\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":1198,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"tablet":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"mobile":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","backgrou