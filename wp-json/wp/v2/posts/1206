{"id":1206,"date":"2026-03-25T21:33:06","date_gmt":"2026-03-25T12:33:06","guid":{"rendered":"https:\/\/shootsense.com\/?p=1206"},"modified":"2026-06-12T14:31:52","modified_gmt":"2026-06-12T05:31:52","slug":"%ec%84%a4%eb%aa%85%ec%9d%80-%ec%96%b4%eb%a0%b5%ec%a7%80%eb%a7%8c-%eb%a7%88%ec%9d%8c%ec%97%90-%eb%82%a8%ec%9d%80-%eb%b0%98%eb%b9%84%ec%97%a5-%ec%99%b8%ea%b3%bd","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%84%a4%eb%aa%85%ec%9d%80-%ec%96%b4%eb%a0%b5%ec%a7%80%eb%a7%8c-%eb%a7%88%ec%9d%8c%ec%97%90-%eb%82%a8%ec%9d%80-%eb%b0%98%eb%b9%84%ec%97%a5-%ec%99%b8%ea%b3%bd\/","title":{"rendered":"\ub77c\uc624\uc2a4 \ubc18\ube44\uc5e5 \uc678\uacfd \ud63c\uc790 \uc5ec\ud589: \uc124\uba85\ubcf4\ub2e4 \ud604\uc7a5 \ud310\ub2e8\uc774 \uc911\uc694\ud55c \uacf3"},"content":{"rendered":"\n<p>\ubc18\ube44\uc5e5 \uc678\uacfd\uc740 \ub9d0\ub85c \uc124\uba85\ud558\uae30\ubcf4\ub2e4 \ud604\uc7a5\uc5d0\uc11c \uccb4\uac10\ub418\ub294 \ud48d\uacbd\uc774 \ud070 \uacf3\uc774\ub2e4. \ub2e4\ub9cc \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc544\ub984\ub2e4\uc6c0\ubcf4\ub2e4 \uc774\ub3d9 \ubc29\uc2dd, \ub0a0\uc528, \ud65c\ub3d9 \uc548\uc804 \uae30\uc900\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ub77c\uc624\uc2a4 \ubc18\ube44\uc5e5 \uc678\uacfd\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \uac10\uc0c1\ubcf4\ub2e4 \uc774\ub3d9 \ub09c\ub3c4, \uc219\uc18c \uc704\uce58, \ub0a0\uc528, \uc2dd\uc0ac, \ud604\uae08\u00b7\ud1b5\uc2e0, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \uc548\uc804\ud558\uac8c \uc77c\uc815\uc744 \uc124\uacc4\ud558\ub294 \ub370 \ucd08\uc810\uc744 \ub454\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub77c\uc624\uc2a4 \ubc18\ube44\uc5e5 \uc678\uacfd \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\ubc18\ube44\uc5e5 \uc678\uacfd\uc740 \uc790\uc5f0 \ud65c\ub3d9\uacfc \uc870\uc6a9\ud55c \uccb4\ub958\uac00 \ubaa8\ub450 \uac00\ub2a5\ud558\uc9c0\ub9cc, \uc989\ud765 \uc774\ub3d9\uc774 \ud56d\uc0c1 \uc548\uc804\ud55c \uac83\uc740 \uc544\ub2c8\ub2e4. \uc219\uc18c \uc704\uce58\uc640 \uc774\ub3d9 \uc218\ub2e8, \ub0a0\uc528\ub97c \uae30\uc900\uc73c\ub85c \ud558\ub8e8 \ubc94\uc704\ub97c \uc815\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589 \uccb4\ud06c \ud3ec\uc778\ud2b8<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uac15\uacfc \uc0b0 \uc8fc\ubcc0 \uc0b0\ucc45, \uc790\uc5f0 \ud65c\ub3d9, \ubc18\ube44\uc5e5 \uc911\uc2ec\ubd80 \ubc16 \uccb4\ub958<\/td><td>\uc790\uc5f0 \ubaa9\uc801\uc9c0\ub294 \ubaa9\uc801\uc774 \ubd88\uba85\ud655\ud558\uba74 \uc774\ub3d9 \ud53c\ub85c\ub9cc \ub0a8\uae30 \uc27d\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ub09c\ub3c4<\/td><td>\uc790\uc804\uac70, \uc624\ud1a0\ubc14\uc774, \ucc28\ub7c9 \ud22c\uc5b4, \uc219\uc18c \ud53d\uc5c5 \uac00\ub2a5 \uc5ec\ubd80 \ud655\uc778<\/td><td>\ud63c\uc790 \uc774\ub3d9 \uc2dc \uc9c0\uc5f0, \ub300\uae30, \ubcf5\uadc0 \ub9ac\uc2a4\ud06c\ub97c \uc9c1\uc811 \uac10\ub2f9\ud574\uc57c \ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ucd5c\uc18c 1\ubc15, \uc678\uacfd \ud65c\ub3d9\uc744 \ub123\uc73c\uba74 2\ubc15 \uc774\uc0c1 \uad8c\uc7a5<\/td><td>\ub3c4\ucc29\uc77c\uacfc \uc774\ub3d9\uc77c\uc744 \ud65c\ub3d9\uc77c\ub85c \uacc4\uc0b0\ud558\uc9c0 \uc54a\ub294 \uac83\uc774 \uc548\uc804\ud558\ub2e4<\/td><\/tr><tr><td>\ud575\uc2ec \ubcc0\uc218<\/td><td>\uc6b0\uae30, \ub3c4\ub85c \uc0c1\ud0dc, \ud65c\ub3d9 \uc548\uc804, \ud1b5\uc2e0, \uc57c\uac04 \uc774\ub3d9<\/td><td>\ub0a0\uc528, \uace0\ub3c4, \ub3c4\ub85c \uc0c1\ud0dc, \ud1b5\uc2e0 \uc0c1\ud0dc\uac00 \uc77c\uc815 \ud488\uc9c8\uc744 \uc88c\uc6b0\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ubc18\ube44\uc5e5 \uc678\uacfd\uc774 \ud63c\uc790\uc5d0\uac8c \ub9de\ub294 \uc870\uac74<\/h2>\n\n\n\n<p>\ubc18\ube44\uc5e5 \uc678\uacfd\uc740 \ud63c\uc790 \uc870\uc6a9\ud788 \uc790\uc5f0\uc744 \ubcf4\uae30 \uc88b\uc9c0\ub9cc, \ud65c\ub3d9\ud615 \uc77c\uc815\uc740 \uc548\uc804 \ud655\uc778\uc774 \ud544\uc218\ub2e4. \ud63c\uc790\ub77c\uba74 \uc774\ub3d9\uc218\ub2e8\uc744 \uacfc\uc2e0\ud558\uc9c0 \ub9d0\uace0 \uc219\uc18c\uc640 \ud604\uc9c0 \uc6b4\uc601\uc790\uc758 \uc815\ubcf4\ub97c \ud568\uaed8 \ubd10\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc790\uc5f0 \uc9c0\uc5ed\uc744 \uc5ec\ud589\ud560 \ub54c\ub294 \u201c\uc5bc\ub9c8\ub098 \uba4b\uc9c4\uac00\u201d\ubcf4\ub2e4 \u201c\ubb34\ub9ac \uc5c6\uc774 \uba38\ubb3c \uc218 \uc788\ub294\uac00\u201d\uac00 \ub354 \uc911\uc694\ud558\ub2e4. \uc88b\uc740 \ud48d\uacbd\ub3c4 \uc774\ub3d9\uc774 \uacfc\ud558\uba74 \ud53c\ub85c\ub85c \ubc14\ub00c\uae30 \ub54c\ubb38\uc5d0, \uc77c\uc815\uc740 \uc904\uc77c \uc218 \uc788\uac8c \uc124\uacc4\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc624\ud1a0\ubc14\uc774 \ub300\uc2e0 \ub300\uccb4 \uc218\ub2e8\uc744 \ubd10\uc57c \ud560 \ub54c<\/h2>\n\n\n\n<p>\uc678\uacfd \uc774\ub3d9\uc740 \ub3c4\ub85c \uc0c1\ud0dc\uc640 \ub0a0\uc528\uc758 \uc601\ud5a5\uc744 \ud06c\uac8c \ubc1b\ub294\ub2e4. \uc9c1\uc811 \uc6b4\uc804\uc774 \uc775\uc219\ud558\uc9c0 \uc54a\ub2e4\uba74 \ucc28\ub7c9 \ud22c\uc5b4\ub098 \uc219\uc18c \ud53d\uc5c5\uc744 \uac80\ud1a0\ud558\uace0, \ud574\uac00 \uc9c4 \ub4a4 \uc678\uacfd \uc774\ub3d9\uc740 \ud53c\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc0c1\ud669<\/th><th>\uc8fc\uc758\ud560 \uc810<\/th><th>\uad8c\uc7a5 \ub300\uc751<\/th><\/tr><\/thead><tbody><tr><td>\ub3c4\ucc29 \ub2f9\uc77c<\/td><td>\uc7a5\uac70\ub9ac \uc774\ub3d9 \ud6c4 \ubc14\ub85c \ud65c\ub3d9\uc744 \ub123\uc73c\uba74 \ud310\ub2e8\ub825\uc774 \ub5a8\uc5b4\uc9c4\ub2e4<\/td><td>\uc219\uc18c \uccb4\ud06c\uc778, \uc2dd\uc0ac, \uc8fc\ubcc0 \ud655\uc778\ub9cc \ud55c\ub2e4<\/td><\/tr><tr><td>\ub0a0\uc528 \uc545\ud654<\/td><td>\uc0b0\uc545\u00b7\uac15\ubcc0 \uc9c0\uc5ed\uc740 \uc9e7\uc740 \ube44\uc5d0\ub3c4 \uc774\ub3d9 \ud53c\ub85c\uac00 \ucee4\uc9c4\ub2e4<\/td><td>\ud575\uc2ec \uc77c\uc815 \ud558\ub098\ub9cc \ub0a8\uae30\uace0 \ub098\uba38\uc9c0\ub294 \uc904\uc778\ub2e4<\/td><\/tr><tr><td>\ud1b5\uc2e0 \ubd88\uc548\uc815<\/td><td>\uc678\uacfd\uc5d0\uc11c\ub294 \uc9c0\ub3c4\uc640 \ud638\ucd9c \uc11c\ube44\uc2a4\uac00 \ub2a6\uac8c \uc791\ub3d9\ud560 \uc218 \uc788\ub2e4<\/td><td>\uc624\ud504\ub77c\uc778 \uc9c0\ub3c4\uc640 \uc219\uc18c \uc8fc\uc18c\ub97c \ubbf8\ub9ac \uc800\uc7a5\ud55c\ub2e4<\/td><\/tr><tr><td>\ud604\uae08 \ubd80\uc871<\/td><td>\uc18c\ub3c4\uc2dc\ub294 \uce74\ub4dc \uc0ac\uc6a9\ucc98\uac00 \uc81c\ud55c\ub420 \uc218 \uc788\ub2e4<\/td><td>\ub3c4\ucc29 \uc804 \uc18c\uc561 \ud604\uae08\uc744 \ub098\ub220 \uc900\ube44\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ud65c\ub3d9\ud615 \uc77c\uc815\uacfc \ud734\uc2dd\ud615 \uc77c\uc815\uc744 \ub098\ub204\ub294 \ubc95<\/h2>\n\n\n\n<p>\uccab\ub0a0\uc740 \uc911\uc2ec\ubd80\uc640 \uc219\uc18c \uc8fc\ubcc0\uc744 \ud655\uc778\ud558\uace0, \uc678\uacfd \ud65c\ub3d9\uc740 \ub2e4\uc74c \ub0a0 \uc624\uc804\uc5d0 \ubc30\uce58\ud558\ub294 \uac83\uc774 \uc548\uc815\uc801\uc774\ub2e4. \ub0a0\uc528\uac00 \ub098\uc058\uba74 \ud65c\ub3d9\uc744 \uc904\uc774\uace0 \uac15\ubcc0 \uc0b0\ucc45\uc774\ub098 \uce74\ud398 \uccb4\ub958\ub85c \uc804\ud658\ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud575\uc2ec\uc740 \uccab\ub0a0\uc5d0 \ub9ce\uc740 \uac83\uc744 \ubcf4\ub824 \ud558\uc9c0 \uc54a\ub294 \uac83\uc774\ub2e4. \uc219\uc18c\uc640 \uc911\uc2ec \uac70\ub9ac, \uc2dd\uc0ac \uc9c0\uc810, \ub2e4\uc74c \uc774\ub3d9\ud3b8\uc744 \uba3c\uc800 \ud655\uc778\ud55c \ub4a4 \ub458\uc9f8 \ub0a0 \uc624\uc804\uc774\ub098 \ub0a0\uc528\uac00 \uc548\uc815\uc801\uc778 \uc2dc\uac04\uc5d0 \ud575\uc2ec \ud65c\ub3d9\uc744 \ub123\ub294 \ubc29\uc2dd\uc774 \uc548\uc804\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ubcc0 \uc804\ub9dd\uacfc \uc2dd\uc0ac \uc811\uadfc\uc131\uc758 \uade0\ud615<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \uc911\uc2ec\ubd80 \uc811\uadfc\uc131\uacfc \uc678\uacfd \ud48d\uacbd \uc0ac\uc774\uc5d0\uc11c \uade0\ud615\uc744 \uc7a1\uc544\uc57c \ud55c\ub2e4. \ub108\ubb34 \uc678\uacfd\uc774\uba74 \uc870\uc6a9\ud558\uc9c0\ub9cc \uc2dd\uc0ac\uc640 \uc774\ub3d9 \uc120\ud0dd\uc9c0\uac00 \uc904\uace0, \uc911\uc2ec\ubd80\ub294 \ud3b8\ud558\uc9c0\ub9cc \uc18c\uc74c\uc774 \uc788\uc744 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790\ub77c\uba74 \uc804\ub9dd \uc88b\uc740 \uc678\uacfd \uc219\uc18c\ubcf4\ub2e4 \uc2dd\uc0ac\uc640 \uad50\ud1b5 \uc811\uadfc\uc131\uc774 \uc788\ub294 \uc704\uce58\uac00 \uc6b0\uc120\uc774\ub2e4. \uc678\uacfd \uc219\uc18c\ub97c \uace0\ub97c \ub54c\ub294 \ud53d\uc5c5 \uac00\ub2a5 \uc5ec\ubd80, \uccb4\ud06c\uc778 \uc2dc\uac04, \uc800\ub141 \uc2dd\uc0ac \uac00\ub2a5 \uc5ec\ubd80\ub97c \ubc18\ub4dc\uc2dc \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc678\uacfd \uc77c\uc815 \uc804\uc5d0 \ucc59\uaca8\uc57c \ud560 \uac83<\/h2>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc911\uc2ec\ubd80\uc5d0\uc11c \ud574\uacb0\ud558\ub294 \ud3b8\uc774 \uac00\uc7a5 \uc548\uc815\uc801\uc774\ub2e4. \uc678\uacfd \uc219\uc18c\uc5d0 \uba38\ubb38\ub2e4\uba74 \uc800\ub141 \uc2dd\uc0ac \uc81c\uacf5 \uc5ec\ubd80\ub098 \uc8fc\ubcc0 \uc2dd\ub2f9 \uc6b4\uc601 \uc2dc\uac04\uc744 \ubbf8\ub9ac \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc18c\ub3c4\uc2dc\uc640 \uc0b0\uc545 \uc9c0\uc5ed\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc601\uc5c5 \uc2dc\uac04, \uce74\ub4dc \uacb0\uc81c \uac00\ub2a5 \uc5ec\ubd80, ATM \uc704\uce58\uac00 \ubaa8\ub450 \ubcc0\uc218\uac00 \ub41c\ub2e4. \ud63c\uc790\ub77c\uba74 \ub2a6\uc740 \uc2dc\uac04 \uc2dd\uc0ac\ub97c \ucc3e\ub294 \uc0c1\ud669\uc744 \ub9cc\ub4e4\uc9c0 \uc54a\ub294 \uac83\uc774 \uac00\uc7a5 \ud604\uc2e4\uc801\uc778 \uc548\uc804 \ub300\ucc45\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubb3c\ub180\uc774\uc640 \uc57c\uac04 \uc774\ub3d9\uc744 \uacb9\uce58\uc9c0 \ub9d0\uc544\uc57c \ud558\ub294 \uc774\uc720<\/h2>\n\n\n\n<p>\ubb3c\ub180\uc774, \ub3d9\uad74, \uc0b0\uae38, \ube44\ud3ec\uc7a5 \ub3c4\ub85c\ub294 \ud63c\uc790 \uc989\ud765\uc801\uc73c\ub85c \uc811\uadfc\ud558\uc9c0 \uc54a\ub294 \uac83\uc774 \uc6d0\uce59\uc774\ub2e4. \ud65c\ub3d9 \uc804\uc5d0\ub294 \uc7a5\ube44, \ubcf4\ud5d8, \ub3d9\ud589 \uc5ec\ubd80, \ud604\uc9c0 \uc548\ub0b4\uc790\uc758 \uc124\uba85\uc744 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc5ec\ud589\uc9c0\uc758 \uc704\ud5d8\uc740 \ud2b9\uc815 \uc7a5\uc18c\ubcf4\ub2e4 \ud53c\ub85c\uac00 \ub204\uc801\ub41c \uc0c1\ud0dc\uc5d0\uc11c \ud310\ub2e8\uc774 \ud750\ub824\uc9c8 \ub54c \ucee4\uc9c4\ub2e4. \uc7a5\uac70\ub9ac \uc774\ub3d9 \uc9c1\ud6c4\uc5d0\ub294 \uc0c8\ub85c\uc6b4 \uae38\uc744 \ub113\uac8c \ud0d0\uc0c9\ud558\uc9c0 \ub9d0\uace0, \uc219\uc18c \uc8fc\ubcc0\uc5d0\uc11c \ubc29\ud5a5\uac10\uac01\uc744 \ub9cc\ub4e0 \ub4a4 \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \ub0ab\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc561\ud2f0\ube44\ud2f0 \ube44\uc6a9\ubcf4\ub2e4 \uc911\uc694\ud55c \ube44\uc6a9<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc219\uc18c\uc640 \ud65c\ub3d9 \ube44\uc6a9\uc5d0\uc11c \ub2ec\ub77c\uc9c4\ub2e4. \uc800\ub834\ud55c \uc774\ub3d9\uc218\ub2e8\uc744 \uace0\ub974\ub354\ub77c\ub3c4 \uc0ac\uace0\ub098 \uae38 \uc783\uc74c \ub9ac\uc2a4\ud06c\uac00 \ucee4\uc9c0\uba74 \uc804\uccb4 \ube44\uc6a9\uacfc \uc704\ud5d8\uc774 \ud568\uaed8 \uc62c\ub77c\uac04\ub2e4.<\/p>\n\n\n\n<p>\uc790\uc5f0 \uc9c0\uc5ed\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uc774\ub3d9\ube44\uc640 \uc219\ubc15\ube44\uac00 \uc608\uc0b0\uc744 \uc88c\uc6b0\ud55c\ub2e4. \ub2f9\uc77c\ub85c \ubb34\ub9ac\ud558\uac8c \ub2e4\ub140\uc624\ub294 \uac83\ubcf4\ub2e4 1\ubc15\uc744 \ucd94\uac00\ud574 \uc774\ub3d9 \ud53c\ub85c\ub97c \ub0ae\ucd94\ub294 \ucabd\uc774 \uc804\uccb4 \ub9cc\uc871\ub3c4\ub97c \ub192\uc77c \ub54c\uac00 \ub9ce\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc18\ube44\uc5e5 \uc678\uacfd\uc5d0\uc11c \ud754\ud55c \uacfc\uc2e0 \ud328\ud134<\/h2>\n\n\n\n<p>\uc220, \uc57c\uac04 \uc774\ub3d9, \uc678\uacfd \ud65c\ub3d9\uc744 \ud55c\ub0a0\uc5d0 \uacb9\uce58\ub294 \uc77c\uc815\uc740 \ud53c\ud574\uc57c \ud55c\ub2e4. \ubc18\ube44\uc5e5 \uc678\uacfd\uc740 \ucee8\ub514\uc158\uc774 \uc88b\uace0 \ub0a0\uc528\uac00 \uc548\uc815\uc801\uc77c \ub54c \ucc9c\ucc9c\ud788 \ubcf4\ub294 \ud3b8\uc774 \ub9de\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc989\ud765\ubcf4\ub2e4 \uc548\uc804 \uae30\uc900\uc744 \ub530\ub97c \uc218 \uc788\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\uc790\uc5f0 \ud48d\uacbd\uc744 \uc88b\uc544\ud558\uace0, \ud63c\uc790\ub77c\ub3c4 \uc548\uc804 \uae30\uc900\uc744 \uc9c0\ud0a4\uba70 \ucc9c\ucc9c\ud788 \uc6c0\uc9c1\uc77c \uc218 \uc788\ub294 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \uc989\ud765\ubcf4\ub2e4 \uc900\ube44\uac00 \ub9cc\uc871\ub3c4\ub97c \ub192\uc774\ub294 \uc9c0\uc5ed\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc18\ube44\uc5e5 \uc678\uacfd \uccb4\ub958\uac00 \ub9de\ub294 \uc0ac\ub78c\uc758 \uae30\uc900<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\ubc18\ube44\uc5e5 \uc678\uacfd\uc5d0\uc11c \uc790\uc720\ub85c\uc6c0\uacfc \uc548\uc804 \uae30\uc900\uc744 \uac19\uc774 \uc7a1\ub294 \ubc95<\/h2>\n<p>\ubc18\ube44\uc5e5 \uc678\uacfd\uc740 \uc790\uc5f0\uc2a4\ub7fd\uace0 \ub290\uc2a8\ud55c \ubd84\uc704\uae30\ub85c \uc18c\ube44\ub418\uae30 \uc27d\uc9c0\ub9cc, \uc2e4\uc81c \ud63c\ud589\uc5d0\uc11c\ub294 \uc790\uc720\ub85c\uc6c0\ub9cc \ubbff\uace0 \uc6c0\uc9c1\uc774\uba74 \uc624\ud788\ub824 \uc791\uc740 \ubcc0\uc218\uc5d0 \uc27d\uac8c \ud754\ub4e4\ub9bd\ub2c8\ub2e4. \uc774\ub3d9 \uc218\ub2e8, \ubb3c\ub180\uc774 \uc774\ud6c4 \ubcf5\uadc0, \uc57c\uac04 \ub3d9\uc120\ucc98\ub7fc \uae30\ubcf8 \uad6c\uc870\ub97c \uba3c\uc800 \uc7a1\uc544\uc57c \uc5ec\uc720\uac00 \uc7a5\uc810\uc73c\ub85c \ub0a8\uc2b5\ub2c8\ub2e4. \ud2b9\ud788 \uc678\uacfd\uc740 \uc120\ud0dd\uc9c0\uac00 \uc801\uc740 \ub9cc\ud07c \ud55c \ubc88\uc758 \ud310\ub2e8 \uc2e4\uc218\uac00 \uccb4\uac10 \ud53c\ub85c\ub97c \ud06c\uac8c \ud0a4\uc6b8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc18\ube44\uc5e5 \uc678\uacfd\uc740 \uc989\ud765 \uc5ec\ud589\ucc98\ub7fc \ubcf4\uc5ec\ub3c4 \uc6b4\uc601\uc740 \uaf64 \ubcf4\uc218\uc801\uc73c\ub85c \ud574\uc57c \ud558\ub294 \uacf3\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ubc18\ube44\uc5e5 \uc678\uacfd \uccb4\ub958\uc5d0\uc11c \ub9cc\uc871\ub3c4\uac00 \uac08\ub9ac\ub294 \uacb0\uc815 \uc21c\uac04<\/h2>\n<p>\ub9cc\uc871\ub3c4\uac00 \ub192\uc740 \uacbd\uc6b0\ub294 \ub300\uccb4\ub85c \uc561\ud2f0\ube44\ud2f0\uc640 \ud734\uc2dd \uad6c\uac04\uc744 \ubd84\ub9ac\ud558\uace0, \ub2a6\uc740 \uc2dc\uac04 \uc774\ub3d9\uc744 \uc77c\ucc0d \ub04a\ub294 \ucabd\uc785\ub2c8\ub2e4. \ubc18\ub300\ub85c \ud558\ub8e8 \uc548\uc5d0 \uc5ec\ub7ec \ud65c\ub3d9\uc744 \ubab0\uc544\ub123\uc73c\uba74 \uc678\uacfd\uc758 \uc774\ub3d9 \ubd88\ud3b8\uacfc \ud53c\ub85c\uac00 \ud55c\uaebc\ubc88\uc5d0 \ub4dc\ub7ec\ub0a9\ub2c8\ub2e4. \uc774 \uc9c0\uc5ed\uc740 \ub9ce\uc774 \ud55c \uc0ac\ub78c\uc774 \uc544\ub2c8\ub77c \uc801\uc808\ud788 \uba48\ucd98 \uc0ac\ub78c\uc774 \ub354 \uc88b\uac8c \uae30\uc5b5\ud558\ub294 \uacbd\uc6b0\uac00 \ub9ce\uc2b5\ub2c8\ub2e4. \ubc18\ube44\uc5e5 \uc678\uacfd\uc758 \ud575\uc2ec\uc740 \uc7a5\uba74\uc774 \uc544\ub2c8\ub77c \uba48\ucd9c \ud0c0\uc774\ubc0d\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ubc18\ube44\uc5e5 \uc678\uacfd\uc5d0\uc11c \uc2e4\uc81c\ub85c \uba3c\uc800 \uc904\uc5ec\uc57c \ud558\ub294 \uc77c\uc815<\/h2>\n\n\n\n<p>\uac00\uc7a5 \uba3c\uc800 \uc904\uc5ec\uc57c \ud558\ub294 \uac83\uc740 \ub3c4\ucc29 \ub2f9\uc77c \uc678\uacfd \uc561\ud2f0\ube44\ud2f0\ub2e4. \uc774\ub3d9 \ud53c\ub85c\uac00 \ub0a8\uc544 \uc788\ub294 \uc0c1\ud0dc\uc5d0\uc11c \ubb3c\ub180\uc774, \ub3d9\uad74, \ube44\ud3ec\uc7a5 \ub3c4\ub85c \uc774\ub3d9\uc744 \ud568\uaed8 \ub123\uc73c\uba74 \uc0ac\uace0 \uc704\ud5d8\ubcf4\ub2e4 \ud310\ub2e8 \uc2e4\uc218\uc640 \uccb4\ub825 \uc800\ud558\uac00 \ud6e8\uc52c \ube68\ub9ac \uc628\ub2e4.<\/p>\n\n\n\n\n\n<p>\ub77c\uc624\uc2a4 \ubc18\ube44\uc5e5 \uc678\uacfd\uc740 \uc124\uba85\ubcf4\ub2e4 \ud604\uc7a5\uc5d0\uc11c \ub0a8\ub294 \uc778\uc0c1\uc774 \ud070 \uacf3\uc774\uc9c0\ub9cc, \uadf8\ub9cc\ud07c \uc900\ube44\uac00 \ud544\uc694\ud558\ub2e4. \ub0a0\uc528, \uc774\ub3d9\uc218\ub2e8, \uc219\uc18c \uc704\uce58, \ud65c\ub3d9 \uc548\uc804\uc744 \uba3c\uc800 \uc815\ud558\uba74 \ud63c\uc790\uc11c\ub3c4 \uc758\ubbf8 \uc788\ub294 \uccb4\ub958\uac00 \uac00\ub2a5\ud558\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ub77c\uc624\uc2a4 \ubc18\ube44\uc5e5 \uc678\uacfd \ud63c\uc790 \uc5ec\ud589\uc744 \uc704\ud55c \uad50\ud1b5, \uc790\uc5f0 \ud65c\ub3d9, \uc219\uc18c, \uc2dd\uc0ac, \ub0a0\uc528\uc640 \uc548\uc804 \uae30\uc900\uc744 \uc815\ub9ac\ud588\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":1207,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opaci