{"id":1187,"date":"2026-03-18T19:02:31","date_gmt":"2026-03-18T10:02:31","guid":{"rendered":"https:\/\/shootsense.com\/?p=1187"},"modified":"2026-06-12T14:06:20","modified_gmt":"2026-06-12T05:06:20","slug":"%ec%9d%bc%ec%a0%95%ec%9d%98-%eb%b9%88%ec%b9%b8%ec%97%90%ec%84%9c-%eb%a7%8c%eb%82%9c-%eb%a7%88%ec%93%b0%ec%95%bc%eb%a7%88-%ea%b7%bc%ea%b5%90%ec%9d%98-%ea%b8%b0%ec%96%b5","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%9d%bc%ec%a0%95%ec%9d%98-%eb%b9%88%ec%b9%b8%ec%97%90%ec%84%9c-%eb%a7%8c%eb%82%9c-%eb%a7%88%ec%93%b0%ec%95%bc%eb%a7%88-%ea%b7%bc%ea%b5%90%ec%9d%98-%ea%b8%b0%ec%96%b5\/","title":{"rendered":"\uc77c\ubcf8 \ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50 \ud63c\uc790 \uc5ec\ud589: \uc77c\uc815\uc758 \ube48\uce78\uc744 \ucc44\uc6b0\ub294 \uc870\uc6a9\ud55c \uc120\ud0dd\uc9c0"},"content":{"rendered":"\n<p>\ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\ub294 \ub300\ub2e8\ud55c \ubaa9\uc801\uc9c0\ub97c \ucc3e\uae30\ubcf4\ub2e4 \uc77c\uc815\uc758 \ube48\uce78\uc744 \uc870\uc6a9\ud788 \ucc44\uc6b0\uae30 \uc88b\uc740 \uc120\ud0dd\uc9c0\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc9e7\uc740 \uc774\ub3d9, \ub2e8\uc21c\ud55c \ub3d9\uc120, \ubd80\ub2f4 \uc5c6\ub294 \uc2dd\uc0ac\uac00 \uc77c\uc815\uc758 \uc9c8\uc744 \ub9cc\ub4e0\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc77c\ubcf8 \ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \uac10\uc0c1\ubcf4\ub2e4 \uad50\ud1b5, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120, \uccb4\ub958 \uc2dc\uac04\uc758 \uade0\ud615\uc744 \uae30\uc900\uc73c\ub85c \uad6c\uc131\ud588\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc77c\ubcf8 \ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50 \uc5ec\ud589\uc740 \uba40\ub9ac \ud655\uc7a5\ud558\uae30\ubcf4\ub2e4 \ub3c4\uc2dc\uc5d0\uc11c \uc811\uadfc \uac00\ub2a5\ud55c \ud55c \uad6c\uac04\uc744 \uc815\ud574 \uac77\ub294 \ubc29\uc2dd\uc774 \ub9de\ub2e4. \ub2f9\uc77c\uce58\uae30\ub77c\uba74 \ubcf5\uadc0\ud3b8\uacfc \uc2dd\uc0ac \uc2dc\uac04\uc744 \uba3c\uc800 \uace0\uc815\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589 \uccb4\ud06c \ud3ec\uc778\ud2b8<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\ub9c8\uc4f0\uc57c\ub9c8 \uc8fc\ubcc0 \uc870\uc6a9\ud55c \uc0b0\ucc45, \uc9e7\uc740 \uadfc\uad50 \uc774\ub3d9, \uc77c\uc815 \uc5ec\ubc31 \ud65c\uc6a9<\/td><td>\ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \uc77c\uc815\uc758 \ube48\uce78\uc744 \uc2e4\ud328\ub85c \ubcf4\uc9c0 \uc54a\ub294\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\uc804\ucca0\u00b7\ubc84\uc2a4 \uc2dc\uac04\ud45c, \ub9c8\uc4f0\uc57c\ub9c8 \ubcf5\uadc0\ud3b8, \ub3c4\ubcf4 \uac70\ub9ac \ud655\uc778<\/td><td>\ud63c\uc790 \uc774\ub3d9 \uc2dc \ub300\uae30, \ud658\uc2b9, \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc9c1\uc811 \uad00\ub9ac\ud574\uc57c \ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ubc18\ub098\uc808 \ub610\ub294 \ud558\ub8e8 \uc77c\uc815, 1\ubc15\uc740 \ubaa9\uc801\uc774 \ubd84\uba85\ud560 \ub54c\ub9cc<\/td><td>\uc9e7\uac8c \ub4e4\ub97c\uc9c0 1\ubc15\ud560\uc9c0\uc5d0 \ub530\ub77c \uc219\uc18c\uc640 \uc2dd\uc0ac \ud310\ub2e8\uc774 \ub2ec\ub77c\uc9c4\ub2e4<\/td><\/tr><tr><td>\ud575\uc2ec \ubcc0\uc218<\/td><td>\ubc30\ucc28 \uac04\uaca9, \uc2dd\ub2f9 \ud734\ubb34, \ube44 \uc624\ub294 \ub0a0 \ubcf4\ud589 \ud53c\ub85c, \ud574\uc9c8 \ubb34\ub835 \uc778\uc801<\/td><td>\ub0a0\uc528, \uc678\uacfd \uc774\ub3d9, \uc601\uc5c5 \uc2dc\uac04, \uc5b8\uc5b4 \uc7a5\ubcbd\uc774 \ud53c\ub85c\ub3c4\ub97c \ubc14\uafbc\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc77c\uc815\uc758 \ube48\uce78\uc744 \uc0b4\ub9ac\ub294 \uadfc\uad50\ub77c\ub294 \uc810<\/h2>\n\n\n\n<p>\ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\ub294 \ud63c\uc790 \ubd80\ub2f4 \uc5c6\uc774 \uc6c0\uc9c1\uc774\uae30 \uc88b\ub2e4. \ub3c4\uc2dc \uc911\uc2ec\ubd80\uc5d0 \uc219\uc18c\ub97c \ub450\uace0 \uc9e7\uac8c \ub2e4\ub140\uc624\uba74 \uc77c\uc815\uc758 \ube48\uce78\uc744 \uacfc\ud558\uac8c \ucc44\uc6b0\uc9c0 \uc54a\uc544\ub3c4 \uc5ec\ud589 \ud750\ub984\uc774 \uc0b4\uc544\ub09c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc720\uba85\ud55c \uc7a5\uba74\ubcf4\ub2e4 \ub0b4\uac00 \ubb34\ub9ac \uc5c6\uc774 \uba38\ubb3c \uc218 \uc788\ub294 \uad6c\uc870\uac00 \uc911\uc694\ud558\ub2e4. \ub3d9\uc120\uc774 \ub2e8\uc21c\ud558\uace0 \uc2dd\uc0ac\uc640 \ubcf5\uadc0 \uae30\uc900\uc774 \ubd84\uba85\ud558\uba74 \uc608\uc0c1 \ubc16\uc758 \uc7a5\uc18c\ub3c4 \uc5ec\ud589\uc758 \uc911\uc2ec\uc774 \ub420 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubcf5\uadc0\ud3b8\uc744 \uba3c\uc800 \uace0\uc815\ud574\uc57c \ud558\ub294 \uc774\uc720<\/h2>\n\n\n\n<p>\uadfc\uad50 \uc774\ub3d9\uc740 \uad50\ud1b5\ud3b8 \uc790\uccb4\ubcf4\ub2e4 \ub3cc\uc544\uc624\ub294 \uc2dc\uac04\uc744 \ub193\uce58\uc9c0 \uc54a\ub294 \uac83\uc774 \uc911\uc694\ud558\ub2e4. \ubc30\ucc28 \uac04\uaca9\uc774 \uae34 \uad6c\uac04\uc740 \uc624\uc804\uc5d0 \ub2e4\ub140\uc624\uace0, \uc624\ud6c4\uc5d0\ub294 \ub9c8\uc4f0\uc57c\ub9c8 \uc911\uc2ec\ubd80\ub85c \ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc900\ube44 \ub2e8\uacc4<\/th><th>\ud655\uc778\ud560 \uac83<\/th><th>\ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ucd9c\ubc1c \uc804<\/td><td>\ub3c4\ucc29 \uc9c0\uc810\uacfc \uc219\uc18c \uc774\ub3d9 \ubc29\ubc95<\/td><td>\ub2a6\uc740 \ub3c4\ucc29\uc774\uba74 \ud53d\uc5c5 \ub610\ub294 \ucc28\ub7c9 \ud638\ucd9c \uac00\ub2a5\uc131\uc744 \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc911\uc2ec \uac70\ub9ac, \uc2dd\uc0ac \uc9c0\uc810, \ubcf5\uadc0 \uae30\uc900\uc810<\/td><td>\uae38\uc744 \uc783\uc5c8\uc744 \ub54c \ub3cc\uc544\uac08 \uae30\uc900\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\ub0ae \uc2dc\uac04<\/td><td>\ub300\ud45c \uc0b0\ucc45 \uad6c\uac04\uacfc \ud734\uc2dd \uc7a5\uc18c<\/td><td>\uac00\uc7a5 \ubc1d\uace0 \uc774\ub3d9\ud558\uae30 \uc26c\uc6b4 \uc2dc\uac04\uc5d0 \ud575\uc2ec \uad6c\uac04\uc744 \ubcf8\ub2e4<\/td><\/tr><tr><td>\uc800\ub141 \uc804<\/td><td>\uc219\uc18c \ubc29\ud5a5\uacfc \ub2e4\uc74c \uc774\ub3d9\ud3b8<\/td><td>\ud63c\uc790\ub77c\uba74 \uc678\uacfd\ubcf4\ub2e4 \ubcf5\uadc0 \uc548\uc815\uc131\uc744 \uc6b0\uc120\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ubc18\ub098\uc808 \uadfc\uad50\ub97c \ub9dd\uce58\uc9c0 \uc54a\ub294 \ub3d9\uc120<\/h2>\n\n\n\n<p>\ub3d9\uc120\uc740 \uc5ed\uc774\ub098 \uc815\ub958\uc7a5\uc744 \uae30\uc900\uc73c\ub85c \ud55c \ubc29\ud5a5\uc73c\ub85c \uac77\uace0 \ub2e4\uc2dc \ub3cc\uc544\uc624\ub294 \ubc29\uc2dd\uc774 \uc88b\ub2e4. \uc5ec\ub7ec \uadfc\uad50 \uc9c0\uc810\uc744 \ud558\ub8e8\uc5d0 \ubb36\uae30\ubcf4\ub2e4 \ud55c \uacf3\uc744 \uc5ec\uc720 \uc788\uac8c \ubcf4\ub294 \ud3b8\uc774 \ud63c\uc790 \uc5ec\ud589\uc5d0 \ub9de\ub2e4.<\/p>\n\n\n\n<p>\uc77c\uc815\uc744 \ub113\uac8c \uc7a1\uae30\ubcf4\ub2e4 \uc911\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \uae30\uc900\uc73c\ub85c \uac77\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ud63c\uc790\ub77c\uba74 \uc774\ub3d9 \ubc94\uc704\ub97c \uc904\uc77c\uc218\ub85d \ud604\uc7a5\uc5d0\uc11c \uc2dd\uc0ac, \ud734\uc2dd, \ubcf5\uadc0\ub97c \uc870\uc815\ud558\uae30 \uc27d\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9c8\uc4f0\uc57c\ub9c8 \uc911\uc2ec \uc219\uc18c\uac00 \uc720\ub9ac\ud55c \uc774\uc720<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \ub9c8\uc4f0\uc57c\ub9c8 \uc911\uc2ec\ubd80\uc5d0 \ub450\ub294 \uac83\uc774 \uac00\uc7a5 \ud604\uc2e4\uc801\uc774\ub2e4. \uadfc\uad50 \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \uc2dd\uc0ac\uc640 \uc774\ub3d9\uc774 \uc81c\ud55c\ub420 \uc218 \uc788\uc5b4 \uccab \ubc29\ubb38\uc774\ub77c\uba74 \uc911\uc2ec\ubd80 \ubca0\uc774\uc2a4\uac00 \ub0ab\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \ubd84\uc704\uae30\ubcf4\ub2e4 \uc811\uadfc\uc131, \uc870\uba85, \uc2dd\uc0ac \uac00\ub2a5\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc678\uacfd \uc219\uc18c\uac00 \uc870\uc6a9\ud574\ub3c4 \ubc24 \uc774\ub3d9\uc774 \uc5b4\ub835\ub2e4\uba74 \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc7a5\uc810\ubcf4\ub2e4 \ubd80\ub2f4\uc774 \ucee4\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc791\uc740 \uc5ed \uc8fc\ubcc0 \uc2dd\ub2f9\uc744 \ubcf4\ub294 \ud604\uc2e4 \uae30\uc900<\/h2>\n\n\n\n<p>\uc810\uc2ec\uc740 \uadfc\uad50\uc5d0\uc11c \uac00\ubccd\uac8c \ud574\uacb0\ud558\uac70\ub098 \ub9c8\uc4f0\uc57c\ub9c8\ub85c \ub3cc\uc544\uc640 \uba39\ub294 \ubc29\uc2dd\uc774 \uc88b\ub2e4. \uc791\uc740 \uc5ed \uc8fc\ubcc0 \uc2dd\ub2f9\uc740 \uc601\uc5c5 \uc2dc\uac04\uc774 \uc81c\ud55c\ub420 \uc218 \uc788\uc73c\ubbc0\ub85c \ud3b8\uc758\uc810\uc774\ub098 \uac04\uc2dd \ub300\uc548\uc744 \ud655\uc778\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub3c4\uc2dc\ub098 \uc678\uacfd \uc9c0\uc5ed\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc218\ubcf4\ub2e4 \uc2e4\uc81c \uc601\uc5c5 \uc2dc\uac04\uacfc \uc219\uc18c\uc5d0\uc11c\uc758 \uc811\uadfc\uc131\uc774 \uc911\uc694\ud558\ub2e4. \uc2dd\uc0ac \ud6c4\ubcf4\ub97c 2\uacf3 \uc774\uc0c1 \ub450\uace0, \ubb3c\uacfc \uac04\ub2e8\ud55c \uac04\uc2dd\uc744 \uc900\ube44\ud558\uba74 \uc77c\uc815\uc774 \uc548\uc815\ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uadfc\uad50 \uc774\ub3d9\uc5d0\uc11c \ud53c\uace4\ud568\uc774 \uc313\uc774\ub294 \uad6c\uac04<\/h2>\n\n\n\n<p>\uc704\ud5d8 \uc694\uc18c\ub294 \ud06c\uc9c0 \uc54a\uc9c0\ub9cc, \ud574\uac00 \uc9c4 \ub4a4 \uc778\uc801\uc774 \uc904\uc5b4\ub4dc\ub294 \uad6c\uac04\uc740 \ud53c\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ud63c\uc790\ub77c\uba74 \ubcf5\uadc0 \ubc29\ud5a5\uc744 \uacc4\uc18d \uc758\uc2dd\ud558\uba70 \ub3d9\uc120\uc744 \uc9e7\uac8c \uc720\uc9c0\ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \uac00\uc7a5 \ud754\ud55c \ubb38\uc81c\ub294 \uc704\ud5d8\ud55c \uc7a5\uc18c\ubcf4\ub2e4 \ud53c\uace4\ud55c \uc0c1\ud0dc\uc5d0\uc11c \ubb34\ub9ac\ud558\uac8c \uc6c0\uc9c1\uc774\ub294 \uac83\uc774\ub2e4. \uc774\ub3d9 \ud6c4\uc5d0\ub294 \ubc14\ub85c \uc678\uacfd\uc744 \ub113\ud788\uc9c0 \ub9d0\uace0, \uc219\uc18c \uc8fc\ubcc0\uc5d0\uc11c \ubc29\ud5a5\uac10\uac01\uc744 \ub9cc\ub4e0 \ub4a4 \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \ub0ab\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc219\ubc15\uc744 \ub298\ub9ac\uc9c0 \uc54a\uace0 \ubc00\ub3c4\ub97c \uc62c\ub9ac\ub294 \ubc95<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uadfc\uad50 \uc655\ubcf5 \uad50\ud1b5\ube44\uc640 \uc2dd\ube44 \uc911\uc2ec\uc774\ub2e4. \uc219\ubc15\uc744 \ucd94\uac00\ud558\uc9c0 \uc54a\uc544\ub3c4 \ucda9\ubd84\ud788 \ub2e4\ub140\uc62c \uc218 \uc788\uc5b4 \ube44\uc6a9 \ub300\ube44 \uc77c\uc815 \ubc00\ub3c4\uac00 \uc88b\uc740 \ud3b8\uc774\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uad50\ud1b5\uacfc \uc219\uc18c \uc704\uce58\uc5d0\uc11c \ucc28\uc774\uac00 \ub09c\ub2e4. \uc800\ub834\ud55c \uc219\uc18c\ub97c \uace0\ub974\ub354\ub77c\ub3c4 \uc774\ub3d9\ube44\uc640 \uc57c\uac04 \ubcf5\uadc0 \ubd80\ub2f4\uc774 \ucee4\uc9c0\uba74 \uc804\uccb4 \ud6a8\uc728\uc740 \ub5a8\uc5b4\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uccb4\ud06c\ub9ac\uc2a4\ud2b8\uc2dd \uadfc\uad50 \ucc0d\uae30 \uc77c\uc815<\/h2>\n\n\n\n<p>\uadfc\uad50\ub97c \uc5ec\ub7ec \uac1c \ubb36\uc5b4 \uccb4\ud06c\ub9ac\uc2a4\ud2b8\ucc98\ub7fc \ub3c4\ub294 \uc77c\uc815\uc740 \ud53c\ud574\uc57c \ud55c\ub2e4. \uc77c\uc815\uc758 \ube48\uce78\uc744 \ucc44\uc6b0\ub824\ub2e4 \uc804\uccb4 \uc5ec\ud589 \ud53c\ub85c\uac00 \ub298\uc5b4\ub0a0 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud070 \uba85\uc18c\ubcf4\ub2e4 \ud750\ub984\uc744 \uc911\uc2dc\ud558\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\ub9c8\uc4f0\uc57c\ub9c8 \uc77c\uc815 \uc911 \ubc18\ub098\uc808\uc758 \uc5ec\uc720\uac00 \uc788\uace0, \uc870\uc6a9\ud55c \uc77c\ubcf8 \uc9c0\ubc29 \ud48d\uacbd\uc744 \ubcf4\uace0 \uc2f6\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50 \ud558\ub8e8\ub97c \ub123\uc744 \uac00\uce58\uac00 \uc788\ub294\uc9c0<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\ub97c \ub123\uc744 \ub54c \uc911\uc2ec \uc77c\uc815\uacfc \ucda9\ub3cc\ud558\uc9c0 \uc54a\uac8c \uc9dc\ub294 \ubc95<\/h2>\n<p>\uadfc\uad50 \uc77c\uc815\uc740 \ube44\uc5b4 \uc788\ub294 \ubc18\ub098\uc808\uc744 \ucc44\uc6b0\ub294 \ub370 \uac15\ud558\uc9c0\ub9cc, \uc911\uc2ec \ub3c4\uc2dc \uc77c\uc815\uacfc \ubaa9\uc801\uc774 \uacb9\uce58\uae30 \uc2dc\uc791\ud558\uba74 \uc624\ud788\ub824 \uc804\uccb4 \ud750\ub984\uc744 \ud750\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub798\uc11c \ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\ub97c \ub123\uc744 \ub54c\ub294 \ubcf8 \uc77c\uc815\uc5d0\uc11c \ubc18\ub4dc\uc2dc \ud574\uc57c \ud560 \uac83\uacfc \uadfc\uad50\uc5d0\uc11c \uae30\ub300\ud558\ub294 \uccb4\ub958\uac10\uc744 \ubd84\ub9ac\ud574\uc11c \ubd10\uc57c \ud569\ub2c8\ub2e4. \uc131\uae09\ud558\uac8c \ub458\uc744 \ud55c \ub0a0\uc5d0 \ubab0\uc544\ub123\uae30\ubcf4\ub2e4, \ud55c\ucabd\uc758 \ub9ac\ub4ec\uc744 \uc0b4\ub9ac\uace0 \ub2e4\ub978 \ud55c\ucabd\uc740 \ucd5c\uc18c\ud654\ud558\ub294 \ucabd\uc774 \ub9cc\uc871\ub3c4\uac00 \ub192\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\uac00 \uc88b\uc740 \uc120\ud0dd\uc774 \ub418\ub294 \uc0ac\ub78c\uc758 \uae30\uc900<\/h2>\n<p>\ud070 \uba85\uc18c\ub97c \ud558\ub098 \ub354 \ubcf4\ub294 \uac83\ubcf4\ub2e4, \uc774\ubbf8 \uc788\ub294 \uc77c\uc815\uc758 \uc555\ubc15\uc744 \ub35c\uace0 \ud558\ub8e8\uc758 \ubc00\ub3c4\ub97c \uc870\uc815\ud558\uace0 \uc2f6\uc740 \uc0ac\ub78c\uc5d0\uac8c \uc774 \uadfc\uad50 \uc120\ud0dd\uc9c0\ub294 \uc798 \ub9de\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \uc774\ub3d9 \uc790\uccb4\uc5d0\uc11c \ud53c\ub85c\ub97c \ud06c\uac8c \ub290\ub07c\uac70\ub098, \uc9e7\uc740 \uc2dc\uac04 \uc548\uc5d0 \uc131\uacfc\ub97c \ud655\uc2e4\ud788 \ub0a8\uae30\uace0 \uc2f6\uc740 \uc0ac\ub78c\uc5d0\uac8c\ub294 \uc560\ub9e4\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\ub294 \ud654\ub824\ud55c \ub300\uccb4\uc7ac\uac00 \uc544\ub2c8\ub77c \ud750\ub984\uc744 \uc815\ub9ac\ud558\ub294 \ub3c4\uad6c\uc5d0 \uac00\uae5d\uae30 \ub54c\ubb38\uc5d0, \ubcf8\uc778\uc758 \uc5ec\ud589 \uc131\ud5a5\uacfc \ub9de\ubb3c\ub9b4 \ub54c\ub9cc \uac00\uce58\uac00 \uc120\uba85\ud574\uc9d1\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\uc5d0\uc11c \ub9cc\uc871\ub3c4\uac00 \uac08\ub9ac\ub294 \uc21c\uac04<\/h2>\n\n\n\n<p>\uc774 \uae00\uc758 \ud575\uc2ec \ubd84\uae30\uc810\uc740 \u201c\uc5b4\ub514\ub97c \ub354 \ubcf4\ub290\ub0d0\u201d\uac00 \uc544\ub2c8\ub77c \u201c\uc5b8\uc81c \ub3cc\uc544\uc624\ub290\ub0d0\u201d\ub2e4. \ub3cc\uc544\uc624\ub294 \uc2dc\uac04\uc744 \ub2a6\ucd94\uba74 \uadfc\uad50 \uc790\uccb4\ubcf4\ub2e4 \uc800\ub141 \uc2dd\uc0ac, \ud658\uc2b9, \uc219\uc18c \ubcf5\uadc0\uc758 \ud53c\ub85c\uac00 \ub354 \ud06c\uac8c \ub0a8\uae30 \ub54c\ubb38\uc5d0, \ub9cc\uc871\ub3c4\ub294 \ubcf5\uadc0\ud3b8 \uace0\uc815 \uc5ec\ubd80\uc5d0\uc11c \uac08\ub9b0\ub2e4.<\/p>\n\n\n\n\n\n<p>\uc77c\ubcf8 \ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50\ub294 \ub300\ub2e8\ud55c \uba85\uc18c\ubcf4\ub2e4 \uc77c\uc815\uc758 \uc228\uc744 \uace0\ub974\ub294 \uc5ed\ud560\uc774 \ud06c\ub2e4. \ubcf5\uadc0\ud3b8\uacfc \uc2dd\uc0ac\ub9cc \uba3c\uc800 \uc815\ud558\uba74 \ud63c\uc790 \uc5ec\ud589\uc758 \ube48\uce78\uc744 \uc548\uc815\uc801\uc73c\ub85c \ucc44\uc6b8 \uc218 \uc788\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc77c\ubcf8 \ub9c8\uc4f0\uc57c\ub9c8 \uadfc\uad50 \ud63c\uc790 \uc5ec\ud589\uc744 \uc704\ud55c \uc5f4\ucc28\u00b7\ubc84\uc2a4 \uc774\ub3d9, \ub3c4\ubcf4 \ub3d9\uc120, \uc2dd\uc0ac, \ub2f9\uc77c\uce58\uae30\uc640 1\ubc15 \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud588\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":1188,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"tablet":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"mobile":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""}},"ast-content-background-meta":{"desktop