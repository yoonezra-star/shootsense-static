{"id":1240,"date":"2026-04-05T10:42:00","date_gmt":"2026-04-05T01:42:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1240"},"modified":"2026-06-12T14:10:20","modified_gmt":"2026-06-12T05:10:20","slug":"%ec%97%ac%ed%96%89%ec%9d%98-%eb%aa%a9%ec%a0%81%ec%9d%b4-%eb%b3%b4%ea%b8%b0%ea%b0%80-%ec%95%84%eb%8b%88%ec%97%88%ec%9d%84-%eb%95%8c-%ec%84%a0%ed%83%9d%ed%95%9c-%eb%a7%88%ec%93%b0%eb%8b%a4%ec%9d%b4","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%97%ac%ed%96%89%ec%9d%98-%eb%aa%a9%ec%a0%81%ec%9d%b4-%eb%b3%b4%ea%b8%b0%ea%b0%80-%ec%95%84%eb%8b%88%ec%97%88%ec%9d%84-%eb%95%8c-%ec%84%a0%ed%83%9d%ed%95%9c-%eb%a7%88%ec%93%b0%eb%8b%a4%ec%9d%b4\/","title":{"rendered":"\uc5ec\ud589\uc758 \ubaa9\uc801\uc774 \ubcf4\uae30\uac00 \uc544\ub2c8\uc5c8\uc744 \ub54c \uc120\ud0dd\ud55c \ub9c8\uc4f0\ub2e4\uc774"},"content":{"rendered":"\n<p>\ub9c8\uc4f0\ub2e4\uc774\uc5d0\uc11c\uc758 \uc2dc\uac04\uc740 \ub300\ud45c \uba85\uc18c\ub97c \ub530\ub77c\uac00\ub294 \uc5ec\ud589\ubcf4\ub2e4 \uba38\ubb34\ub984\uc5d0 \uac00\uae4c\uc6e0\uc2b5\ub2c8\ub2e4. \uc77c\ubcf8 \uc18c\ub3c4\uc2dc\uc5d0\uc11c\ub294 \uad00\uad11\ubcf4\ub2e4 \uad50\ud1b5 \uc2dc\uac04\ud45c\uc640 \uc2dd\uc0ac \uc2dc\uac04, \uc870\uc6a9\ud55c \uc0b0\ucc45 \uae30\uc900\uc774 \ub354 \uc911\uc694\ud588\uc2b5\ub2c8\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \uc774\ub7f0 \uc9c0\uc5ed\uc740 \ud3b8\uc548\ud568\uacfc \ubd88\ud3b8\ud568\uc774 \ud568\uaed8 \uc635\ub2c8\ub2e4. \uc870\uc6a9\ud574\uc11c \uc624\ub798 \uc788\uc744 \uc218 \uc788\uc9c0\ub9cc, \uc2dd\uc0ac\uc640 \uc774\ub3d9, \uc219\uc18c \uc8fc\ubcc0 \uc0dd\ud65c\uad8c\uc744 \uc2a4\uc2a4\ub85c \ud655\uc778\ud574\uc57c \ud558\uae30 \ub54c\ubb38\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ub9c8\uc4f0\ub2e4\uc774\ub97c \ub2e8\uc21c\ud55c \uac10\uc0c1\uc73c\ub85c \ub0a8\uae30\uc9c0 \uc54a\uace0, \uc77c\ubcf8 \uc18c\ub3c4\uc2dc\uc5d0\uc11c \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \uc2e4\uc81c\ub85c \ud655\uc778\ud574\uc57c \ud560 \uae30\uc900\uc73c\ub85c \uc815\ub9ac\ud569\ub2c8\ub2e4. \uc678\uacfd\uc774\ub098 \uc18c\ub3c4\uc2dc\uc5d0\uc11c\ub294 \ubcfc\uac70\ub9ac \uc218\ubcf4\ub2e4 \uc219\uc18c \uc704\uce58, \ub0ae \uc0b0\ucc45, \uc2dd\uc0ac \ud6c4\ubcf4, \ubc24 \uadc0\uac00, \ubcf5\uadc0 \uad50\ud1b5\uc774 \ub354 \uc911\uc694\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"matsudai-fit\">\ub9c8\uc4f0\ub2e4\uc774\ub294 \ube60\ub978 \uad00\uad11\ubcf4\ub2e4 \uccb4\ub958\ud615 \uc5ec\ud589\uc5d0 \ub9de\uc2b5\ub2c8\ub2e4<\/h2>\n\n\n<p>\uc870\uc6a9\ud55c \uc9c0\uc5ed\uc5d0\uc11c\ub294 \ud558\ub8e8\ub97c \ube7d\ube7d\ud558\uac8c \ucc44\uc6b0\uae30\ubcf4\ub2e4 \ubc18\ubcf5 \uac00\ub2a5\ud55c \ub8e8\ud2f4\uc744 \ub9cc\ub4dc\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4. \uc219\uc18c \uc8fc\ubcc0\uc744 \uc775\ud788\uace0, \uc2dd\uc0ac \ud6c4\ubcf4\ub97c \uc815\ud558\uace0, \ud55c\ub450 \uad6c\uac04\uc744 \ucc9c\ucc9c\ud788 \uac77\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc785\ub2c8\ub2e4. \ubc18\ub300\ub85c \uba85\uc18c\ub97c \uacc4\uc18d \ucd94\uac00\ud558\ub824 \ud558\uba74 \uc774\ub3d9 \ud53c\ub85c\uac00 \ucee4\uc9c0\uace0, \uc800\ub141 \ubcf5\uadc0\uac00 \ubcf5\uc7a1\ud574\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc5ec\ud589 \uc870\uac74<\/th><th>\uc798 \ub9de\ub294 \ubc29\uc2dd<\/th><th>\uc8fc\uc758\ud560 \uc810<\/th><\/tr><\/thead><tbody><tr><td>\ub290\ub9b0 \uccb4\ub958<\/td><td>\uc219\uc18c \uc8fc\ubcc0 \uc0dd\ud65c\uad8c \ubc18\ubcf5 \uc0b0\ucc45<\/td><td>\uc77c\uc815\uc744 \ube44\uc6cc \ub450\ub294 \ub370 \uc775\uc219\ud574\uc57c \ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>\ud63c\uc790 \ucd08\ud589<\/td><td>\ub0ae \uc2dc\uac04 \uc911\uc2ec\uc73c\ub85c \uc9e7\uac8c \uc774\ub3d9<\/td><td>\ubc24 \uc678\uacfd \uc774\ub3d9\uc740 \ud53c\ud558\ub294 \ud3b8\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/td><\/tr><tr><td>\ud68c\ubcf5 \uc5ec\ud589<\/td><td>\uce74\ud398, \uc2dc\uc7a5, \uc219\uc18c \uc8fc\ubcc0 \ub8e8\ud2f4<\/td><td>\uc2dd\uc0ac \ud6c4\ubcf4\ub97c \ubbf8\ub9ac \ud655\ubcf4\ud574\uc57c \ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uc0ac\uc9c4 \uc911\uc2ec \uc5ec\ud589<\/td><td>\ub300\ud45c \uad6c\uc5ed \ud55c \uacf3\ub9cc \uc120\ud0dd<\/td><td>\uc5ec\ub7ec \uc9c0\uc810\uc744 \ud558\ub8e8\uc5d0 \ubb36\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"matsudai-stay\">\ub9c8\uc4f0\ub2e4\uc774 \uc219\uc18c\ub294 \ubd84\uc704\uae30\ubcf4\ub2e4 \ub2e4\uc74c \uc774\ub3d9 \uc5f0\uacb0\uc774 \uc911\uc694\ud558\ub2e4<\/h2>\n\n\n<p>\uc678\uacfd\uc774\ub098 \uc18c\ub3c4\uc2dc\uc5d0\uc11c \uc219\uc18c\ub294 \uc5ec\ud589\uc758 \uae30\uc900\uc810\uc785\ub2c8\ub2e4. \uc219\uc18c\uac00 \uc870\uc6a9\ud558\uace0 \uc608\ubed0\ub3c4 \uc2dd\uc0ac \uc7a5\uc18c\uac00 \uba40\uac70\ub098 \ubc24\uc5d0 \ub3cc\uc544\uc624\uae30 \uc5b4\ub835\ub2e4\uba74 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ubd80\ub2f4\uc774 \ub429\ub2c8\ub2e4. \uc219\uc18c\uc5d0\uc11c \ud070\uae38, \uc2dd\ub2f9, \ub9c8\ud2b8\ub098 \ud3b8\uc758\uc810, \ud0dd\uc2dc \uc2b9\ud558\ucc28 \uc9c0\uc810\uae4c\uc9c0\uc758 \uac70\ub9ac\ub97c \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n<p>\ud6c4\uae30\ub294 \ud3c9\uc810\ubcf4\ub2e4 \u201c\ubc24\uc5d0 \ub3cc\uc544\uc624\uae30 \uad1c\ucc2e\uc558\ub294\uc9c0\u201d, \u201c\uc8fc\ubcc0 \uc2dd\ub2f9\uc774 \uc788\uc5c8\ub294\uc9c0\u201d, \u201c\uc9c1\uc6d0 \uc751\ub300\uac00 \ube68\ub790\ub294\uc9c0\u201d, \u201c\ud63c\uc790 \uba38\ubb3c\uae30 \ubd88\ud3b8\ud558\uc9c0 \uc54a\uc558\ub294\uc9c0\u201d\ub97c \ubd10\uc57c \ud569\ub2c8\ub2e4. \uc790\uc138\ud55c \uae30\uc900\uc740 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-sukso-goreuneun-beop\/\">\ud63c\uc790 \uc5ec\ud589 \uc219\uc18c \uace0\ub974\ub294 \ubc95<\/a>\uacfc \ud568\uaed8 \ud655\uc778\ud558\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"matsudai-day\">\ub9c8\uc4f0\ub2e4\uc774 \ud558\ub8e8\ub294 \uc5ed\uacfc \ub9c8\uc744 \uc911\uc2ec\ucd95 \uc548\uc5d0\uc11c \ub05d\ub0b4\ub294 \ud3b8\uc774 \ub0ab\ub2e4<\/h2>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc2dc\uac04\ub300<\/th><th>\uad8c\uc7a5 \ud589\ub3d9<\/th><th>\ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\uc624\uc804<\/td><td>\uc219\uc18c \uc8fc\ubcc0 \ud070\uae38, \uc2dd\ub2f9, \uad50\ud1b5 \uc704\uce58 \ud655\uc778<\/td><td>\ud558\ub8e8 \uae30\uc900\uc810\uc744 \uba3c\uc800 \ub9cc\ub4ed\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uc810\uc2ec<\/td><td>\ud63c\uc790 \ub4e4\uc5b4\uac00\uae30 \uc26c\uc6b4 \uc2dd\ub2f9 \uc774\uc6a9<\/td><td>\uc2dd\uc0ac\ub97c \ubbf8\ub8e8\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uc624\ud6c4<\/td><td>\uc9e7\uc740 \uc0b0\ucc45 \ub610\ub294 \uc0dd\ud65c\uad8c \uad6c\uacbd<\/td><td>\ubb34\ub9ac\ud574\uc11c \uc678\uacfd\uc744 \ub113\ud788\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uc800\ub141<\/td><td>\uc219\uc18c \uac00\uae4c\uc6b4 \uacf3\uc5d0\uc11c \ub9c8\ubb34\ub9ac<\/td><td>\ubc24\uc5d0\ub294 \uc775\uc219\ud55c \uae38\ub9cc \uc0ac\uc6a9\ud569\ub2c8\ub2e4.<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"matsudai-meal\">\ub9c8\uc4f0\ub2e4\uc774\ub294 \uba39\uc744 \uacf3\ubcf4\ub2e4 \uc26c\uc5b4 \uac08 \ub9ac\ub4ec\uc744 \uba3c\uc800 \uc815\ud55c\ub2e4<\/h2>\n\n\n<p>\uad00\uad11 \uc815\ubcf4\uac00 \uc801\uc740 \uacf3\uc5d0\uc11c\ub294 \ub9e4\ubc88 \uc0c8\ub85c\uc6b4 \ub9db\uc9d1\uc744 \ucc3e\ub294 \uac83\ubcf4\ub2e4, \ud63c\uc790 \uc774\uc6a9\ud558\uae30 \uc26c\uc6b4 \uc2dd\ub2f9\uc744 \ud558\ub098 \ud655\ubcf4\ud558\ub294 \uac83\uc774 \ub354 \uc911\uc694\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc8fc\ubb38 \ubc29\uc2dd\uc774 \ub2e8\uc21c\ud558\uace0, \uc219\uc18c\uc640 \uac00\uae5d\uace0, \uac00\uaca9\uc774 \uc608\uce21 \uac00\ub2a5\ud55c \uacf3\uc774\uba74 \ucda9\ubd84\ud569\ub2c8\ub2e4. \uc2dd\uc0ac \ud310\ub2e8\uc774 \uc904\uc5b4\ub4e4\uba74 \uc5ec\ud589 \uc804\uccb4\uac00 \uc548\uc815\ub429\ub2c8\ub2e4.<\/p>\n\n\n<p>\ud63c\uc790 \uc2dd\uc0ac\uac00 \ubd80\ub2f4\uc2a4\ub7fd\ub2e4\uba74 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-sikdang-goreuneun-beop\/\">\ud63c\uc790 \uc5ec\ud589 \uc911 \uc2dd\ub2f9 \uace0\ub974\ub294 \ubc95<\/a> \uae30\uc900\ucc98\ub7fc 1\uc778 \uc88c\uc11d, \uc8fc\ubb38 \ubc29\uc2dd, \ub300\uae30 \uc2dc\uac04, \uc219\uc18c \ubcf5\uadc0 \ub3d9\uc120\uc744 \ud568\uaed8 \ubcf4\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"matsudai-safety\">\ub9c8\uc4f0\ub2e4\uc774\uc5d0\uc11c\ub294 \ub2a6\uc740 \uc2dc\uac04 \uc0c8 \ub3d9\uc120\uc744 \ub9cc\ub4e4\uc9c0 \uc54a\ub294 \ud3b8\uc774 \uc88b\ub2e4<\/h2>\n\n\n<p>\ub0ae\uc5d0 \ud3b8\uc548\ud588\ub358 \uae38\ub3c4 \ubc24\uc5d0\ub294 \ub2e4\ub974\uac8c \ub290\uaef4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ubc24\uc5d0 \uc0c8\ub85c\uc6b4 \uace8\ubaa9\uc774\ub098 \uc678\uacfd \ubc29\ud5a5\uc73c\ub85c \uac77\uae30\ubcf4\ub2e4 \ub0ae\uc5d0 \ud655\uc778\ud55c \ud070\uae38\uacfc \uc219\uc18c \uac00\uae4c\uc6b4 \uad6c\uac04\ub9cc \uc0ac\uc6a9\ud558\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4. \ud0dd\uc2dc\ub098 \ub300\uccb4 \uc774\ub3d9 \uc218\ub2e8\uc744 \uc0ac\uc6a9\ud560 \uc218 \uc788\ub294 \uc9c0\uc810\ub3c4 \ubbf8\ub9ac \ud655\uc778\ud558\uc138\uc694.<\/p>\n\n\n<p>\uccb4\ud06c\uc778 \uc9c1\ud6c4\uc5d0\ub294 \ubb38 \uc7a0\uae08, \ube44\uc0c1\uad6c, \ud504\ub7f0\ud2b8 \uc5f0\ub77d\ucc98, \uc219\uc18c \uc8fc\ubcc0 \ud070\uae38\uc744 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4. \uc219\uc18c \uc548\uc5d0\uc11c\uc758 \uae30\uc900\uc740 <a href=\"https:\/\/shootsense.com\/honja-sukso-anjeon-checklist\/\">\ud63c\uc790 \uc219\uc18c\uc5d0\uc11c \uc548\uc804\ud558\uac8c \uba38\ubb34\ub294 \ud301<\/a>\uc744 \ucc38\uace0\ud558\uba74 \ub429\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"matsudai-avoid\">\ub9c8\uc4f0\ub2e4\uc774\ub294 \uad50\ud1b5 \uac04\uaca9\uc774 \uae38\uba74 \uc77c\uc815 \uc790\uccb4\ub97c \uc904\uc774\ub294 \uac8c \ub0ab\ub2e4<\/h2>\n\n\n<ul class=\"wp-block-list\"><li>\uc219\uc18c \uc8fc\ubcc0 \uc2dd\uc0ac \ud6c4\ubcf4\uac00 \ud655\uc778\ub418\uc9c0 \uc54a\uc740 \uacbd\uc6b0<\/li><li>\ubcf5\uadc0 \uad50\ud1b5\ud3b8\uc774\ub098 \ud0dd\uc2dc \ub300\uccb4 \uc218\ub2e8\uc774 \ubd88\uba85\ud655\ud55c \uacbd\uc6b0<\/li><li>\ubc24\uc5d0 \uc678\uacfd\uc744 \uac78\uc5b4\uc57c\ub9cc \uc219\uc18c\ub85c \ub3cc\uc544\uac08 \uc218 \uc788\ub294 \uacbd\uc6b0<\/li><li>\uc870\uc6a9\ud568\uc744 \uacac\ub514\uae30 \uc5b4\ub824\uc6cc \uacc4\uc18d \uba3c \uacf3\uc744 \ucd94\uac00\ud558\uac8c \ub418\ub294 \uacbd\uc6b0<\/li><\/ul>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9c8\uc4f0\ub2e4\uc774\ub97c \uc120\ud0dd\ud558\uae30 \uc804 \ud655\uc778\ud560 \uccb4\ub958 \uc870\uac74<\/h2>\n\n\n<ul class=\"wp-block-list\"><li>\uc219\uc18c \uc8fc\ubcc0 \ud070\uae38\uacfc \uc2dd\uc0ac \ud6c4\ubcf4\ub97c \ub0ae\uc5d0 \ud655\uc778\ud569\ub2c8\ub2e4.<\/li><li>\ubc18\ubcf5\ud574\uc11c \uac08 \uc218 \uc788\ub294 \uce74\ud398\ub098 \uc2dd\ub2f9\uc744 \ud558\ub098 \uc815\ud569\ub2c8\ub2e4.<\/li><li>\ubc24\uc5d0\ub294 \ub0ae\uc5d0 \uac78\uc5b4\ubcf8 \uae38\ub9cc \uc0ac\uc6a9\ud569\ub2c8\ub2e4.<\/li><li>\uc678\uacfd \uc774\ub3d9 \uc804 \ubcf5\uadc0 \uc218\ub2e8\uc744 \uba3c\uc800 \ud655\uc778\ud569\ub2c8\ub2e4.<\/li><li>\uc2ec\uc2ec\ud55c \uc2dc\uac04\uc744 \uc2e4\ud328\ub85c \ubcf4\uc9c0 \uc54a\uace0 \uae30\ub85d, \uc0b0\ucc45, \ud734\uc2dd\uc73c\ub85c \uc804\ud658\ud569\ub2c8\ub2e4.<\/li><\/ul>\n<!-- \/wp:post-content -->\n\n<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">\ub9c8\uc4f0\ub2e4\uc774\uc5d0\uc11c \ud55c\uc801\ud568\uc774 \uc7a5\uc810\uc774 \ub418\ub824\uba74 \ud544\uc694\ud55c \uc804\uc81c<\/h2>\n<p>\ub9c8\uc4f0\ub2e4\uc774\ub294 \uc870\uc6a9\ud558\ub2e4\ub294 \uc774\uc720\ub9cc\uc73c\ub85c \ub9cc\uc871\ub3c4\uac00 \ubcf4\uc7a5\ub418\ub294 \uacf3\uc740 \uc544\ub2d9\ub2c8\ub2e4. \uad50\ud1b5 \uac04\uaca9\uc774 \uae34 \uc9c0\uc5ed\uc5d0\uc11c\ub294 \ud55c\uc801\ud568\uc774 \uace7 \uc5ec\uc720\uac00 \ub418\uae30\ub3c4 \ud558\uc9c0\ub9cc, \uc900\ube44 \uc5c6\uc774 \ub4e4\uc5b4\uac00\uba74 \uace7\ubc14\ub85c \ubd88\ud3b8\ud568\uc73c\ub85c \ubc14\ub014 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc2dd\uc0ac \uac00\ub2a5 \uc2dc\uac04, \ub2e4\uc74c \uc774\ub3d9 \uc5f0\uacb0, \ud734\uc2dd\ud560 \uacf5\uac04\uc774 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc774\uc5b4\uc9c8 \ub54c\ub9cc \uadf8 \uc870\uc6a9\ud568\uc774 \uc7a5\uc810\uc73c\ub85c \uc791\ub3d9\ud569\ub2c8\ub2e4. \uadf8\ub798\uc11c \ub9c8\uc4f0\ub2e4\uc774\ub294 \uac10\uc131\ubcf4\ub2e4 \uad6c\uc870\ub97c \uba3c\uc800 \ub9de\ucd98 \uc0ac\ub78c\uc5d0\uac8c \ub354 \uc798 \ub9de\ub294 \uccb4\ub958\uc9c0\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub9c8\uc4f0\ub2e4\uc774\ub97c \uc9e7\uac8c \ub123\uc744 \ub54c\uc640 \uae38\uac8c \uba38\ubb3c \ub54c\uc758 \ucc28\uc774<\/h2>\n<p>\uc9e7\uac8c \ub123\uc744 \ub54c\ub294 \uc5ed\uacfc \uc911\uc2ec\ucd95 \uc8fc\ubcc0\ub9cc \uc815\ub9ac\ud574\ub3c4 \ucda9\ubd84\ud558\uc9c0\ub9cc, \uae38\uac8c \uba38\ubb3c\uc218\ub85d \uc0dd\ud65c \ub9ac\ub4ec\uacfc \uc774\ub3d9 \uacf5\ubc31\uc744 \ub354 \uc138\ubc00\ud558\uac8c \uad00\ub9ac\ud574\uc57c \ud569\ub2c8\ub2e4. \ubc18\ub098\uc808 \uc77c\uc815\uc740 \uc758\uc0ac\uacb0\uc815 \ud3ec\uc778\ud2b8\uac00 \uc801\uc5b4 \ube44\uad50\uc801 \ub2e8\uc21c\ud558\uc9c0\ub9cc, 1\ubc15 \uc774\uc0c1\uc774 \ub418\uba74 \uc800\ub141 \uc2dc\uac04\ub300\uc640 \uc544\uce68 \ucd9c\ubc1c \ub3d9\uc120\uae4c\uc9c0 \uacc4\uc0b0\ud574\uc57c \uc804\uccb4 \ub9cc\uc871\ub3c4\uac00 \uc720\uc9c0\ub429\ub2c8\ub2e4. \uacb0\uad6d \ub9c8\uc4f0\ub2e4\uc774\ub294 \uccb4\ub958 \uc2dc\uac04\uc774 \ub298\uc5b4\ub0a0\uc218\ub85d \ud48d\uacbd\ubcf4\ub2e4 \uc6b4\uc601 \ub09c\ub3c4\uac00 \uc911\uc694\ud55c \uc7a5\uc18c\uc5d0 \uac00\uae5d\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\" id=\"matsudai-faq\">\ub9c8\uc4f0\ub2e4\uc774 \uc120\ud0dd \uc804\uc5d0 \ud655\uc778\ud560 \ud575\uc2ec \uc9c8\ubb38<\/h2>\n<!-- \/wp:heading -->\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Q1. \ub9c8\uc4f0\ub2e4\uc774\ub294 \ud63c\uc790 \uc5ec\ud589\ud558\uae30 \uc88b\uc740\uac00\uc694?<\/h3>\n<!-- \/wp:heading -->\n<!-- wp:paragraph -->\n<p>\ub290\ub9b0 \uccb4\ub958\uc640 \uc870\uc6a9\ud55c \uc0b0\ucc45\uc744 \uc88b\uc544\ud55c\ub2e4\uba74 \uad1c\ucc2e\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac \ud6c4\ubcf4, \ubc24 \uadc0\uac00 \ub3d9\uc120\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n<!-- \/wp:paragraph -->\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Q2. \uba70\uce60 \uba38\ubb34\ub294 \uac83\uc774 \uc801\ub2f9\ud55c\uac00\uc694?<\/h3>\n<!-- \/wp:heading -->\n<!-- wp:paragraph -->\n<p>\ucc98\uc74c\uc774\ub77c\uba74 1~2\ubc15\uc73c\ub85c \ucda9\ubd84\ud569\ub2c8\ub2e4. \ubd84\uc704\uae30\uac00 \ub9de\ub294\ub2e4\uace0 \ub290\uaef4\uc9c0\uba74 \ub354 \uba38\ubb3c \uc218 \uc788\uc9c0\ub9cc \uc774\ub3d9\uacfc \uc2dd\uc0ac \uae30\uc900\uc744 \uba3c\uc800 \uc7a1\uc544\uc57c \ud569\ub2c8\ub2e4.<\/p>\n<!-- \/wp:paragraph -->\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Q3. \ubc24 \uc0b0\ucc45\uc740 \uad1c\ucc2e\ub098\uc694?<\/h3>\n<!-- \/wp:heading -->\n<!-- wp:paragraph -->\n<p>\ucd08\ubcf4\uc790\ub77c\uba74 \uad8c\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \ud544\uc694\ud558\ub2e4\uba74 \uc219\uc18c \uac00\uae4c\uc6b4 \ud070\uae38\uacfc \ubc1d\uc740 \uad6c\uac04\ub9cc \uc9e7\uac8c \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n<!-- \/wp:paragraph -->\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Q4. \ubcfc\uac70\ub9ac\uac00 \uc801\uc73c\uba74 \uc5ec\ud589 \uac00\uce58\uac00 \ub0ae\uc740 \uac74\uac00\uc694?<\/h3>\n<!-- \/wp:heading -->\n<!-- wp:paragraph -->\n<p>\uc544\ub2d9\ub2c8\ub2e4. \ub2e4\ub9cc \ube60\ub978 \uad00\uad11\ubcf4\ub2e4 \ud68c\ubcf5, \uc0b0\ucc45, \uc0dd\ud65c\uad8c \uad00\ucc30\uc5d0 \ub9de\ub294 \uc5ec\ud589\uc9c0\uc778\uc9c0 \uc2a4\uc2a4\ub85c \ud310\ub2e8\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n<!-- \/wp:paragraph -->","protected":false},"excerpt":{"rendered":"<p>\ub9c8\uc4f0\ub2e4\uc774\ub294 \ub9ce\uc774 \ubcf4\ub294 \uc5ec\ud589\ubcf4\ub2e4 \uc870\uc6a9\ud788 \uba38\ubb34\ub294 \uc5ec\ud589\uc5d0 \ub9de\uc2b5\ub2c8\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc790\ub294 \uad50\ud1b5 \uc2dc\uac04\ud45c, \uc774\ub978 \uc2dd\uc0ac, \uc219\uc18c \uc8fc\ubcc0 \uc0b0\ucc45, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uba3c\uc800 \ubd10\uc57c \ud569\ub2c8\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":1241,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"tablet":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"mobile":{"background-color":"","background-image":"","background-repeat":"repeat","backgroun