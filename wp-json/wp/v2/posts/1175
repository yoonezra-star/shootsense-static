{"id":1175,"date":"2026-03-08T21:40:28","date_gmt":"2026-03-08T12:40:28","guid":{"rendered":"https:\/\/shootsense.com\/?p=1175"},"modified":"2026-06-12T14:10:24","modified_gmt":"2026-06-12T05:10:24","slug":"%ea%b5%ac%ea%b2%bd-%eb%8c%80%ec%8b%a0-%ec%82%b0%ec%b1%85%ec%9d%b4-%ec%a0%84%eb%b6%80%ec%98%80%eb%8d%98-%ec%9a%b0%eb%b6%93-%ec%99%b8%ea%b3%bd%ec%9d%98-%ed%95%98%eb%a3%a8","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ea%b5%ac%ea%b2%bd-%eb%8c%80%ec%8b%a0-%ec%82%b0%ec%b1%85%ec%9d%b4-%ec%a0%84%eb%b6%80%ec%98%80%eb%8d%98-%ec%9a%b0%eb%b6%93-%ec%99%b8%ea%b3%bd%ec%9d%98-%ed%95%98%eb%a3%a8\/","title":{"rendered":"\ubc1c\ub9ac \uc6b0\ubd93 \uc678\uacfd \ud63c\uc790 \uc5ec\ud589: \uad6c\uacbd\ubcf4\ub2e4 \uc0b0\ucc45\uc774 \ub9de\ub294 \ud558\ub8e8 \uc124\uacc4"},"content":{"rendered":"\n<p>\uc6b0\ubd93 \uc678\uacfd\uc740 \ub300\ud45c \uba85\uc18c\ub97c \ucc0d\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \ucc9c\ucc9c\ud788 \uac77\uace0 \uc26c\ub294 \ubc29\uc2dd\uc774 \uc798 \ub9de\ub294 \uc9c0\uc5ed\uc774\ub2e4. \ub2e4\ub9cc \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uae38 \uc0c1\ud0dc, \ucc28\ub7c9 \uc774\ub3d9, \uc57c\uac04 \ubcf5\uadc0 \uae30\uc900\uc744 \uba3c\uc800 \uc815\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ubc1c\ub9ac \uc6b0\ubd93 \uc678\uacfd\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c \uac10\uc0c1\uc774 \uc544\ub2c8\ub77c \uad50\ud1b5, \uc219\uc18c, \uc2dd\uc0ac, \ub0a0\uc528, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \ud558\ub8e8\ub97c \uc124\uacc4\ud558\ub294 \ub370 \ucd08\uc810\uc744 \ub454\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc1c\ub9ac \uc6b0\ubd93 \uc678\uacfd \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\uc6b0\ubd93 \uc678\uacfd\uc740 \ub17c\uae38\uacfc \uc870\uc6a9\ud55c \uc219\uc18c, \uc791\uc740 \uce74\ud398\uac00 \ub9e4\ub825\uc801\uc774\uc9c0\ub9cc \ub3c4\ubcf4 \uc774\ub3d9\uc774 \ud56d\uc0c1 \ud3b8\ud55c \uac83\uc740 \uc544\ub2c8\ub2e4. \ub0ae \uc2dc\uac04 \uc0b0\ucc45\uacfc \uc800\ub141 \ubcf5\uadc0 \ub3d9\uc120\uc744 \ubd84\ub9ac\ud574 \uacc4\ud68d\ud558\ub294 \uac83\uc774 \uc88b\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \ubcf4\ub294 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\ub17c\uae38 \uc0b0\ucc45, \uc870\uc6a9\ud55c \uc219\uc18c \uccb4\ub958, \uc6b0\ubd93 \uc911\uc2ec\ubd80 \ud63c\uc7a1 \ud68c\ud53c<\/td><td>\uc0ac\uc9c4\ubcf4\ub2e4 \uccb4\ub958 \ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \ub9cc\uc871\ub3c4\uac00 \uc548\uc815\ub41c\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\ub3c4\ubcf4, \ucc28\ub7c9 \ud638\ucd9c, \uc219\uc18c \uc154\ud2c0, \uc57c\uac04 \ubcf5\uadc0 \uac00\ub2a5\uc131 \ud655\uc778<\/td><td>\uc678\uacfd\u00b7\uc0b0\uc545 \uc9c0\uc5ed\uc740 \ubcf5\uadc0 \uc218\ub2e8\uc774 \uace7 \uc548\uc804 \uae30\uc900\uc774\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>1\ubc15 \uc774\uc0c1 \uad8c\uc7a5, \uc678\uacfd \uc219\uc18c\ub294 2\ubc15\uc774\uba74 \ub9ac\ub4ec\uc774 \uc548\uc815\uc801<\/td><td>\ub3c4\ucc29\uc77c\uacfc \ud65c\ub3d9\uc77c\uc744 \ubd84\ub9ac\ud574\uc57c \ud53c\ub85c \ub204\uc801\uc744 \uc904\uc77c \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\ube44, \uc881\uc740 \uae38, \uc57c\uac04 \uc870\uba85, \ucc28\ub7c9 \ud638\ucd9c \ub300\uae30, \uc219\uc18c \uc704\uce58<\/td><td>\ub0a0\uc528, \uae38 \uc0c1\ud0dc, \uc778\uc801, \uc2dd\uc0ac \uac00\ub2a5\uc131\uc774 \uc77c\uc815\uc744 \ubc14\uafbc\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc6b0\ubd93 \uc911\uc2ec\ubcf4\ub2e4 \uc678\uacfd\uc774 \ud3b8\ud574\uc9c0\ub294 \uc870\uac74<\/h2>\n\n\n\n<p>\uc6b0\ubd93 \uc678\uacfd\uc740 \ud63c\uc790 \uc26c\uace0 \uac77\uae30 \uc88b\uc9c0\ub9cc, \uae38\uacfc \uad50\ud1b5\uc744 \uacfc\uc18c\ud3c9\uac00\ud558\uba74 \ud53c\ub85c\ud574\uc9c4\ub2e4. \ud63c\uc790\ub77c\uba74 \uc219\uc18c \uc8fc\ubcc0\uc5d0\uc11c \uc548\uc804\ud558\uac8c \ubc18\ubcf5\ud560 \uc218 \uc788\ub294 \uc0b0\ucc45 \uad6c\uac04\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uba4b\uc9c4 \uc7a5\uba74\ubcf4\ub2e4 \ud604\uc7a5\uc5d0\uc11c \ubd88\uc548\ud558\uc9c0 \uc54a\uc740 \uad6c\uc870\uac00 \uba3c\uc800\ub2e4. \uc219\uc18c\uc640 \uc2dd\uc0ac, \ubcf5\uadc0 \uae30\uc900\uc774 \uc815\ub9ac\ub418\uc5b4 \uc788\uc73c\uba74 \uc870\uc6a9\ud55c \uc7a5\uc18c\ub3c4 \ucda9\ubd84\ud788 \uc758\ubbf8 \uc788\ub294 \uccb4\ub958\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ucc28\ub7c9 \ud638\ucd9c\uc774 \ub04a\uae30\uae30 \uc804 \uc815\ud560 \uac83<\/h2>\n\n\n\n<p>\uc678\uacfd \uc219\uc18c\ub294 \uc911\uc2ec\ubd80\uae4c\uc9c0 \uac70\ub9ac\uac00 \uc9e7\uc544 \ubcf4\uc5ec\ub3c4 \uc2e4\uc81c \ubcf4\ud589 \ud658\uacbd\uc774 \ubd88\ud3b8\ud560 \uc218 \uc788\ub2e4. \ucc28\ub7c9 \ud638\ucd9c\uc774 \uc798 \ub418\ub294\uc9c0, \uc219\uc18c \uc154\ud2c0\uc774 \uc788\ub294\uc9c0, \ubc24\uc5d0\ub3c4 \ubcf5\uadc0\uac00 \uac00\ub2a5\ud55c\uc9c0 \ud655\uc778\ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc0c1\ud669<\/th><th>\uc704\ud5d8 \uc2e0\ud638<\/th><th>\uad8c\uc7a5 \ub300\uc751<\/th><\/tr><\/thead><tbody><tr><td>\ub2a6\uc740 \ub3c4\ucc29<\/td><td>\uc219\uc18c \uc704\uce58\ub97c \ucc3e\uae30 \uc5b4\ub835\uac70\ub098 \ucc28\ub7c9 \ud638\ucd9c\uc774 \ubd88\uc548\uc815\ud558\ub2e4<\/td><td>\ubc1d\uc740 \uc2dc\uac04 \uccb4\ud06c\uc778\uc744 \uc6b0\uc120\ud558\uace0 \ud53d\uc5c5\uc744 \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\ub0a0\uc528 \ubcc0\ud654<\/td><td>\ube44, \uc548\uac1c, \ubbf8\ub044\ub7ec\uc6b4 \uae38\ub85c \ubcf4\ud589 \uc2dc\uac04\uc774 \ub298\uc5b4\ub09c\ub2e4<\/td><td>\uc678\uacfd \ub3d9\uc120\uc744 \uc904\uc774\uace0 \uc219\uc18c \uc8fc\ubcc0 \uccb4\ub958\ub85c \ubc14\uafbc\ub2e4<\/td><\/tr><tr><td>\uc2dd\uc0ac \uacf5\ubc31<\/td><td>\uc8fc\ubcc0 \uc2dd\ub2f9\uc774 \ub2eb\ud788\uac70\ub098 \uba40\ub2e4<\/td><td>\ub3c4\ucc29 \uc804\uc5d0 \ubb3c, \uac04\uc2dd, \uc219\uc18c \uc2dd\uc0ac \uc5ec\ubd80\ub97c \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\ud1b5\uc2e0 \ubd88\uc548\uc815<\/td><td>\uc9c0\ub3c4\uc640 \ud638\ucd9c \uc11c\ube44\uc2a4\uac00 \ub2a6\uac8c \uc791\ub3d9\ud55c\ub2e4<\/td><td>\uc624\ud504\ub77c\uc778 \uc9c0\ub3c4\uc640 \uc219\uc18c \uc8fc\uc18c\ub97c \uc800\uc7a5\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ub17c\uae38 \uc0b0\ucc45\uacfc \uc911\uc2ec\ubd80 \uc774\ub3d9\uc744 \ub098\ub204\ub294 \ubc95<\/h2>\n\n\n\n<p>\uc624\uc804\uc5d0\ub294 \uc219\uc18c \uc8fc\ubcc0 \ub17c\uae38\uc774\ub098 \uac00\uae4c\uc6b4 \uce74\ud398\ub97c \uc911\uc2ec\uc73c\ub85c \uac77\uace0, \uc624\ud6c4\uc5d0\ub294 \uc911\uc2ec\ubd80 \uc774\ub3d9\uc744 \uc9e7\uac8c \ub123\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\ub2e4. \ube44\uac00 \uc624\uba74 \uc678\uacfd \ub3c4\ubcf4 \ub300\uc2e0 \uc219\uc18c \uccb4\ub958\ub85c \uc804\ud658\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc77c\uc815\uc740 \ub113\uac8c \ud655\uc7a5\ud558\uae30\ubcf4\ub2e4 \uc219\uc18c\uc640 \uc911\uc2ec \uad6c\uac04\uc744 \uae30\uc900\uc73c\ub85c \uc904\uc77c \uc218 \uc788\uac8c \uc7a1\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ud63c\uc790\ub77c\uba74 \u201c\ub354 \ubcf4\ub294 \uac83\u201d\ubcf4\ub2e4 \u201c\ubb34\ub9ac\ud558\uc9c0 \uc54a\uace0 \ub3cc\uc544\uc624\ub294 \uac83\u201d\uc774 \uc77c\uc815 \ud488\uc9c8\uc744 \uc88c\uc6b0\ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc870\uc6a9\ud55c \uc219\uc18c\uc640 \ubcf5\uadc0 \ud3b8\uc758\uc758 \uade0\ud615<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \uc870\uc6a9\ud568\uacfc \uc811\uadfc\uc131\uc758 \uade0\ud615\uc774 \uc911\uc694\ud558\ub2e4. \ub108\ubb34 \uc678\uacfd\uc774\uba74 \ud48d\uacbd\uc740 \uc88b\uc9c0\ub9cc \uc2dd\uc0ac\uc640 \uc57c\uac04 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud574\uc9c8 \uc218 \uc788\uc73c\ubbc0\ub85c \uc8fc\ubcc0 \uc2dd\ub2f9\uacfc \uc154\ud2c0 \uc5ec\ubd80\ub97c \ud655\uc778\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc678\uacfd \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \ud63c\uc790\uc5d0\uac8c\ub294 \uc2dd\uc0ac\uc640 \uc57c\uac04 \uc774\ub3d9\uc774 \ubcc0\uc218\ub2e4. \uc219\uc18c\ub97c \uace0\ub97c \ub54c\ub294 \uc804\ub9dd\ubcf4\ub2e4 \uccb4\ud06c\uc778 \uc2dc\uac04, \ud53d\uc5c5 \uac00\ub2a5 \uc5ec\ubd80, \uc8fc\ubcc0 \uc2dd\uc0ac \uac00\ub2a5\uc131\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2a6\uc740 \uce74\ud398 \uc77c\uc815\uc774 \ud53c\uace4\ud574\uc9c0\ub294 \uc21c\uac04<\/h2>\n\n\n\n<p>\uc678\uacfd \uce74\ud398\uc640 \uc2dd\ub2f9\uc740 \ubd84\uc704\uae30\uac00 \uc88b\uc9c0\ub9cc \uc601\uc5c5 \uc2dc\uac04\uacfc \uc774\ub3d9 \uac70\ub9ac\uac00 \ubcc0\uc218\ub2e4. \uc800\ub141\uc740 \uc219\uc18c\uc5d0\uc11c \uac78\uc5b4\uac08 \uc218 \uc788\uac70\ub098 \ucc28\ub7c9 \ubcf5\uadc0\uac00 \ud655\uc2e4\ud55c \uacf3\uc73c\ub85c \uc81c\ud55c\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc77c\uc815\uc758 \ubcf4\uc870\uac00 \uc544\ub2c8\ub77c \uc548\uc804 \uae30\uc900\uc774\ub2e4. \uc2dd\uc0ac \uc2dc\uac04\uc774 \ubc00\ub9ac\uba74 \ud53c\ub85c\uc640 \ud310\ub2e8 \uc2e4\uc218\uac00 \ud568\uaed8 \ub298\uc5b4\ub098\ubbc0\ub85c, \ud63c\uc790\ub77c\uba74 \ub2a6\uc740 \uc2dc\uac04\uae4c\uc9c0 \uc2dd\uc0ac\ub97c \ubbf8\ub8e8\uc9c0 \uc54a\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ube44 \uc624\ub294 \ubc24\uae38\uc744 \ud53c\ud558\ub294 \ubc29\uc2dd<\/h2>\n\n\n\n<p>\uc6b0\ubd93 \uc678\uacfd\uc758 \ub9ac\uc2a4\ud06c\ub294 \ub2a6\uc740 \uc2dc\uac04 \uc5b4\ub450\uc6b4 \uae38\uacfc \ucc28\ub7c9 \uc774\ub3d9\uc774\ub2e4. \ud63c\uc790\ub77c\uba74 \ubc24\uc5d0 \ub17c\uae38\uc774\ub098 \uc870\uba85 \uc5c6\ub294 \uae38\uc744 \uac77\uc9c0 \uc54a\uace0, \ube44 \uc624\ub294 \ub0a0\uc5d0\ub294 \uc624\ud1a0\ubc14\uc774 \uc774\ub3d9\ub3c4 \uc2e0\uc911\ud788 \ud310\ub2e8\ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \uac00\uc7a5 \ud53c\ud574\uc57c \ud560 \uc870\ud569\uc740 \ud53c\ub85c, \uc5b4\ub450\uc6b4 \uae38, \ubd88\ud655\uc2e4\ud55c \ubcf5\uadc0 \uc218\ub2e8\uc774 \ub3d9\uc2dc\uc5d0 \uc0dd\uae30\ub294 \uc0c1\ud669\uc774\ub2e4. \uc14b \uc911 \ud558\ub098\ub77c\ub3c4 \ubcf4\uc774\uba74 \uadf8\ub0a0\uc758 \uc77c\uc815\uc740 \uc904\uc774\ub294 \uac83\uc774 \ub9de\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc800\ub834\ud55c \uc678\uacfd \uc219\uc18c\uac00 \ube44\uc2f8\uc9c0\ub294 \uacbd\uc6b0<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc219\uc18c \uc704\uce58\uc640 \ucc28\ub7c9 \uc774\ub3d9 \ube48\ub3c4\uc5d0\uc11c \ub2ec\ub77c\uc9c4\ub2e4. \uc800\ub834\ud55c \uc678\uacfd \uc219\uc18c\ub97c \uace0\ub974\ub354\ub77c\ub3c4 \ub9e4\ubc88 \ucc28\ub7c9\uc744 \uc4f0\uba74 \ucd1d\ube44\uc6a9\uc774 \uc62c\ub77c\uac08 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc219\ubc15\ube44\ub9cc \ube44\uad50\ud558\uba74 \ud310\ub2e8\uc774 \ud2c0\uc5b4\uc9c8 \uc218 \uc788\ub2e4. \uc678\uacfd \uc774\ub3d9\ube44, \ud53d\uc5c5 \ube44\uc6a9, \uc2dd\uc0ac \ud3ec\ud568 \uc5ec\ubd80, \ub0a0\uc528 \ub54c\ubb38\uc5d0 \uc0dd\uae30\ub294 \ub300\uccb4 \uad50\ud1b5\ube44\uae4c\uc9c0 \ud568\uaed8 \ubd10\uc57c \uc2e4\uc81c \ube44\uc6a9\uc774 \ubcf4\uc778\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc6b0\ubd93 \uc678\uacfd\uc5d0\uc11c \ud754\ud55c \ubb34\ub9ac\ud55c \ubc24 \uc77c\uc815<\/h2>\n\n\n\n<p>\ub0ae\uc5d0\ub294 \uc678\uacfd \uc0b0\ucc45, \ubc24\uc5d0\ub294 \uc911\uc2ec\ubd80\uae4c\uc9c0 \ub3c4\ubcf4 \ubcf5\uadc0\ub97c \uae30\ub300\ud558\ub294 \uc77c\uc815\uc740 \ud53c\ud574\uc57c \ud55c\ub2e4. \uc6b0\ubd93 \uc678\uacfd\uc740 \ub0ae\uacfc \ubc24\uc758 \uc774\ub3d9 \uc870\uac74\uc774 \ub2e4\ub974\uac8c \ub290\uaef4\uc9c4\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0b0\ucc45\uc774 \ud734\uc2dd\uc774 \ub418\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\ubc1c\ub9ac\uc5d0\uc11c \ud654\ub824\ud55c \uc77c\uc815\ubcf4\ub2e4 \uc870\uc6a9\ud55c \uc219\uc18c\uc640 \uc0b0\ucc45 \uc2dc\uac04\uc744 \uc6d0\ud558\ub294 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \ub290\ub9b0 \uccb4\ub958\uc640 \uc548\uc804\ud55c \ubcf5\uadc0 \uae30\uc900\uc744 \ud568\uaed8 \uc911\uc2dc\ud558\ub294 \uc0ac\ub78c\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc6b0\ubd93 \uc678\uacfd \ud558\ub8e8\uac00 \ud3b8\uc548\ud588\ub358 \uacb0\uc815\uc801 \uc774\uc720<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\uc6b0\ubd93 \uc678\uacfd\uc5d0\uc11c \uc0b0\ucc45\uacfc \uc774\ub3d9\uc744 \uc11e\uc744 \ub54c \uc0dd\uae30\ub294 \ud53c\ub85c<\/h2>\n<p>\uc6b0\ubd93 \uc678\uacfd\uc740 \uac77\ub294 \uc21c\uac04\ub9cc \ubcf4\uba74 \ud3c9\uc628\ud558\uc9c0\ub9cc, \ucc28\ub7c9 \uc774\ub3d9\uacfc \ub3c4\ubcf4 \uc0b0\ucc45\uc744 \ud55c\ub0a0\uc5d0 \uc5ec\ub7ec \ubc88 \uc11e\uc73c\uba74 \ud53c\ub85c\uac00 \uc608\uc0c1\ubcf4\ub2e4 \ube68\ub9ac \ub204\uc801\ub429\ub2c8\ub2e4. \ud638\ucd9c \ub300\uae30 \uc2dc\uac04, \ub3c4\ub85c \uc0c1\ud669, \ub354\uc704\uc640 \uc2b5\ub3c4\uae4c\uc9c0 \uacb9\uce58\uba74 \uc9e7\uc740 \uc774\ub3d9\ub3c4 \uccb4\uac10\uc0c1 \uae38\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub798\uc11c \uc678\uacfd \uc77c\uc815\uc740 \ucf54\uc2a4\ub97c \ub9ce\uc774 \ub123\uae30\ubcf4\ub2e4, \ud55c \ubc88 \ub098\uac04 \ub4a4 \uc624\ub798 \uba38\ubb34\ub974\uac70\ub098 \uc544\uc608 \uc219\uc18c \uc8fc\ubcc0\uc5d0\uc11c \ub05d\ub0b4\ub294 \uc2dd\uc73c\ub85c \uc555\ucd95\ud558\ub294 \ud3b8\uc774 \ud6e8\uc52c \uc548\uc815\uc801\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc6b0\ubd93 \uc678\uacfd \uc219\uc18c\ub97c \uace0\ub97c \ub54c \ubd84\uc704\uae30\ub9cc \ubcf4\uba74 \ubd80\uc871\ud55c \uc774\uc720<\/h2>\n<p>\uc0ac\uc9c4\uc0c1 \ubd84\uc704\uae30\uac00 \uc88b\uc544 \ubcf4\uc5ec\ub3c4 \uc2e4\uc81c \uccb4\ub958 \ub9cc\uc871\ub3c4\ub294 \ubcf5\uadc0 \ud3b8\uc758\uc640 \uc8fc\ubcc0 \uc0dd\ud65c \uc778\ud504\ub77c\uc5d0 \ud06c\uac8c \uc88c\uc6b0\ub429\ub2c8\ub2e4. \ub2a6\uc740 \uc800\ub141 \uc2dd\uc0ac \uac00\ub2a5 \uc5ec\ubd80, \ube44\uac00 \uc62c \ub54c \uc774\ub3d9 \ub09c\ub3c4, \uc9d0\uc744 \ub4e4\uace0 \uc774\ub3d9\ud560 \ub54c\uc758 \uc811\uadfc\uc131\uae4c\uc9c0 \uac19\uc774 \ubd10\uc57c \uc219\uc18c \uc120\ud0dd\uc774 \uc815\ud655\ud574\uc9d1\ub2c8\ub2e4. \uc6b0\ubd93 \uc678\uacfd\uc740 \uac10\uc131 \uc219\uc18c\uac00 \ub9ce\uc9c0\ub9cc, \uadf8 \uac10\uc131\uc774 \ubd88\ud3b8\uc744 \uc0c1\uc1c4\ud560 \uc815\ub3c4\uc778\uc9c0\uae4c\uc9c0 \ub530\uc838\uc57c \uc2e4\uc81c \ud3c9\uac00\uac00 \ud754\ub4e4\ub9ac\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc6b0\ubd93 \uc678\uacfd\uc5d0\uc11c \uc2e4\uc81c\ub85c \uc2dc\uac04\uc774 \uc0c8\ub294 \uad6c\uac04<\/h2>\n\n\n\n<p>\uccb4\uac10\uc0c1 \uac00\uc7a5 \uc2dc\uac04\uc774 \uc0c8\ub294 \uad6c\uac04\uc740 \uc678\uacfd \uc219\uc18c\uc5d0\uc11c \uc911\uc2ec\ubd80\ub85c \ub098\uac08 \ub54c\ubcf4\ub2e4, \uc911\uc2ec\ubd80\uc5d0\uc11c \ub2e4\uc2dc \uc678\uacfd \uc219\uc18c\ub85c \ub3cc\uc544\uc62c \ub54c\ub2e4. \uc800\ub141 \uc774\ud6c4 \ucc28\ub7c9 \ub300\uae30\uc640 \ub3c4\ub85c \uccb4\uc99d\uc774 \uacb9\uce58\uba74 \uc9e7\uc740 \uc800\ub141 \uc77c\uc815 \ud558\ub098\uac00 \uc804\uccb4 \ud53c\ub85c\ub97c \ud06c\uac8c \uc62c\ub9b4 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n\n\n<p>\ubc1c\ub9ac \uc6b0\ubd93 \uc678\uacfd\uc740 \uad6c\uacbd\ubcf4\ub2e4 \uc0b0\ucc45\uc774 \uc798 \ub9de\ub294 \uc9c0\uc5ed\uc774\ub2e4. \uc219\uc18c \uc704\uce58, \ucc28\ub7c9 \uc774\ub3d9, \uc57c\uac04 \ubcf5\uadc0, \uc2dd\uc0ac \uac00\ub2a5\uc131\uc744 \uba3c\uc800 \ud655\uc778\ud558\uba74 \ud63c\uc790\uc11c\ub3c4 \ud3b8\uc548\ud55c \ud558\ub8e8\ub97c \ub9cc\ub4e4 \uc218 \uc788\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ubc1c\ub9ac \uc6b0\ubd93 \uc678\uacfd \ud63c\uc790 \uc5ec\ud589\uc744 \uc704\ud55c \uc219\uc18c \uc704\uce58, \ub3c4\ubcf4 \ub3d9\uc120, \ucc28\ub7c9 \uc774\ub3d9