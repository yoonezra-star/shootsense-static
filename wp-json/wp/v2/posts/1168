{"id":1168,"date":"2026-03-02T08:59:00","date_gmt":"2026-03-01T23:59:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1168"},"modified":"2026-06-12T14:06:19","modified_gmt":"2026-06-12T05:06:19","slug":"%ea%b3%84%ed%9a%8d%ec%9d%84-%eb%b2%84%eb%a6%ac%ea%b2%8c-%eb%a7%8c%eb%93%a0-%eb%82%98%ea%b0%80%eb%a5%b4%ec%bd%94%ed%8a%b8%ec%9d%98-%ec%a1%b0%ec%9a%a9%ed%95%9c-%eb%8f%99%eb%84%a4","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ea%b3%84%ed%9a%8d%ec%9d%84-%eb%b2%84%eb%a6%ac%ea%b2%8c-%eb%a7%8c%eb%93%a0-%eb%82%98%ea%b0%80%eb%a5%b4%ec%bd%94%ed%8a%b8%ec%9d%98-%ec%a1%b0%ec%9a%a9%ed%95%9c-%eb%8f%99%eb%84%a4\/","title":{"rendered":"\ub124\ud314 \ub098\uac00\ub974\ucf54\ud2b8 \ud63c\uc790 \uc5ec\ud589: \uacc4\ud68d\uc744 \uc904\uc5ec\uc57c \ubcf4\uc774\ub294 \uc0b0\uc545 \ub9c8\uc744 \uae30\uc900"},"content":{"rendered":"\n<p>\ub098\uac00\ub974\ucf54\ud2b8\ub294 \uacc4\ud68d\uc744 \ub9ce\uc774 \uc138\uc6b8\uc218\ub85d \uc624\ud788\ub824 \ud754\ub4e4\ub9b4 \uc218 \uc788\ub294 \uc0b0\uc545 \ub9c8\uc744\uc774\ub2e4. \uc804\ub9dd\uc740 \ub0a0\uc528\uc5d0 \uc88c\uc6b0\ub418\uace0, \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc219\uc18c \uc704\uce58\uc640 \uc2dd\uc0ac, \uc774\ub3d9 \uc218\ub2e8\uc774 \ub9cc\uc871\ub3c4\ub97c \uacb0\uc815\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ub124\ud314 \ub098\uac00\ub974\ucf54\ud2b8\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c \uac10\uc0c1\uc774 \uc544\ub2c8\ub77c \uad50\ud1b5, \uc219\uc18c, \uc2dd\uc0ac, \ub0a0\uc528, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \ud558\ub8e8\ub97c \uc124\uacc4\ud558\ub294 \ub370 \ucd08\uc810\uc744 \ub454\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub124\ud314 \ub098\uac00\ub974\ucf54\ud2b8 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\ub098\uac00\ub974\ucf54\ud2b8\ub294 \uc804\ub9dd\uc744 \ubcf4\uc7a5\ubc1b\ub294 \ubaa9\uc801\uc9c0\uac00 \uc544\ub2c8\ub77c \ub0a0\uc528\ub97c \uae30\ub2e4\ub9ac\ub294 \uccb4\ub958\uc9c0\uc5d0 \uac00\uae5d\ub2e4. \uc77c\uc815\uc744 \uc904\uc774\uace0 \uc219\uc18c \uc911\uc2ec\uc73c\ub85c \uc6c0\uc9c1\uc77c \ub54c \uc548\uc815\uc801\uc778 \uacbd\ud5d8\uc774 \ub41c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \ubcf4\ub294 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\ud788\ub9d0\ub77c\uc57c \uc804\ub9dd \uae30\ub300, \uc870\uc6a9\ud55c \uc0b0\uc545 \uc219\uc18c \uccb4\ub958, \uc9e7\uc740 \ud734\uc2dd<\/td><td>\uc0ac\uc9c4\ubcf4\ub2e4 \uccb4\ub958 \ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \ub9cc\uc871\ub3c4\uac00 \uc548\uc815\ub41c\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\uce74\ud2b8\ub9cc\ub450 \ucd9c\ubc1c \ucc28\ub7c9, \uc219\uc18c \ud53d\uc5c5, \ub3c4\ub85c \uc0c1\ud0dc \ud655\uc778<\/td><td>\uc678\uacfd\u00b7\uc0b0\uc545 \uc9c0\uc5ed\uc740 \ubcf5\uadc0 \uc218\ub2e8\uc774 \uace7 \uc548\uc804 \uae30\uc900\uc774\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>1\ubc15 \uc774\uc0c1 \uad8c\uc7a5, \uc804\ub9dd \ubaa9\uc801\uc774\uba74 \uc5ec\uc720 \uc2dc\uac04 \ud544\uc694<\/td><td>\ub3c4\ucc29\uc77c\uacfc \ud65c\ub3d9\uc77c\uc744 \ubd84\ub9ac\ud574\uc57c \ud53c\ub85c \ub204\uc801\uc744 \uc904\uc77c \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\uad6c\ub984, \uc548\uac1c, \ub3c4\ub85c \uc0c1\ud0dc, \uc219\uc18c \uc2dd\uc0ac, \ubc24 \uae30\uc628<\/td><td>\ub0a0\uc528, \uae38 \uc0c1\ud0dc, \uc778\uc801, \uc2dd\uc0ac \uac00\ub2a5\uc131\uc774 \uc77c\uc815\uc744 \ubc14\uafbc\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc804\ub9dd\ubcf4\ub2e4 \uc219\uc18c \ub9ac\ub4ec\uc774 \uc911\uc694\ud55c \uc774\uc720<\/h2>\n\n\n\n<p>\ub098\uac00\ub974\ucf54\ud2b8\ub294 \ud63c\uc790 \uc870\uc6a9\ud788 \uc26c\uae30 \uc88b\uc740 \uacf3\uc774\uc9c0\ub9cc, \uc804\ub9dd\ub9cc \ubaa9\ud45c\ub85c \uc7a1\uc73c\uba74 \uc2e4\ub9dd\ud560 \uc218 \uc788\ub2e4. \uc219\uc18c\uc5d0\uc11c \ubcf4\ub0b4\ub294 \uc2dc\uac04\uae4c\uc9c0 \uc5ec\ud589\uc73c\ub85c \ubc1b\uc544\ub4e4\uc77c \uc218 \uc788\uc744 \ub54c \ub9cc\uc871\ub3c4\uac00 \ub192\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uba4b\uc9c4 \uc7a5\uba74\ubcf4\ub2e4 \ud604\uc7a5\uc5d0\uc11c \ubd88\uc548\ud558\uc9c0 \uc54a\uc740 \uad6c\uc870\uac00 \uba3c\uc800\ub2e4. \uc219\uc18c\uc640 \uc2dd\uc0ac, \ubcf5\uadc0 \uae30\uc900\uc774 \uc815\ub9ac\ub418\uc5b4 \uc788\uc73c\uba74 \uc870\uc6a9\ud55c \uc7a5\uc18c\ub3c4 \ucda9\ubd84\ud788 \uc758\ubbf8 \uc788\ub294 \uccb4\ub958\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uce74\ud2b8\ub9cc\ub450\uc5d0\uc11c \ub4e4\uc5b4\uac00\ub294 \uc2dc\uac04\ub300 \ud310\ub2e8<\/h2>\n\n\n\n<p>\uce74\ud2b8\ub9cc\ub450\uc5d0\uc11c \uc774\ub3d9\ud560 \ub54c \ub3c4\ub85c \uc0c1\ud0dc\uc640 \ub3c4\ucc29 \uc2dc\uac04\uc744 \ud655\uc778\ud574\uc57c \ud55c\ub2e4. \ub2a6\uc740 \uc2dc\uac04 \ub3c4\ucc29\uc740 \uc219\uc18c \ucc3e\uae30\uc640 \uc2dd\uc0ac \ubb38\uc81c\uac00 \uc0dd\uae38 \uc218 \uc788\uc73c\ubbc0\ub85c \ubc1d\uc740 \uc2dc\uac04 \uc774\ub3d9\uc774 \uc88b\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc0c1\ud669<\/th><th>\uc704\ud5d8 \uc2e0\ud638<\/th><th>\uad8c\uc7a5 \ub300\uc751<\/th><\/tr><\/thead><tbody><tr><td>\ub2a6\uc740 \ub3c4\ucc29<\/td><td>\uc219\uc18c \uc704\uce58\ub97c \ucc3e\uae30 \uc5b4\ub835\uac70\ub098 \ucc28\ub7c9 \ud638\ucd9c\uc774 \ubd88\uc548\uc815\ud558\ub2e4<\/td><td>\ubc1d\uc740 \uc2dc\uac04 \uccb4\ud06c\uc778\uc744 \uc6b0\uc120\ud558\uace0 \ud53d\uc5c5\uc744 \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\ub0a0\uc528 \ubcc0\ud654<\/td><td>\ube44, \uc548\uac1c, \ubbf8\ub044\ub7ec\uc6b4 \uae38\ub85c \ubcf4\ud589 \uc2dc\uac04\uc774 \ub298\uc5b4\ub09c\ub2e4<\/td><td>\uc678\uacfd \ub3d9\uc120\uc744 \uc904\uc774\uace0 \uc219\uc18c \uc8fc\ubcc0 \uccb4\ub958\ub85c \ubc14\uafbc\ub2e4<\/td><\/tr><tr><td>\uc2dd\uc0ac \uacf5\ubc31<\/td><td>\uc8fc\ubcc0 \uc2dd\ub2f9\uc774 \ub2eb\ud788\uac70\ub098 \uba40\ub2e4<\/td><td>\ub3c4\ucc29 \uc804\uc5d0 \ubb3c, \uac04\uc2dd, \uc219\uc18c \uc2dd\uc0ac \uc5ec\ubd80\ub97c \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\ud1b5\uc2e0 \ubd88\uc548\uc815<\/td><td>\uc9c0\ub3c4\uc640 \ud638\ucd9c \uc11c\ube44\uc2a4\uac00 \ub2a6\uac8c \uc791\ub3d9\ud55c\ub2e4<\/td><td>\uc624\ud504\ub77c\uc778 \uc9c0\ub3c4\uc640 \uc219\uc18c \uc8fc\uc18c\ub97c \uc800\uc7a5\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc548\uac1c\ub97c \uc804\uc81c\ub85c \ud55c \ud558\ub8e8 \ubc30\uce58<\/h2>\n\n\n\n<p>\uccab\ub0a0\uc740 \uc219\uc18c \uccb4\ud06c\uc778\uacfc \uc8fc\ubcc0 \uc0b0\ucc45, \ub2e4\uc74c \ub0a0 \uc544\uce68 \uc804\ub9dd \ud655\uc778 \uc815\ub3c4\ub85c \ub2e8\uc21c\ud558\uac8c \uc7a1\ub294\ub2e4. \ub0a0\uc528\uac00 \ud750\ub9ac\uba74 \uba40\ub9ac \uc774\ub3d9\ud558\uae30\ubcf4\ub2e4 \uc219\uc18c \uc8fc\ubcc0\uc5d0\uc11c \uc26c\ub294 \ubc29\uc2dd\uc73c\ub85c \uc870\uc815\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc77c\uc815\uc740 \ub113\uac8c \ud655\uc7a5\ud558\uae30\ubcf4\ub2e4 \uc219\uc18c\uc640 \uc911\uc2ec \uad6c\uac04\uc744 \uae30\uc900\uc73c\ub85c \uc904\uc77c \uc218 \uc788\uac8c \uc7a1\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ud63c\uc790\ub77c\uba74 \u201c\ub354 \ubcf4\ub294 \uac83\u201d\ubcf4\ub2e4 \u201c\ubb34\ub9ac\ud558\uc9c0 \uc54a\uace0 \ub3cc\uc544\uc624\ub294 \uac83\u201d\uc774 \uc77c\uc815 \ud488\uc9c8\uc744 \uc88c\uc6b0\ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2a5\uc120 \uc219\uc18c\ub97c \uace0\ub97c \ub54c \ubc84\ub9b4 \uac83<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \uc804\ub9dd\ubcf4\ub2e4 \uc2dd\uc0ac \uc81c\uacf5, \ub09c\ubc29, \uc628\uc218, \ucc28\ub7c9 \uc811\uadfc\uc131\uc744 \ud568\uaed8 \ubd10\uc57c \ud55c\ub2e4. \uc678\uacfd \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \ud63c\uc790\uc5d0\uac8c\ub294 \uc2dd\uc0ac\uc640 \uc774\ub3d9\uc774 \uc81c\ud55c\ub420 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc678\uacfd \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \ud63c\uc790\uc5d0\uac8c\ub294 \uc2dd\uc0ac\uc640 \uc57c\uac04 \uc774\ub3d9\uc774 \ubcc0\uc218\ub2e4. \uc219\uc18c\ub97c \uace0\ub97c \ub54c\ub294 \uc804\ub9dd\ubcf4\ub2e4 \uccb4\ud06c\uc778 \uc2dc\uac04, \ud53d\uc5c5 \uac00\ub2a5 \uc5ec\ubd80, \uc8fc\ubcc0 \uc2dd\uc0ac \uac00\ub2a5\uc131\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc800\ub141 \uc2dd\uc0ac \uacf5\ubc31\uc744 \ub9c9\ub294 \ubc29\ubc95<\/h2>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc219\uc18c \uc81c\uacf5 \uc5ec\ubd80\uac00 \uc911\uc694\ud558\ub2e4. \uc8fc\ubcc0 \uc2dd\ub2f9\uc774 \ub9ce\uc9c0 \uc54a\uc744 \uc218 \uc788\uc73c\ubbc0\ub85c \uc800\ub141\uacfc \uc544\uce68 \uc2dd\uc0ac\ub97c \uc219\uc18c\uc5d0\uc11c \ud574\uacb0\ud560 \uc218 \uc788\ub294\uc9c0 \ud655\uc778\ud558\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc77c\uc815\uc758 \ubcf4\uc870\uac00 \uc544\ub2c8\ub77c \uc548\uc804 \uae30\uc900\uc774\ub2e4. \uc2dd\uc0ac \uc2dc\uac04\uc774 \ubc00\ub9ac\uba74 \ud53c\ub85c\uc640 \ud310\ub2e8 \uc2e4\uc218\uac00 \ud568\uaed8 \ub298\uc5b4\ub098\ubbc0\ub85c, \ud63c\uc790\ub77c\uba74 \ub2a6\uc740 \uc2dc\uac04\uae4c\uc9c0 \uc2dd\uc0ac\ub97c \ubbf8\ub8e8\uc9c0 \uc54a\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0b0\uae38\uacfc \uc57c\uac04 \ubcf5\uadc0\ub97c \ub2e4\ub8e8\ub294 \ubc95<\/h2>\n\n\n\n<p>\ub9ac\uc2a4\ud06c\ub294 \ub0a0\uc528\uc640 \uc5b4\ub450\uc6b4 \uc0b0\uae38, \ub3c4\ub85c \uc774\ub3d9\uc5d0\uc11c \uc628\ub2e4. \ud63c\uc790\ub77c\uba74 \ud574\uac00 \uc9c4 \ub4a4 \uc678\uacfd \uc0b0\ucc45\uc744 \ud53c\ud558\uace0, \uc219\uc18c\uc5d0 \ub2e4\uc74c \uc774\ub3d9 \uacc4\ud68d\uc744 \uacf5\uc720\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \uac00\uc7a5 \ud53c\ud574\uc57c \ud560 \uc870\ud569\uc740 \ud53c\ub85c, \uc5b4\ub450\uc6b4 \uae38, \ubd88\ud655\uc2e4\ud55c \ubcf5\uadc0 \uc218\ub2e8\uc774 \ub3d9\uc2dc\uc5d0 \uc0dd\uae30\ub294 \uc0c1\ud669\uc774\ub2e4. \uc14b \uc911 \ud558\ub098\ub77c\ub3c4 \ubcf4\uc774\uba74 \uadf8\ub0a0\uc758 \uc77c\uc815\uc740 \uc904\uc774\ub294 \uac83\uc774 \ub9de\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc804\ub9dd \uae30\ub300 \ube44\uc6a9\uc744 \uc904\uc774\ub294 \uc120\ud0dd<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \ucc28\ub7c9 \uc774\ub3d9\uacfc \uc219\uc18c \uc218\uc900\uc5d0\uc11c \ucc28\uc774\uac00 \ub09c\ub2e4. \uc800\ub834\ud55c \uc219\uc18c\ubcf4\ub2e4 \uc2dd\uc0ac\uc640 \uc774\ub3d9\uc774 \ud3ec\ud568\ub418\uac70\ub098 \uc548\uc815\uc801\uc778 \uacf3\uc774 \uc804\uccb4 \ub9cc\uc871\ub3c4\uc5d0\ub294 \ub354 \uc720\ub9ac\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc219\ubc15\ube44\ub9cc \ube44\uad50\ud558\uba74 \ud310\ub2e8\uc774 \ud2c0\uc5b4\uc9c8 \uc218 \uc788\ub2e4. \uc678\uacfd \uc774\ub3d9\ube44, \ud53d\uc5c5 \ube44\uc6a9, \uc2dd\uc0ac \ud3ec\ud568 \uc5ec\ubd80, \ub0a0\uc528 \ub54c\ubb38\uc5d0 \uc0dd\uae30\ub294 \ub300\uccb4 \uad50\ud1b5\ube44\uae4c\uc9c0 \ud568\uaed8 \ubd10\uc57c \uc2e4\uc81c \ube44\uc6a9\uc774 \ubcf4\uc778\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\uac00\ub974\ucf54\ud2b8\uc5d0\uc11c \uc2e4\ud328\ud558\ub294 \ub2f9\uc77c\uce58\uae30 \ud328\ud134<\/h2>\n\n\n\n<p>\ub098\uac00\ub974\ucf54\ud2b8\ub97c \ub2f9\uc77c\ub85c \ube60\ub974\uac8c \ub2e4\ub140\uc624\uba70 \uc804\ub9dd\ub9cc \uae30\ub300\ud558\ub294 \uc77c\uc815\uc740 \ud53c\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ub0a0\uc528\uac00 \ub9de\uc9c0 \uc54a\uc73c\uba74 \uc774\ub3d9 \ud53c\ub85c\ub9cc \ub0a8\uc744 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uae30\ub2e4\ub9ac\ub294 \uc2dc\uac04\uc744 \uacac\ub51c \uc218 \uc788\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\ud48d\uacbd\uc744 \uae30\ub2e4\ub9ac\ub294 \ub290\ub9b0 \uc2dc\uac04\uc744 \ubc1b\uc544\ub4e4\uc77c \uc218 \uc788\uace0, \uc870\uc6a9\ud55c \uc0b0\uc545 \uc219\uc18c\uc5d0\uc11c \uc26c\uace0 \uc2f6\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\uac00\ub974\ucf54\ud2b8 \uc77c\uc815\uc740 \ube44\uc6b0\ub294 \ucabd\uc774 \ub9de\ub2e4<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\ub098\uac00\ub974\ucf54\ud2b8\uc5d0\uc11c \ub0a0\uc528 \uc6b4\uc5d0\ub9cc \uae30\ub300\uba74 \ud754\ub4e4\ub9ac\ub294 \uc774\uc720<\/h2>\n<p>\ub098\uac00\ub974\ucf54\ud2b8\ub294 \uc804\ub9dd\uc774 \ud575\uc2ec\ucc98\ub7fc \ubcf4\uc774\uc9c0\ub9cc \uc2e4\uc81c \ub9cc\uc871\ub3c4\ub294 \ub0a0\uc528 \ud558\ub098\ub85c \uacb0\uc815\ub418\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uc548\uac1c\ub098 \ud750\ub9bc\uc774 \uc788\uc5b4\ub3c4 \uc219\uc18c\uc5d0\uc11c \uc26c\ub294 \uc2dc\uac04, \uc9e7\uac8c \uac77\ub294 \ubc18\uacbd, \uc800\ub141 \uc774\ud6c4\uc758 \uc815\ub9ac \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\uba74 \uccb4\ub958 \uacbd\ud5d8\uc740 \ucda9\ubd84\ud788 \uc88b\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \ubaa8\ub4e0 \uae30\ub300\ub97c \uc870\ub9dd \ud55c \ubc88\uc5d0 \uac78\uc5b4\ub450\uba74, \uc804\ub9dd\uc774 \ud750\ub9b0 \uc21c\uac04 \uc77c\uc815 \uc804\uccb4\uac00 \uc2e4\ud328\ucc98\ub7fc \ub290\uaef4\uc9c8 \uac00\ub2a5\uc131\uc774 \ud07d\ub2c8\ub2e4. \uadf8\ub798\uc11c \ub098\uac00\ub974\ucf54\ud2b8\ub294 \ud48d\uacbd \uae30\ub300\ub97c \ub0ae\ucd94\uace0 \uccb4\ub958 \uad6c\uc870\ub97c \uba3c\uc800 \ub9de\ucd94\ub294 \ud3b8\uc774 \ub0ab\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub098\uac00\ub974\ucf54\ud2b8 1\ubc15\uc774 \uc758\ubbf8 \uc788\uc73c\ub824\uba74 \ud544\uc694\ud55c \ucd5c\uc18c \uc870\uac74<\/h2>\n<p>1\ubc15 \uac00\uce58\uac00 \uc0dd\uae30\ub824\uba74 \ub2e8\uc21c\ud788 \uc219\ubc15\ub9cc \ud558\ub294 \uac83\uc774 \uc544\ub2c8\ub77c, \uc800\ub141\ubd80\ud130 \ub2e4\uc74c \ub0a0 \uc624\uc804\uae4c\uc9c0\uc758 \ub9ac\ub4ec\uc774 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc774\uc5b4\uc838\uc57c \ud569\ub2c8\ub2e4. \uc219\uc18c\uc5d0\uc11c \ubc14\ub85c \uc26c\uc5b4\ub3c4 \ub2f5\ub2f5\ud558\uc9c0 \uc54a\uc740\uc9c0, \uc2dd\uc0ac \uacf5\ubc31\uc774 \ud06c\uc9c0 \uc54a\uc740\uc9c0, \uc0c8\ubcbd\uc774\ub098 \uc544\uce68 \uc2dc\uac04\uc744 \ubb34\ub9ac \uc5c6\uc774 \uc0ac\uc6a9\ud560 \uc218 \uc788\ub294\uc9c0\uac00 \ud575\uc2ec\uc785\ub2c8\ub2e4. \uc774 \uc870\uac74\uc774 \ub9de\uc9c0 \uc54a\uc73c\uba74 1\ubc15\uc740 \ub0ad\ub9cc\uc774 \uc544\ub2c8\ub77c \uc774\ub3d9 \ubd80\ub2f4\uc73c\ub85c \ub05d\ub0a0 \uc218 \uc788\uace0, \uc624\ud788\ub824 \uce74\ud2b8\ub9cc\ub450\ub098 \ub2e4\ub978 \uac70\uc810\uc5d0\uc11c \uc77c\uc815\uc744 \uc870\uc815\ud558\ub294 \ud3b8\uc774 \ub354 \ub098\uc740 \uc120\ud0dd\uc774 \ub429\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub098\uac00\ub974\ucf54\ud2b8\uc5d0\uc11c \uc804\ub9dd\ubcf4\ub2e4 \uba3c\uc800 \ud655\uc778\ud560 \uac83<\/h2>\n\n\n\n<p>\uc774 \uc9c0\uc5ed\uc740 \ud48d\uacbd \uc790\uccb4\ubcf4\ub2e4 \uc219\uc18c\uc5d0\uc11c \uc804\ub9dd \uc9c0\uc810\uae4c\uc9c0 \uc5b4\ub5bb\uac8c \uc6c0\uc9c1\uc774\uace0, \ud750\ub9b0 \ub0a0\uc5d0 \ubb34\uc5c7\uc744 \ud558\uba70, \uc800\ub141 \uc2dd\uc0ac\ub97c \uc5b4\ub514\uc11c \ub05d\ub0bc\uc9c0\ub97c \uba3c\uc800 \uc815\ud574\uc57c \ub9cc\uc871\ub3c4\uac00 \uc62c\ub77c\uac04\ub2e4. \uc804\ub9dd\uc774 \uc548 \ubcf4\uc774\ub294 \ub0a0\uc5d0\ub3c4 \uc77c\uc815\uc774 \ubb34\ub108\uc9c0\uc9c0 \uc54a\ub294 \uad6c\uc870\ub97c \ub9cc\ub4e4\uc5b4\ub450\ub294 \uac83\uc774 \ud575\uc2ec\uc774\ub2e4.<\/p>\n\n\n\n\n\n<p>\ub124\ud314 \ub098\uac00\ub974\ucf54\ud2b8\ub294 \uacc4\ud68d\uc744 \uc904\uc5ec\uc57c \uc7a5\uc810\uc774 \ubcf4\uc774\ub294 \uc0b0\uc545 \ub9c8\uc744\uc774\ub2e4. \ub0a0\uc528, \uc219\uc18c \uc2dd\uc0ac, \ucc28\ub7c9 \uc774\ub3d9, \ub3c4\ucc29 \uc2dc\uac04\uc744 \uba3c\uc800 \uc815\ud558\uba74 \ud63c\uc790\uc11c\ub3c4 \uc548\uc815\uc801\uc778 \ud734\uc2dd \uc77c\uc815\uc774 \ub41c\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ub124\ud314 \ub098\uac00\ub974\ucf54\ud2b8 \ud63c\uc790 \uc5ec\ud589\uc744 \uc704\ud55c \uc804\ub9dd, \uc219\uc18c \uc704\uce58, \ub0a0\uc528, \ucc28\ub7c9 \uc774\ub3d9, \uc2dd\uc0ac\uc640 \uc548\uc804 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc2e4\uc804 \uac00\uc774\ub4dc.<\/p>\n","protected":false},"author":1,"featured_media":1169,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"tablet":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-color":"","overlay-opacity":"","overlay-gradient":""},"mobile":{"background-color":"","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","ov