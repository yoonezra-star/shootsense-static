{"id":1231,"date":"2026-04-02T10:23:00","date_gmt":"2026-04-02T01:23:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1231"},"modified":"2026-06-12T11:47:34","modified_gmt":"2026-06-12T02:47:34","slug":"%ec%97%ac%ed%96%89%ea%b3%bc-%ec%83%9d%ed%99%9c%ec%9d%98-%ea%b2%bd%ea%b3%84%ea%b0%80-%ed%9d%90%eb%a0%a4%ec%a7%84-%eb%82%98%ec%bd%98%ec%8b%9c%ed%83%90%eb%a7%88%eb%9e%8f","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%97%ac%ed%96%89%ea%b3%bc-%ec%83%9d%ed%99%9c%ec%9d%98-%ea%b2%bd%ea%b3%84%ea%b0%80-%ed%9d%90%eb%a0%a4%ec%a7%84-%eb%82%98%ec%bd%98%ec%8b%9c%ed%83%90%eb%a7%88%eb%9e%8f\/","title":{"rendered":"\ud0dc\uad6d \ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f \ud63c\uc790 \uc5ec\ud589: \uc0dd\ud65c\uad8c\ucc98\ub7fc \uac77\ub294 \ub0a8\ubd80 \ub3c4\uc2dc \uae30\uc900"},"content":{"rendered":"\n<p>\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc740 \ud0dc\uad6d \ub0a8\ubd80\uc758 \uc720\uba85 \ud734\uc591\uc9c0\ucc98\ub7fc \uc989\uc2dc \uc18c\ube44\ub418\ub294 \ubaa9\uc801\uc9c0\ub294 \uc544\ub2c8\ub2e4. \ub300\uc2e0 \uc2dc\ub0b4\uc640 \uc0ac\uc6d0, \uc2dc\uc7a5, \uc0dd\ud65c\uad8c\uc774 \uac00\uae4c\uc774 \uc788\uc5b4 \ud63c\uc790 \ucc9c\ucc9c\ud788 \uac78\uc744\uc218\ub85d \ub3c4\uc2dc\uc758 \uc18d\ub3c4\uac00 \ubcf4\uc778\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ud0dc\uad6d \ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c\ud55c \uac10\uc0c1\uc774\ub098 \ucd94\ucc9c \ubaa9\ub85d\uc774 \uc544\ub2c8\ub77c \uad50\ud1b5, \uc219\uc18c, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \ud558\ub8e8\ub97c \uc124\uacc4\ud558\ub294 \ub370 \ucd08\uc810\uc744 \ub454\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud0dc\uad6d \ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\uc774 \ub3c4\uc2dc\ub294 \uba85\uc18c \uac1c\uc218\ubcf4\ub2e4 \uc0dd\ud65c \ub3d9\uc120\uc758 \uc548\uc815\uc131\uc774 \uc911\uc694\ud558\ub2e4. \uc219\uc18c\ub97c \uc2dc\ub0b4 \uc811\uadfc\uc131\uc774 \uc88b\uc740 \uacf3\uc5d0 \uc7a1\uace0, \ub0ae \uc2dc\uac04\uc5d0 \ud575\uc2ec \uad6c\uac04\uc744 \ubcf8 \ub4a4 \uc800\ub141\uc5d0\ub294 \uc911\uc2ec\ubd80\ub85c \ub3d9\uc120\uc744 \uc904\uc774\ub294 \ubc29\uc2dd\uc774 \ub9de\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \uc911\uc694\ud55c \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\ub0a8\ubd80 \ud0dc\uad6d \uc0dd\ud65c\uad8c \uc0b0\ucc45, \uc0ac\uc6d0 \ubc29\ubb38, \uc2dc\uc7a5\uacfc \uc2dc\ub0b4 \uccb4\ub958<\/td><td>\ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \uc870\uc6a9\ud55c \uc2dc\uac04\uc744 \uc2e4\ud328\ub85c \ubcf4\uc9c0 \uc54a\ub294\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\uacf5\ud56d, \uae30\ucc28\uc5ed, \ubc84\uc2a4\ud130\ubbf8\ub110\uacfc \uc219\uc18c \uc774\ub3d9 \ubc29\ubc95 \ud655\uc778<\/td><td>\ud63c\uc790 \uc774\ub3d9\ud560 \ub54c\ub294 \ud658\uc2b9\uacfc \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc9c1\uc811 \uad00\ub9ac\ud574\uc57c \ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>1\ubc15 \uc774\uc0c1 \uad8c\uc7a5, \uc774\ub3d9 \uc804\ud6c4 \ud558\ub8e8\ub97c \uc5ec\uc720 \uc788\uac8c \ubc30\uce58<\/td><td>\ub3c4\ucc29 \uc2dc\uac04\uacfc \uc2dd\uc0ac \uc2dc\uac04\uc5d0 \ub530\ub77c \uccb4\uac10 \ub9cc\uc871\ub3c4\uac00 \ud06c\uac8c \ubc14\ub010\ub2e4<\/td><\/tr><tr><td>\ud575\uc2ec \ubcc0\uc218<\/td><td>\ub354\uc704, \ube44, \uc800\ub141 \uc774\ub3d9, \ud604\uc9c0 \uad50\ud1b5 \ud638\ucd9c \uac00\ub2a5 \uc5ec\ubd80<\/td><td>\uc791\uc740 \ubaa9\uc801\uc9c0\ub294 \ub0a0\uc528, \ud734\ubb34, \uad50\ud1b5 \uac04\uaca9\uc758 \uc601\ud5a5\uc774 \ud06c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc774 \ud63c\ud589\uc5d0 \ud3b8\ud55c \uad6c\uc870\uc778 \uc774\uc720<\/h2>\n\n\n\n<p>\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \uad00\uad11\uac1d \ud750\ub984\uc5d0 \ub04c\ub824\ub2e4\ub2c8\uc9c0 \uc54a\uace0 \uc790\uae30 \uc18d\ub3c4\ub85c \uc6c0\uc9c1\uc774\uae30 \uc88b\uc740 \ub3c4\uc2dc\ub2e4. \ub2e4\ub9cc \ub300\ub3c4\uc2dc\ud615 \ud3b8\uc758\uac00 \ud56d\uc0c1 \ucd18\ucd18\ud55c \uac83\uc740 \uc544\ub2c8\ubbc0\ub85c \uc774\ub3d9 \uae30\uc900\uc744 \uba3c\uc800 \uc7a1\uc544\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uad00\uad11\uc9c0\uc758 \uc720\uba85\ub3c4\ubcf4\ub2e4 \ud63c\uc790 \uc788\uc5b4\ub3c4 \uc2dc\uac04\uc774 \uc790\uc5f0\uc2a4\ub7fd\uac8c \ud750\ub974\ub294\uc9c0\uac00 \ub354 \uc911\uc694\ud558\ub2e4. \uc0ac\ub78c\uc774 \ub9ce\uc9c0 \uc54a\uc740 \ubaa9\uc801\uc9c0\ub294 \uacc4\ud68d\uc774 \uc57d\ud558\uba74 \uc2ec\uc2ec\ud574\uc9c0\uc9c0\ub9cc, \uae30\uc900\uc810\uc744 \uc7a1\uc73c\uba74 \uc624\ud788\ub824 \ud3b8\uc548\ud55c \uccb4\ub958\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc740 \ub9c9\ucc28\ubcf4\ub2e4 \uadc0\uac00 \uc2dc\uac04\ub300\ub97c \uba3c\uc800 \uc815\ud55c\ub2e4<\/h2>\n\n\n\n<p>\ub3c4\ucc29 \uc9c0\uc810\uc774 \uacf5\ud56d\uc778\uc9c0 \uae30\ucc28\uc5ed\uc778\uc9c0 \ubc84\uc2a4\ud130\ubbf8\ub110\uc778\uc9c0\uc5d0 \ub530\ub77c \uccab \ub3d9\uc120\uc774 \ub2ec\ub77c\uc9c4\ub2e4. \ub2a6\uc740 \uc2dc\uac04 \ub3c4\ucc29\uc774\ub77c\uba74 \uc219\uc18c\uae4c\uc9c0\uc758 \uc774\ub3d9 \uc218\ub2e8\uacfc \uccb4\ud06c\uc778 \uac00\ub2a5 \uc2dc\uac04\uc744 \uba3c\uc800 \ud655\uc778\ud558\ub294 \uac83\uc774 \uc548\uc804\ud558\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uad6c\uac04<\/th><th>\uba3c\uc800 \ud655\uc778\ud560 \uac83<\/th><th>\ud604\uc7a5 \ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ucd9c\ubc1c \uc804<\/td><td>\uacf5\uc2dd \uad50\ud1b5\ud3b8\uacfc \ub9c8\uc9c0\ub9c9 \ubcf5\uadc0 \uc2dc\uac04<\/td><td>\ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \uc801\uc73c\uba74 \uc77c\uc815 \uc804\uccb4\ub97c \uc55e\ub2f9\uae34\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \uc815\ub958\uc7a5, \uc219\uc18c, \uc911\uc2ec \uac70\ub9ac \uc704\uce58<\/td><td>\uae38\uc744 \uc783\uc5c8\uc744 \ub54c \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\ub0ae \uc2dc\uac04<\/td><td>\ub300\ud45c \uc0b0\ucc45 \uad6c\uac04\uacfc \uc2dd\uc0ac \ud6c4\ubcf4<\/td><td>\uac00\uc7a5 \ubc1d\uace0 \uc774\ub3d9\ud558\uae30 \uc26c\uc6b4 \uc2dc\uac04\uc5d0 \ud575\uc2ec \uad6c\uac04\uc744 \ubcf8\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4 \ud6c4\ubc18<\/td><td>\uc778\uc801, \uc870\uba85, \ub2e4\uc74c \uc774\ub3d9\ud3b8<\/td><td>\ud63c\uc790\ub77c\uba74 \ud574\uc9c0\uae30 \uc804 \ubcf5\uadc0 \ud750\ub984\uc744 \ud655\uc815\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f \ud558\ub8e8\ub294 \uc2dc\uc7a5\uacfc \uac15\ubcc0 \uc911\uc2ec\uc73c\ub85c \ubb36\ub294\ub2e4<\/h2>\n\n\n\n<p>\uccab\ub0a0\uc740 \uc219\uc18c \uc8fc\ubcc0, \uc2dc\uc7a5, \uc2dd\uc0ac \uc9c0\uc810\uc744 \ud655\uc778\ud558\uace0 \ub2e4\uc74c \ub0a0 \ub0ae\uc5d0 \uc0ac\uc6d0\uacfc \uc911\uc2ec\ubd80 \uc0b0\ucc45\uc744 \ubc30\uce58\ud558\ub294 \uac83\uc774 \uc88b\ub2e4. \ub354\uc6b4 \uc2dc\uac04\uc5d0\ub294 \uae34 \ub3c4\ubcf4 \uc774\ub3d9\ubcf4\ub2e4 \uce74\ud398\ub098 \uc219\uc18c \ud734\uc2dd\uc744 \ub123\ub294 \ud3b8\uc774 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<p>\uc5ec\ub7ec \uc9c0\uc810\uc744 \ube60\ub974\uac8c \uc5f0\uacb0\ud558\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \uc911\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \uc815\ud574 \ubc18\ubcf5\ud574\uc11c \uac77\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\ub2e4. \ud63c\uc790\ub77c\uba74 \uc77c\uc815\uc744 \ub113\ud788\ub294 \uac83\ubcf4\ub2e4 \uc904\uc77c \uc218 \uc788\ub294 \uad6c\uc870\ub97c \ub9cc\ub4dc\ub294 \uac83\uc774 \ub354 \uc911\uc694\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f \uc219\uc18c\ub294 \uc57c\uc2dc\uc7a5 \uc811\uadfc\uc131\ubd80\ud130 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \uc2dc\ub0b4 \uc911\uc2ec\ubd80, \uc2dd\ub2f9 \uc811\uadfc\uc131, \ucc28\ub7c9 \ud638\ucd9c \uac00\ub2a5\uc131\uc744 \ud568\uaed8 \ubd10\uc57c \ud55c\ub2e4. \uc678\uacfd \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \ud63c\uc790 \uc800\ub141\uc5d0 \uc774\ub3d9\ud558\uae30 \ubd88\ud3b8\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \uac00\uaca9\ubcf4\ub2e4 \ubcf5\uadc0 \ub3d9\uc120\uacfc \uc2dd\uc0ac \uc811\uadfc\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc870\uc6a9\ud55c \uc678\uacfd \uc219\uc18c\uac00 \ub9e4\ub825\uc801\uc73c\ub85c \ubcf4\uc5ec\ub3c4 \ubc24 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud558\uba74 \ud63c\uc790 \uc5ec\ud589\uc758 \ud53c\ub85c\uac00 \ud06c\uac8c \ub298\uc5b4\ub09c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc5d0\uc11c \uc26c\ub294 \ud0c0\uc774\ubc0d\uacfc \uc2dd\uc0ac \uc704\uce58<\/h2>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc2dc\uc7a5\uacfc \uc2dc\ub0b4 \uc2dd\ub2f9\uc744 \uc911\uc2ec\uc73c\ub85c \uc7a1\uc73c\uba74 \uc120\ud0dd\uc9c0\uac00 \ub113\ub2e4. \ub2e4\ub9cc \ub354\uc6b4 \uc9c0\uc5ed\uc774\ubbc0\ub85c \ubb3c\uc744 \ucda9\ubd84\ud788 \uc900\ube44\ud558\uace0, \uc704\uc0dd\uc774 \uc560\ub9e4\ud55c \uacf3\uc5d0\uc11c\ub294 \ubb34\ub9ac\ud558\uc9c0 \uc54a\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub3c4\uc2dc\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc218\ubcf4\ub2e4 \uc601\uc5c5 \uc2dc\uac04\uacfc \uc26c\ub294 \ub0a0 \ud655\uc778\uc774 \uc911\uc694\ud558\ub2e4. \ud63c\uc790\ub77c\uba74 \uae34 \ub300\uae30\ub97c \ud53c\ud558\uae30 \uc704\ud574 \uc810\uc2ec \ud6c4\ubcf4\uc640 \uc26c\uc5b4\uac08 \uc7a5\uc18c\ub97c \ub530\ub85c \ud655\ubcf4\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc740 \ub354\uc704\uc640 \uc774\ub3d9 \uacf5\ubc31\uc744 \uba3c\uc800 \uad00\ub9ac\ud55c\ub2e4<\/h2>\n\n\n\n<p>\ub3c4\uc2dc \uc790\uccb4\ubcf4\ub2e4 \ub354\uc704\uc640 \ub2a6\uc740 \uc2dc\uac04 \uc774\ub3d9\uc774 \ubcc0\uc218\ub2e4. \ub0ae\uc5d0\ub294 \uadf8\ub298\uacfc \ud734\uc2dd\uc744 \uc790\uc8fc \ub123\uace0, \ubc24\uc5d0\ub294 \uc911\uc2ec \uac70\ub9ac\uc640 \uc219\uc18c \uc8fc\ubcc0\uc73c\ub85c \ub3d9\uc120\uc744 \uc81c\ud55c\ud558\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc758 \uc548\uc804\uc740 \uc704\ud5d8\ud55c \uc7a5\uc18c\ub97c \ud53c\ud558\ub294 \uac83\ub9cc\uc774 \uc544\ub2c8\ub77c, \ud53c\uace4\ud574\uc84c\uc744 \ub54c \ubc14\ub85c \uc77c\uc815\uc744 \uc904\uc77c \uc218 \uc788\ub294 \uad6c\uc870\ub97c \ub9cc\ub4dc\ub294 \uac83\uc774\ub2e4. \uc911\uc2ec \uac70\ub9ac\uc640 \uad50\ud1b5 \uac70\uc810\uc744 \uacc4\uc18d \uc758\uc2dd\ud558\uba74 \ud604\uc7a5 \ud310\ub2e8\uc774 \uc26c\uc6cc\uc9c4\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc5d0\uc11c \ub3c8\uacfc \uc2dc\uac04\uc744 \uc4f0\ub294 \uc6b0\uc120\uc21c\uc704<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc219\ubc15\uacfc \uc9c0\uc5ed \uc774\ub3d9\ube44 \uc911\uc2ec\uc73c\ub85c \uacc4\uc0b0\ud558\uba74 \ub41c\ub2e4. \ud734\uc591\uc9c0\ubcf4\ub2e4 \uc18c\ube44 \uc555\ubc15\uc740 \ub0ae\uc9c0\ub9cc, \uad50\ud1b5\uc744 \uc989\ud765\uc801\uc73c\ub85c \uc4f0\uba74 \uc608\uc0c1\ubcf4\ub2e4 \ube44\uc6a9\uc774 \ub298 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uc774\ub3d9 \ubc29\uc2dd\uacfc \uc219\uc18c \uc704\uce58\uc5d0\uc11c \ub354 \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \ub2f9\uc77c\uce58\uae30\ub294 \ube44\uc6a9\uc774 \ub0ae\uc9c0\ub9cc \uccb4\ub958 \uc2dc\uac04\uc774 \uc9e7\uace0, 1\ubc15\uc740 \ube44\uc6a9\uc774 \ub298\uc9c0\ub9cc \uac00\uc7a5 \uc870\uc6a9\ud55c \uc2dc\uac04\ub300\ub97c \ubcfc \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0a8\ubd80 \ud0dc\uad6d \ub3c4\uc2dc\uc5d0\uc11c \uad00\uad11\uc9c0\ubcf4\ub2e4 \uc911\uc694\ud55c \uc2dc\uac04\ub300<\/h2>\n\n\n\n<p>\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f \uac19\uc740 \ub0a8\ubd80 \ub3c4\uc2dc\ub294 \uba85\uc18c\ubcf4\ub2e4 \uc2dc\uac04\ub300\uac00 \ub354 \uc911\uc694\ud569\ub2c8\ub2e4. \ub0ae \ub354\uc704\uac00 \uac15\ud55c \uc2dc\uac04, \uc2dc\uc7a5\uacfc \uc2dd\ub2f9\uc774 \uc0b4\uc544\ub098\ub294 \uc2dc\uac04, \uc0ac\uc6d0 \ubc29\ubb38\uc774 \ub35c \ud53c\uace4\ud55c \uc2dc\uac04\ub300\uac00 \ubd84\uba85\ud558\uac8c \uac08\ub9bd\ub2c8\ub2e4. \uadf8\ub798\uc11c \uc774 \ub3c4\uc2dc\ub294 \u201c\uc5b4\ub514\ub97c \ubcf4\ub290\ub0d0\u201d\ubcf4\ub2e4 \u201c\uc5b8\uc81c \uc6c0\uc9c1\uc774\ub290\ub0d0\u201d\uac00 \ud6e8\uc52c \uc911\uc694\ud55c \uc9c0\uc5ed\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc5d0\uc11c \ubb34\ub9ac\ub418\ub294 \uc77c\uc815 \ud328\ud134<\/h2>\n\n\n\n<p>\ub3c4\ucc29 \ub2f9\uc77c\uc5d0 \uba40\ub9ac \uc774\ub3d9\ud558\uac70\ub098 \ub0ae \ub354\uc704 \uc18d\uc5d0\uc11c \uae34 \ub3c4\ubcf4 \uc77c\uc815\uc744 \ub123\ub294 \uac83\uc740 \ud53c\ud574\uc57c \ud55c\ub2e4. \ub0a8\ubd80 \ub3c4\uc2dc \uc5ec\ud589\uc740 \uccb4\ub825 \uad00\ub9ac\uac00 \uc77c\uc815 \ud488\uc9c8\uc744 \ud06c\uac8c \uc88c\uc6b0\ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc774 \uc798 \ub9de\ub294 \ud63c\ud589 \uc2a4\ud0c0\uc77c<\/h2>\n\n\n\n<p>\ud0dc\uad6d\uc744 \ud574\ubcc0\uc774\ub098 \ub300\ub3c4\uc2dc\uac00 \uc544\ub2c8\ub77c \uc0dd\ud65c\uad8c\uc758 \uc18d\ub3c4\ub85c \ubcf4\uace0 \uc2f6\uc740 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \ud63c\uc790 \uc870\uc6a9\ud788 \uac77\uace0 \uc2dc\uc7a5\uacfc \uc2dc\ub0b4 \ubd84\uc704\uae30\ub97c \uad00\ucc30\ud558\ub294 \uc0ac\ub78c\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f \uccb4\ub958\uc758 \ucd5c\uc885 \uae30\uc900<\/h2>\n\n\n\n<p>\ud0dc\uad6d \ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f\uc740 \ub208\uc5d0 \ub744\ub294 \uad00\uad11\uc9c0\ub9cc \ucc3e\uc73c\uba74 \ud3c9\ubc94\ud574 \ubcf4\uc77c \uc218 \uc788\uc9c0\ub9cc, \uc219\uc18c\uc640 \ub3d9\uc120\uc744 \uc798 \uc7a1\uc73c\uba74 \ud63c\uc790 \uba38\ubb3c\uae30 \uc88b\uc740 \ub0a8\ubd80 \ub3c4\uc2dc\uac00 \ub41c\ub2e4. \ub354\uc704, \uc774\ub3d9, \uc2dd\uc0ac \uc2dc\uac04\uc744 \uae30\uc900\uc73c\ub85c \uc124\uacc4\ud558\ub294 \uac83\uc774 \ud575\uc2ec\uc774\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ud0dc\uad6d \ub098\ucf58\uc2dc\ud0d0\ub9c8\ub78f \ud63c\uc790 \uc5ec\ud589\uc744 \uc704\ud55c \uad50\ud1b5, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac, \uc0ac\uc6d0\uacfc \uc2dc\ub0b4 \ub3d9\uc120, \uc548\uc804 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc2e4\uc804 \uac00\uc774\ub4dc.<\/p>\n","protected":false},"author":1,"featured_media":1232,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position":"center center","background-size":"auto","background-attachment":"scroll","background-type":"","background-media":"","overlay-type":"","overlay-