{"id":1165,"date":"2026-03-08T20:55:13","date_gmt":"2026-03-08T11:55:13","guid":{"rendered":"https:\/\/shootsense.com\/?p=1165"},"modified":"2026-06-12T14:10:25","modified_gmt":"2026-06-12T05:10:25","slug":"%ea%b4%80%ea%b4%91-%ec%bd%94%ec%8a%a4%ea%b0%80-%ec%97%86%ec%96%b4-%ec%9e%90%ec%9c%a0%eb%a1%9c%ec%9b%a0%eb%8d%98-%ec%8b%9c%eb%9d%bc%ec%b9%b4%ec%99%80%ea%b3%a0-%ec%9d%b8%ea%b7%bc-%eb%a7%88%ec%9d%84","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ea%b4%80%ea%b4%91-%ec%bd%94%ec%8a%a4%ea%b0%80-%ec%97%86%ec%96%b4-%ec%9e%90%ec%9c%a0%eb%a1%9c%ec%9b%a0%eb%8d%98-%ec%8b%9c%eb%9d%bc%ec%b9%b4%ec%99%80%ea%b3%a0-%ec%9d%b8%ea%b7%bc-%eb%a7%88%ec%9d%84\/","title":{"rendered":"\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744 \ud63c\uc790 \uc5ec\ud589: \uad00\uad11 \ucf54\uc2a4 \ubc16\uc5d0\uc11c \uc5ec\uc720 \ucc3e\ub294 \ubc95"},"content":{"rendered":"\n<p>\uc2dc\ub77c\uce74\uc640\uace0\ub294 \ub300\ud45c \uad00\uad11\uc9c0 \uc774\ubbf8\uc9c0\uac00 \uac15\ud558\uc9c0\ub9cc, \uc778\uadfc \ub9c8\uc744\uae4c\uc9c0 \uc2dc\uc57c\ub97c \ub113\ud788\uba74 \ud6e8\uc52c \uc870\uc6a9\ud55c \uc5ec\ud589\uc774 \uac00\ub2a5\ud558\ub2e4. \ub2e4\ub9cc \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uad50\ud1b5\uacfc \ub0a0\uc528 \ubcc0\uc218\ub97c \uba3c\uc800 \uacc4\uc0b0\ud574\uc57c \uc790\uc720\ub85c\uc6c0\uc774 \uc2e4\uc81c \uc5ec\uc720\ub85c \uc774\uc5b4\uc9c4\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc815\ubcf4\ud615 \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c \uac10\uc0c1\ubcf4\ub2e4 \uad50\ud1b5, \uccb4\ub958 \uc2dc\uac04, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \uc2e4\uc81c \uc77c\uc815\uc744 \uc9e4 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud588\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\uc2dc\ub77c\uce74\uc640\uace0 \uc8fc\ubcc0\uc740 \uacc4\uc808\uc5d0 \ub530\ub77c \uacbd\ud5d8\uc774 \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \ud2b9\ud788 \uaca8\uc6b8\uacfc \ube44 \uc624\ub294 \ub0a0\uc5d0\ub294 \uc774\ub3d9 \ub09c\ub3c4\uac00 \uc62c\ub77c\uac00\ubbc0\ub85c, \ub3d9\uc120\uc744 \uc9e7\uac8c \uc7a1\uace0 \ubcf5\uadc0 \uae30\uc900\uc744 \ubd84\uba85\ud788 \ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud655\uc778 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uc2dc\ub77c\uce74\uc640\uace0 \uc8fc\ubcc0 \uc0b0\ucc45, \uc870\uc6a9\ud55c \ub9c8\uc744 \uccb4\ub958, \uacc4\uc808 \ud48d\uacbd \uac10\uc0c1<\/td><td>\ubaa9\uc801\uc774 \ubaa8\ud638\ud558\uba74 \uc870\uc6a9\ud55c \uc7a5\uc18c\ub97c \ubcfc\uac70\ub9ac \ubd80\uc871\uc73c\ub85c \uc624\ud574\ud558\uae30 \uc27d\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\uace0\uc18d\ubc84\uc2a4, \uc9c0\uc5ed \ubc84\uc2a4, \uc219\uc18c \uc154\ud2c0 \uac00\ub2a5 \uc5ec\ubd80 \ud655\uc778<\/td><td>\uc77c\ubcf8 \uc9c0\ubc29 \uc5ec\ud589\uc740 \ub9c9\ucc28\uc640 \ud658\uc2b9 \uc2dc\uac04\uc774 \uc77c\uc815 \uc804\uccb4\ub97c \uc88c\uc6b0\ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ub2f9\uc77c\uce58\uae30 \uac00\ub2a5, \uc5ec\uc720 \uc788\uac8c \ubcf4\ub824\uba74 1\ubc15\uc774 \uc548\uc815\uc801<\/td><td>\uc9e7\uac8c \ubcfc\uc9c0, \ubc18\ub098\uc808 \uba38\ubb3c\uc9c0, 1\ubc15\ud560\uc9c0\uc5d0 \ub530\ub77c \ub9cc\uc871\ub3c4\uac00 \ub2ec\ub77c\uc9c4\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\ub208, \ube44, \ubc84\uc2a4 \uc608\uc57d, \uc219\uc18c \uc704\uce58, \uc2dd\ub2f9 \uc6b4\uc601 \uc2dc\uac04<\/td><td>\ub0a0\uc528, \uc601\uc5c5\uc77c, \uad50\ud1b5 \uac04\uaca9\uc744 \ud655\uc778\ud574\uc57c \ud604\uc7a5 \uc2a4\ud2b8\ub808\uc2a4\uac00 \uc904\uc5b4\ub4e0\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc774 \ud63c\uc790 \ub354 \ud3b8\ud55c \uc774\uc720<\/h2>\n\n\n\n<p>\uc778\uadfc \ub9c8\uc744\uc740 \ub300\ud45c \uba85\uc18c\uc758 \ud63c\uc7a1\uc744 \ud53c\ud558\uace0 \uc2f6\uc744 \ub54c \uc88b\ub2e4. \ud63c\uc790\ub77c\uba74 \ub3d9\uc120\uc744 \uc9e7\uac8c \uc720\uc9c0\ud558\uba74\uc11c \uc8fc\ubcc0 \ud48d\uacbd\uacfc \uc0dd\ud65c\uad8c\uc744 \ucc9c\ucc9c\ud788 \ubcfc \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc720\uba85\ub3c4\ubcf4\ub2e4 \uccb4\ub958 \uc548\uc815\uc131\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \uc0ac\ub78c\uc774 \uc801\uc740 \uacf3\uc740 \uc2ec\uc2ec\ud560 \uc218 \uc788\uc9c0\ub9cc, \ub3d9\uc120\uc774 \ub2e8\uc21c\ud558\uace0 \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc774 \uba85\ud655\ud558\uba74 \uc624\ud788\ub824 \ud63c\uc790 \uac77\uae30 \ud3b8\ud55c \ubaa9\uc801\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc\uc740 \ubc84\uc2a4 \uac04\uaca9\ubd80\ud130 \ud655\uc778\ud574\uc57c \ud3b8\ud558\ub2e4<\/h2>\n\n\n\n<p>\uc2dc\ub77c\uce74\uc640\uace0 \uc77c\ub300\ub294 \ubc84\uc2a4 \uc608\uc57d\uacfc \uacc4\uc808 \uc6b4\ud589 \uc815\ubcf4\ub97c \ud655\uc778\ud574\uc57c \ud55c\ub2e4. \ud604\uc7a5\uc5d0\uc11c \uc989\ud765\uc801\uc73c\ub85c \uc774\ub3d9 \ubc94\uc704\ub97c \ub113\ud788\uae30\ubcf4\ub2e4, \ub3c4\ucc29 \uc804\ubd80\ud130 \ub3cc\uc544\uac08 \ud3b8\uacfc \uc219\uc18c \uc774\ub3d9 \ubc29\ubc95\uc744 \ud655\uc815\ud558\ub294 \ud3b8\uc774 \uc548\uc804\ud558\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc900\ube44 \ub2e8\uacc4<\/th><th>\ud655\uc778\ud560 \ub0b4\uc6a9<\/th><th>\ud63c\uc790 \uc5ec\ud589 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\uc804\ub0a0<\/td><td>\uacf5\uc2dd \uad50\ud1b5 \uc2dc\uac04\ud45c\uc640 \ubcf5\uadc0\ud3b8<\/td><td>\ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \uc801\uc73c\uba74 \uc624\uc804 \ucd9c\ubc1c\ub85c \uace0\uc815\ud55c\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \ubc84\uc2a4 \uc815\ub958\uc7a5, \uc548\ub0b4\uc18c \uc704\uce58<\/td><td>\uae38\uc744 \uc783\uc5c8\uc744 \ub54c \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\uc810\uc2ec \uc804\ud6c4<\/td><td>\uc2dd\ub2f9 \uc601\uc5c5 \uc5ec\ubd80\uc640 \ud734\uc2dd \uc7a5\uc18c<\/td><td>\uc791\uc740 \ub9c8\uc744\uc740 \uc601\uc5c5 \uc2dc\uac04\uc774 \uc9e7\uac70\ub098 \uc26c\ub294 \ub0a0\uc774 \uc788\uc744 \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4 \ud6c4\ubc18<\/td><td>\uc870\uba85, \uc778\uc801, \uc219\uc18c \ub610\ub294 \ucd9c\ubc1c\uc9c0 \ubc29\ud5a5<\/td><td>\ud63c\uc790\ub77c\uba74 \ud574\uc9c0\uae30 \uc804 \ubcf5\uadc0 \ud750\ub984\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc740 \uc9e7\uac8c \uac77\uace0 \uc624\ub798 \uba38\ubb38\ub2e4<\/h2>\n\n\n\n<p>\uccab \ubc29\ubb38\uc774\ub77c\uba74 \uc2dc\ub77c\uce74\uc640\uace0 \uc911\uc2ec\ubd80\uc640 \uc778\uadfc \ub9c8\uc744 \ud558\ub098\ub97c \ubb36\ub294 \uc815\ub3c4\uac00 \uc801\ub2f9\ud558\ub2e4. \uc5ec\ub7ec \ub9c8\uc744\uc744 \ud55c \ubc88\uc5d0 \ubcf4\ub824 \ud558\uba74 \uad50\ud1b5 \ub300\uae30\uc640 \ubcf4\ud589 \ud53c\ub85c\uac00 \ucee4\uc838 \ud575\uc2ec \uacbd\ud5d8\uc774 \ud750\ub824\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc77c\ubcf8 \uc9c0\ubc29 \uc18c\ub3c4\uc2dc\ub294 \uc5ec\ub7ec \uc9c0\uc810\uc744 \ube60\ub974\uac8c \ucc0d\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \ud55c \ubc29\ud5a5\uc73c\ub85c \uac77\uace0 \ub2e4\uc2dc \ub3cc\uc544\uc624\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\ub2e4. \uc5ed\uc774\ub098 \uc815\ub958\uc7a5, \uc548\ub0b4\uc18c, \uc219\uc18c\ub97c \uae30\uc900\uc810\uc73c\ub85c \uc0bc\uc73c\uba74 \ud604\uc7a5\uc5d0\uc11c \uc77c\uc815\uc744 \uc904\uc774\uae30\ub3c4 \uc27d\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \uc219\uc18c\ub294 1\ubc15 \uc774\ub3d9 \ubd80\ub2f4\uae4c\uc9c0 \uac19\uc774 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>1\ubc15\uc744 \ud55c\ub2e4\uba74 \uc219\uc18c \uc704\uce58\uc640 \uc800\ub141 \uc2dd\uc0ac \ud3ec\ud568 \uc5ec\ubd80\ub97c \uaf2d \ud655\uc778\ud574\uc57c \ud55c\ub2e4. \uc778\uadfc \ub9c8\uc744 \uc219\uc18c\ub294 \uc870\uc6a9\ud55c \uc7a5\uc810\uc774 \uc788\uc9c0\ub9cc, \uc678\ubd80 \uc2dd\ub2f9 \uc120\ud0dd\uc9c0\uac00 \uc801\uc744 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \ubd84\uc704\uae30\ubcf4\ub2e4 \uc811\uadfc\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc678\uacfd \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \uc800\ub141 \uc2dd\uc0ac\uc640 \uccb4\ud06c\uc778, \uc9d0 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud560 \uc218 \uc788\uc73c\ubbc0\ub85c \ud63c\uc790\ub77c\uba74 \uad50\ud1b5 \uac70\uc810\uacfc \uc2dd\uc0ac \uac00\ub2a5 \uad6c\uc5ed \uc0ac\uc774\uac00 \uac00\uc7a5 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc5d0\uc11c \ubc25\uacfc \ud734\uc2dd\uc744 \ub123\ub294 \ubc95<\/h2>\n\n\n\n<p>\uc810\uc2ec\uc740 \uad00\uad11\uac1d\uc774 \ub9ce\uc740 \uc2dc\uac04\ub300\uc5d0 \uc120\ud0dd\uc9c0\uac00 \uc788\uc9c0\ub9cc, \uc800\ub141\uc740 \uc219\uc18c \uc2dd\uc0ac \uc5ec\ubd80\uac00 \uc911\uc694\ud558\ub2e4. \ud2b9\ud788 \uaca8\uc6b8\uc5d0\ub294 \uc774\ub3d9 \ud6c4 \uc2dd\uc0ac\ub97c \ucc3e\uae30 \uc5b4\ub824\uc6b8 \uc218 \uc788\uc5b4 \uc0ac\uc804 \ud655\uc778\uc774 \ud544\uc694\ud558\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub9c8\uc744\uc5d0\uc11c\ub294 \ub9db\uc9d1\ubcf4\ub2e4 \uc601\uc5c5\uc77c\uacfc \uc601\uc5c5 \uc2dc\uac04\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \uc810\uc2ec \ud6c4\ubcf4\ub97c 2\uacf3 \uc774\uc0c1 \ub450\uace0, \uc2dd\ub2f9\uc774 \ub2eb\ud614\uc744 \ub54c\ub97c \ub300\ube44\ud574 \ud3b8\uc758\uc810\uc774\ub098 \uac04\ub2e8\ud55c \uac04\uc2dd \ud655\ubcf4 \uc5ec\ubd80\ub97c \ud655\uc778\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc\uc740 \uad50\ud1b5 \uac04\uaca9\uacfc \ud53c\ub85c \ub204\uc801\uc744 \uac19\uc774 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\ub208\uae38\uacfc \uc5b4\ub450\uc6b4 \ub3c4\ub85c\uac00 \uac00\uc7a5 \ud070 \ubcc0\uc218\ub2e4. \ud63c\uc790\ub77c\uba74 \ud574\uac00 \uc9c4 \ub4a4 \uc678\uacfd \uae38\uc744 \uac77\ub294 \uc77c\uc815\uc744 \ud53c\ud558\uace0, \ub0a0\uc528\uac00 \ub098\uc058\uba74 \ub9c8\uc744 \uc774\ub3d9\ubcf4\ub2e4 \uc219\uc18c \uc8fc\ubcc0 \uccb4\ub958\ub85c \uc804\ud658\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc0ac\ub78c\uc774 \uc801\uc740 \uae38\uc774 \ud56d\uc0c1 \uc704\ud5d8\ud558\ub2e4\ub294 \ub73b\uc740 \uc544\ub2c8\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ub2a6\uc740 \uc2dc\uac04\uacfc \uc678\uc9c4 \uae38\uc744 \ub3d9\uc2dc\uc5d0 \ub9cc\ub4e4\uc9c0 \uc54a\ub294 \uac83\uc774 \uc6d0\uce59\uc774\ub2e4. \uc0ac\uc9c4\uc744 \ub354 \ucc0d\uae30\ubcf4\ub2e4 \ubcf5\uadc0\uac00 \uc26c\uc6b4 \uc2dc\uac04\ub300\uc5d0 \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \uacb0\uacfc\uc801\uc73c\ub85c \uc5ec\ud589 \ub9cc\uc871\ub3c4\ub97c \ub192\uc778\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc5d0\uc11c \uc2dc\uac04 \ubc30\ubd84\ud558\ub294 \ubc95<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \ubc84\uc2a4 \uc608\uc57d, \uc219\uc18c, \uc2dd\uc0ac \ud3ec\ud568 \uc5ec\ubd80\uc5d0 \ub530\ub77c \ub2ec\ub77c\uc9c4\ub2e4. \ub2f9\uc77c\uce58\uae30\ub294 \ube44\uc6a9\uc774 \ub0ae\uc9c0\ub9cc \uccb4\ub958 \uc2dc\uac04\uc774 \uc9e7\uace0, 1\ubc15\uc740 \ube44\uc6a9\uc774 \ub298\uc9c0\ub9cc \ud63c\uc7a1\ud558\uc9c0 \uc54a\uc740 \uc2dc\uac04\ub300\ub97c \ubcfc \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uad50\ud1b5\uacfc \uc219\ubc15\uc5d0\uc11c \ucc28\uc774\uac00 \ub09c\ub2e4. \ub2f9\uc77c\uce58\uae30\ub77c\uba74 \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc783\uc9c0 \uc54a\ub294 \uad50\ud1b5\ud3b8\uc774 \uc911\uc694\ud558\uace0, 1\ubc15\uc774\ub77c\uba74 \uc219\uc18c \uc704\uce58\uac00 \ub2e4\uc74c \ub0a0 \uc774\ub3d9\uae4c\uc9c0 \uc601\ud5a5\uc744 \uc900\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc774 \ub9de\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\ub300\ud45c \uad00\uad11\uc9c0\ub9cc \ube60\ub974\uac8c \ucc0d\uae30\ubcf4\ub2e4 \uadf8 \uc8fc\ubcc0\uc758 \uc870\uc6a9\ud55c \ud48d\uacbd\uacfc \uacc4\uc808\uac10\uc744 \ubcf4\uace0 \uc2f6\uc740 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \ud63c\uc790\ub77c\ub3c4 \uad50\ud1b5\uacfc \ub0a0\uc528\ub97c \uaf3c\uaf3c\ud788 \ud655\uc778\ud558\ub294 \uc0ac\ub78c\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc5d0\uc11c \ube44\uad50 \ub300\uc0c1 \uc124\uc815\uc744 \uc798\ud574\uc57c \ud558\ub294 \uc774\uc720<\/h2>\n<p>\uc774 \uc9c0\uc5ed\uc740 \uc2dc\ub77c\uce74\uc640\uace0 \uc790\uccb4\uc640 \uc9c1\uc811 \uacbd\uc7c1\uc2dc\ud0a4\uba74 \uc624\ud788\ub824 \uc7a5\uc810\uc774 \ud750\ub824\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud575\uc2ec\uc740 \uc720\uba85 \uad00\uad11\uc9c0\ub97c \ub300\uccb4\ud558\ub294 \ub370 \uc788\uc9c0 \uc54a\uace0, \ub354 \uc801\uc740 \uc790\uadf9\uacfc \ub354 \uc548\uc815\uc801\uc778 \ud750\ub984 \uc18d\uc5d0\uc11c \uba38\ubb34\ub97c \uc218 \uc788\ub2e4\ub294 \ub370 \uc788\uc2b5\ub2c8\ub2e4. \ub530\ub77c\uc11c \ube44\uad50 \uae30\uc900\ub3c4 \ubcfc\uac70\ub9ac \uac1c\uc218\ubcf4\ub2e4 \uccb4\ub958 \ud53c\ub85c, \uc774\ub3d9 \ub09c\ub3c4, \ud63c\uc790 \uac77\ub294 \ud3b8\uc548\ud568 \ucabd\uc73c\ub85c \uc62e\uaca8\uc57c \uc815\ud655\ud569\ub2c8\ub2e4. \uadf8\ub798\uc57c \uc778\uadfc \ub9c8\uc744\uc758 \uac15\uc810\uc774 \u2018\ubd80\uc871\ud568\u2019\uc774 \uc544\ub2c8\ub77c \u2018\ub2e4\ub978 \ud615\ud0dc\uc758 \uc644\uc131\ub3c4\u2019\ub85c \uc77d\ud799\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc774 \uacfc\uc18c\ud3c9\uac00\ub418\uae30 \uc26c\uc6b4 \uad6c\uc870<\/h2>\n<p>\uac80\uc0c9 \ub2e8\uacc4\uc5d0\uc11c\ub294 \ub300\ud45c \uba85\uc18c\uac00 \uc544\ub2cc \ub9cc\ud07c \uc815\ubcf4\ub7c9\uc774 \uc801\uace0, \uc0ac\uc9c4\ub9cc \ubd10\uc11c\ub294 \ucc28\ubcc4\uc810\uc774 \uc57d\ud574 \ubcf4\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \ud604\uc7a5\uc5d0\uc11c\ub294 \ud63c\uc7a1\ub3c4\uc640 \uc774\ub3d9 \uc555\ubc15\uc774 \ub0ae\uc544\uc9c0\uba74\uc11c \uccb4\ub958 \ud488\uc9c8\uc774 \ub354 \ub192\uac8c \ub290\uaef4\uc9c0\ub294 \uacbd\uc6b0\uac00 \uc801\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uc989, \uc628\ub77c\uc778\uc5d0\uc11c \ub35c \uac15\ud574 \ubcf4\uc774\ub294 \uc694\uc18c\uac00 \uc624\ud504\ub77c\uc778\uc5d0\uc11c\ub294 \uc624\ud788\ub824 \uc7a5\uc810\uc73c\ub85c \uc791\ub3d9\ud569\ub2c8\ub2e4. \uc774\ub7f0 \uad6c\uc870\ub97c \uc774\ud574\ud55c \uc0ac\ub78c\uc5d0\uac8c\ub294 \uc778\uadfc \ub9c8\uc744 \uccb4\ub958\uac00 \uaf64 \uc124\ub4dd\ub825 \uc788\ub294 \uc120\ud0dd\uc9c0\uac00 \ub429\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc774 \ub354 \ud3b8\ud588\ub358 \uc774\uc720<\/h2>\n\n\n\n<p>\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc740 \uad00\uad11 \ucf54\uc2a4 \ubc16\uc758 \uc790\uc720\ub85c\uc6c0\uc774 \uc7a5\uc810\uc774\uc9c0\ub9cc, \uadf8 \uc790\uc720\ub294 \uc900\ube44\uac00 \uc788\uc744 \ub54c\ub9cc \uc548\uc804\ud558\ub2e4. \ubc84\uc2a4, \uc219\uc18c, \uc2dd\uc0ac, \ub0a0\uc528\ub97c \uba3c\uc800 \ud655\uc778\ud558\uba74 \ud63c\uc790\uc11c\ub3c4 \ubc00\ub3c4 \uc788\ub294 \uc9c0\ubc29 \uc5ec\ud589\uc774 \ub41c\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc2dc\ub77c\uce74\uc640\uace0 \uc778\uadfc \ub9c8\uc744\uc744 \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uad50\ud1b5, \uc219\uc18c, \uc2dd\uc0ac, \ub208\u00b7\ub0a0\uc528 \ubcc0\uc218, \ub2f9\uc77c\uacfc 1\ubc15 \ud