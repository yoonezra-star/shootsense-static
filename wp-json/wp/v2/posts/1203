{"id":1203,"date":"2026-03-24T21:27:31","date_gmt":"2026-03-24T12:27:31","guid":{"rendered":"https:\/\/shootsense.com\/?p=1203"},"modified":"2026-06-12T14:31:51","modified_gmt":"2026-06-12T05:31:51","slug":"%ea%b8%b0%eb%8c%80%ed%95%98%ec%a7%80-%ec%95%8a%ec%95%98%ea%b8%b0%ec%97%90-%eb%8d%94-%ec%86%94%ec%a7%81%ed%96%88%eb%8d%98-%ed%8c%8c%ed%82%a4%ec%8a%a4%ed%83%84-%eb%82%98%eb%9e%80-%ec%97%ac%ed%96%89","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ea%b8%b0%eb%8c%80%ed%95%98%ec%a7%80-%ec%95%8a%ec%95%98%ea%b8%b0%ec%97%90-%eb%8d%94-%ec%86%94%ec%a7%81%ed%96%88%eb%8d%98-%ed%8c%8c%ed%82%a4%ec%8a%a4%ed%83%84-%eb%82%98%eb%9e%80-%ec%97%ac%ed%96%89\/","title":{"rendered":"\ud30c\ud0a4\uc2a4\ud0c4 \ub098\ub780 \ud63c\uc790 \uc5ec\ud589: \uae30\ub300\ubcf4\ub2e4 \uc900\ube44\uac00 \uba3c\uc800\uc778 \uc0b0\uc545 \uc5ec\ud589 \uae30\uc900"},"content":{"rendered":"\n<p>\ub098\ub780\uc740 \uae30\ub300\ub9cc\uc73c\ub85c \uac00\uae30\uc5d0\ub294 \ubcc0\uc218\uac00 \ub9ce\uc740 \uc0b0\uc545 \uc5ec\ud589\uc9c0\ub2e4. \ud48d\uacbd\uc740 \uac15\ud558\uc9c0\ub9cc \ub3c4\ub85c, \ub0a0\uc528, \uc219\uc18c, \ud1b5\uc2e0, \ud604\uae08 \uc900\ube44\uac00 \ubd80\uc871\ud558\uba74 \ud63c\uc790 \uc5ec\ud589\uc758 \ubd80\ub2f4\uc774 \ud06c\uac8c \ucee4\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ud30c\ud0a4\uc2a4\ud0c4 \ub098\ub780\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \uac10\uc0c1\ubcf4\ub2e4 \uc774\ub3d9 \ub09c\ub3c4, \uc219\uc18c \uc704\uce58, \ub0a0\uc528, \uc2dd\uc0ac, \ud604\uae08\u00b7\ud1b5\uc2e0, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \uc548\uc804\ud558\uac8c \uc77c\uc815\uc744 \uc124\uacc4\ud558\ub294 \ub370 \ucd08\uc810\uc744 \ub454\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud30c\ud0a4\uc2a4\ud0c4 \ub098\ub780 \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\ub098\ub780\uc740 \ubaa9\uc801\uc9c0 \uc790\uccb4\ubcf4\ub2e4 \uc811\uadfc \uacfc\uc815\uc774 \uc911\uc694\ud55c \uacf3\uc774\ub2e4. \uc774\ub3d9 \uac00\ub2a5 \uc2dc\uae30\uc640 \ub3c4\ub85c \uc0c1\ud0dc, \uc219\uc18c \uc704\uce58, \ud604\uae08 \uc900\ube44\ub97c \uba3c\uc800 \ud655\uc778\ud574\uc57c \uc548\uc804\ud55c \uc77c\uc815\uc774 \ub41c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589 \uccb4\ud06c \ud3ec\uc778\ud2b8<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uc0b0\uc545 \ud48d\uacbd, \uacc4\uace1 \uc9c0\uc5ed \uccb4\ub958, \uc790\uc5f0 \uc911\uc2ec \uc5ec\ud589<\/td><td>\uc790\uc5f0 \ubaa9\uc801\uc9c0\ub294 \ubaa9\uc801\uc774 \ubd88\uba85\ud655\ud558\uba74 \uc774\ub3d9 \ud53c\ub85c\ub9cc \ub0a8\uae30 \uc27d\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ub09c\ub3c4<\/td><td>\ub3c4\ub85c \uc0c1\ud0dc, \ucc28\ub7c9 \uc774\ub3d9 \uc2dc\uac04, \uc6b4\uc804 \uae30\uc0ac \ub610\ub294 \ud604\uc9c0 \uc774\ub3d9 \uc218\ub2e8 \ud655\uc778<\/td><td>\ud63c\uc790 \uc774\ub3d9 \uc2dc \uc9c0\uc5f0, \ub300\uae30, \ubcf5\uadc0 \ub9ac\uc2a4\ud06c\ub97c \uc9c1\uc811 \uac10\ub2f9\ud574\uc57c \ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\uc774\ub3d9\uc77c\uc744 \uc81c\uc678\ud558\uace0 \ucd5c\uc18c 1\ubc15 \uc774\uc0c1, \uc5ec\uc720 \uc77c\uc815 \uad8c\uc7a5<\/td><td>\ub3c4\ucc29\uc77c\uacfc \uc774\ub3d9\uc77c\uc744 \ud65c\ub3d9\uc77c\ub85c \uacc4\uc0b0\ud558\uc9c0 \uc54a\ub294 \uac83\uc774 \uc548\uc804\ud558\ub2e4<\/td><\/tr><tr><td>\ud575\uc2ec \ubcc0\uc218<\/td><td>\ub3c4\ub85c \ud3d0\uc1c4, \ub0a0\uc528, \uace0\ub3c4 \ud53c\ub85c, \ud604\uae08, \ud1b5\uc2e0, \uc219\uc18c \ud488\uc9c8<\/td><td>\ub0a0\uc528, \uace0\ub3c4, \ub3c4\ub85c \uc0c1\ud0dc, \ud1b5\uc2e0 \uc0c1\ud0dc\uac00 \uc77c\uc815 \ud488\uc9c8\uc744 \uc88c\uc6b0\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ub098\ub780\uc744 \ud63c\uc790 \uac08 \uc218 \uc788\ub294 \uc804\uc81c \uc870\uac74<\/h2>\n\n\n\n<p>\ub098\ub780\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \uac15\ud55c \uc778\uc0c1\uc744 \uc904 \uc218 \uc788\uc9c0\ub9cc, \uc900\ube44 \uc5c6\uc774 \uac00\ubccd\uac8c \uc811\uadfc\ud560 \ubaa9\uc801\uc9c0\ub294 \uc544\ub2c8\ub2e4. \ud63c\uc790\ub77c\uba74 \ud604\uc9c0 \uc774\ub3d9\uacfc \uc219\uc18c, \ube44\uc0c1 \uc5f0\ub77d \uae30\uc900\uc744 \ub354 \uad6c\uccb4\uc801\uc73c\ub85c \uc7a1\uc544\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc790\uc5f0 \uc9c0\uc5ed\uc744 \uc5ec\ud589\ud560 \ub54c\ub294 \u201c\uc5bc\ub9c8\ub098 \uba4b\uc9c4\uac00\u201d\ubcf4\ub2e4 \u201c\ubb34\ub9ac \uc5c6\uc774 \uba38\ubb3c \uc218 \uc788\ub294\uac00\u201d\uac00 \ub354 \uc911\uc694\ud558\ub2e4. \uc88b\uc740 \ud48d\uacbd\ub3c4 \uc774\ub3d9\uc774 \uacfc\ud558\uba74 \ud53c\ub85c\ub85c \ubc14\ub00c\uae30 \ub54c\ubb38\uc5d0, \uc77c\uc815\uc740 \uc904\uc77c \uc218 \uc788\uac8c \uc124\uacc4\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub3c4\ub85c \uc0c1\ud669\uc744 \uc77c\uc815\uc758 \uccab \uae30\uc900\uc73c\ub85c \ub450\uae30<\/h2>\n\n\n\n<p>\ub3c4\ub85c \uc774\ub3d9\uc774 \uc77c\uc815\uc758 \ud575\uc2ec \ubcc0\uc218\ub2e4. \ucd9c\ubc1c \uc804 \ud604\uc9c0 \ub3c4\ub85c \uc0c1\ud669\uacfc \ub0a0\uc528\ub97c \ud655\uc778\ud558\uace0, \ubc24 \uc774\ub3d9\ubcf4\ub2e4\ub294 \ubc1d\uc740 \uc2dc\uac04 \uc774\ub3d9\uc744 \uae30\ubcf8\uc73c\ub85c \uc7a1\ub294 \ud3b8\uc774 \uc548\uc804\ud558\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc0c1\ud669<\/th><th>\uc8fc\uc758\ud560 \uc810<\/th><th>\uad8c\uc7a5 \ub300\uc751<\/th><\/tr><\/thead><tbody><tr><td>\ub3c4\ucc29 \ub2f9\uc77c<\/td><td>\uc7a5\uac70\ub9ac \uc774\ub3d9 \ud6c4 \ubc14\ub85c \ud65c\ub3d9\uc744 \ub123\uc73c\uba74 \ud310\ub2e8\ub825\uc774 \ub5a8\uc5b4\uc9c4\ub2e4<\/td><td>\uc219\uc18c \uccb4\ud06c\uc778, \uc2dd\uc0ac, \uc8fc\ubcc0 \ud655\uc778\ub9cc \ud55c\ub2e4<\/td><\/tr><tr><td>\ub0a0\uc528 \uc545\ud654<\/td><td>\uc0b0\uc545\u00b7\uac15\ubcc0 \uc9c0\uc5ed\uc740 \uc9e7\uc740 \ube44\uc5d0\ub3c4 \uc774\ub3d9 \ud53c\ub85c\uac00 \ucee4\uc9c4\ub2e4<\/td><td>\ud575\uc2ec \uc77c\uc815 \ud558\ub098\ub9cc \ub0a8\uae30\uace0 \ub098\uba38\uc9c0\ub294 \uc904\uc778\ub2e4<\/td><\/tr><tr><td>\ud1b5\uc2e0 \ubd88\uc548\uc815<\/td><td>\uc678\uacfd\uc5d0\uc11c\ub294 \uc9c0\ub3c4\uc640 \ud638\ucd9c \uc11c\ube44\uc2a4\uac00 \ub2a6\uac8c \uc791\ub3d9\ud560 \uc218 \uc788\ub2e4<\/td><td>\uc624\ud504\ub77c\uc778 \uc9c0\ub3c4\uc640 \uc219\uc18c \uc8fc\uc18c\ub97c \ubbf8\ub9ac \uc800\uc7a5\ud55c\ub2e4<\/td><\/tr><tr><td>\ud604\uae08 \ubd80\uc871<\/td><td>\uc18c\ub3c4\uc2dc\ub294 \uce74\ub4dc \uc0ac\uc6a9\ucc98\uac00 \uc81c\ud55c\ub420 \uc218 \uc788\ub2e4<\/td><td>\ub3c4\ucc29 \uc804 \uc18c\uc561 \ud604\uae08\uc744 \ub098\ub220 \uc900\ube44\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc774\ub3d9\uc77c\uacfc \ud65c\ub3d9\uc77c\uc744 \ubd84\ub9ac\ud558\ub294 \ubc29\uc2dd<\/h2>\n\n\n\n<p>\ub3c4\ucc29\uc77c\uc5d0\ub294 \uc219\uc18c \uccb4\ud06c\uc778, \uc2dd\uc0ac, \uc8fc\ubcc0 \ud655\uc778\ub9cc \ud558\uace0 \ubcf8\uaca9\uc801\uc778 \uc678\uacfd \uc774\ub3d9\uc740 \ub2e4\uc74c \ub0a0\ub85c \ub118\uae34\ub2e4. \ud48d\uacbd \uc9c0\uc810\uc744 \uc5ec\ub7ec \uacf3 \ubb36\uae30\ubcf4\ub2e4 \ub3c4\ub85c \uc0c1\ud0dc\uc640 \ucee8\ub514\uc158\uc5d0 \ub530\ub77c \ud558\ub098\uc529 \uc120\ud0dd\ud558\ub294 \uac83\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\ud575\uc2ec\uc740 \uccab\ub0a0\uc5d0 \ub9ce\uc740 \uac83\uc744 \ubcf4\ub824 \ud558\uc9c0 \uc54a\ub294 \uac83\uc774\ub2e4. \uc219\uc18c\uc640 \uc911\uc2ec \uac70\ub9ac, \uc2dd\uc0ac \uc9c0\uc810, \ub2e4\uc74c \uc774\ub3d9\ud3b8\uc744 \uba3c\uc800 \ud655\uc778\ud55c \ub4a4 \ub458\uc9f8 \ub0a0 \uc624\uc804\uc774\ub098 \ub0a0\uc528\uac00 \uc548\uc815\uc801\uc778 \uc2dc\uac04\uc5d0 \ud575\uc2ec \ud65c\ub3d9\uc744 \ub123\ub294 \ubc29\uc2dd\uc774 \uc548\uc804\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud48d\uacbd\ubcf4\ub2e4 \ucc28\ub7c9 \uc811\uadfc\uc774 \uc911\uc694\ud55c \uc219\uc18c<\/h2>\n\n\n\n<p>\uc219\uc18c\ub294 \uc911\uc2ec\ubd80 \uc811\uadfc\uc131, \ub09c\ubc29 \ub610\ub294 \uc628\uc218, \uc2dd\uc0ac \uac00\ub2a5 \uc5ec\ubd80, \ucc28\ub7c9 \uc811\uadfc\uc131\uc744 \ud568\uaed8 \ubd10\uc57c \ud55c\ub2e4. \uac00\uaca9\ub9cc \ubcf4\uace0 \uace0\ub974\uba74 \uc2e4\uc81c \uccb4\ub958 \ud488\uc9c8\uc774 \ud06c\uac8c \ub5a8\uc5b4\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790\ub77c\uba74 \uc804\ub9dd \uc88b\uc740 \uc678\uacfd \uc219\uc18c\ubcf4\ub2e4 \uc2dd\uc0ac\uc640 \uad50\ud1b5 \uc811\uadfc\uc131\uc774 \uc788\ub294 \uc704\uce58\uac00 \uc6b0\uc120\uc774\ub2e4. \uc678\uacfd \uc219\uc18c\ub97c \uace0\ub97c \ub54c\ub294 \ud53d\uc5c5 \uac00\ub2a5 \uc5ec\ubd80, \uccb4\ud06c\uc778 \uc2dc\uac04, \uc800\ub141 \uc2dd\uc0ac \uac00\ub2a5 \uc5ec\ubd80\ub97c \ubc18\ub4dc\uc2dc \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0b0\uc545 \uc9c0\uc5ed\uc5d0\uc11c \ub04a\uae30\uae30 \uc26c\uc6b4 \uc900\ube44\ubb3c<\/h2>\n\n\n\n<p>\uc2dd\uc0ac\ub294 \uc219\uc18c\ub098 \uc911\uc2ec\ubd80\uc5d0\uc11c \uc548\uc815\uc801\uc73c\ub85c \ud574\uacb0\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ud604\uae08 \uacb0\uc81c \uac00\ub2a5\uc131\uc774 \ub192\uc73c\ubbc0\ub85c \uc18c\uc561\uad8c\uc744 \ub098\ub220 \uc900\ube44\ud558\uace0, \uc7a5\uac70\ub9ac \uc774\ub3d9 \uc804\uc5d0\ub294 \ubb3c\uacfc \uac04\ub2e8\ud55c \uc74c\uc2dd\uc744 \ud655\ubcf4\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc18c\ub3c4\uc2dc\uc640 \uc0b0\uc545 \uc9c0\uc5ed\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc601\uc5c5 \uc2dc\uac04, \uce74\ub4dc \uacb0\uc81c \uac00\ub2a5 \uc5ec\ubd80, ATM \uc704\uce58\uac00 \ubaa8\ub450 \ubcc0\uc218\uac00 \ub41c\ub2e4. \ud63c\uc790\ub77c\uba74 \ub2a6\uc740 \uc2dc\uac04 \uc2dd\uc0ac\ub97c \ucc3e\ub294 \uc0c1\ud669\uc744 \ub9cc\ub4e4\uc9c0 \uc54a\ub294 \uac83\uc774 \uac00\uc7a5 \ud604\uc2e4\uc801\uc778 \uc548\uc804 \ub300\ucc45\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud1b5\uc2e0\uacfc \ud53c\ub85c\ub97c \ub3d9\uc2dc\uc5d0 \uad00\ub9ac\ud558\ub294 \ubc95<\/h2>\n\n\n\n<p>\uac00\uc7a5 \ud070 \ubcc0\uc218\ub294 \ub3c4\ub85c\uc640 \ub0a0\uc528\ub2e4. \ud63c\uc790\ub77c\uba74 \ubb34\ub9ac\ud55c \uc678\uacfd \uc774\ub3d9, \ub2a6\uc740 \ucd9c\ubc1c, \ud1b5\uc2e0 \ubd88\uc548\uc815 \uad6c\uac04 \ub2e8\ub3c5 \uc774\ub3d9\uc744 \ud53c\ud558\uace0 \uc219\uc18c\uc5d0 \uc774\ub3d9 \uacc4\ud68d\uc744 \ub0a8\uae30\ub294 \uac83\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc5ec\ud589\uc9c0\uc758 \uc704\ud5d8\uc740 \ud2b9\uc815 \uc7a5\uc18c\ubcf4\ub2e4 \ud53c\ub85c\uac00 \ub204\uc801\ub41c \uc0c1\ud0dc\uc5d0\uc11c \ud310\ub2e8\uc774 \ud750\ub824\uc9c8 \ub54c \ucee4\uc9c4\ub2e4. \uc7a5\uac70\ub9ac \uc774\ub3d9 \uc9c1\ud6c4\uc5d0\ub294 \uc0c8\ub85c\uc6b4 \uae38\uc744 \ub113\uac8c \ud0d0\uc0c9\ud558\uc9c0 \ub9d0\uace0, \uc219\uc18c \uc8fc\ubcc0\uc5d0\uc11c \ubc29\ud5a5\uac10\uac01\uc744 \ub9cc\ub4e0 \ub4a4 \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \ub0ab\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc774\ub3d9\ube44\ub97c \uc544\ub07c\ub2e4 \uc77c\uc815\uc774 \ub9dd\uac00\uc9c0\ub294 \uacbd\uc6b0<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \ucc28\ub7c9 \uc774\ub3d9\uacfc \uc219\uc18c \ud488\uc9c8\uc5d0\uc11c \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \uc800\uac00 \uc774\ub3d9\ub9cc \uace0\uc9d1\ud558\uba74 \ub300\uae30 \uc2dc\uac04\uacfc \ud53c\ub85c\uac00 \ucee4\uc9c8 \uc218 \uc788\uc5b4 \uc548\uc804 \ube44\uc6a9\uc744 \ud3ec\ud568\ud574 \uacc4\uc0b0\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc790\uc5f0 \uc9c0\uc5ed\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uc774\ub3d9\ube44\uc640 \uc219\ubc15\ube44\uac00 \uc608\uc0b0\uc744 \uc88c\uc6b0\ud55c\ub2e4. \ub2f9\uc77c\ub85c \ubb34\ub9ac\ud558\uac8c \ub2e4\ub140\uc624\ub294 \uac83\ubcf4\ub2e4 1\ubc15\uc744 \ucd94\uac00\ud574 \uc774\ub3d9 \ud53c\ub85c\ub97c \ub0ae\ucd94\ub294 \ucabd\uc774 \uc804\uccb4 \ub9cc\uc871\ub3c4\ub97c \ub192\uc77c \ub54c\uac00 \ub9ce\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ub780\uc5d0\uc11c \uc704\ud5d8\ud574\uc9c0\ub294 \uae09\ud589 \uc77c\uc815<\/h2>\n\n\n\n<p>\ub3c4\ucc29 \ub2f9\uc77c \ubc14\ub85c \uc7a5\uac70\ub9ac \uc678\uacfd \ucf54\uc2a4\ub97c \ub123\uac70\ub098, \ub3c4\ub85c \uc0c1\ud669\uc744 \ud655\uc778\ud558\uc9c0 \uc54a\uace0 \uc77c\uc815\ud45c\ub97c \uace0\uc815\ud558\ub294 \ubc29\uc2dd\uc740 \ud53c\ud574\uc57c \ud55c\ub2e4. \ub098\ub780\uc740 \ud604\uc7a5 \ubcc0\uc218\ub97c \ubc18\uc601\ud560 \uc5ec\uc720\uac00 \ud544\uc218\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc900\ube44\ub97c \ud48d\uacbd\ubcf4\ub2e4 \uba3c\uc800 \ub458 \uc218 \uc788\ub294 \uc0ac\ub78c<\/h2>\n\n\n\n<p>\uac15\ud55c \uc790\uc5f0 \ud48d\uacbd\uc744 \uc6d0\ud558\uc9c0\ub9cc \uc900\ube44\uc640 \ub9ac\uc2a4\ud06c \uad00\ub9ac\ub97c \uc18c\ud640\ud788 \ud558\uc9c0 \uc54a\ub294 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \ud63c\uc790\ub77c\uba74 \ub354 \ubcf4\uc218\uc801\uc73c\ub85c \uc6c0\uc9c1\uc774\ub294 \uc0ac\ub78c\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub098\ub780 \uc77c\uc815\uc744 \ud655\uc815\ud558\uae30 \uc804 \ub9c8\uc9c0\ub9c9 \ud310\ub2e8<\/h2>\n\n\n<h2 class=\"wp-block-heading\">\ub098\ub780\uc5d0\uc11c\ub294 \ud48d\uacbd \uae30\ub300\ubcf4\ub2e4 \uc77c\uc815 \ubcf4\uc218\uc131\uc774 \ub354 \uc911\uc694\ud569\ub2c8\ub2e4<\/h2>\n<p>\ub098\ub780\uc740 \uc0ac\uc9c4\uc0c1 \uc778\uc0c1\uc774 \uac15\ud55c \ub9cc\ud07c \ud604\uc7a5\uc5d0\uc11c\ub3c4 \ud070 \uae30\ub300\ub97c \ud488\uae30 \uc27d\uc9c0\ub9cc, \uc2e4\uc81c\ub85c\ub294 \uc774\ub3d9 \uc548\uc815\uc131\uacfc \ub3c4\ub85c \uc0c1\ud669\uc744 \ub354 \ubcf4\uc218\uc801\uc73c\ub85c \uc7a1\ub294 \ud3b8\uc774 \uacb0\uacfc\uac00 \uc88b\uc2b5\ub2c8\ub2e4. \uc0b0\uc545 \uc9c0\uc5ed \ud2b9\uc131\uc0c1 \ud55c \ubc88 \uc5b4\uae0b\ub09c \ubcc0\uc218\ub294 \ubc14\ub85c \ubcf5\uadc0 \uc2dc\uac04\uacfc \uc219\uc18c \ub3c4\ucc29 \uc2dc\uac04\uc5d0 \uc601\ud5a5\uc744 \uc90d\ub2c8\ub2e4. \uadf8\ub798\uc11c \ub098\ub780\uc5d0\uc11c\ub294 \u201c\uc5bc\ub9c8\ub098 \ub9ce\uc774 \ubcfc\uae4c\u201d\ubcf4\ub2e4 \u201c\uc5b4\ub514\uae4c\uc9c0 \ubb34\ub9ac \uc5c6\uc774 \ub2eb\uc744 \uc218 \uc788\uc744\uae4c\u201d\ub97c \uba3c\uc800 \uc815\ud574\uc57c \ud569\ub2c8\ub2e4. \uc774 \uae30\uc900\uc774 \uc788\uc5b4\uc57c \ud48d\uacbd\uc774 \ubcf4\uc774\uace0, \uc5c6\uc73c\uba74 \ud48d\uacbd\ubcf4\ub2e4 \ud53c\ub85c\uac00 \uba3c\uc800 \ub0a8\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub098\ub780\uc5d0\uc11c \ud558\ub8e8\ub97c \uc904\uc774\ub294 \uacb0\uc815\uc774 \uc624\ud788\ub824 \uc88b\uc740 \uc120\ud0dd\uc774 \ub418\ub294 \uacbd\uc6b0<\/h2>\n<p>\ub0a0\uc528, \ud1b5\uc2e0, \ucc28\ub7c9 \uc0c1\ud669\uc774 \ud754\ub4e4\ub9b4 \ub54c\ub294 \uc77c\uc815\uc744 \uc904\uc774\ub294 \ud310\ub2e8\uc774 \uc18c\uadf9\uc801\uc778 \ub300\uc751\uc774 \uc544\ub2c8\ub77c \ub9ac\uc2a4\ud06c \uad00\ub9ac\uc785\ub2c8\ub2e4. \ud2b9\ud788 \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ub300\uccb4 \uc218\ub2e8\uc774 \uc81c\ud55c\ub418\uae30 \ub54c\ubb38\uc5d0, \ubb34\ub9ac\ud558\uac8c \uacc4\ud68d\uc744 \uc720\uc9c0\ud558\ub294 \ucabd\uc774 \uc804\uccb4 \uccb4\ub958\ub97c \ub9dd\uce58\uae30 \uc27d\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \ud575\uc2ec \uad6c\uac04\ub9cc \ub0a8\uae30\uace0 \ub098\uba38\uc9c0\ub97c \uc815\ub9ac\ud558\uba74 \uccb4\ub825\uacfc \ud310\ub2e8\ub825\uc744 \uc9c0\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub098\ub780\uc740 \uc131\uacfc \uc911\uc2ec \uc5ec\ud589\uc9c0\uac00 \uc544\ub2c8\ub77c, \ud604\uc7a5 \uc870\uac74\uc744 \ubc1b\uc544\ub4e4\uc774\ub294 \ubc29\uc2dd\uc774 \uc911\uc694\ud55c \uc0b0\uc545 \uc77c\uc815\ud615 \ubaa9\uc801\uc9c0\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\ub098\ub780\uc5d0\uc11c \uc2e4\uc81c\ub85c \uc5ec\ud589\uc744 \ub9dd\uce58\ub294 \ubcc0\uc218<\/h2>\n\n\n\n<p>\uac00\uc7a5 \ud070 \ubcc0\uc218\ub294 \ud48d\uacbd\uc774 \uc544\ub2c8\ub77c \uc774\ub3d9 \uc9c0\uc5f0\uc774 \uc5f0\uc1c4\uc801\uc73c\ub85c \uc313\uc774\ub294 \uc0c1\ud669\uc774\ub2e4. \ub3c4\ub85c, \ub0a0\uc528, \ud604\uae08, \ud1b5\uc2e0 \uc911 \ud558\ub098\ub9cc \ud754\ub4e4\ub824\ub3c4 \ud63c\uc790 \uc5ec\ud589\uc790\ub294 \ub300\uc751 \ube44\uc6a9\uc774 \uae09\uaca9\ud788 \uc62c\ub77c\uac00\ubbc0\ub85c, \uc5ec\uc720\uc77c\uacfc \ub300\uc548 \uc219\uc18c\ub97c \ud568\uaed8 \uc0dd\uac01\ud558\ub294 \ud3b8\uc774 \uc548\uc804\ud558\ub2e4.<\/p>\n\n\n\n\n\n<p>\ud30c\ud0a4\uc2a4\ud0c4 \ub098\ub780\uc740 \uae30\ub300\ubcf4\ub2e4 \uc900\ube44\uac00 \uba3c\uc800\uc778 \uc0b0\uc545 \uc5ec\ud589\uc9c0\ub2e4. \ub3c4\ub85c, \ub0a0\uc528, \uc219\uc18c, \ud604\uae08, \ud1b5\uc2e0\uc744 \ud655\uc778\ud558\uace0 \uc774\ub3d9\uc77c\uc744 \uc5ec\uc720 \uc788\uac8c \ub450\uba74 \ud63c\uc790\uc11c\ub3c4 \ud604\uc2e4\uc801\uc778 \uc77c\uc815\uc73c\ub85c \ub9cc\ub4e4 \uc218 \uc788\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ud30c\ud0a4\uc2a4\ud0c4 \ub098\ub780 \ud63c\uc790 \uc5ec\ud589\uc744 \uc900\ube44\ud560 \ub54c \ud544\uc694\ud55c \ub3c4\ub85c \uc774\ub3d9, \uc219\uc18c, \uc2dd\uc0ac, \ud604\uae08, \ud1b5\uc2e0, \ub0a0\uc528\uc640 \uc548\uc804 \uae30\uc900\uc744 \uc815\ub9ac\ud588\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":1204,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"backgroun