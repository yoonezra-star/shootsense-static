{"id":1222,"date":"2026-03-30T10:06:00","date_gmt":"2026-03-30T01:06:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1222"},"modified":"2026-06-12T14:24:11","modified_gmt":"2026-06-12T05:24:11","slug":"%ec%84%9c%eb%b9%84%ec%8a%a4%eb%b3%b4%eb%8b%a4-%ec%83%9d%ed%99%9c%ec%9d%b4-%eb%a8%bc%ec%a0%80%ec%98%80%eb%8d%98-%ea%b0%80%ec%99%80%ea%b3%a0%ec%97%90-%ec%99%b8%ea%b3%bd","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%84%9c%eb%b9%84%ec%8a%a4%eb%b3%b4%eb%8b%a4-%ec%83%9d%ed%99%9c%ec%9d%b4-%eb%a8%bc%ec%a0%80%ec%98%80%eb%8d%98-%ea%b0%80%ec%99%80%ea%b3%a0%ec%97%90-%ec%99%b8%ea%b3%bd\/","title":{"rendered":"\uc77c\ubcf8 \uac00\uc640\uace0\uc5d0 \uc678\uacfd \ud63c\uc790 \uc5ec\ud589: \uc11c\ube44\uc2a4\ubcf4\ub2e4 \uc0dd\ud65c\uc774 \uba3c\uc800 \ubcf4\uc774\ub294 \ub3d9\uc120"},"content":{"rendered":"\n<p>\uac00\uc640\uace0\uc5d0\ub294 \uc911\uc2ec \uad00\uad11 \uac70\ub9ac\ub85c \uc798 \uc54c\ub824\uc838 \uc788\uc9c0\ub9cc, \uc678\uacfd\uc73c\ub85c \uc870\uae08 \ubc97\uc5b4\ub098\uba74 \uc11c\ube44\uc2a4\ubcf4\ub2e4 \uc0dd\ud65c\uc758 \uc18d\ub3c4\uac00 \uba3c\uc800 \ubcf4\uc778\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc774 \ucc28\uc774\ub97c \uc774\ud574\ud558\uace0 \ub3d9\uc120\uc744 \uc881\uac8c \uc7a1\ub294 \uac83\uc774 \uc911\uc694\ud558\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc77c\ubcf8 \uac00\uc640\uace0\uc5d0 \uc678\uacfd\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \uc2e4\uc81c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c\ud55c \uac10\uc0c1\uc774\ub098 \ucd94\ucc9c \ubaa9\ub85d\uc774 \uc544\ub2c8\ub77c \uad50\ud1b5, \uc219\uc18c, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \ud558\ub8e8\ub97c \uc124\uacc4\ud558\ub294 \ub370 \ucd08\uc810\uc744 \ub454\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc77c\ubcf8 \uac00\uc640\uace0\uc5d0 \uc678\uacfd \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc740 \ub300\ud45c \uba85\uc18c\ub97c \ubaa8\ub450 \ucc0d\ub294 \ubaa9\uc801\uc9c0\ub77c\uae30\ubcf4\ub2e4, \uc911\uc2ec\ubd80 \ud63c\uc7a1\uc744 \ud53c\ud558\uace0 \uc0dd\ud65c\uad8c\uc744 \ucc9c\ucc9c\ud788 \uac77\ub294 \uc77c\uc815\uc5d0 \ub9de\ub2e4. \uc5ed\uacfc \uc911\uc2ec \uac70\ub9ac, \uc678\uacfd \uc0b0\ucc45 \uad6c\uac04\uc758 \uac70\ub9ac\ub97c \uba3c\uc800 \uacc4\uc0b0\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c \uc911\uc694\ud55c \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uac00\uc640\uace0\uc5d0 \uc911\uc2ec\ubd80 \uc774\ud6c4 \uc870\uc6a9\ud55c \uac70\ub9ac \uc0b0\ucc45, \uc0dd\ud65c\uad8c \uad00\ucc30<\/td><td>\ubaa9\uc801\uc774 \uba85\ud655\ud574\uc57c \uc870\uc6a9\ud55c \uc2dc\uac04\uc744 \uc2e4\ud328\ub85c \ubcf4\uc9c0 \uc54a\ub294\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\ub3c4\ucfc4\uad8c \uc5f4\ucc28, \uc5ed \uc704\uce58, \ub3c4\ubcf4 \ubcf5\uadc0 \uac00\ub2a5 \uac70\ub9ac \ud655\uc778<\/td><td>\ud63c\uc790 \uc774\ub3d9\ud560 \ub54c\ub294 \ud658\uc2b9\uacfc \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc9c1\uc811 \uad00\ub9ac\ud574\uc57c \ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ubc18\ub098\uc808\uc5d0\uc11c \ud558\ub8e8 \uc77c\uc815, \uc678\uacfd\uae4c\uc9c0 \ubcf4\uba74 \uc2dc\uac04 \uc5ec\uc720 \ud544\uc694<\/td><td>\ub3c4\ucc29 \uc2dc\uac04\uacfc \uc2dd\uc0ac \uc2dc\uac04\uc5d0 \ub530\ub77c \uccb4\uac10 \ub9cc\uc871\ub3c4\uac00 \ud06c\uac8c \ubc14\ub010\ub2e4<\/td><\/tr><tr><td>\ud575\uc2ec \ubcc0\uc218<\/td><td>\uc0c1\uc810 \ud734\ubb34, \ud574\uc9c8 \ubb34\ub835 \uc778\uc801, \uc5ed\uae4c\uc9c0 \ub3c4\ubcf4 \uac70\ub9ac<\/td><td>\uc791\uc740 \ubaa9\uc801\uc9c0\ub294 \ub0a0\uc528, \ud734\ubb34, \uad50\ud1b5 \uac04\uaca9\uc758 \uc601\ud5a5\uc774 \ud06c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc774 \ud63c\uc790 \uac77\uae30 \ud3b8\ud55c \uc774\uc720<\/h2>\n\n\n\n<p>\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc740 \ud63c\uc790 \uac78\uc73c\uba70 \uc911\uc2ec \uad00\uad11\uc9c0\uc640 \uc0dd\ud65c\uad8c\uc758 \ucc28\uc774\ub97c \ubcf4\uae30 \uc88b\ub2e4. \uc0ac\ub78c\uc774 \ub108\ubb34 \ub9ce\uc740 \uac70\ub9ac\uc5d0\uc11c \ubc97\uc5b4\ub098 \uc790\uae30 \uc18d\ub3c4\ub85c \uc6c0\uc9c1\uc77c \uc218 \uc788\ub2e4\ub294 \uc810\uc774 \uc7a5\uc810\uc774\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uad00\uad11\uc9c0\uc758 \uc720\uba85\ub3c4\ubcf4\ub2e4 \ud63c\uc790 \uc788\uc5b4\ub3c4 \uc2dc\uac04\uc774 \uc790\uc5f0\uc2a4\ub7fd\uac8c \ud750\ub974\ub294\uc9c0\uac00 \ub354 \uc911\uc694\ud558\ub2e4. \uc0ac\ub78c\uc774 \ub9ce\uc9c0 \uc54a\uc740 \ubaa9\uc801\uc9c0\ub294 \uacc4\ud68d\uc774 \uc57d\ud558\uba74 \uc2ec\uc2ec\ud574\uc9c0\uc9c0\ub9cc, \uae30\uc900\uc810\uc744 \uc7a1\uc73c\uba74 \uc624\ud788\ub824 \ud3b8\uc548\ud55c \uccb4\ub958\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc740 \ub3cc\uc544\uc624\ub294 \uae38\uc774 \ub04a\uae30\uc9c0 \uc54a\ub294\uc9c0 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\uac00\uc640\uace0\uc5d0\ub294 \ub3c4\ucfc4\uad8c\uc5d0\uc11c \uc811\uadfc\uc131\uc774 \uc88b\uc740 \ud3b8\uc774\uc9c0\ub9cc, \uc678\uacfd\uae4c\uc9c0 \uac78\uc73c\uba74 \uc5ed \ubcf5\uadc0 \uc2dc\uac04\uc774 \uae38\uc5b4\uc9c4\ub2e4. \ub3cc\uc544\uac08 \uc5f4\ucc28\ubcf4\ub2e4 \uc2e4\uc81c \uc5ed\uae4c\uc9c0 \uac77\ub294 \uc2dc\uac04\uc744 \uba3c\uc800 \uacc4\uc0b0\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uad6c\uac04<\/th><th>\uba3c\uc800 \ud655\uc778\ud560 \uac83<\/th><th>\ud604\uc7a5 \ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ucd9c\ubc1c \uc804<\/td><td>\uacf5\uc2dd \uad50\ud1b5\ud3b8\uacfc \ub9c8\uc9c0\ub9c9 \ubcf5\uadc0 \uc2dc\uac04<\/td><td>\ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \uc801\uc73c\uba74 \uc77c\uc815 \uc804\uccb4\ub97c \uc55e\ub2f9\uae34\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \uc815\ub958\uc7a5, \uc219\uc18c, \uc911\uc2ec \uac70\ub9ac \uc704\uce58<\/td><td>\uae38\uc744 \uc783\uc5c8\uc744 \ub54c \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\ub0ae \uc2dc\uac04<\/td><td>\ub300\ud45c \uc0b0\ucc45 \uad6c\uac04\uacfc \uc2dd\uc0ac \ud6c4\ubcf4<\/td><td>\uac00\uc7a5 \ubc1d\uace0 \uc774\ub3d9\ud558\uae30 \uc26c\uc6b4 \uc2dc\uac04\uc5d0 \ud575\uc2ec \uad6c\uac04\uc744 \ubcf8\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4 \ud6c4\ubc18<\/td><td>\uc778\uc801, \uc870\uba85, \ub2e4\uc74c \uc774\ub3d9\ud3b8<\/td><td>\ud63c\uc790\ub77c\uba74 \ud574\uc9c0\uae30 \uc804 \ubcf5\uadc0 \ud750\ub984\uc744 \ud655\uc815\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd \ub3d9\uc120\uc740 \uc0dd\ud65c \uace8\ubaa9 \ud558\ub098\ub85c \uc881\ud78c\ub2e4<\/h2>\n\n\n\n<p>\uc911\uc2ec \uad00\uad11 \uac70\ub9ac\uc5d0\uc11c \uc2dc\uc791\ud574 \uc678\uacfd \uc8fc\uac70\uc9c0\ub098 \uc870\uc6a9\ud55c \uc0c1\uc810\uac00\ub85c \uc870\uae08\ub9cc \ud655\uc7a5\ud558\ub294 \ubc29\uc2dd\uc774 \uc88b\ub2e4. \ucc98\uc74c\ubd80\ud130 \uc678\uacfd\uc744 \ud06c\uac8c \ub3cc\uba74 \uac77\ub294 \uc2dc\uac04\uc740 \uae38\uc5b4\uc9c0\uace0 \uc5ec\ud589\uc758 \ucd08\uc810\uc740 \ud750\ub824\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc5ec\ub7ec \uc9c0\uc810\uc744 \ube60\ub974\uac8c \uc5f0\uacb0\ud558\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \uc911\uc2ec \uad6c\uac04 \ud558\ub098\ub97c \uc815\ud574 \ubc18\ubcf5\ud574\uc11c \uac77\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\ub2e4. \ud63c\uc790\ub77c\uba74 \uc77c\uc815\uc744 \ub113\ud788\ub294 \uac83\ubcf4\ub2e4 \uc904\uc77c \uc218 \uc788\ub294 \uad6c\uc870\ub97c \ub9cc\ub4dc\ub294 \uac83\uc774 \ub354 \uc911\uc694\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd \uc219\uc18c\ub294 \uc5ed\uc138\uad8c\ubcf4\ub2e4 \uadc0\uac00 \ub3d9\uc120\uc744 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\ub300\ubd80\ubd84\uc740 \ub3c4\ucfc4\uad8c \ub2f9\uc77c\uce58\uae30\uac00 \ud604\uc2e4\uc801\uc774\ub2e4. 1\ubc15\uc744 \ud55c\ub2e4\uba74 \uad00\uad11 \uac70\ub9ac\ubcf4\ub2e4 \uc5ed \uc811\uadfc\uc131\uacfc \uc800\ub141 \uc2dd\uc0ac \uc120\ud0dd\uc9c0\ub97c \uc6b0\uc120\ud574\uc11c \uc219\uc18c\ub97c \uace0\ub974\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \uac00\uaca9\ubcf4\ub2e4 \ubcf5\uadc0 \ub3d9\uc120\uacfc \uc2dd\uc0ac \uc811\uadfc\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc870\uc6a9\ud55c \uc678\uacfd \uc219\uc18c\uac00 \ub9e4\ub825\uc801\uc73c\ub85c \ubcf4\uc5ec\ub3c4 \ubc24 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud558\uba74 \ud63c\uc790 \uc5ec\ud589\uc758 \ud53c\ub85c\uac00 \ud06c\uac8c \ub298\uc5b4\ub09c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc5d0\uc11c \ub04a\uc5b4 \uc26c\uc5b4\uc57c \ud3b8\ud55c \uad6c\uac04<\/h2>\n\n\n\n<p>\uc911\uc2ec\ubd80\ub294 \uc120\ud0dd\uc9c0\uac00 \ub9ce\uc9c0\ub9cc \uc678\uacfd\uc740 \uc601\uc5c5 \uc2dc\uac04\uc774 \uc81c\ud55c\uc801\uc77c \uc218 \uc788\ub2e4. \uc810\uc2ec\uc740 \uc911\uc2ec\ubd80\uc5d0\uc11c \ud574\uacb0\ud558\uace0 \uc678\uacfd \uc0b0\ucc45\uc740 \uc2dd\uc0ac \ud6c4 \uac00\ubccd\uac8c \ubc30\uce58\ud558\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub3c4\uc2dc\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc218\ubcf4\ub2e4 \uc601\uc5c5 \uc2dc\uac04\uacfc \uc26c\ub294 \ub0a0 \ud655\uc778\uc774 \uc911\uc694\ud558\ub2e4. \ud63c\uc790\ub77c\uba74 \uae34 \ub300\uae30\ub97c \ud53c\ud558\uae30 \uc704\ud574 \uc810\uc2ec \ud6c4\ubcf4\uc640 \uc26c\uc5b4\uac08 \uc7a5\uc18c\ub97c \ub530\ub85c \ud655\ubcf4\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc740 \ub2a6\uc740 \ubcf5\uadc0\ubcf4\ub2e4 \ub0ae \ud53c\ub85c \uad00\ub9ac\uac00 \uc911\uc694\ud558\ub2e4<\/h2>\n\n\n\n<p>\uc678\uacfd \uc0dd\ud65c\uad8c\uc740 \uc870\uc6a9\ud558\uc9c0\ub9cc \ud574\uac00 \uc9c4 \ub4a4\uc5d0\ub294 \uc778\uc801\uc774 \uc904 \uc218 \uc788\ub2e4. \ud63c\uc790\ub77c\uba74 \ub2a6\uc740 \uc2dc\uac04 \uace8\ubaa9 \uc0b0\ucc45\ubcf4\ub2e4 \uc5ed \ubc29\ud5a5 \ubcf5\uadc0\ub97c \uc6b0\uc120\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc758 \uc548\uc804\uc740 \uc704\ud5d8\ud55c \uc7a5\uc18c\ub97c \ud53c\ud558\ub294 \uac83\ub9cc\uc774 \uc544\ub2c8\ub77c, \ud53c\uace4\ud574\uc84c\uc744 \ub54c \ubc14\ub85c \uc77c\uc815\uc744 \uc904\uc77c \uc218 \uc788\ub294 \uad6c\uc870\ub97c \ub9cc\ub4dc\ub294 \uac83\uc774\ub2e4. \uc911\uc2ec \uac70\ub9ac\uc640 \uad50\ud1b5 \uac70\uc810\uc744 \uacc4\uc18d \uc758\uc2dd\ud558\uba74 \ud604\uc7a5 \ud310\ub2e8\uc774 \uc26c\uc6cc\uc9c4\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd \uc77c\uc815\uc758 \ube44\uc6a9 \ub300\ube44 \ub9cc\uc871\ub3c4<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc655\ubcf5 \uad50\ud1b5\ube44\uc640 \uc2dd\ube44 \uc911\uc2ec\uc73c\ub85c \uc7a1\uc73c\uba74 \ub41c\ub2e4. \uc219\ubc15 \uc5c6\uc774\ub3c4 \ucda9\ubd84\ud788 \ub2e4\ub140\uc62c \uc218 \uc788\uc9c0\ub9cc, \uc678\uacfd\uae4c\uc9c0 \ubcf4\ub824\uba74 \uc2dc\uac04 \ube44\uc6a9\uc744 \ub109\ub109\ud788 \uc7a1\uc544\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uc774\ub3d9 \ubc29\uc2dd\uacfc \uc219\uc18c \uc704\uce58\uc5d0\uc11c \ub354 \ud06c\uac8c \ub2ec\ub77c\uc9c4\ub2e4. \ub2f9\uc77c\uce58\uae30\ub294 \ube44\uc6a9\uc774 \ub0ae\uc9c0\ub9cc \uccb4\ub958 \uc2dc\uac04\uc774 \uc9e7\uace0, 1\ubc15\uc740 \ube44\uc6a9\uc774 \ub298\uc9c0\ub9cc \uac00\uc7a5 \uc870\uc6a9\ud55c \uc2dc\uac04\ub300\ub97c \ubcfc \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc5d0\uc11c \ud53c\ud574\uc57c \ud560 \uacfc\ud55c \uc655\ubcf5 \uc77c\uc815<\/h2>\n\n\n\n<p>\uac00\uc640\uace0\uc5d0 \uc911\uc2ec \uba85\uc18c, \uc678\uacfd \uc0b0\ucc45, \ub2e4\ub978 \uadfc\uad50 \ub3c4\uc2dc\ub97c \ud558\ub8e8\uc5d0 \ubaa8\ub450 \ubb36\ub294 \uc77c\uc815\uc740 \ud53c\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \ud63c\uc7a1\uacfc \ub3c4\ubcf4 \ud53c\ub85c\uac00 \uacb9\uce58\uba74 \uc678\uacfd\uc758 \uc7a5\uc810\uc774 \uac70\uc758 \ub0a8\uc9c0 \uc54a\ub294\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc774 \ud3b8\ud55c \uc5ec\ud589\uc790 \uc720\ud615<\/h2>\n\n\n\n<p>\ub3c4\ucfc4 \uadfc\uad50\uc5d0\uc11c \ub108\ubb34 \ubd90\ube44\uc9c0 \uc54a\ub294 \uc2dc\uac04\uc744 \ub9cc\ub4e4\uace0 \uc2f6\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \uad00\uad11 \uc11c\ube44\uc2a4\ubcf4\ub2e4 \uc2e4\uc81c \uc0dd\ud65c\uad8c \ubd84\uc704\uae30\ub97c \ubcf4\uace0 \uc2f6\uc740 \uc0ac\ub78c\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc774 \uc911\uc2ec\uc9c0\ubcf4\ub2e4 \ub354 \ud3b8\ud558\uac8c \ub290\uaef4\uc9c0\ub294 \uc870\uac74<\/h2>\n<p>\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc740 \ubcfc\uac70\ub9ac \ubc00\ub3c4\ub9cc \ubcf4\uba74 \uc911\uc2ec\uc9c0\ubcf4\ub2e4 \uc57d\ud574 \ubcf4\uc77c \uc218 \uc788\uc9c0\ub9cc, \ud63c\uc790 \uac77\ub294 \uc785\uc7a5\uc5d0\uc11c\ub294 \uc624\ud788\ub824 \ub9ac\ub4ec\uc774 \ub354 \ub2e8\uc21c\ud558\uace0 \uc548\uc815\uc801\uc77c \ub54c\uac00 \ub9ce\uc2b5\ub2c8\ub2e4. \uc0ac\ub78c\uc774 \ubab0\ub9ac\ub294 \uad6c\uac04\uc744 \ubc97\uc5b4\ub098\uba74 \uc2dd\uc0ac, \uc0b0\ucc45, \ubcf5\uadc0\ub97c \uac19\uc740 \ubc18\uacbd \uc548\uc5d0\uc11c \uc815\ub9ac\ud558\uae30 \uc26c\uc6cc\uc9c0\uae30 \ub54c\ubb38\uc785\ub2c8\ub2e4. \uadf8\ub798\uc11c \uc774 \uc9c0\uc5ed\uc758 \uc7a5\uc810\uc740 \ubb34\uc5c7\uc744 \ub354 \ub9ce\uc774 \ubcf4\ub290\ub0d0\ubcf4\ub2e4, \uc5bc\ub9c8\ub098 \ub35c \uc18c\ubaa8\ub418\uba74\uc11c \ud558\ub8e8\ub97c \uc815\ub9ac\ud560 \uc218 \uc788\ub290\ub0d0\uc5d0 \uc788\uc2b5\ub2c8\ub2e4. \uc678\uacfd\uc758 \uac00\uce58\ub294 \uc720\uba85\uc138\uac00 \uc544\ub2c8\ub77c \ud750\ub984 \uad00\ub9ac\uc5d0\uc11c \ub098\uc635\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc744 \uc9e7\uac8c \ub123\uc744 \ub54c \ub9cc\uc871\ub3c4\uac00 \ub192\uc544\uc9c0\ub294 \ubc29\uc2dd<\/h2>\n<p>\ubc18\ub098\uc808 \uc77c\uc815\uc73c\ub85c \ub123\uc744 \uacbd\uc6b0\uc5d0\ub294 \uc0dd\ud65c \uace8\ubaa9 \ud55c \ucd95\ub9cc \uc815\ud558\uace0, \uc2dd\uc0ac\uc640 \ud734\uc2dd\uc744 \uadf8 \uc8fc\ubcc0\uc5d0\uc11c \ud574\uacb0\ud558\ub294 \ud3b8\uc774 \uac00\uc7a5 \uc548\uc815\uc801\uc785\ub2c8\ub2e4. \uc774\ub3d9\uc744 \ub354 \ucd94\uac00\ud560\uc218\ub85d \uc678\uacfd\uc758 \uc7a5\uc810\uc740 \uc904\uc5b4\ub4e4\uace0, \uc911\uc2ec\ubd80\uc640 \ube44\uc2b7\ud55c \ud53c\ub85c\ub9cc \ub0a8\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc740 \ud655\uc7a5\ubcf4\ub2e4 \uc555\ucd95\uc774 \uc798 \ub9de\ub294 \uc720\ud615\uc774\ub77c\uc11c, \uc81c\ud55c\ub41c \ubc18\uacbd \uc548\uc5d0\uc11c \uc815\ub3c8\ub41c \uc2dc\uac04\uc744 \ubcf4\ub0b4\ub294 \ucabd\uc774 \uacb0\uacfc\uac00 \uc88b\uc2b5\ub2c8\ub2e4. \uc774 \uae30\uc900\uc774 \ub9de\uc73c\uba74 \uc9e7\uc740 \uccb4\ub958\ub3c4 \ucda9\ubd84\ud788 \uc120\uba85\ud574\uc9d1\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc744 \ub2e4\uc2dc \uace0\ub97c \uc774\uc720<\/h2>\n\n\n\n<p>\uc77c\ubcf8 \uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc740 \ub300\ud45c \ucf54\uc2a4 \ubc16\uc73c\ub85c \uc870\uae08\ub9cc \ubc97\uc5b4\ub098\ub3c4 \ub2e4\ub978 \ud45c\uc815\uc774 \ubcf4\uc774\ub294 \uacf3\uc774\ub2e4. \uc5ed \ubcf5\uadc0 \uc2dc\uac04\uacfc \uc2dd\uc0ac \uc704\uce58\ub97c \uba3c\uc800 \uc7a1\uc73c\uba74 \ud63c\uc790\uc11c\ub3c4 \ubd80\ub2f4 \uc5c6\ub294 \uadfc\uad50 \uc5ec\ud589\uc774 \ub41c\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc77c\ubcf8 \uac00\uc640\uace0\uc5d0 \uc678\uacfd\uc744 \ud63c\uc790 \u