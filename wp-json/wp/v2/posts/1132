{"id":1132,"date":"2026-03-04T18:26:00","date_gmt":"2026-03-04T09:26:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1132"},"modified":"2026-06-12T14:06:16","modified_gmt":"2026-06-12T05:06:16","slug":"%ea%b4%80%ea%b4%91%ea%b0%9d%ec%9d%b4-%ec%97%86%ec%96%b4%ec%84%9c-%ec%98%a4%ed%9e%88%eb%a0%a4-%ec%95%88%ec%a0%84%ed%96%88%eb%8d%98-%ec%82%ac%ec%99%80%eb%9d%bc","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ea%b4%80%ea%b4%91%ea%b0%9d%ec%9d%b4-%ec%97%86%ec%96%b4%ec%84%9c-%ec%98%a4%ed%9e%88%eb%a0%a4-%ec%95%88%ec%a0%84%ed%96%88%eb%8d%98-%ec%82%ac%ec%99%80%eb%9d%bc\/","title":{"rendered":"\uc77c\ubcf8 \uc0ac\uc640\ub77c \ud63c\uc790 \uc5ec\ud589: \uad00\uad11\uac1d\uc774 \uc801\uc5b4 \ub354 \ud3b8\ud55c \uc218\ub85c \ub9c8\uc744 \uc0b0\ucc45"},"content":{"rendered":"\n<p>\uc0ac\uc640\ub77c\ub294 \ud654\ub824\ud55c \ub300\ub3c4\uc2dc \uc5ec\ud589\uacfc\ub294 \ub2e4\ub978 \uacb0\uc744 \uac00\uc9c4 \uc218\ub85c \ub9c8\uc744\uc774\ub2e4. \uad00\uad11\uac1d\uc774 \uc801\uc740 \uc2dc\uac04\ub300\uc5d0\ub294 \uc624\ud788\ub824 \ud63c\uc790 \uac77\uae30 \ud3b8\ud558\uace0, \uae38\uc758 \ubc29\ud5a5\ub3c4 \ub2e8\uc21c\ud574 \uc870\uc6a9\ud55c \ud558\ub8e8\ub97c \ub9cc\ub4e4\uae30 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc77c\ubcf8 \uc0ac\uc640\ub77c\ub97c \ud63c\uc790 \uc5ec\ud589\ud560 \ub54c \ud544\uc694\ud55c \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc815\ubcf4\ud615 \uac00\uc774\ub4dc\ub2e4. \ub2e8\uc21c \uac10\uc0c1\ubcf4\ub2e4 \uad50\ud1b5, \uccb4\ub958 \uc2dc\uac04, \uc2dd\uc0ac, \uc548\uc804, \ubcf5\uadc0 \ub3d9\uc120\uc744 \uae30\uc900\uc73c\ub85c \uc2e4\uc81c \uc77c\uc815\uc744 \uc9e4 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud588\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc77c\ubcf8 \uc0ac\uc640\ub77c \uc5ec\ud589 \ud575\uc2ec \ud310\ub2e8\ud45c<\/h2>\n\n\n\n<p>\uc0ac\uc640\ub77c\ub294 \uc218\ub85c\uc640 \uc624\ub798\ub41c \uac70\ub9ac \ubd84\uc704\uae30\ub97c \uc911\uc2ec\uc73c\ub85c \ubcf4\ub294 \ubaa9\uc801\uc9c0\ub2e4. \uc77c\uc815\uc740 \uba40\ub9ac \ud655\uc7a5\ud558\uae30\ubcf4\ub2e4 \uc5ed\uacfc \uc218\ub85c \uad6c\uac04\uc744 \uae30\uc900\uc73c\ub85c \uc7a1\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud56d\ubaa9<\/th><th>\uad8c\uc7a5 \uae30\uc900<\/th><th>\ud655\uc778 \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uc218\ub85c \uc0b0\ucc45, \uc624\ub798\ub41c \uac70\ub9ac \uac10\uc0c1, \uc870\uc6a9\ud55c \ub2f9\uc77c\uce58\uae30<\/td><td>\ubaa9\uc801\uc774 \ubaa8\ud638\ud558\uba74 \uc870\uc6a9\ud55c \uc7a5\uc18c\ub97c \ubcfc\uac70\ub9ac \ubd80\uc871\uc73c\ub85c \uc624\ud574\ud558\uae30 \uc27d\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\ub3c4\ucfc4 \ub610\ub294 \uc9c0\ubc14\uad8c \ucd9c\ubc1c \uc5f4\ucc28\uc640 \ud658\uc2b9 \uc2dc\uac04 \ud655\uc778<\/td><td>\uc77c\ubcf8 \uc9c0\ubc29 \uc5ec\ud589\uc740 \ub9c9\ucc28\uc640 \ud658\uc2b9 \uc2dc\uac04\uc774 \uc77c\uc815 \uc804\uccb4\ub97c \uc88c\uc6b0\ud55c\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ubc18\ub098\uc808\uc5d0\uc11c \ud558\ub8e8 \uc77c\uc815\uc774 \uc801\ud569\ud558\uba70 1\ubc15\uc740 \uc5ec\uc720\ud615 \uc120\ud0dd<\/td><td>\uc9e7\uac8c \ubcfc\uc9c0, \ubc18\ub098\uc808 \uba38\ubb3c\uc9c0, 1\ubc15\ud560\uc9c0\uc5d0 \ub530\ub77c \ub9cc\uc871\ub3c4\uac00 \ub2ec\ub77c\uc9c4\ub2e4<\/td><\/tr><tr><td>\uc8fc\uc758 \ubcc0\uc218<\/td><td>\uc5f4\ucc28 \uac04\uaca9, \uc2dd\ub2f9 \uc601\uc5c5\uc77c, \ube44 \uc624\ub294 \ub0a0 \ubcf4\ud589 \ud53c\ub85c<\/td><td>\ub0a0\uc528, \uc601\uc5c5\uc77c, \uad50\ud1b5 \uac04\uaca9\uc744 \ud655\uc778\ud574\uc57c \ud604\uc7a5 \uc2a4\ud2b8\ub808\uc2a4\uac00 \uc904\uc5b4\ub4e0\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\uac00 \ud63c\ud589\uc5d0 \ub9de\ub294 \uc774\uc720\ub294 \ubc00\ub3c4\ubcf4\ub2e4 \uc5ec\ubc31\uc5d0 \uc788\ub2e4<\/h2>\n\n\n\n<p>\uc0ac\uc640\ub77c\ub294 \ud63c\uc790\uc11c \uc18d\ub3c4\ub97c \ub0ae\ucdb0 \uac77\uae30 \uc88b\ub2e4. \uc0ac\ub78c \ub9ce\uc740 \uad00\uad11\uc9c0\ucc98\ub7fc \uc904\uc744 \uc11c\uac70\ub098 \ub3d9\ud589\uc790\uc640 \uc77c\uc815\uc744 \ub9de\ucd9c \ud544\uc694\uac00 \uc801\uace0, \uc218\ub85c\ub97c \ub530\ub77c \uae30\uc900\uc810\uc744 \uc7a1\uae30 \uc27d\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc720\uba85\ub3c4\ubcf4\ub2e4 \uccb4\ub958 \uc548\uc815\uc131\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \uc0ac\ub78c\uc774 \uc801\uc740 \uacf3\uc740 \uc2ec\uc2ec\ud560 \uc218 \uc788\uc9c0\ub9cc, \ub3d9\uc120\uc774 \ub2e8\uc21c\ud558\uace0 \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc774 \uba85\ud655\ud558\uba74 \uc624\ud788\ub824 \ud63c\uc790 \uac77\uae30 \ud3b8\ud55c \ubaa9\uc801\uc9c0\uac00 \ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\ub294 \ub9c9\ucc28\ubcf4\ub2e4 \ub3cc\uc544\uc624\ub294 \ub8e8\ud2b8\uc758 \ub2e8\uc21c\ud568\uc774 \uc911\uc694\ud558\ub2e4<\/h2>\n\n\n\n<p>\uc0ac\uc640\ub77c\ub294 \ub300\ub3c4\uc2dc \uc911\uc2ec\ubd80\ucc98\ub7fc \uc5f4\ucc28 \uc120\ud0dd\uc9c0\uac00 \ucd18\ucd18\ud558\uc9c0 \uc54a\uc744 \uc218 \uc788\ub2e4. \ucd9c\ubc1c \uc804 \uc655\ubcf5 \ud658\uc2b9 \uc2dc\uac04\uacfc \ub9c8\uc9c0\ub9c9\uc73c\ub85c \uc5ec\uc720 \uc788\uac8c \ub3cc\uc544\uac08 \uc218 \uc788\ub294 \uc5f4\ucc28\ub97c \ud655\uc778\ud558\ub294 \uac83\uc774 \uc88b\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc900\ube44 \ub2e8\uacc4<\/th><th>\ud655\uc778\ud560 \ub0b4\uc6a9<\/th><th>\ud63c\uc790 \uc5ec\ud589 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\uc804\ub0a0<\/td><td>\uacf5\uc2dd \uad50\ud1b5 \uc2dc\uac04\ud45c\uc640 \ubcf5\uadc0\ud3b8<\/td><td>\ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \uc801\uc73c\uba74 \uc624\uc804 \ucd9c\ubc1c\ub85c \uace0\uc815\ud55c\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \ubc84\uc2a4 \uc815\ub958\uc7a5, \uc548\ub0b4\uc18c \uc704\uce58<\/td><td>\uae38\uc744 \uc783\uc5c8\uc744 \ub54c \ub3cc\uc544\uac08 \uae30\uc900\uc810\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><tr><td>\uc810\uc2ec \uc804\ud6c4<\/td><td>\uc2dd\ub2f9 \uc601\uc5c5 \uc5ec\ubd80\uc640 \ud734\uc2dd \uc7a5\uc18c<\/td><td>\uc791\uc740 \ub9c8\uc744\uc740 \uc601\uc5c5 \uc2dc\uac04\uc774 \uc9e7\uac70\ub098 \uc26c\ub294 \ub0a0\uc774 \uc788\uc744 \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4 \ud6c4\ubc18<\/td><td>\uc870\uba85, \uc778\uc801, \uc219\uc18c \ub610\ub294 \ucd9c\ubc1c\uc9c0 \ubc29\ud5a5<\/td><td>\ud63c\uc790\ub77c\uba74 \ud574\uc9c0\uae30 \uc804 \ubcf5\uadc0 \ud750\ub984\uc744 \ub9cc\ub4e0\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\ub294 \uc218\ub85c\ucd95 \ud558\ub098\ub85c \ub3d9\uc120\uc744 \uc815\ub9ac\ud558\ub294 \ud3b8\uc774 \ub0ab\ub2e4<\/h2>\n\n\n\n<p>\ub3d9\uc120\uc740 \uc5ed\uc5d0\uc11c \uc2dc\uc791\ud574 \uc218\ub85c\uc640 \uc624\ub798\ub41c \uac70\ub9ac \uc8fc\ubcc0\uc73c\ub85c \uc881\uac8c \uc7a1\ub294\ub2e4. \uc0ac\uc9c4\uc744 \ucc0d\uae30 \uc88b\uc740 \uc9c0\uc810\uc744 \ubaa8\ub450 \ub530\ub77c\uac00\uae30\ubcf4\ub2e4 \uc218\ub85c \ud55c \ucd95\uc744 \uae30\uc900\uc73c\ub85c \uac78\uc73c\uba74 \ud63c\uc790\uc11c\ub3c4 \ubc29\ud5a5\uc744 \uc783\uae30 \uc5b4\ub835\ub2e4.<\/p>\n\n\n\n<p>\uc77c\ubcf8 \uc9c0\ubc29 \uc18c\ub3c4\uc2dc\ub294 \uc5ec\ub7ec \uc9c0\uc810\uc744 \ube60\ub974\uac8c \ucc0d\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \ud55c \ubc29\ud5a5\uc73c\ub85c \uac77\uace0 \ub2e4\uc2dc \ub3cc\uc544\uc624\ub294 \ubc29\uc2dd\uc774 \uc548\uc815\uc801\uc774\ub2e4. \uc5ed\uc774\ub098 \uc815\ub958\uc7a5, \uc548\ub0b4\uc18c, \uc219\uc18c\ub97c \uae30\uc900\uc810\uc73c\ub85c \uc0bc\uc73c\uba74 \ud604\uc7a5\uc5d0\uc11c \uc77c\uc815\uc744 \uc904\uc774\uae30\ub3c4 \uc27d\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\ub294 1\ubc15\ubcf4\ub2e4 \ub2f9\uc77c \ub3d9\uc120 \uc644\uc131\ub3c4\uac00 \ub354 \uc911\uc694\ud560 \uc218 \uc788\ub2e4<\/h2>\n\n\n\n<p>\ub300\ubd80\ubd84\uc740 \ub2f9\uc77c\uce58\uae30\uac00 \ud604\uc2e4\uc801\uc774\ub2e4. 1\ubc15\uc744 \ud55c\ub2e4\uba74 \uc5ed\uacfc \uc911\uc2ec \uac70\ub9ac \uc811\uadfc\uc131\uc744 \ud568\uaed8 \ubd10\uc57c \ud558\uba70, \uc800\ub141 \uc2dd\uc0ac \uc120\ud0dd\uc9c0\uac00 \uc904\uc5b4\ub4e4 \uc218 \uc788\ub2e4\ub294 \uc810\uc744 \uac10\uc548\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub294 \ubd84\uc704\uae30\ubcf4\ub2e4 \uc811\uadfc\uc131\uc744 \uba3c\uc800 \ubd10\uc57c \ud55c\ub2e4. \uc678\uacfd \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \uc800\ub141 \uc2dd\uc0ac\uc640 \uccb4\ud06c\uc778, \uc9d0 \uc774\ub3d9\uc774 \ubd88\ud3b8\ud560 \uc218 \uc788\uc73c\ubbc0\ub85c \ud63c\uc790\ub77c\uba74 \uad50\ud1b5 \uac70\uc810\uacfc \uc2dd\uc0ac \uac00\ub2a5 \uad6c\uc5ed \uc0ac\uc774\uac00 \uac00\uc7a5 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c \uc218\ub85c \uc0b0\ucc45 \uc911 \uc26c\uc5b4\uc57c \ud558\ub294 \uc9c0\uc810<\/h2>\n\n\n\n<p>\uc810\uc2ec \uc2dc\uac04\uc5d0 \ub9de\ucdb0 \ub3c4\ucc29\ud558\uba74 \uc2dd\uc0ac \uc120\ud0dd\uc9c0\uac00 \ube44\uad50\uc801 \uc548\uc815\uc801\uc774\ub2e4. \ub2e4\ub9cc \uc9c0\ubc29 \uc18c\ub3c4\uc2dc\ub294 \uc26c\ub294 \ub0a0\uc774 \uc788\uc744 \uc218 \uc788\uc73c\ubbc0\ub85c \ubc29\ubb38 \uc804 \uc601\uc5c5\uc77c\uc744 \ud655\uc778\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub9c8\uc744\uc5d0\uc11c\ub294 \ub9db\uc9d1\ubcf4\ub2e4 \uc601\uc5c5\uc77c\uacfc \uc601\uc5c5 \uc2dc\uac04\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \uc810\uc2ec \ud6c4\ubcf4\ub97c 2\uacf3 \uc774\uc0c1 \ub450\uace0, \uc2dd\ub2f9\uc774 \ub2eb\ud614\uc744 \ub54c\ub97c \ub300\ube44\ud574 \ud3b8\uc758\uc810\uc774\ub098 \uac04\ub2e8\ud55c \uac04\uc2dd \ud655\ubcf4 \uc5ec\ubd80\ub97c \ud655\uc778\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\ub294 \uc800\ub141 \uc2dc\uac04\ub300 \uc774\ub3d9 \uacf5\ubc31\uc744 \uc904\uc5ec\uc57c \ud3b8\ud558\ub2e4<\/h2>\n\n\n\n<p>\uad00\uad11\uac1d\uc774 \uc801\uc740 \uc2dc\uac04\ub300\uc5d0\ub3c4 \uc8fc\uc694 \uc218\ub85c\uc640 \uc911\uc2ec \uac70\ub9ac \uc8fc\ubcc0\uc740 \uac77\uae30 \ud3b8\ud558\ub2e4. \ub2e4\ub9cc \ud574\uac00 \uc9c4 \ub4a4 \uc678\uc9c4 \uace8\ubaa9\uc744 \uae38\uac8c \uac77\ub294 \uc77c\uc815\uc740 \ud53c\ud558\uace0, \uc5ed \ubc29\ud5a5\uc744 \uacc4\uc18d \uc758\uc2dd\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc0ac\ub78c\uc774 \uc801\uc740 \uae38\uc774 \ud56d\uc0c1 \uc704\ud5d8\ud558\ub2e4\ub294 \ub73b\uc740 \uc544\ub2c8\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ub2a6\uc740 \uc2dc\uac04\uacfc \uc678\uc9c4 \uae38\uc744 \ub3d9\uc2dc\uc5d0 \ub9cc\ub4e4\uc9c0 \uc54a\ub294 \uac83\uc774 \uc6d0\uce59\uc774\ub2e4. \uc0ac\uc9c4\uc744 \ub354 \ucc0d\uae30\ubcf4\ub2e4 \ubcf5\uadc0\uac00 \uc26c\uc6b4 \uc2dc\uac04\ub300\uc5d0 \uc6c0\uc9c1\uc774\ub294 \ud3b8\uc774 \uacb0\uacfc\uc801\uc73c\ub85c \uc5ec\ud589 \ub9cc\uc871\ub3c4\ub97c \ub192\uc778\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c \uc77c\uc815\uc740 \uc774\ub3d9\ube44\ubcf4\ub2e4 \uccb4\ub958 \uc2dc\uac04\uc744 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\uc0ac\uc640\ub77c \uc5ec\ud589 \uc608\uc0b0\uc740 \uc655\ubcf5 \uad50\ud1b5\ube44\uc640 \uc2dd\ube44 \uc911\uc2ec\uc73c\ub85c \uc7a1\uc73c\uba74 \ub41c\ub2e4. \uc785\uc7a5\ud615 \uad00\uad11\ubcf4\ub2e4 \uc0b0\ucc45 \ube44\uc911\uc774 \ub192\uc544 \uacfc\uc18c\ube44 \uac00\ub2a5\uc131\uc740 \ub0ae\uc9c0\ub9cc, \uad50\ud1b5 \uc2dc\uac04\uc774 \uae38\uba74 \ud558\ub8e8 \ud6a8\uc728\uc740 \ub5a8\uc5b4\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uad50\ud1b5\uacfc \uc219\ubc15\uc5d0\uc11c \ucc28\uc774\uac00 \ub09c\ub2e4. \ub2f9\uc77c\uce58\uae30\ub77c\uba74 \ubcf5\uadc0 \uc2dc\uac04\uc744 \uc783\uc9c0 \uc54a\ub294 \uad50\ud1b5\ud3b8\uc774 \uc911\uc694\ud558\uace0, 1\ubc15\uc774\ub77c\uba74 \uc219\uc18c \uc704\uce58\uac00 \ub2e4\uc74c \ub0a0 \uc774\ub3d9\uae4c\uc9c0 \uc601\ud5a5\uc744 \uc900\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\uac00 \uc798 \ub9de\ub294 \ud63c\ud589 \ub9ac\ub4ec<\/h2>\n\n\n\n<p>\uc870\uc6a9\ud55c \uc77c\ubcf8 \uc18c\ub3c4\uc2dc, \uc218\ub85c \ud48d\uacbd, \uc624\ub798\ub41c \uac70\ub9ac \ubd84\uc704\uae30\ub97c \uc88b\uc544\ud558\ub294 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ub9de\ub294\ub2e4. \ub300\ub3c4\uc2dc \uc77c\uc815 \uc911 \ud558\ub8e8\ub97c \ub0ae\uc740 \ubc00\ub3c4\ub85c \uc4f0\uace0 \uc2f6\uc740 \uacbd\uc6b0 \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\uc5d0\uc11c \uc624\ub798 \uac77\uae30 \uc804\uc5d0 \uba3c\uc800 \uc815\ud574\uc57c \ud558\ub294 \ubcf5\uadc0 \uae30\uc900<\/h2>\n<p>\uc0ac\uc640\ub77c\ub294 \uace8\ubaa9\uacfc \uc218\ub85c \uc8fc\ubcc0\uc774 \ud3b8\uc548\ud574\uc11c \uc0dd\uac01\ubcf4\ub2e4 \uc624\ub798 \uac77\uac8c \ub418\uc9c0\ub9cc, \uc2e4\uc81c \ub9cc\uc871\ub3c4\ub294 \uc0b0\ucc45 \uc790\uccb4\ubcf4\ub2e4 \ubcf5\uadc0\ub97c \uc5b4\ub5bb\uac8c \uc815\ub9ac\ud588\ub294\uc9c0\uc5d0 \ud06c\uac8c \uc88c\uc6b0\ub429\ub2c8\ub2e4. \uc5ed\uc73c\ub85c \ub3cc\uc544\uac00\ub294 \uc2dc\uac04, \uc800\ub141 \uc774\ud6c4 \ubb38\uc744 \ub2eb\ub294 \uac00\uac8c \ube44\uc728, \uc9d0 \ubcf4\uad00 \uc5ec\ubd80\ucc98\ub7fc \ub9c8\uc9c0\ub9c9 \ud55c \uc2dc\uac04\uc744 \uc548\uc815\uc801\uc73c\ub85c \ub9c8\ubb34\ub9ac\ud560 \uc218 \uc788\ub294 \uc870\uac74\uc744 \uba3c\uc800 \uc7a1\uc544\ub450\uba74 \uc0b0\ucc45\uc758 \uc5ec\ubc31\uc774 \uc7a5\uc810\uc73c\ub85c \uc791\ub3d9\ud569\ub2c8\ub2e4. \ubc18\ub300\ub85c \ubcf5\uadc0 \uae30\uc900 \uc5c6\uc774 \uac77\uae30\ub9cc \ub298\ub9ac\uba74 \ud55c\uc801\ud568\uc774 \uace7\ubc14\ub85c \uc560\ub9e4\ud568\uc73c\ub85c \ubc14\ub014 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\ub97c \ub2f9\uc77c\uce58\uae30\ub85c \ub123\uc744 \ub54c \uae30\ub300\uce58\ub97c \uc870\uc808\ud558\ub294 \ubc29\ubc95<\/h2>\n<p>\uc0ac\uc640\ub77c\ub294 \uac15\ud55c \ubcfc\uac70\ub9ac\ubcf4\ub2e4 \ud750\ub984\uc774 \uc815\ub3c8\ub41c \ub9c8\uc744\uc744 \ucc9c\ucc9c\ud788 \ubcf4\ub294 \ucabd\uc5d0 \uac00\uae5d\uae30 \ub54c\ubb38\uc5d0, \ub2f9\uc77c\uce58\uae30\ub85c \ub123\uc744 \ub54c\ub294 \u201c\ubb34\uc5c7\uc744 \ub9ce\uc774 \ubcfc\uae4c\u201d\ubcf4\ub2e4 \u201c\uc5b4\ub5a4 \uc18d\ub3c4\ub85c \uba38\ubb3c\uae4c\u201d\ub97c \uba3c\uc800 \uc815\ud558\ub294 \ud3b8\uc774 \ub0ab\uc2b5\ub2c8\ub2e4. \uc0ac\uc9c4 \uba85\uc18c\ub97c \uc5f0\uc18d\ud574\uc11c \ucc0d\ub294 \uc77c\uc815\uacfc\ub294 \uacb0\uc774 \ub2e4\ub974\uace0, \uc218\ub85c\uc640 \uc0c1\uc810\uac00\ub97c \ubc18\ubcf5\ud574\uc11c \uc9c0\ub098\uba70 \ubd84\uc704\uae30\ub97c \ud655\uc778\ud558\ub294 \uc2dc\uac04\uc774 \ud575\uc2ec\uc774 \ub429\ub2c8\ub2e4. \uc774 \uae30\ub300\uce58\uac00 \ub9de\ub294 \uc0ac\ub78c\uc5d0\uac8c\ub294 \uc9e7\uc740 \ubc29\ubb38\ub3c4 \ucda9\ubd84\ud788 \ub9cc\uc871\uc2a4\ub7fd\uc9c0\ub9cc, \uc989\uac01\uc801\uc778 \uc790\uadf9\uc744 \uae30\ub300\ud558\uba74 \ud3c9\uac00\uac00 \ub0ae\uc544\uc9c8 \uac00\ub2a5\uc131\uc774 \ud07d\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc0ac\uc640\ub77c\ub294 \ubd90\ube44\uc9c0 \uc54a\uc744 \ub54c \uac15\uc810\uc774 \ubd84\uba85\ud574\uc9c4\ub2e4<\/h2>\n\n\n\n<p>\uc77c\ubcf8 \uc0ac\uc640\ub77c\ub294 \uad00\uad11\uac1d\uc774 \uc801\uc5b4\uc11c \ubd88\uc548\ud55c \uacf3\uc774 \uc544\ub2c8\ub77c, \ub3d9\uc120\uc744 \uc798 \uc7a1\uc73c\uba74 \ud63c\uc790 \ub354 \ud3b8\ud574\uc9c0\ub294 \ubaa9\uc801\uc9c0\ub2e4. \uc655\ubcf5 \uad50\ud1b5\uacfc \uc810\uc2ec \uc2dc\uac04\uc744 \uba3c\uc800 \uc815\ud558\uba74 \uc548\uc815\uc801\uc778 \ub2f9\uc77c \uc5ec\ud589\uc9c0\ub85c \ucda9\ubd84\ud558\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc77c\ubcf8 \uc0ac\uc640\ub77c \ud63c\uc790 \uc5ec\ud589\uc744 \uc704\ud55c \uc218\ub85c \uc0b0\ucc45, \uad50\ud1b5, \uc2dd\uc0ac, \uc548\uc804, \ub2f9\uc77c\uce58\uae30\uc640 1\ubc15 \ud310\ub2e8 \uae30\uc900\uc744 \uc815\ub9ac\ud55c \uc2e4\uc804 \uac00\uc774\ub4dc.<\/p>\n","protected":false},"author":1,"feature