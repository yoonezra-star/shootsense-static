{"id":387,"date":"2025-05-07T15:53:19","date_gmt":"2025-05-07T06:53:19","guid":{"rendered":"https:\/\/shootsense.com\/?p=387"},"modified":"2026-06-12T14:19:28","modified_gmt":"2026-06-12T05:19:28","slug":"honja-jeonju-yeohaeng-course","status":"publish","type":"post","link":"https:\/\/shootsense.com\/honja-jeonju-yeohaeng-course\/","title":{"rendered":"\ud63c\uc790 \uc804\uc8fc \uc5ec\ud589 \ucf54\uc2a4: \ud55c\uc625\ub9c8\uc744\uc744 \ubb34\ub9ac \uc5c6\uc774 \uac77\ub294 \ubc29\ubc95"},"content":{"rendered":"\n<p>\uc804\uc8fc\ub294 \ud63c\uc790 \uac77\uae30 \uc88b\uc740 \ub3c4\uc2dc\ub85c \uc54c\ub824\uc838 \uc788\uc9c0\ub9cc, \ud55c\uc625\ub9c8\uc744\ub9cc \ubcf4\uace0 \uc77c\uc815\uc744 \uc9dc\uba74 \uc5ec\ud589\uc774 \ub2e8\uc870\ub85c\uc6cc\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \uac1d\uc0ac, \ub0a8\ubd80\uc2dc\uc7a5, \uacbd\uae30\uc804, \uc804\ub3d9\uc131\ub2f9, \uc790\ub9cc\ubcbd\ud654\ub9c8\uc744\uc744 \ubaa8\ub450 \ub123\uc73c\uba74 \uac77\ub294 \uc591\uc774 \ub9ce\uc544\uc838 \ud53c\ub85c\uac00 \ucee4\uc9d1\ub2c8\ub2e4. \ud63c\uc790 \uc804\uc8fc\ub97c \uc5ec\ud589\ud560 \ub54c\ub294 \u201c\ud55c\uc625\ub9c8\uc744\uc744 \uc911\uc2ec\uc73c\ub85c \uc5bc\ub9c8\ub098 \ub113\ud790 \uac83\uc778\uac00\u201d\ub97c \uba3c\uc800 \uc815\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc804\uc8fc\ub97c \ucc98\uc74c \ud63c\uc790 \uc5ec\ud589\ud558\ub294 \uc0ac\ub78c\uc744 \uae30\uc900\uc73c\ub85c, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac, \ubc24 \ub3d9\uc120, \uac77\ub294 \ubc94\uc704, \uc26c\ub294 \uc2dc\uac04\uc744 \ud568\uaed8 \ud310\ub2e8\ud558\ub294 \ubc29\ubc95\uc744 \uc815\ub9ac\ud569\ub2c8\ub2e4. \ub9ce\uc774 \ubcf4\ub294 \uc5ec\ud589\ubcf4\ub2e4 \ub3cc\uc544\uc624\uae30 \uc26c\uc6b4 \uc5ec\ud589\uc744 \ub9cc\ub4dc\ub294 \uac83\uc774 \ud575\uc2ec\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"jeonju-core\">\uc804\uc8fc \ud63c\uc790 \uc5ec\ud589\uc758 \uc911\uc2ec\uc740 \ud55c\uc625\ub9c8\uc744\uc774\uc9c0\ub9cc \uc804\ubd80\ub294 \uc544\ub2d9\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc804\uc8fc \ucd08\ud589\uc774\ub77c\uba74 \ud55c\uc625\ub9c8\uc744\uc744 \uc911\uc2ec\uc5d0 \ub450\ub294 \uac83\uc774 \uac00\uc7a5 \uc27d\uc2b5\ub2c8\ub2e4. \uc8fc\uc694 \uba85\uc18c\uac00 \ubaa8\uc5ec \uc788\uace0, \uce74\ud398\uc640 \uc2dd\ub2f9\uc774 \ub9ce\uc544 \ud63c\uc790 \uc788\uc5b4\ub3c4 \uc5b4\uc0c9\ud568\uc774 \ub35c\ud569\ub2c8\ub2e4. \ub2e4\ub9cc \uc8fc\ub9d0\uc5d0\ub294 \uc0ac\ub78c\uc774 \ub9ce\uace0, \uc0ac\uc9c4 \uc911\uc2ec \ub3d9\uc120\uc73c\ub85c \ud750\ub974\uba74 \uc2e4\uc81c\ub85c \uc26c\ub294 \uc2dc\uac04\uc774 \ubd80\uc871\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc5ec\ud589\uc790 \uc0c1\ud669<\/th><th>\ucd94\ucc9c \uc911\uc2ec<\/th><th>\uc8fc\uc758\uc810<\/th><\/tr><\/thead><tbody><tr><td>\uccab \uc804\uc8fc \ud63c\ud589<\/td><td>\ud55c\uc625\ub9c8\uc744, \uacbd\uae30\uc804, \uc804\ub3d9\uc131\ub2f9<\/td><td>\uc8fc\ub9d0 \ud63c\uc7a1 \uc2dc\uac04\ub300\ub97c \ud53c\ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uba39\uac70\ub9ac \uc911\uc2ec<\/td><td>\ub0a8\ubd80\uc2dc\uc7a5, \uac1d\uc0ac \uc8fc\ubcc0, \ud55c\uc625\ub9c8\uc744 \uace8\ubaa9<\/td><td>\ub300\uae30 \ub9ce\uc740 \uc2dd\ub2f9\uc5d0 \uc77c\uc815\uc774 \ub04c\ub824\uac00\uc9c0 \uc54a\uac8c \ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>\uc870\uc6a9\ud55c \uc5ec\ud589<\/td><td>\uc624\uc804 \uc0b0\ucc45, \uce74\ud398, \uc219\uc18c \uc8fc\ubcc0 \ud734\uc2dd<\/td><td>\uc624\ud6c4 \ub2a6\uac8c \uba85\uc18c\ub97c \ubab0\uc544\ub123\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/td><\/tr><tr><td>\ub69c\ubc85\uc774 \uc5ec\ud589<\/td><td>\ub3c4\ubcf4\uad8c \uc911\uc2ec<\/td><td>\uc790\ub9cc\ubcbd\ud654\ub9c8\uc744\ucc98\ub7fc \uc624\ub974\ub9c9\uc774 \uc788\ub294 \uacf3\uc740 \uccb4\ub825\uc744 \uace0\ub824\ud569\ub2c8\ub2e4.<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"jeonju-route\">\ub3d9\uc120\uc740 \ud55c\uc625\ub9c8\uc744 \uc548\uacfc \ubc16\uc744 \ub098\ub220\uc57c \ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc804\uc8fc\ub294 \uc9c0\ub3c4\uc0c1 \uac00\uae4c\uc6cc \ubcf4\uc5ec\ub3c4 \uc2e4\uc81c\ub85c\ub294 \uac77\ub294 \uc2dc\uac04\uc774 \uae38\uac8c \ub290\uaef4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uace8\ubaa9\uc744 \ub3cc\uc544\ubcf4\uace0, \uc0ac\uc9c4\uc744 \ucc0d\uace0, \uc2dd\uc0ac \ub300\uae30\ub97c \ud558\ub2e4 \ubcf4\uba74 \ud55c\ub450 \uc2dc\uac04\uc774 \uc27d\uac8c \uc9c0\ub098\uac11\ub2c8\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ub3d9\ud589\uc790\uc640 \uc5ed\ud560\uc744 \ub098\ub20c \uc218 \uc5c6\uae30 \ub54c\ubb38\uc5d0 \uae38 \ucc3e\uae30, \uc2dd\ub2f9 \uc120\ud0dd, \ud734\uc2dd \ud310\ub2e8\uc744 \ubaa8\ub450 \ud63c\uc790 \ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\ucd08\ubcf4\uc790\ub77c\uba74 \uc624\uc804\uc5d0\ub294 \ud55c\uc625\ub9c8\uc744 \uc548\ucabd\uc744 \ucc9c\ucc9c\ud788 \uac77\uace0, \uc624\ud6c4\uc5d0\ub294 \uac1d\uc0ac\ub098 \ub0a8\ubd80\uc2dc\uc7a5\ucc98\ub7fc \ud55c\uc625\ub9c8\uc744 \ubc16 \ud55c \uacf3\ub9cc \ucd94\uac00\ud558\ub294 \uc2dd\uc774 \uc88b\uc2b5\ub2c8\ub2e4. \ubc24\uc5d0\ub294 \uc219\uc18c \uc8fc\ubcc0\uc73c\ub85c \ub3cc\uc544\uc640 \uc2dd\uc0ac\uc640 \uc0b0\ucc45\uc744 \uc9e7\uac8c \uc815\ub9ac\ud558\ub294 \ud3b8\uc774 \uc548\uc804\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"jeonju-sample\">\uc804\uc8fc 1\ubc15 2\uc77c \ud63c\ud589 \uc608\uc2dc<\/h2>\n\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc2dc\uac04\ub300<\/th><th>\uad8c\uc7a5 \ub3d9\uc120<\/th><th>\ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>1\uc77c\ucc28 \ub0ae<\/td><td>\uc804\uc8fc \ub3c4\ucc29, \uc219\uc18c \uc9d0 \ubcf4\uad00, \ud55c\uc625\ub9c8\uc744 \uc785\uc7a5<\/td><td>\ub3c4\ucc29 \uc9c1\ud6c4 \ub113\uac8c \uc774\ub3d9\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<\/td><\/tr><tr><td>1\uc77c\ucc28 \uc624\ud6c4<\/td><td>\uacbd\uae30\uc804, \uc804\ub3d9\uc131\ub2f9, \uace8\ubaa9 \uce74\ud398<\/td><td>\uc0ac\uc9c4\ubcf4\ub2e4 \uac77\ub294 \ud53c\ub85c\ub97c \uae30\uc900\uc73c\ub85c \uc870\uc808\ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>1\uc77c\ucc28 \uc800\ub141<\/td><td>\ud55c\uc625\ub9c8\uc744 \ub610\ub294 \uc219\uc18c \uadfc\ucc98 \uc2dd\uc0ac<\/td><td>\ubc24 \ub3d9\uc120\uc740 \uc9e7\uac8c \uc720\uc9c0\ud569\ub2c8\ub2e4.<\/td><\/tr><tr><td>2\uc77c\ucc28 \uc624\uc804<\/td><td>\ub0a8\ubd80\uc2dc\uc7a5 \ub610\ub294 \uac1d\uc0ac \uc8fc\ubcc0<\/td><td>\ud55c \uacf3\ub9cc \uace8\ub77c \uc5ec\uc720 \uc788\uac8c \ubd05\ub2c8\ub2e4.<\/td><\/tr><tr><td>2\uc77c\ucc28 \uc624\ud6c4<\/td><td>\uae30\ub150\ud488, \uce74\ud398, \ud130\ubbf8\ub110\u00b7\uc5ed \ubcf5\uadc0<\/td><td>\ucd9c\ubc1c 1\uc2dc\uac04 \uc804\uc5d0\ub294 \ubcf5\uadc0 \ub3d9\uc120\uc744 \uc2dc\uc791\ud569\ub2c8\ub2e4.<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"jeonju-lodging\">\uc219\uc18c\ub294 \ubd84\uc704\uae30\ubcf4\ub2e4 \ubc24\uae38\uacfc \uc18c\uc74c \ud6c4\uae30\ub97c \ubd05\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc804\uc8fc \uc219\uc18c\ub294 \ud55c\uc625\uc2a4\ud14c\uc774, \uac8c\uc2a4\ud2b8\ud558\uc6b0\uc2a4, \ud638\ud154, \ubaa8\ud154\ud615 \uc219\uc18c \ub4f1 \uc120\ud0dd\uc9c0\uac00 \ub2e4\uc591\ud569\ub2c8\ub2e4. \ud63c\uc790 \uc5ec\ud589\uc774\ub77c\uba74 \ubd84\uc704\uae30\ubcf4\ub2e4 \ubc24\uc5d0 \ub3cc\uc544\uc624\uae30 \uc26c\uc6b4\uc9c0, \uc8fc\ubcc0\uc774 \ub108\ubb34 \uc5b4\ub461\uc9c0 \uc54a\uc740\uc9c0, \ubc29\uc74c\uacfc \uccad\uacb0 \ud6c4\uae30\uac00 \ubc18\ubcf5\uc801\uc73c\ub85c \ub098\uc624\ub294\uc9c0 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4. \ud55c\uc625 \uc219\uc18c\ub294 \ub9e4\ub825\uc801\uc774\uc9c0\ub9cc \uad6c\uc870\uc0c1 \ubc29\uc74c\uc774\ub098 \ud654\uc7a5\uc2e4 \ud3b8\uc758\uac00 \ub2e4\ub97c \uc218 \uc788\uc73c\ubbc0\ub85c \ud6c4\uae30\ub97c \uc138\ubc00\ud558\uac8c \ubd10\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c \uc120\ud0dd\uc740 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-sukso-goreuneun-beop\/\">\ud63c\uc790 \uc5ec\ud589 \uc219\uc18c \uace0\ub974\ub294 \ubc95<\/a> \uae30\uc900\uacfc \uc5f0\uacb0\ud574 \ubcf4\uba74 \uc88b\uc2b5\ub2c8\ub2e4. \uccb4\ud06c\uc778 \ud6c4\uc5d0\ub294 \ubb38 \uc7a0\uae08, \ucc3d\ubb38, \ube44\uc0c1 \uc5f0\ub77d\ucc98, \ubc24 \ubcf5\uadc0 \uacbd\ub85c\ub97c <a href=\"https:\/\/shootsense.com\/honja-sukso-anjeon-checklist\/\">\uc219\uc18c \uc548\uc804 \uc810\uac80<\/a> \uae30\uc900\uc73c\ub85c \ud655\uc778\ud558\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"jeonju-meal\">\uc804\uc8fc \ud63c\ubc25\uc740 \uba54\ub274\ubcf4\ub2e4 \uc2dc\uac04\ub300\uac00 \uc911\uc694\ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc804\uc8fc\ub294 \uba39\uac70\ub9ac \ub3c4\uc2dc\ub77c\ub294 \uc774\ubbf8\uc9c0\uac00 \uac15\ud558\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c\ub294 \uc2dd\uc0ac \uc2dc\uac04\ub300\uac00 \uc911\uc694\ud569\ub2c8\ub2e4. \uc810\uc2ec \ud53c\ud06c\uc5d0\ub294 \uc720\uba85 \uc2dd\ub2f9 \ub300\uae30\uac00 \uae38\uace0, \uc800\ub141\uc5d0\ub294 \ud63c\uc790 \ub4e4\uc5b4\uac00\uae30 \uc5b4\uc0c9\ud55c \ubd84\uc704\uae30\uc758 \uc2dd\ub2f9\ub3c4 \uc788\uc2b5\ub2c8\ub2e4. \ube44\ube54\ubc25, \ucf69\ub098\ubb3c\uad6d\ubc25, \ubd84\uc2dd, \uc2dc\uc7a5 \uc74c\uc2dd, \uce74\ud398 \uc2dd\uc0ac\ucc98\ub7fc \ud63c\uc790 \uc774\uc6a9\ud558\uae30 \uc26c\uc6b4 \ud6c4\ubcf4\ub97c \ubbf8\ub9ac \uc815\ud574 \ub450\uba74 \ubd80\ub2f4\uc774 \uc904\uc5b4\ub4ed\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc2dd\ub2f9\uc740 \ub9db\ubcf4\ub2e4 \uba3c\uc800 1\uc778 \uc774\uc6a9 \uac00\ub2a5\uc131, \uc88c\uc11d \uad6c\uc870, \uc8fc\ubb38 \ubc29\uc2dd, \ub300\uae30 \uc2dc\uac04\uc744 \ubd10\uc57c \ud569\ub2c8\ub2e4. \uc790\uc138\ud55c \uae30\uc900\uc740 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-sikdang-goreuneun-beop\/\">\ud63c\uc790 \uc5ec\ud589 \uc911 \uc2dd\ub2f9 \uace0\ub974\ub294 \ubc95<\/a>\uc5d0\uc11c \ud655\uc778\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"jeonju-avoid\">\uc804\uc8fc\uc5d0\uc11c \ud53c\ud574\uc57c \ud560 \uc77c\uc815 \uad6c\uc131<\/h2>\n\n\n\n<ul class=\"wp-block-list\"><li>\uc8fc\ub9d0 \uc624\ud6c4 \ud55c\uc625\ub9c8\uc744 \ud63c\uc7a1 \uc2dc\uac04\uc5d0 \ubaa8\ub4e0 \uba85\uc18c\ub97c \ubab0\uc544\ub123\ub294 \uc77c\uc815<\/li><li>\uc790\ub9cc\ubcbd\ud654\ub9c8\uc744, \uac1d\uc0ac, \ub0a8\ubd80\uc2dc\uc7a5, \ud55c\uc625\ub9c8\uc744\uc744 \ud558\ub8e8\uc5d0 \ubaa8\ub450 \uac77\ub294 \uc77c\uc815<\/li><li>\uc219\uc18c \uc704\uce58\ub97c \ubcf4\uc9c0 \uc54a\uace0 \ubd84\uc704\uae30\ub9cc \ubcf4\uace0 \uc608\uc57d\ud558\ub294 \uc120\ud0dd<\/li><li>\uc720\uba85 \uc2dd\ub2f9 \ub300\uae30 \uc2dc\uac04\uc744 \uace0\ub824\ud558\uc9c0 \uc54a\uc740 \uc2dd\uc0ac \uacc4\ud68d<\/li><\/ul>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"jeonju-checklist\">\uc804\uc8fc \ucd9c\ubc1c \uc804 \uccb4\ud06c\ub9ac\uc2a4\ud2b8<\/h2>\n\n\n\n<ul class=\"wp-block-list\"><li>\ud55c\uc625\ub9c8\uc744 \uc548\ucabd\uacfc \ubc14\uae65 \ub3d9\uc120\uc744 \ud558\ub8e8\uc5d0 \uc5b4\ub5bb\uac8c \ub098\ub20c\uc9c0 \uc815\ud569\ub2c8\ub2e4.<\/li><li>\uc219\uc18c\uc5d0\uc11c \ubc24 \uc2dd\uc0ac \uc7a5\uc18c\uae4c\uc9c0\uc758 \uae38\uc744 \uba3c\uc800 \ud655\uc778\ud569\ub2c8\ub2e4.<\/li><li>\uc2dd\ub2f9 \ud6c4\ubcf4\ub294 \uc720\uba85 \ub9db\uc9d1 \ud558\ub098\uc640 \ub300\uae30 \uc5c6\ub294 \ud6c4\ubcf4 \ud558\ub098\ub97c \ud568\uaed8 \ub461\ub2c8\ub2e4.<\/li><li>\uc9d0\uc740 \uc624\ub798 \uac77\ub294 \uc77c\uc815\uc5d0 \ub9de\uac8c \uc904\uc774\uace0, \ubcf4\uc870\ubc30\ud130\ub9ac\uc640 \uc219\uc18c \uc8fc\uc18c \ucea1\ucc98\ub97c \uc900\ube44\ud569\ub2c8\ub2e4.<\/li><li>\ubab8 \uc0c1\ud0dc\uac00 \uc88b\uc9c0 \uc54a\uc744 \ub54c \ubc14\ub85c \uc904\uc77c \uc218 \uc788\ub294 \uc7a5\uc18c\ub97c \uc815\ud574 \ub461\ub2c8\ub2e4.<\/li><\/ul>\n\n\n\n<h2 class=\"wp-block-heading\">\uc804\uc8fc \ud63c\ud589\uc5d0\uc11c \ud55c\uc625\ub9c8\uc744\ub9cc\uc73c\ub85c \ud558\ub8e8\ub97c \ucc44\uc6b0\uae30 \uc5b4\ub824\uc6b4 \uc774\uc720<\/h2>\n<p>\uc804\uc8fc\ub294 \ud55c\uc625\ub9c8\uc744\uc774 \uc911\uc2ec\uc774 \ub9de\uc9c0\ub9cc, \ucc98\uc74c \ubc29\ubb38\ud55c \ud63c\ud589\uc790\uc77c\uc218\ub85d \uadf8 \uc548\uc5d0 \ub108\ubb34 \ub9ce\uc740 \uae30\ub300\ub97c \uac78\uae30 \uc27d\uc2b5\ub2c8\ub2e4. \uc2e4\uc81c\ub85c\ub294 \uac77\ub294 \uc2dc\uac04\uacfc \uc26c\ub294 \uc2dc\uac04, \uc2dd\uc0ac \ub300\uae30, \uce74\ud398 \ud734\uc2dd\uc774 \ud568\uaed8 \ub4e4\uc5b4\uac00\uc57c \ud558\ub8e8 \ud750\ub984\uc774 \uc548\uc815\ub429\ub2c8\ub2e4. \uadf8\ub798\uc11c \ud55c\uc625\ub9c8\uc744\ub9cc \ubcf8\ub2e4\uace0 \ud574\ub3c4 \ub3d9\uc120\uc774 \ub2e8\uc870\ub86d\uc9c0 \uc54a\uac8c \uc27c\ud45c\ub97c \ub123\ub294 \uc124\uacc4\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc774 \uae30\uc900 \uc5c6\uc774 \uba85\uc18c\ub9cc \ub530\ub77c\uac00\uba74 \uc804\uc8fc\ub294 \ud48d\uc131\ud55c \ub3c4\uc2dc\uac00 \uc544\ub2c8\ub77c \uae08\ubc29 \uc9c0\uce58\ub294 \uad00\uad11\uc9c0\ub85c \ub290\uaef4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc804\uc8fc\uc5d0\uc11c \uc219\uc18c \uc704\uce58\uac00 \ubd84\uc704\uae30\ubcf4\ub2e4 \uc911\uc694\ud55c \uc2e4\uc81c \uc774\uc720<\/h2>\n<p>\uc57c\uac04 \uc0b0\ucc45\uacfc \uc544\uce68 \uc774\ub3d9\uc774 \ubaa8\ub450 \uc788\ub294 \ub3c4\uc2dc\uc5d0\uc11c\ub294 \uc219\uc18c \uc704\uce58\uac00 \uc5ec\ud589 \ud488\uc9c8\uc744 \ud06c\uac8c \ubc14\uafc9\ub2c8\ub2e4. \uc804\uc8fc\ub294 \ub0ae\ubcf4\ub2e4 \ubc24\uc5d0 \uace8\ubaa9 \ubd84\uc704\uae30\ub97c \uc990\uae30\uace0 \uc2f6\uc5b4\uc9c0\ub294 \uacbd\uc6b0\uac00 \ub9ce\uc740\ub370, \uadf8\ub7f4\uc218\ub85d \uadc0\uac00 \ub3d9\uc120\uacfc \uc18c\uc74c \uc218\uc900\uc744 \uac19\uc774 \ubd10\uc57c \ud569\ub2c8\ub2e4. \uc219\uc18c\uac00 \ud55c\uc625 \uac10\uc131\ub9cc \uc88b\uace0 \uc2e4\uc81c \uc774\ub3d9\uc774 \ubd88\ud3b8\ud558\uba74 \ud558\ub8e8 \ub05d\uc774 \ud53c\uace4\ud574\uc9c0\uace0, \ub2e4\uc74c \ub0a0 \uc2dc\uc791\ub3c4 \ubb34\uac70\uc6cc\uc9d1\ub2c8\ub2e4. \uc804\uc8fc\ub294 \ucf54\uc2a4 \ucd94\ucc9c\ubcf4\ub2e4 \uc219\uc18c-\uc0b0\ucc45-\uc2dd\uc0ac\uc758 \uc5f0\uacb0\uc131\uc744 \ub9de\ucd94\ub294 \ud3b8\uc774 \ub354 \uc2e4\uc804\uc801\uc785\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\" id=\"jeonju-faq\">\uc804\uc8fc \uc77c\uc815 \uc804\uc5d0 \ud655\uc778\ud560 \ud604\uc2e4 \uc9c8\ubb38<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">Q1. \uc804\uc8fc\ub294 \ud63c\uc790 \uc5ec\ud589\ud558\uae30 \uc548\uc804\ud55c \ud3b8\uc778\uac00\uc694?<\/h3>\n\n\n<p>\uc8fc\uc694 \uad00\uad11\uc9c0 \uae30\uc900\uc73c\ub85c\ub294 \ud63c\uc790 \uc5ec\ud589\ud558\uae30 \ud3b8\ud55c \ud3b8\uc785\ub2c8\ub2e4. \ub2e4\ub9cc \ubc24\uae38\uacfc \uc219\uc18c \uc704\uce58\ub294 \ubcc4\ub3c4\ub85c \ud655\uc778\ud574\uc57c \ud558\uba70, \ub2a6\uc740 \uc2dc\uac04\uc5d0\ub294 \uc774\ub3d9 \ubc94\uc704\ub97c \uc904\uc774\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q2. \uc804\uc8fc \ud55c\uc625\ub9c8\uc744\ub9cc \ubd10\ub3c4 \ucda9\ubd84\ud55c\uac00\uc694?<\/h3>\n\n\n<p>\ucd08\ud589 1\ubc15 2\uc77c\uc774\ub77c\uba74 \ucda9\ubd84\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubb34\ub9ac\ud574\uc11c \uc678\uacfd\uae4c\uc9c0 \ub113\ud788\uae30\ubcf4\ub2e4 \ud55c\uc625\ub9c8\uc744, \uacbd\uae30\uc804, \ub0a8\ubd80\uc2dc\uc7a5 \uc815\ub3c4\ub97c \uc5ec\uc720 \uc788\uac8c \ubcf4\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc785\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q3. \uc804\uc8fc\uc5d0\uc11c \ud63c\uc790 \ubc25 \uba39\uae30 \uc5b4\ub835\ub098\uc694?<\/h3>\n\n\n<p>\uc5b4\ub835\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uad6d\ubc25, \ubd84\uc2dd, \uc2dc\uc7a5 \uc74c\uc2dd, \uce74\ud398 \uc2dd\uc0ac\ucc98\ub7fc \ud63c\uc790 \uc774\uc6a9\ud558\uae30 \uc26c\uc6b4 \uc120\ud0dd\uc9c0\uac00 \ub9ce\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc \ud53c\ud06c \uc2dc\uac04 \uc720\uba85 \uc2dd\ub2f9\uc740 \ub300\uae30 \ubd80\ub2f4\uc774 \uc788\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q4. \uc219\uc18c\ub294 \ud55c\uc625\ub9c8\uc744 \uc548\uc774 \uc88b\ub098\uc694?<\/h3>\n\n\n<p>\ub3d9\uc120\uc740 \ud3b8\ud558\uc9c0\ub9cc \uc18c\uc74c, \ubc29\uc74c, \ud654\uc7a5\uc2e4 \ud3b8\uc758, \uac00\uaca9\uc744 \ud568\uaed8 \ubd10\uc57c \ud569\ub2c8\ub2e4. \ubd84\uc704\uae30\ub9cc \ubcf4\uace0 \uace0\ub974\uae30\ubcf4\ub2e4 \ubc24 \ubcf5\uadc0\uc640 \ud6c4\uae30 \ubc18\ubcf5 \uc2e0\ud638\ub97c \ud655\uc778\ud558\uc138\uc694.<\/p>\n\n\n\n<p>\uc6b4\uc601\uc2dc\uac04, \uc785\uc7a5 \uac00\ub2a5 \uc5ec\ubd80, \uc2dc\uc7a5 \ud734\ubb34, \uad50\ud1b5\ud3b8\uc740 \ubc14\ub014 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubc29\ubb38 \uc804 \uacf5\uc2dd \ucc44\ub110\uacfc \uc9c0\ub3c4 \uc571\uc5d0\uc11c \ucd5c\uc2e0 \uc815\ubcf4\ub97c \ud655\uc778\ud558\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc804\uc8fc \ud63c\uc790 \uc5ec\ud589\uc740 \ud55c\uc625\ub9c8\uc744\uc744 \uc911\uc2ec\uc73c\ub85c \ud558\ub418 \uc219\uc18c \uc704\uce58, \ud63c\uc7a1 \uc2dc\uac04, \ud63c\ubc25 \ud6c4\ubcf4, \ubc24 \ub3d9\uc120\uc744 \ud568\uaed8 \uace0\ub824\ud574\uc57c \ubb34\ub9ac \uc5c6\ub294 \uc77c\uc815\uc774 \ub429\ub2c8\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-below-header-display":"","ast-hfb-mobile-header-display":"","site-post-title":"","ast-breadcrumbs-content":"","ast-featured-img":"","footer-sml-layout":"","theme-transparent-header-meta":"","adv-header-id-meta":"","stick-header-meta":"","header-above-stick-meta":"","header-main-stick-meta":"","header-below-stick-meta":"","astra-migrate-meta-layouts":"default","ast-page-background-enabled":"default","ast-page-background-meta":{"desktop":{"background-color":"var(--ast-global-color-5)","background-image":"","background-repeat":"repeat","background-position"