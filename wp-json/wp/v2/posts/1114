{"id":1114,"date":"2026-03-05T12:34:00","date_gmt":"2026-03-05T03:34:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1114"},"modified":"2026-06-12T12:34:40","modified_gmt":"2026-06-12T03:34:40","slug":"%ec%9c%a0%eb%aa%85-%ea%b4%80%ea%b4%91%ec%a7%80%ec%97%90%ec%84%9c-%eb%8a%90%eb%81%bc%ec%a7%80-%eb%aa%bb%ed%95%9c-%ec%8a%a4%ed%8e%98%ec%9d%b8-%eb%b2%a0%ec%82%ac%eb%a3%a8","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%9c%a0%eb%aa%85-%ea%b4%80%ea%b4%91%ec%a7%80%ec%97%90%ec%84%9c-%eb%8a%90%eb%81%bc%ec%a7%80-%eb%aa%bb%ed%95%9c-%ec%8a%a4%ed%8e%98%ec%9d%b8-%eb%b2%a0%ec%82%ac%eb%a3%a8\/","title":{"rendered":"\uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8 \ud63c\uc790 \uc5ec\ud589: \uc911\uc138 \ub9c8\uc744\uc744 \uc870\uc6a9\ud788 \uac77\ub294 \ubc95"},"content":{"rendered":"\n<p>\uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8\ub294 \uc911\uc138 \ub9c8\uc744\uc758 \uc774\ubbf8\uc9c0\uac00 \uac15\ud558\uc9c0\ub9cc, \ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \uc0ac\uc9c4\ubcf4\ub2e4 \uc2dc\uac04\ub300 \uc120\ud0dd\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \ubc29\ubb38\uac1d\uc774 \ubab0\ub9ac\ub294 \uc2dc\uac04\uacfc \uc870\uc6a9\ud55c \uc2dc\uac04\uc758 \uccb4\uac10 \ucc28\uc774\uac00 \ucee4\uc11c \uc77c\uc815 \uc124\uacc4\uac00 \uace7 \ub9cc\uc871\ub3c4\ub97c \uc88c\uc6b0\ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8\ub97c \u201c\uac00\ubcfc \ub9cc\ud55c \uacf3 \ubaa9\ub85d\u201d\uc73c\ub85c \uc18c\ube44\ud558\uae30\ubcf4\ub2e4, \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \uc2e4\uc81c\ub85c \ud558\ub8e8\ub97c \ubc30\uce58\ud560 \uc218 \uc788\ub294\uc9c0 \ud310\ub2e8\ud558\ub3c4\ub85d \uc815\ub9ac\ud55c \uae30\uc900\ud45c\ub2e4. \uad50\ud1b5\ud3b8, \uc2dd\uc0ac \uc2dc\uac04, \uc219\uc18c \uc704\uce58, \ud574\uc9c8 \ubb34\ub835 \ubcf5\uadc0 \ub3d9\uc120\uc744 \ud568\uaed8 \ubd10\uc57c \ub9cc\uc871\ub3c4\uac00 \uc548\uc815\ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8 \uc5ec\ud589\uc744 \uba3c\uc800 \uc774\ub807\uac8c \ud310\ub2e8\ud55c\ub2e4<\/h2>\n\n\n\n<p>\uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8\ub294 \uac15\ud55c \ub79c\ub4dc\ub9c8\ud06c \ud558\ub098\ub85c \ub05d\ub098\ub294 \ubaa9\uc801\uc9c0\ub77c\uae30\ubcf4\ub2e4, \uac77\ub294 \uc18d\ub3c4\uc640 \uba38\ubb34\ub294 \uc704\uce58\uc5d0 \ub530\ub77c \uc778\uc0c1\uc774 \ub2ec\ub77c\uc9c0\ub294 \uacf3\uc774\ub2e4. \uadf8\ub798\uc11c \uc77c\uc815\ud45c\ub97c \ube7d\ube7d\ud558\uac8c \ucc44\uc6b0\uae30\ubcf4\ub2e4 \u201c\uc5b4\ub514\uae4c\uc9c0 \uac78\uc744\uc9c0, \uc5b8\uc81c \uc26c\uc5b4\uac08\uc9c0, \uc5b8\uc81c \ub3cc\uc544\uc62c\uc9c0\u201d\ub97c \uba3c\uc800 \uc815\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uc774 \uae00\uc758 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \uc911\uc694\ud55c \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\uc911\uc138 \ub9c8\uc744 \uc0b0\ucc45, \ub2e4\ub9ac\uc640 \uace8\ubaa9 \uac10\uc0c1, \uc870\uc6a9\ud55c \ubc18\ub098\uc808 \uccb4\ub958<\/td><td>\uc0ac\uc9c4 \uba85\uc18c\ubcf4\ub2e4 \ud558\ub8e8\uc758 \ubc00\ub3c4\uc640 \ud53c\ub85c\ub3c4\ub97c \uba3c\uc800 \ud310\ub2e8\ud560 \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\uc9c0\ub85c\ub098 \ub610\ub294 \uc8fc\ubcc0 \ub3c4\uc2dc\ub97c \uae30\uc900\uc73c\ub85c \ubc84\uc2a4\uc640 \ucc28\ub7c9 \uc774\ub3d9\uc744 \uac80\ud1a0<\/td><td>\ub9c9\ucc28, \ud658\uc2b9, \ub3c4\ubcf4 \ubcf5\uadc0 \uac00\ub2a5\uc131\uc744 \uae30\uc900\uc73c\ub85c \uc77c\uc815\uc744 \uc904\uc77c \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ubc18\ub098\uc808\ub3c4 \uac00\ub2a5\ud558\uc9c0\ub9cc \uc2dd\uc0ac\uc640 \ud734\uc2dd\uc744 \ub123\uc73c\uba74 \ud558\ub8e8\uac00 \uc548\uc815\uc801\uc774\ub2e4<\/td><td>\ub108\ubb34 \uc9e7\uc73c\uba74 \uc0dd\ud65c\uac10\uc774 \ubcf4\uc774\uc9c0 \uc54a\uace0, \ub108\ubb34 \uae38\uba74 \ub3d9\uc120 \ud6a8\uc728\uc774 \ub5a8\uc5b4\uc9c8 \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uad8c\uc7a5 \uc131\ud5a5<\/td><td>\uc791\uc740 \uc5ed\uc0ac \ub9c8\uc744\uc744 \ucc9c\ucc9c\ud788 \uac77\uace0 \uc0ac\uc9c4\ubcf4\ub2e4 \ubd84\uc704\uae30\ub97c \uc911\uc2dc\ud558\ub294 \uc5ec\ud589\uc790<\/td><td>\uc870\uc6a9\ud55c \ub3c4\uc2dc \uc0b0\ucc45\uc744 \uc88b\uc544\ud558\ub294\uc9c0\uc5d0 \ub530\ub77c \ub9cc\uc871\ub3c4\uac00 \ud06c\uac8c \uac08\ub9b0\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8\uc5d0\uc11c\ub294 \uc0ac\uc9c4\ubcf4\ub2e4 \uc870\uc6a9\ud788 \uac77\ub294 \ubaa9\uc801\uc774 \ub9de\uc544\uc57c \ud55c\ub2e4<\/h2>\n\n\n\n<p>\ubca0\uc0ac\ub8e8\ub294 \ub300\ud45c \uc7a5\uba74\uc744 \ucc0d\uace0 \ub05d\ub0b4\uba74 \uccb4\ub958 \uc2dc\uac04\uc774 \uc9e7\uc544\uc9c4\ub2e4. \uadf8\ub7ec\ub098 \ub2e4\ub9ac, \uace8\ubaa9, \uad11\uc7a5, \uac15 \uc8fc\ubcc0\uc744 \ucc9c\ucc9c\ud788 \uc5f0\uacb0\ud558\uba74 \uc791\uc740 \ub9c8\uc744 \ud2b9\uc720\uc758 \ud3b8\uc548\ud568\uc774 \uc0b4\uc544\ub09c\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ubaa9\uc801\uc9c0\uac00 \uc720\uba85\ud55c\uc9c0\ubcf4\ub2e4 \ud63c\uc790 \uc788\uc5b4\ub3c4 \uc5b4\uc0c9\ud558\uc9c0 \uc54a\uc740\uc9c0\uac00 \ub354 \uc911\uc694\ud558\ub2e4. \uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8\ucc98\ub7fc \uc0dd\ud65c\uad8c\uacfc \uad00\uad11\uad8c\uc774 \uacb9\uce58\ub294 \uc7a5\uc18c\ub294 \uce74\ud398, \uc2dc\uc7a5, \uac15\ubcc0, \uace8\ubaa9, \uc815\ub958\uc7a5 \uac19\uc740 \ud3c9\ubc94\ud55c \uc9c0\uc810\uc774 \uc2e4\uc81c \ub9cc\uc871\ub3c4\ub97c \ub9cc\ub4e0\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8\ub294 \uc624\uc804 \uc9c4\uc785 \ud6c4 \ub0ae \uc0b0\ucc45 \uc911\uc2ec\uc73c\ub85c \ubcf4\ub294 \ud3b8\uc774 \ub0ab\ub2e4<\/h2>\n\n\n\n<p>\uac00\ub2a5\ud558\ub2e4\uba74 \uc624\uc804 \uc77c\ucc0d \ub3c4\ucc29\ud558\uac70\ub098 \ub2a6\uc740 \uc624\ud6c4 \uc804\uc5d0 \ube60\uc838\ub098\uc624\ub294 \ubc29\uc2dd\uc774 \uc88b\ub2e4. \ud55c\ub0ae\uc5d0\ub294 \ubc29\ubb38\uac1d\uc774 \ub298\uc5b4 \uace8\ubaa9\uc758 \uc870\uc6a9\ud568\uc774 \uc57d\ud574\uc9c8 \uc218 \uc788\uace0, \ub2a6\uc740 \uc2dc\uac04\uc5d0\ub294 \uad50\ud1b5 \uc120\ud0dd\uc9c0\uac00 \uc904\uc5b4\ub4e4 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\uac00\uc7a5 \ubb34\ub09c\ud55c \ubc29\uc2dd\uc740 \uc624\uc804\uc5d0 \ub3c4\ucc29\ud574 \ub3d9\uc120\uc744 \ud55c \ubc88 \ub113\ud788\uace0, \uc810\uc2ec \uc774\ud6c4\uc5d0\ub294 \uc911\uc2ec\ubd80 \uc8fc\ubcc0\uc73c\ub85c \ub2e4\uc2dc \uc881\ud788\ub294 \uac83\uc774\ub2e4. \uc791\uc740 \ub3c4\uc2dc\ub098 \uadfc\uad50 \ub9c8\uc744\uc740 \ub2a6\uc740 \uc624\ud6c4\ubd80\ud130 \uc120\ud0dd\uc9c0\uac00 \uc904\uc5b4\ub4dc\ub294 \uacbd\uc6b0\uac00 \ub9ce\uc73c\ubbc0\ub85c, \ud574\uac00 \uc9c0\uae30 \uc804\uc5d0 \ub3cc\uc544\uac08 \ubc29\ud5a5\uc744 \ud655\uc815\ud558\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8\uc5d0\uc11c \ud63c\uc790 \uac77\uae30 \uc804\uc5d0 \ud655\uc778\ud560 \uc2dc\uac04\ub300\uc640 \uadc0\uac00\uc120<\/h2>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \uac00\uc7a5 \uc911\uc694\ud55c \ubcc0\uc218\ub294 \ubcf5\uadc0\ud3b8\uc774\ub2e4. \uc791\uc740 \ub9c8\uc744\uc740 \ub300\uc911\uad50\ud1b5 \uac04\uaca9\uc774 \uae38 \uc218 \uc788\uc73c\ubbc0\ub85c \ub3c4\ucc29\ud558\uc790\ub9c8\uc790 \ub3cc\uc544\uac08 \uc2dc\uac04\uacfc \uc815\ub958\uc7a5 \uc704\uce58\ub97c \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uad6c\uac04<\/th><th>\uccb4\ud06c\ud560 \uac83<\/th><th>\ud604\uc7a5 \ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ucd9c\ubc1c \uc804<\/td><td>\uacf5\uc2dd \uad50\ud1b5 \uc2dc\uac04\ud45c\uc640 \uadc0\uac00\ud3b8<\/td><td>\ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \ud558\ub8e8 1~2\ud68c\ubfd0\uc774\uba74 \uc624\uc804 \ucd9c\ubc1c\ub85c \uace0\uc815\ud55c\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \uc815\ub958\uc7a5, \uc219\uc18c \ubc29\ud5a5<\/td><td>\uc9c0\ub3c4 \uc571\ub9cc \ubbff\uc9c0 \ub9d0\uace0 \uc2e4\uc81c \ud45c\uc9c0\ud310\uacfc \ubcf4\ud589\ub85c\ub97c \uac19\uc774 \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4 \uc77c\uc815<\/td><td>\uc2dd\ub2f9 \ud734\uc2dd \uc2dc\uac04\uacfc \uc0c1\uc810 \ub9c8\uac10<\/td><td>\uc791\uc740 \ub9c8\uc744\uc740 \ube0c\ub808\uc774\ud06c \ud0c0\uc784\uc774 \uae38 \uc218 \uc788\uc5b4 \uac04\uc2dd\uc744 \ubbf8\ub9ac \ud655\ubcf4\ud55c\ub2e4<\/td><\/tr><tr><td>\ud574\uc9c8 \ubb34\ub835<\/td><td>\uc870\uba85, \uc778\uc801, \ubcf5\uadc0 \ub3d9\uc120<\/td><td>\ud63c\uc790\ub77c\uba74 \ud48d\uacbd\ubcf4\ub2e4 \ubcf5\uadc0 \uc548\uc815\uc131\uc744 \uc6b0\uc120\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8\ub294 \ub2e4\ub9ac\uc640 \uad6c\uc2dc\uac00 \ucd95\ub9cc\uc73c\ub85c\ub3c4 \ucda9\ubd84\ud558\ub2e4<\/h2>\n\n\n\n<p>\ub3d9\uc120\uc740 \ub9c8\uc744 \uc785\uad6c, \ub2e4\ub9ac, \uc911\uc2ec \uad11\uc7a5, \uace8\ubaa9, \uac15\ubcc0 \uc21c\uc11c\ub85c \ub2e8\uc21c\ud558\uac8c \uc7a1\ub294 \uac83\uc774 \uc88b\ub2e4. \uc881\uc740 \uace8\ubaa9\uc744 \uc5ec\ub7ec \ubc88 \uc624\uac00\ub294 \uac83\ubcf4\ub2e4 \uae30\uc900 \uc9c0\uc810\uc744 \uc815\ud574 \uc6d0\ud615\uc73c\ub85c \uac77\ub294 \ud3b8\uc774 \ub35c \ud53c\uace4\ud558\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790\uc77c \ub54c\ub294 \uc5ec\ub7ec \uad6c\uc5ed\uc744 \uc810\uc73c\ub85c \uc5f0\uacb0\ud558\ub294 \uc77c\uc815\uc774 \uc27d\uac8c \ud53c\ub85c\ud574\uc9c4\ub2e4. \uc5ed\uc774\ub098 \uc815\ub958\uc7a5, \uc219\uc18c, \uc2dd\uc0ac \uc9c0\uc810, \uc0b0\ucc45 \uad6c\uac04\uc744 \ud558\ub098\uc758 \ucd95\uc73c\ub85c \ubb36\uc73c\uba74 \uae38\uc744 \uc783\uc744 \uac00\ub2a5\uc131\uc774 \uc904\uace0 \uc911\uac04\uc5d0 \uc77c\uc815\uc744 \uc904\uc774\uae30\ub3c4 \uc27d\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8 \uc219\uc18c\ub294 \uc131\ubcbd \uc811\uadfc\ubcf4\ub2e4 \uc800\ub141 \ub3d9\uc120\uc744 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\ubca0\uc0ac\ub8e8\uc5d0\uc11c \uc219\ubc15\ud558\uba74 \uc870\uc6a9\ud55c \uc544\uce68\uacfc \uc800\ub141\uc744 \ubcfc \uc218 \uc788\uc9c0\ub9cc, \uc2dd\uc0ac\uc640 \uc774\ub3d9 \uc120\ud0dd\uc9c0\ub294 \uc81c\ud55c\ub420 \uc218 \uc788\ub2e4. \ucc98\uc74c \ubc29\ubb38\uc774\ub77c\uba74 \uc9c0\ub85c\ub098 \ub4f1 \uc811\uadfc\uc131\uc774 \uc88b\uc740 \ub3c4\uc2dc\ub97c \ubca0\uc774\uc2a4\ub85c \uc0bc\uace0 \ub2f9\uc77c \ubc29\ubb38\ud558\ub294 \ubc29\uc2dd\ub3c4 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub97c \uc7a1\ub294\ub2e4\uba74 \uc911\uc2ec\ubd80\uc640 \uad50\ud1b5 \uac70\uc810 \uc0ac\uc774\uac00 \uac00\uc7a5 \ubb34\ub09c\ud558\ub2e4. \uc911\uc2ec\ubd80\uc5d0\uc11c \ub108\ubb34 \uba40\uba74 \ubc24 \ubcf5\uadc0\uac00 \ubd80\ub2f4\uc2a4\ub7fd\uace0, \uad00\uad11 \ub3d9\uc120 \ud55c\uac00\uc6b4\ub370\ub9cc \uace0\ub974\uba74 \uc2dd\uc0ac\uc640 \uc0dd\ud65c \ud3b8\uc758\uac00 \uc624\ud788\ub824 \ubd88\ud3b8\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8\uc5d0\uc11c\ub294 \uc2dd\ub2f9\ubcf4\ub2e4 \uc26c\ub294 \uc9c0\uc810\uc744 \uba3c\uc800 \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\uc810\uc2ec \uc2dc\uac04\uc5d0 \ub9de\ucdb0 \ubc29\ubb38\ud558\uba74 \uc2dd\uc0ac \uc120\ud0dd\uc9c0\uac00 \ube44\uad50\uc801 \uc548\uc815\uc801\uc774\ub2e4. \ub2e4\ub9cc \uad00\uad11\uac1d\uc774 \ubab0\ub9ac\ub294 \uacc4\uc808\uc5d0\ub294 \uc88c\uc11d\uacfc \uc601\uc5c5 \uc2dc\uac04\uc774 \ubcc0\uc218\uc774\ubbc0\ub85c \uac04\ub2e8\ud55c \uac04\uc2dd\uacfc \ubb3c\uc744 \uc900\ube44\ud574 \ub450\ub294 \ud3b8\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub3c4\uc2dc\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc218\ubcf4\ub2e4 \uc601\uc5c5 \uc2dc\uac04 \ud655\uc778\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \ud63c\uc790\ub77c\uba74 \uc608\uc57d\uc774 \ud544\uc694\ud55c \uace0\uae09 \uc2dd\ub2f9\ubcf4\ub2e4, \uc810\uc2ec\uacfc \uc800\ub141 \uc0ac\uc774\uc5d0 \uc26c\uc5b4\uac08 \uc218 \uc788\ub294 \uce74\ud398\ub098 \uac04\ub2e8\ud55c \uc2dd\uc0ac\ucc98\ub97c \ud655\ubcf4\ud558\ub294 \ucabd\uc774 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8\uc5d0\uc11c\ub294 \uccb4\ub958 \uc2dc\uac04\uc744 \uc9e7\uac8c \ub04a\ub294 \ud3b8\uc774 \ub0ab\ub2e4<\/h2>\n\n\n\n<p>\uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uc774\ub3d9 \ubc29\uc2dd\uc774 \uc608\uc0b0\uc744 \uc88c\uc6b0\ud55c\ub2e4. \ubc84\uc2a4\ub294 \uc800\ub834\ud558\uc9c0\ub9cc \uc2dc\uac04\ud45c \uc81c\uc57d\uc774 \uc788\uace0, \ucc28\ub7c9 \uc774\ub3d9\uc740 \ud3b8\ud558\uc9c0\ub9cc \uc8fc\ucc28\uc640 \ube44\uc6a9\uc744 \ud568\uaed8 \uace0\ub824\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uad50\ud1b5\uacfc \uc219\ubc15\uc5d0\uc11c \ucc28\uc774\uac00 \ub09c\ub2e4. \ub2f9\uc77c\uce58\uae30\ub77c\uba74 \uc655\ubcf5 \uad50\ud1b5\ube44\uc640 \uc2dd\ube44 \uc911\uc2ec\uc73c\ub85c \uacc4\uc0b0\ud558\uace0, 1\ubc15\uc744 \ud55c\ub2e4\uba74 \uc219\uc18c \uc704\uce58\uac00 \uc774\ub3d9\ube44\uc640 \ud53c\ub85c\ub3c4\ub97c \ub3d9\uc2dc\uc5d0 \ubc14\uafbc\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8\ub294 \ubc00\ub3c4\ubcf4\ub2e4 \uace0\uc694\ud568\uc744 \uc6d0\ud558\ub294 \uc0ac\ub78c\uc5d0\uac8c \ub9de\ub294\ub2e4<\/h2>\n\n\n\n<p>\ud654\ub824\ud55c \ub300\ub3c4\uc2dc\ubcf4\ub2e4 \uc791\uc740 \uc5ed\uc0ac \ub9c8\uc744\uc758 \uace0\uc694\ud568\uc744 \uc88b\uc544\ud558\ub294 \uc0ac\ub78c\uc5d0\uac8c \ub9de\ub294\ub2e4. \ud63c\uc790 \uc0ac\uc9c4\uc744 \ub9ce\uc774 \ucc0d\uae30\ubcf4\ub2e4 \uac77\uace0 \uc26c\uba70 \uc7a5\uc18c\uc758 \ubd84\uc704\uae30\ub97c \ub290\ub07c\ub824\ub294 \uc5ec\ud589\uc790\uc5d0\uac8c \ud2b9\ud788 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\ubc18\ub300\ub85c \uc9e7\uc740 \uc2dc\uac04\uc5d0 \ub300\ud45c \uba85\uc18c\ub97c \ub9ce\uc774 \ucc0d\uace0 \uc2f6\uc740 \uc5ec\ud589\uc790\ub77c\uba74 \ub9cc\uc871\ub3c4\uac00 \ub0ae\uc744 \uc218 \uc788\ub2e4. \uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8\ub294 \uc18d\ub3c4\ub97c \ub0ae\ucdb0\uc57c \uc7a5\uc810\uc774 \ubcf4\uc774\ub294 \ubaa9\uc801\uc9c0\uc774\ubbc0\ub85c, \uc77c\uc815\uc758 \uc131\uacf5 \uae30\uc900\uc744 \u201c\uc5bc\ub9c8\ub098 \ub9ce\uc774 \ubd24\ub294\uac00\u201d\uac00 \uc544\ub2c8\ub77c \u201c\ud63c\uc790 \ubb34\ub9ac \uc5c6\uc774 \uba38\ubb3c \uc218 \uc788\uc5c8\ub294\uac00\u201d\ub85c \uc7a1\ub294 \ud3b8\uc774 \ub0ab\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubca0\uc0ac\ub8e8 \uc0b0\ucc45\uc740 \uc870\uc6a9\ud568\uc744 \uc6d0\ud560 \ub54c \ub9de\ub294\ub2e4<\/h2>\n\n\n\n<p>\uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8 \ud63c\uc790 \uc5ec\ud589: \uc911\uc138 \ub9c8\uc744\uc744 \uc870\uc6a9\ud788 \uac77\ub294 \ubc95\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ud654\ub824\ud55c \uc131\ucde8\uac10\uc744 \uc8fc\ub294 \uc77c\uc815\uc740 \uc544\ub2c8\uc9c0\ub9cc, \uc774\ub3d9\uacfc \uccb4\ub958\uc758 \uade0\ud615\uc744 \uc5f0\uc2b5\ud558\uae30 \uc88b\uc740 \ubaa9\uc801\uc9c0\ub2e4. \uacf5\uc2dd \uad50\ud1b5 \uc815\ubcf4, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac \uac00\ub2a5 \uc2dc\uac04\ub9cc \uc0ac\uc804\uc5d0 \ud655\uc778\ud558\uba74 \ud558\ub8e8 \ub610\ub294 1\ubc15 \uc77c\uc815\uc73c\ub85c \ucda9\ubd84\ud788 \uc124\uacc4\ud560 \uc218 \uc788\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc2a4\ud398\uc778 \ubca0\uc0ac\ub8e8 \ud63c\uc790 \uc5ec\ud589\uc744 \uc900\ube44\ud560 \ub54c \ud544\uc694\ud55c \ubc29\ubb38 \uc2dc\uac04, \ubc84\uc2a4\uc640 \ubcf5\uadc0 \uae30\uc900, \uace8\ubaa9 \uc0b0\ucc45 \ub3d9\uc120, \uc2dd\uc0ac\uc640 \uccb4\ub958 \ubc29\uc2dd\uc744 \uc815\ub9ac\ud588\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":1115,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ub_ctt_via":"","site-sidebar-layout":"default","site-content-layout":"","ast-site-content-layout":"","site-content-style":"default","site-sidebar-style":"default","ast-global-header-display":"","ast-banner-title-visibility":"","ast-main-header-display":"","ast-hfb-above-header-display":"","ast-hfb-