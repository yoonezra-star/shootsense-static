{"id":781,"date":"2025-06-19T15:13:41","date_gmt":"2025-06-19T06:13:41","guid":{"rendered":"https:\/\/shootsense.com\/?p=781"},"modified":"2026-06-12T14:36:18","modified_gmt":"2026-06-12T05:36:18","slug":"honja-sukso-anjeon-checklist","status":"publish","type":"post","link":"https:\/\/shootsense.com\/honja-sukso-anjeon-checklist\/","title":{"rendered":"\ud63c\uc790 \uc219\uc18c\uc5d0\uc11c \uc548\uc804\ud558\uac8c \uba38\ubb34\ub294 \ud301: \uccb4\ud06c\uc778 \uc9c1\ud6c4 \ud655\uc778\ud560 \uac83"},"content":{"rendered":"\n<p>\ud63c\uc790 \uc219\uc18c\uc5d0 \uba38\ubb34\ub97c \ub54c \uc548\uc804\uc740 \uccb4\ud06c\uc778 \uc804 \uc608\uc57d \ub2e8\uacc4\uc5d0\uc11c \uc2dc\uc791\ub418\uace0, \uccb4\ud06c\uc778 \uc9c1\ud6c4 \uc2e4\uc81c \ubc29\uc744 \ud655\uc778\ud558\uba74\uc11c \uc644\uc131\ub429\ub2c8\ub2e4. \uc219\uc18c\uac00 \uae68\ub057\ud558\uace0 \uc0ac\uc9c4\uc774 \uc88b\uc544 \ubcf4\uc5ec\ub3c4 \ubb38 \uc7a0\uae08, \ucc3d\ubb38, \ubcf5\ub3c4, \ud504\ub7f0\ud2b8 \uc5f0\ub77d, \ube44\uc0c1\uad6c \uc704\uce58\ub97c \ud655\uc778\ud558\uc9c0 \uc54a\uc73c\uba74 \ubb38\uc81c\uac00 \uc0dd\uacbc\uc744 \ub54c \ub300\uc751\uc774 \ub2a6\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \uc219\uc18c\uc5d0 \ub3c4\ucc29\ud55c \ub4a4 \ubc14\ub85c \ud655\uc778\ud574\uc57c \ud560 \ud56d\ubaa9\uc744 \uc21c\uc11c\ub300\ub85c \uc815\ub9ac\ud569\ub2c8\ub2e4. \ubd88\uc548\uc744 \ud0a4\uc6b0\uae30 \uc704\ud55c \uae00\uc774 \uc544\ub2c8\ub77c, \ub0af\uc120 \uacf5\uac04\uc5d0\uc11c \ud310\ub2e8\ud574\uc57c \ud560 \uc77c\uc744 \uc904\uc774\uae30 \uc704\ud55c \uccb4\ud06c\ub9ac\uc2a4\ud2b8\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"room-first-check\">\uc219\uc18c\uc5d0 \ub4e4\uc5b4\uac00\uba74 \uc9d0\uc744 \ud480\uae30 \uc804\uc5d0 \uba3c\uc800 \ud655\uc778\ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uccb4\ud06c\uc778 \uc9c1\ud6c4\uc5d0\ub294 \ud53c\uace4\ud574\uc11c \ubc14\ub85c \uc26c\uace0 \uc2f6\uc9c0\ub9cc, \uc774\ub54c \ud655\uc778\ud574\uc57c \ud560 \ud56d\ubaa9\uc774 \uc788\uc2b5\ub2c8\ub2e4. \ubb38\uc774 \uc81c\ub300\ub85c \uc7a0\uae30\ub294\uc9c0, \ubcf4\uc870 \uc7a0\uae08\uc7a5\uce58\uac00 \uc788\ub294\uc9c0, \ucc3d\ubb38\uc774 \uc678\ubd80\uc5d0\uc11c \uc811\uadfc \uac00\ub2a5\ud55c\uc9c0, \ud504\ub7f0\ud2b8\ub098 \ud638\uc2a4\ud2b8\uc5d0\uac8c \ubc14\ub85c \uc5f0\ub77d\ud560 \uc218 \uc788\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694. \ubb38\uc81c\uac00 \uc788\uc73c\uba74 \ub2a6\uc740 \ubc24\ubcf4\ub2e4 \uccb4\ud06c\uc778 \uc9c1\ud6c4\uc5d0 \ub9d0\ud558\ub294 \uac83\uc774 \ub300\uc751\uc774 \uc27d\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud655\uc778 \ud56d\ubaa9<\/th><th>\uc815\uc0c1 \uae30\uc900<\/th><th>\ubb38\uc81c \uc2e0\ud638<\/th><\/tr><\/thead><tbody><tr><td>\ubb38 \uc7a0\uae08<\/td><td>\ub3c4\uc5b4\ub77d, \uccb4\uc778, \ubcf4\uc870 \uc7a0\uae08\uc774 \uc815\uc0c1 \uc791\ub3d9<\/td><td>\ubb38\uc774 \ud5d0\uac81\uac70\ub098 \uc7a0\uae08\uc774 \ubd88\uc548\uc815\ud568<\/td><\/tr><tr><td>\ucc3d\ubb38<\/td><td>\uc548\uc5d0\uc11c \uc7a0\uae30\uace0 \uc678\ubd80 \uc811\uadfc\uc774 \uc5b4\ub824\uc6c0<\/td><td>\uc800\uce35\uc778\ub370 \ucc3d\ubb38 \uc7a0\uae08\uc774 \uc57d\ud568<\/td><\/tr><tr><td>\uc5f0\ub77d \uc218\ub2e8<\/td><td>\ud504\ub7f0\ud2b8\u00b7\ud638\uc2a4\ud2b8 \uc5f0\ub77d\ucc98\uac00 \ubc14\ub85c \ubcf4\uc784<\/td><td>\ubb38\uc81c \ubc1c\uc0dd \uc2dc \uc5f0\ub77d \ubc29\ubc95\uc774 \ubd88\uba85\ud655\ud568<\/td><\/tr><tr><td>\ube44\uc0c1\uad6c<\/td><td>\ubc29\uc5d0\uc11c \ub098\uc640 \uc5b4\ub290 \ubc29\ud5a5\uc778\uc9c0 \uc54c \uc218 \uc788\uc74c<\/td><td>\ubcf5\ub3c4 \uad6c\uc870\ub97c \uc804\ud600 \ubaa8\ub984<\/td><\/tr><tr><td>\uc8fc\ubcc0 \ub3d9\uc120<\/td><td>\ud3b8\uc758\uc810, \ud070\uae38, \ud0dd\uc2dc \uc2b9\ud558\ucc28 \uc9c0\uc810\uc744 \ud655\uc778<\/td><td>\ubc24\uc5d0 \uc5b4\ub514\ub85c \ub098\uac00\uc57c \ud560\uc9c0 \ubaa8\ub984<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"door-window\">\ubb38\uacfc \ucc3d\ubb38\uc740 \uc2e4\uc81c\ub85c \uc7a0\uac00 \ubd10\uc57c \ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\ubb38\uc740 \ub2eb\ud78c \uac83\ucc98\ub7fc \ubcf4\uc5ec\ub3c4 \uc7a0\uae08\uc774 \uc81c\ub300\ub85c \uac78\ub9ac\uc9c0 \uc54a\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub3c4\uc5b4\ub77d\uc774 \uc788\ub2e4\uba74 \ubb38\uc744 \ub2eb\uace0 \ubc14\uae65\uc5d0\uc11c \uc5f4\ub9ac\uc9c0 \uc54a\ub294\uc9c0 \ud655\uc778\ud558\uace0, \uc548\ucabd \ubcf4\uc870 \uc7a0\uae08\uc774\ub098 \uccb4\uc778\uc774 \uc788\uc73c\uba74 \uc791\ub3d9 \uc5ec\ubd80\ub97c \ud655\uc778\ud569\ub2c8\ub2e4. \ucc3d\ubb38\ub3c4 \ub9c8\ucc2c\uac00\uc9c0\uc785\ub2c8\ub2e4. \uc800\uce35\uc774\uac70\ub098 \ubc1c\ucf54\ub2c8\uac00 \uc788\ub294 \uc219\uc18c\ub77c\uba74 \ucc3d\ubb38 \uc7a0\uae08 \uc0c1\ud0dc\ub97c \ubc18\ub4dc\uc2dc \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\ubb38\uc81c \uc2e0\ud638\uac00 \uc788\uc73c\uba74 \ud63c\uc790 \ud574\uacb0\ud558\ub824 \ud558\uc9c0 \ub9d0\uace0 \ubc14\ub85c \ud504\ub7f0\ud2b8\ub098 \ud638\uc2a4\ud2b8\uc5d0\uac8c \ub9d0\ud558\uc138\uc694. \ubc29 \ubcc0\uacbd\uc774 \ud544\uc694\ud55c \uc0c1\ud669\uc77c \uc218\ub3c4 \uc788\uc2b5\ub2c8\ub2e4. \uc219\uc18c \uc120\ud0dd \ub2e8\uacc4\uc758 \uae30\uc900\uc740 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-sukso-goreuneun-beop\/\">\ud63c\uc790 \uc5ec\ud589 \uc219\uc18c \uace0\ub974\ub294 \ubc95<\/a>\uc5d0\uc11c \ud568\uaed8 \ud655\uc778\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"night-return\">\ubc24 \uadc0\uac00 \ub3d9\uc120\uc740 \ub0ae\uc5d0 \ud55c \ubc88 \ud655\uc778\ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc219\uc18c\uc5d0 \ub3c4\ucc29\ud55c \ub0a0 \ubc1d\uc740 \uc2dc\uac04\uc5d0 \uc8fc\ubcc0\uc744 \ud55c \ubc14\ud034 \ubcf4\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4. \uc219\uc18c \uc785\uad6c, \ud070\uae38, \ud3b8\uc758\uc810, \ud0dd\uc2dc \uc2b9\ud558\ucc28 \uc9c0\uc810, \uac00\uc7a5 \uac00\uae4c\uc6b4 \uc9c0\ud558\ucca0\uc5ed\uc774\ub098 \ubc84\uc2a4\uc815\ub958\uc7a5\uc744 \ud655\uc778\ud574 \ub450\uba74 \ubc24\uc5d0 \ub3cc\uc544\uc62c \ub54c \ud310\ub2e8\uc774 \uc904\uc5b4\ub4ed\ub2c8\ub2e4. \ubc24\uc5d0 \ucc98\uc74c \ubcf4\ub294 \uace8\ubaa9\uc744 \uc9c0\ub098\uc57c \ud558\ub294 \uc219\uc18c\ub77c\uba74 \ucd08\ubcf4\uc790\uc5d0\uac8c \ubd80\ub2f4\uc774 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uc0c1\ud669<\/th><th>\uad8c\uc7a5 \ud589\ub3d9<\/th><th>\ud53c\ud574\uc57c \ud560 \ud589\ub3d9<\/th><\/tr><\/thead><tbody><tr><td>\ubc24 \uc2dd\uc0ac \ud6c4 \ubcf5\uadc0<\/td><td>\ub0ae\uc5d0 \ud655\uc778\ud55c \uae38\ub85c \ub3cc\uc544\uc624\uae30<\/td><td>\uc0c8\ub85c\uc6b4 \uace8\ubaa9\uae38\uc744 \uc989\ud765\uc801\uc73c\ub85c \uc120\ud0dd<\/td><\/tr><tr><td>\ub9c9\ucc28 \uc774\ud6c4<\/td><td>\ud0dd\uc2dc\u00b7\uc571 \ud638\ucd9c \uac00\ub2a5 \uc9c0\uc810 \ud655\uc778<\/td><td>\ud558\ucc28 \ud6c4 \uba3c \uac70\ub9ac\ub97c \ud63c\uc790 \uac77\uae30<\/td><\/tr><tr><td>\uae38\uc774 \uc5b4\ub450\uc6c0<\/td><td>\ud070\uae38\ub85c \uc6b0\ud68c\ud558\uac70\ub098 \uc774\ub3d9 \uc218\ub2e8 \ubcc0\uacbd<\/td><td>\uac70\ub9ac\ub9cc \uc9e7\ub2e4\uace0 \uc5b4\ub450\uc6b4 \uae38 \uc120\ud0dd<\/td><\/tr><tr><td>\ucee8\ub514\uc158 \uc800\ud558<\/td><td>\uc77c\uc815 \uc911\ub2e8 \ud6c4 \uc219\uc18c \ubcf5\uadc0<\/td><td>\uc57c\uac04 \uc77c\uc815\uc744 \uac15\ud589<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"front-host\">\ud504\ub7f0\ud2b8\uc640 \ud638\uc2a4\ud2b8 \uc5f0\ub77d \uc218\ub2e8\uc744 \uc800\uc7a5\ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc219\uc18c \ubb38\uc81c\ub294 \ud63c\uc790 \ud310\ub2e8\ud558\uae30\ubcf4\ub2e4 \uc6b4\uc601\uc790\uc5d0\uac8c \ube60\ub974\uac8c \uc804\ub2ec\ud558\ub294 \uac83\uc774 \uc548\uc804\ud569\ub2c8\ub2e4. \ud504\ub7f0\ud2b8 \ubc88\ud638, \ud638\uc2a4\ud2b8 \uc5f0\ub77d\ucc98, \uc608\uc57d \uc571 \uba54\uc2dc\uc9c0, \uccb4\ud06c\uc778 \uc548\ub0b4 \ub9c1\ud06c\ub97c \ubc14\ub85c \uc5f4 \uc218 \uc788\uac8c \uc800\uc7a5\ud558\uc138\uc694. \ud574\uc678\ub77c\uba74 \ud604\uc9c0\uc5b4 \uc8fc\uc18c\uc640 \uc601\uc5b4 \uc8fc\uc18c\ub97c \ubaa8\ub450 \ucea1\ucc98\ud574 \ub450\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\ubb34\uc778 \uccb4\ud06c\uc778 \uc219\uc18c\ub294 \ud3b8\ud558\uc9c0\ub9cc, \ubb38\uc81c\uac00 \uc0dd\uacbc\uc744 \ub54c \uc751\ub2f5 \uc18d\ub3c4\uac00 \uc911\uc694\ud569\ub2c8\ub2e4. \ubc24 \ub3c4\ucc29\uc774\ub77c\uba74 \uccb4\ud06c\uc778 \uc124\uba85\uc774 \uba85\ud655\ud55c\uc9c0, \ube44\uc0c1 \uc5f0\ub77d \uc218\ub2e8\uc774 \uc788\ub294\uc9c0 \uc608\uc57d \uc804\ubd80\ud130 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"room-privacy\">\ubc29 \uc548\uc5d0\uc11c\ub294 \uac1c\uc778\uc815\ubcf4\uc640 \uc18c\uc9c0\ud488\uc744 \ubd84\ub9ac\ud569\ub2c8\ub2e4<\/h2>\n\n\n\n<p>\uc219\uc18c \uc548\uc774\ub77c\uace0 \ubaa8\ub4e0 \ubb3c\uac74\uc744 \ud55c\uacf3\uc5d0 \ub450\ub294 \uac83\uc740 \uc88b\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uc5ec\uad8c, \uce74\ub4dc, \ud604\uae08, \uc608\ube44 \ud604\uae08, \ud734\ub300\ud3f0, \ubcf4\uc870\ubc30\ud130\ub9ac\ub97c \ubd84\ub9ac\ud574 \ub450\uba74 \ubd84\uc2e4\uc774\ub098 \ub3c4\ub09c \uc0c1\ud669\uc5d0\uc11c \ub300\uc751\uc774 \uc26c\uc6cc\uc9d1\ub2c8\ub2e4. \uc678\ucd9c\ud560 \ub54c\ub294 \ud558\ub8e8 \uc0ac\uc6a9\ud560 \uac83\ub9cc \ub4e4\uace0 \ub098\uac00\uace0, \uc911\uc694\ud55c \uc11c\ub958\ub294 \ubcf4\uc774\uc9c0 \uc54a\ub294 \uacf3\uc5d0 \uc815\ub9ac\ud558\uc138\uc694.<\/p>\n\n\n\n<p>\ubd84\uc2e4 \uc0c1\ud669\uc5d0 \ub300\ube44\ud55c \ud589\ub3d9 \uc21c\uc11c\ub294 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-emergency-response\/\">\ud63c\uc790 \uc5ec\ud589 \uc911 \uc704\uae09 \uc0c1\ud669 \ub300\uc751 \ubc29\ubc95<\/a>\uc5d0\uc11c \ubbf8\ub9ac \ud655\uc778\ud574 \ub450\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4. \uc900\ube44\ubb3c\uc740 <a href=\"https:\/\/shootsense.com\/honja-yeohaeng-junbimul-checklist\/\">\ud63c\uc790 \uc5ec\ud589 \uc900\ube44\ubb3c \uccb4\ud06c\ub9ac\uc2a4\ud2b8<\/a>\uc640 \uc5f0\uacb0\ud574 \uc815\ub9ac\ud558\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"room-avoid\">\uc219\uc18c\uc5d0\uc11c \ud53c\ud574\uc57c \ud560 \ud589\ub3d9<\/h2>\n\n\n\n<ul class=\"wp-block-list\"><li>\ubb38\uacfc \ucc3d\ubb38\uc744 \ud655\uc778\ud558\uc9c0 \uc54a\uace0 \ubc14\ub85c \uc7a0\ub4dc\ub294 \uac83<\/li><li>\uc219\uc18c \uc8fc\uc18c\uc640 \uc5f0\ub77d\ucc98\ub97c \ud734\ub300\ud3f0 \uc628\ub77c\uc778 \uc0c1\ud0dc\uc5d0\uc11c\ub9cc \ubcfc \uc218 \uc788\uac8c \ub450\ub294 \uac83<\/li><li>\ubc24\uc5d0 \ucc98\uc74c \ubcf4\ub294 \uace8\ubaa9\uae38\ub85c \ud63c\uc790 \ub3cc\uc544\uc624\ub294 \uac83<\/li><li>\ubb38\uc81c \uc2e0\ud638\uac00 \uc788\ub294\ub370 \ucc38\uace0 \ub118\uc5b4\uac00\ub294 \uac83<\/li><\/ul>\n\n\n\n<h2 class=\"wp-block-heading\" id=\"room-checklist\">\uccb4\ud06c\uc778 \uc9c1\ud6c4 10\ubd84 \uccb4\ud06c\ub9ac\uc2a4\ud2b8<\/h2>\n\n\n\n<ul class=\"wp-block-list\"><li>\ubb38 \uc7a0\uae08\uacfc \ubcf4\uc870 \uc7a0\uae08 \uc791\ub3d9 \ud655\uc778<\/li><li>\ucc3d\ubb38 \uc7a0\uae08\uacfc \uc678\ubd80 \uc811\uadfc \uac00\ub2a5\uc131 \ud655\uc778<\/li><li>\ud504\ub7f0\ud2b8\u00b7\ud638\uc2a4\ud2b8 \uc5f0\ub77d\ucc98 \uc800\uc7a5<\/li><li>\ube44\uc0c1\uad6c\uc640 \uacc4\ub2e8 \uc704\uce58 \ud655\uc778<\/li><li>\uc219\uc18c \uc8fc\uc18c, \uc8fc\ubcc0 \ud3b8\uc758\uc810, \ud0dd\uc2dc \uc9c0\uc810 \ucea1\ucc98<\/li><\/ul>\n\n\n\n<h2 class=\"wp-block-heading\">\uc219\uc18c \uc548\uc804\uc5d0\uc11c \uc2e4\uc81c\ub85c \ub2e4\uc2dc \ud655\uc778\ud574\uc57c \ud558\ub294 \uc815\ubcf4<\/h2>\n<p>\uc219\uc18c \uc0ac\uc9c4\uacfc \ud3c9\uc810\ub9cc\uc73c\ub85c\ub294 \uc548\uc804\uc744 \ud310\ub2e8\ud558\uae30 \uc5b4\ub835\uc2b5\ub2c8\ub2e4. \uccb4\ud06c\uc778 \uac00\ub2a5 \uc2dc\uac04, \ud504\ub7f0\ud2b8 \uc0c1\uc8fc \uc5ec\ubd80, \ub2a6\uc740 \uadc0\uac00 \uc2dc \ucd9c\uc785 \ubc29\uc2dd, \ube44\uc0c1 \uc5f0\ub77d \uc218\ub2e8, \uc8fc\ubcc0 \ud3b8\uc758\uc2dc\uc124\uacfc \uace8\ubaa9 \uc870\ub3c4 \uac19\uc740 \uc815\ubcf4\ub294 \uc608\uc57d \uc9c1\ud6c4\uc640 \uccb4\ud06c\uc778 \uc9c1\ud6c4 \ub450 \ubc88 \ub098\ub220\uc11c \ubcf4\ub294 \ud3b8\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc219\uc18c \uc548\uc804 \uc810\uac80\uc774 \ud2b9\ud788 \uc911\uc694\ud55c \uc0c1\ud669<\/h2>\n<p>\ub2a6\uc740 \ubc24 \ub3c4\ucc29, \uc678\uacfd \uc219\uc18c, 1\uce35 \uac1d\uc2e4, \uac8c\uc2a4\ud2b8\ud558\uc6b0\uc2a4, \uacf5\uc6a9 \uc695\uc2e4 \uad6c\uc870, \uc7a5\uae30 \uccb4\ub958 \uc77c\uc815\uc740 \ubaa8\ub450 \uc548\uc804 \uc810\uac80 \uc6b0\uc120\uc21c\uc704\ub97c \ub192\uc785\ub2c8\ub2e4. \uac19\uc740 \uc219\uc18c\ub77c\ub3c4 \ub3c4\ucc29 \uc2dc\uac04\uacfc \uac1d\uc2e4 \uc704\uce58, \uc8fc\ubcc0 \ub3d9\uc120\uc5d0 \ub530\ub77c \uccb4\uac10 \uc548\uc804\uc774 \ub2ec\ub77c\uc9c8 \uc218 \uc788\uc73c\ubbc0\ub85c, \u201c\ud6c4\uae30\uac00 \uc88b\ub2e4\u201d\ub294 \ud55c \ubb38\uc7a5\ub9cc\uc73c\ub85c \ub118\uae30\uc9c0 \uc54a\ub294 \ud3b8\uc774 \uc911\uc694\ud569\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uccb4\ud06c\uc778 \uc9c1\ud6c4 10\ubd84\uc774 \uc219\uc18c \uc548\uc804\uc758 \ud575\uc2ec\uc778 \uc774\uc720<\/h2>\n<p>\uc219\uc18c \uc548\uc804\uc740 \ud070 \uc0ac\uac74\uc774 \uc0dd\uacbc\uc744 \ub54c\uac00 \uc544\ub2c8\ub77c, \ucc98\uc74c \ub4e4\uc5b4\uac04 \uc9c1\ud6c4 \uc544\ubb34\ub807\uc9c0 \uc54a\uc744 \ub54c \uac00\uc7a5 \uc798 \uc810\uac80\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubb38, \ucc3d\ubb38, \uc7a0\uae08 \uc0c1\ud0dc, \ube44\uc0c1 \uc5f0\ub77d \uc218\ub2e8, \uadc0\uac00 \uacbd\ub85c\ub97c \uc774\ub54c \uc815\ub9ac\ud574 \ub450\uba74 \uc774\ud6c4\uc758 \uc791\uc740 \ubd88\uc548\uc774 \ud06c\uac8c \uc904\uc5b4\ub4ed\ub2c8\ub2e4. \ubc18\ub300\ub85c \ud53c\uace4\ud558\ub2e4\ub294 \uc774\uc720\ub85c \uc810\uac80\uc744 \ubbf8\ub8e8\uba74 \ubc24\uc774 \ub41c \ub4a4 \ub354 \ud070 \uc5d0\ub108\uc9c0\uac00 \ud544\uc694\ud574\uc9d1\ub2c8\ub2e4. \ud63c\uc790 \uba38\ubb34\ub294 \uc219\uc18c\uc77c\uc218\ub85d \uccab 10\ubd84\uc758 \uc815\ub9ac\ub825\uc774 \uc804\uccb4 \uccb4\ub958 \uc548\uc815\uc131\uc744 \ud06c\uac8c \ubc14\uafc9\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\">\uc219\uc18c \uc548\uc804 \uc810\uac80\uc774 \uacfc\ud55c \uac71\uc815\uc774 \uc544\ub2cc \uc774\uc720<\/h2>\n<p>\ub9ce\uc740 \uc0ac\ub78c\uc740 \ubb38\ub2e8\uc18d\uc774\ub098 \uc8fc\ubcc0 \ud655\uc778\uc744 \uc608\ubbfc\ud55c \ud589\ub3d9\ucc98\ub7fc \ub290\ub07c\uc9c0\ub9cc, \uc2e4\uc81c\ub85c\ub294 \ud63c\uc790 \uc5ec\ud589\uc790\uc758 \uae30\ubcf8 \uc6b4\uc601 \uc808\ucc28\uc5d0 \uac00\uae5d\uc2b5\ub2c8\ub2e4. \ud55c \ubc88\ub9cc \ud655\uc778\ud574 \ub450\uba74 \uc774\ud6c4 \ub0b4\ub0b4 \ub35c \ubd88\uc548\ud558\uace0, \ubb38\uc81c\uac00 \uc0dd\uaca8\ub3c4 \ub300\uc751 \uc21c\uc11c\uac00 \ud6e8\uc52c \ube68\ub77c\uc9d1\ub2c8\ub2e4. \uc548\uc804 \uc810\uac80\uc740 \uacf5\ud3ec\ub97c \ud0a4\uc6b0\ub294 \ud589\ub3d9\uc774 \uc544\ub2c8\ub77c \ubd88\ud655\uc2e4\uc131\uc744 \uc904\uc774\ub294 \ud589\ub3d9\uc785\ub2c8\ub2e4. \uc774 \uae00\uc758 \ubaa9\uc801\uc740 \uac81\uc744 \uc8fc\ub294 \uac83\uc774 \uc544\ub2c8\ub77c, \ud63c\uc790 \uba38\ubb34\ub294 \uc2dc\uac04\uc744 \ub354 \uc608\uce21 \uac00\ub2a5\ud558\uac8c \ub9cc\ub4dc\ub294 \ub370 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n<h2 class=\"wp-block-heading\" id=\"room-faq\">\uc219\uc18c \uc548\uc804 \uc810\uac80 \uc804\uc5d0 \uc790\uc8fc \ubb3b\ub294 \ud575\uc2ec<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">Q1. \ud63c\uc790 \uc219\uc18c\uc5d0\uc11c \uac00\uc7a5 \uba3c\uc800 \ud655\uc778\ud560 \uac83\uc740 \ubb34\uc5c7\uc778\uac00\uc694?<\/h3>\n\n\n<p>\ubb38 \uc7a0\uae08, \ucc3d\ubb38, \ud504\ub7f0\ud2b8 \uc5f0\ub77d\ucc98, \ube44\uc0c1\uad6c, \ubc24 \ubcf5\uadc0 \ub3d9\uc120\uc785\ub2c8\ub2e4. \uc774 \ub2e4\uc12f \uac00\uc9c0\ub294 \uccb4\ud06c\uc778 \uc9c1\ud6c4 \ubc14\ub85c \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q2. \ubb34\uc778 \uccb4\ud06c\uc778 \uc219\uc18c\ub294 \uad1c\ucc2e\ub098\uc694?<\/h3>\n\n\n<p>\uad1c\ucc2e\uc744 \uc218 \uc788\uc9c0\ub9cc \uccb4\ud06c\uc778 \uc548\ub0b4\uac00 \uba85\ud655\ud558\uace0 \ube44\uc0c1 \uc5f0\ub77d \uc218\ub2e8\uc774 \uc788\uc5b4\uc57c \ud569\ub2c8\ub2e4. \ubc24 \ub3c4\ucc29\uc774\ub77c\uba74 \ud2b9\ud788 \uc2e0\uc911\ud558\uac8c \ubd10\uc57c \ud569\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q3. \ubc29\uc5d0 \ubb38\uc81c\uac00 \uc788\uc73c\uba74 \uc5b4\ub5bb\uac8c \ud574\uc57c \ud558\ub098\uc694?<\/h3>\n\n\n<p>\ud63c\uc790 \ud574\uacb0\ud558\ub824 \ud558\uc9c0 \ub9d0\uace0 \uc989\uc2dc \ud504\ub7f0\ud2b8\ub098 \ud638\uc2a4\ud2b8\uc5d0\uac8c \uc54c\ub9ac\uc138\uc694. \ubb38 \uc7a0\uae08\uc774\ub098 \uc548\uc804 \ubb38\uc81c\ub77c\uba74 \ubc29 \ubcc0\uacbd\uc744 \uc694\uccad\ud558\ub294 \uac83\uc774 \uc88b\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n<h3 class=\"wp-block-heading\">Q4. \ubc24\uc5d0 \ub3cc\uc544\uc62c \ub54c \uac00\uc7a5 \uc911\uc694\ud55c \uae30\uc900\uc740 \ubb34\uc5c7\uc778\uac00\uc694?<\/h3>\n\n\n<p>\uc9e7\uc740 \uae38\ubcf4\ub2e4 \ubc1d\uace0 \uc775\uc219\ud55c \uae38\uc785\ub2c8\ub2e4. \ub0ae\uc5d0 \ud655\uc778\ud55c \ud070\uae38 \uc911\uc2ec\uc73c\ub85c \ub3cc\uc544\uc624\ub294 \uac83\uc774 \uc548\uc804\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c \uc6b4\uc601 \ubc29\uc2dd, \ud504\ub7f0\ud2b8 \uc2dc\uac04, \uccb4\ud06c\uc778 \uc548\ub0b4, \uc8fc\ubcc0 \ud658\uacbd\uc740 \ubc14\ub014 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc608\uc57d \uc804\uacfc \uccb4\ud06c\uc778 \ub2f9\uc77c \ucd5c\uc2e0 \uc548\ub0b4\ub97c \ub2e4\uc2dc \ud655\uc778\ud558\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ud63c\uc790 \uc219\uc18c\uc5d0 \uba38\ubb34\ub97c \ub54c\ub294 \uccb4\ud06c\uc778 \uc9c1\ud6c4 \ubb38 \uc7a0\uae08, \ucc3d\ubb38, \uc5f0\ub77d \uc218\ub2e8, \ube44\uc0c1\uad6c, \ubc24 \uadc0\uac00 \ub3d9\uc120\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4.<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"open","ping_status":"open","sti