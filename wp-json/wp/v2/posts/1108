{"id":1108,"date":"2026-03-01T12:28:00","date_gmt":"2026-03-01T03:28:00","guid":{"rendered":"https:\/\/shootsense.com\/?p=1108"},"modified":"2026-06-12T12:34:42","modified_gmt":"2026-06-12T03:34:42","slug":"%ec%97%ac%ed%96%89%ea%b3%bc-%ec%83%9d%ed%99%9c%ec%9d%98-%ea%b2%bd%ea%b3%84%ea%b0%80-%ed%9d%90%eb%a0%a4%ec%a7%84-%ed%94%84%eb%9e%91%ec%8a%a4-%ec%95%88%ec%8b%9c-%ea%b7%bc%ea%b5%90-%eb%a7%88%ec%9d%84","status":"publish","type":"post","link":"https:\/\/shootsense.com\/%ec%97%ac%ed%96%89%ea%b3%bc-%ec%83%9d%ed%99%9c%ec%9d%98-%ea%b2%bd%ea%b3%84%ea%b0%80-%ed%9d%90%eb%a0%a4%ec%a7%84-%ed%94%84%eb%9e%91%ec%8a%a4-%ec%95%88%ec%8b%9c-%ea%b7%bc%ea%b5%90-%eb%a7%88%ec%9d%84\/","title":{"rendered":"\ud504\ub791\uc2a4 \uc548\uc2dc \uadfc\uad50 \ub9c8\uc744 \ud63c\uc790 \uc5ec\ud589: \uc0dd\ud65c\uad8c\ucc98\ub7fc \uba38\ubb34\ub294 \ud558\ub8e8 \uc124\uacc4"},"content":{"rendered":"\n<p>\ud504\ub791\uc2a4 \uc548\uc2dc \uc8fc\ubcc0\uc758 \uc791\uc740 \ub9c8\uc744\uc740 \ud638\uc218\uc640 \uc54c\ud504\uc2a4 \ud48d\uacbd\ub9cc \ubcf4\uace0 \uac00\uba74 \uae30\ub300\uac00 \ub2e8\uc21c\ud574\uc9c0\uae30 \uc27d\ub2e4. \uc2e4\uc81c\ub85c\ub294 \uad00\uad11\uc9c0\uc640 \uc0dd\ud65c\uad8c\uc758 \uacbd\uacc4\uac00 \ubd80\ub4dc\ub7fd\uac8c \uacb9\uccd0 \uc788\uc5b4, \ud63c\uc790 \uac77\uace0 \uc26c\ub294 \ubc29\uc2dd\uc5d0 \ub530\ub77c \uc5ec\ud589\uc758 \uc9c8\uc774 \ub2ec\ub77c\uc9c4\ub2e4.<\/p>\n\n\n\n<p>\uc774 \uae00\uc740 \ud504\ub791\uc2a4 \uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\ub97c \u201c\uac00\ubcfc \ub9cc\ud55c \uacf3 \ubaa9\ub85d\u201d\uc73c\ub85c \uc18c\ube44\ud558\uae30\ubcf4\ub2e4, \ud63c\uc790 \uc5ec\ud589\uc790\uac00 \uc2e4\uc81c\ub85c \ud558\ub8e8\ub97c \ubc30\uce58\ud560 \uc218 \uc788\ub294\uc9c0 \ud310\ub2e8\ud558\ub3c4\ub85d \uc815\ub9ac\ud55c \uae30\uc900\ud45c\ub2e4. \uad50\ud1b5\ud3b8, \uc2dd\uc0ac \uc2dc\uac04, \uc219\uc18c \uc704\uce58, \ud574\uc9c8 \ubb34\ub835 \ubcf5\uadc0 \ub3d9\uc120\uc744 \ud568\uaed8 \ubd10\uc57c \ub9cc\uc871\ub3c4\uac00 \uc548\uc815\ub41c\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud504\ub791\uc2a4 \uc548\uc2dc \uadfc\uad50 \ub9c8\uc744 \uc5ec\ud589\uc744 \uba3c\uc800 \uc774\ub807\uac8c \ud310\ub2e8\ud55c\ub2e4<\/h2>\n\n\n\n<p>\ud504\ub791\uc2a4 \uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\ub294 \uac15\ud55c \ub79c\ub4dc\ub9c8\ud06c \ud558\ub098\ub85c \ub05d\ub098\ub294 \ubaa9\uc801\uc9c0\ub77c\uae30\ubcf4\ub2e4, \uac77\ub294 \uc18d\ub3c4\uc640 \uba38\ubb34\ub294 \uc704\uce58\uc5d0 \ub530\ub77c \uc778\uc0c1\uc774 \ub2ec\ub77c\uc9c0\ub294 \uacf3\uc774\ub2e4. \uadf8\ub798\uc11c \uc77c\uc815\ud45c\ub97c \ube7d\ube7d\ud558\uac8c \ucc44\uc6b0\uae30\ubcf4\ub2e4 \u201c\uc5b4\ub514\uae4c\uc9c0 \uac78\uc744\uc9c0, \uc5b8\uc81c \uc26c\uc5b4\uac08\uc9c0, \uc5b8\uc81c \ub3cc\uc544\uc62c\uc9c0\u201d\ub97c \uba3c\uc800 \uc815\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\ud310\ub2e8 \ud56d\ubaa9<\/th><th>\uc774 \uae00\uc758 \uae30\uc900<\/th><th>\ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \uc911\uc694\ud55c \uc774\uc720<\/th><\/tr><\/thead><tbody><tr><td>\ubc29\ubb38 \ubaa9\uc801<\/td><td>\ud638\uc218 \uc8fc\ubcc0 \uc0b0\ucc45, \uc791\uc740 \ub9c8\uc744 \uccb4\ub958\uac10, \uc870\uc6a9\ud55c \uc624\ud6c4 \uc77c\uc815<\/td><td>\uc0ac\uc9c4 \uba85\uc18c\ubcf4\ub2e4 \ud558\ub8e8\uc758 \ubc00\ub3c4\uc640 \ud53c\ub85c\ub3c4\ub97c \uba3c\uc800 \ud310\ub2e8\ud560 \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uc774\ub3d9 \ubc29\uc2dd<\/td><td>\uc548\uc2dc \uc911\uc2ec\ubd80\ub97c \uae30\uc900\uc73c\ub85c \ubc84\uc2a4, \uc790\uc804\uac70, \ub3c4\ubcf4, \ud0dd\uc2dc\ub97c \uc870\ud569<\/td><td>\ub9c9\ucc28, \ud658\uc2b9, \ub3c4\ubcf4 \ubcf5\uadc0 \uac00\ub2a5\uc131\uc744 \uae30\uc900\uc73c\ub85c \uc77c\uc815\uc744 \uc904\uc77c \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uccb4\ub958 \uc2dc\uac04<\/td><td>\ubc18\ub098\uc808\ubcf4\ub2e4 \ud558\ub8e8 \uc77c\uc815\uc774 \uc548\uc815\uc801\uc774\uba70 1\ubc15\uc740 \ub354 \uc5ec\uc720\ub86d\ub2e4<\/td><td>\ub108\ubb34 \uc9e7\uc73c\uba74 \uc0dd\ud65c\uac10\uc774 \ubcf4\uc774\uc9c0 \uc54a\uace0, \ub108\ubb34 \uae38\uba74 \ub3d9\uc120 \ud6a8\uc728\uc774 \ub5a8\uc5b4\uc9c8 \uc218 \uc788\ub2e4<\/td><\/tr><tr><td>\uad8c\uc7a5 \uc131\ud5a5<\/td><td>\ud48d\uacbd\uc744 \ubcf4\ub418 \uc870\uc6a9\ud55c \uc0dd\ud65c\uad8c \uc0b0\ucc45\uc744 \uc120\ud638\ud558\ub294 \uc5ec\ud589\uc790<\/td><td>\uc870\uc6a9\ud55c \ub3c4\uc2dc \uc0b0\ucc45\uc744 \uc88b\uc544\ud558\ub294\uc9c0\uc5d0 \ub530\ub77c \ub9cc\uc871\ub3c4\uac00 \ud06c\uac8c \uac08\ub9b0\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\uc740 \uc18c\ube44\ubcf4\ub2e4 \uccb4\ub958\uac10\uc774 \ubaa9\uc801\uc77c \ub54c \ub9de\ub294\ub2e4<\/h2>\n\n\n\n<p>\uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\uc740 \ub300\ud45c \uba85\uc18c\ub97c \ube60\ub974\uac8c \ub3c4\ub294 \ubc29\uc2dd\ubcf4\ub2e4 \ubb3c\uac00\uc640 \uace8\ubaa9, \uc791\uc740 \uad11\uc7a5, \ub85c\uceec \uc0c1\uc810 \uc8fc\ubcc0\uc744 \ucc9c\ucc9c\ud788 \ubcf4\ub294 \ubc29\uc2dd\uc774 \uc798 \ub9de\ub294\ub2e4. \uad00\uad11\uac1d\uc774 \ubab0\ub9ac\ub294 \uc911\uc2ec\ubd80\uc5d0\uc11c \uc870\uae08\ub9cc \ubc97\uc5b4\ub098\ub3c4 \uc5ec\ud589\uc790\uc758 \uc2dc\uc120\uc774 \ud48d\uacbd\uc5d0\uc11c \uc0dd\ud65c \ub9ac\ub4ec\uc73c\ub85c \ubc14\ub010\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790 \uc5ec\ud589\uc5d0\uc11c\ub294 \ubaa9\uc801\uc9c0\uac00 \uc720\uba85\ud55c\uc9c0\ubcf4\ub2e4 \ud63c\uc790 \uc788\uc5b4\ub3c4 \uc5b4\uc0c9\ud558\uc9c0 \uc54a\uc740\uc9c0\uac00 \ub354 \uc911\uc694\ud558\ub2e4. \ud504\ub791\uc2a4 \uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\ucc98\ub7fc \uc0dd\ud65c\uad8c\uacfc \uad00\uad11\uad8c\uc774 \uacb9\uce58\ub294 \uc7a5\uc18c\ub294 \uce74\ud398, \uc2dc\uc7a5, \uac15\ubcc0, \uace8\ubaa9, \uc815\ub958\uc7a5 \uac19\uc740 \ud3c9\ubc94\ud55c \uc9c0\uc810\uc774 \uc2e4\uc81c \ub9cc\uc871\ub3c4\ub97c \ub9cc\ub4e0\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50\ub294 \uc624\uc804 \uc774\ub3d9 \ub4a4 \ud55c \uad6c\uc5ed\uc5d0 \uc624\ub798 \uba38\ubb34\ub294 \ud3b8\uc774 \ub0ab\ub2e4<\/h2>\n\n\n\n<p>\uc624\uc804\uc5d0\ub294 \uc548\uc2dc \uc911\uc2ec\ubd80\uc5d0\uc11c \ucd9c\ubc1c\ud574 \ud638\uc218 \ubc29\ud5a5 \ub610\ub294 \uadfc\uad50 \ub9c8\uc744\ub85c \uc774\ub3d9\ud558\uace0, \ub0ae\uc5d0\ub294 \uc0b0\ucc45\uacfc \uc2dd\uc0ac\ub97c \ud568\uaed8 \ubc30\uce58\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \uc624\ud6c4 \ub2a6\uac8c\ub294 \ub300\uc911\uad50\ud1b5 \uac04\uaca9\uacfc \ubcf5\uadc0 \uc2dc\uac04\uc744 \ub2e4\uc2dc \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uac00\uc7a5 \ubb34\ub09c\ud55c \ubc29\uc2dd\uc740 \uc624\uc804\uc5d0 \ub3c4\ucc29\ud574 \ub3d9\uc120\uc744 \ud55c \ubc88 \ub113\ud788\uace0, \uc810\uc2ec \uc774\ud6c4\uc5d0\ub294 \uc911\uc2ec\ubd80 \uc8fc\ubcc0\uc73c\ub85c \ub2e4\uc2dc \uc881\ud788\ub294 \uac83\uc774\ub2e4. \uc791\uc740 \ub3c4\uc2dc\ub098 \uadfc\uad50 \ub9c8\uc744\uc740 \ub2a6\uc740 \uc624\ud6c4\ubd80\ud130 \uc120\ud0dd\uc9c0\uac00 \uc904\uc5b4\ub4dc\ub294 \uacbd\uc6b0\uac00 \ub9ce\uc73c\ubbc0\ub85c, \ud574\uac00 \uc9c0\uae30 \uc804\uc5d0 \ub3cc\uc544\uac08 \ubc29\ud5a5\uc744 \ud655\uc815\ud558\ub294 \ud3b8\uc774 \uc548\uc815\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50\uc5d0\uc11c\ub294 \ub9c8\uc9c0\ub9c9 \uad50\ud1b5\ud3b8\uacfc \uc800\ub141 \ub3d9\uc120\uc744 \ubbf8\ub9ac \ubcf8\ub2e4<\/h2>\n\n\n\n<p>\uac00\uc7a5 \ud070 \ubcc0\uc218\ub294 \uad50\ud1b5 \uac04\uaca9\uacfc \ub0a0\uc528\ub2e4. \ud638\uc218 \uc8fc\ubcc0\uc740 \ub0a0\uc528\uac00 \uc88b\uc73c\uba74 \uac77\uae30 \uc88b\uc9c0\ub9cc, \ube44\ub098 \uac15\ud48d\uc774 \uc788\uc73c\uba74 \uccb4\uac10 \ud53c\ub85c\uac00 \ucee4\uc9c4\ub2e4. \ubc84\uc2a4 \uc6b4\ud589 \uac04\uaca9\uc774 \uae34 \uad6c\uac04\uc740 \ub3cc\uc544\uc624\ub294 \uc2dc\uac04\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n<figure class=\"wp-block-table\"><table><thead><tr><th>\uad6c\uac04<\/th><th>\uccb4\ud06c\ud560 \uac83<\/th><th>\ud604\uc7a5 \ud310\ub2e8 \uae30\uc900<\/th><\/tr><\/thead><tbody><tr><td>\ucd9c\ubc1c \uc804<\/td><td>\uacf5\uc2dd \uad50\ud1b5 \uc2dc\uac04\ud45c\uc640 \uadc0\uac00\ud3b8<\/td><td>\ub3cc\uc544\uc624\ub294 \ud3b8\uc774 \ud558\ub8e8 1~2\ud68c\ubfd0\uc774\uba74 \uc624\uc804 \ucd9c\ubc1c\ub85c \uace0\uc815\ud55c\ub2e4<\/td><\/tr><tr><td>\ub3c4\ucc29 \uc9c1\ud6c4<\/td><td>\uc5ed, \uc815\ub958\uc7a5, \uc219\uc18c \ubc29\ud5a5<\/td><td>\uc9c0\ub3c4 \uc571\ub9cc \ubbff\uc9c0 \ub9d0\uace0 \uc2e4\uc81c \ud45c\uc9c0\ud310\uacfc \ubcf4\ud589\ub85c\ub97c \uac19\uc774 \ud655\uc778\ud55c\ub2e4<\/td><\/tr><tr><td>\uc624\ud6c4 \uc77c\uc815<\/td><td>\uc2dd\ub2f9 \ud734\uc2dd \uc2dc\uac04\uacfc \uc0c1\uc810 \ub9c8\uac10<\/td><td>\uc791\uc740 \ub9c8\uc744\uc740 \ube0c\ub808\uc774\ud06c \ud0c0\uc784\uc774 \uae38 \uc218 \uc788\uc5b4 \uac04\uc2dd\uc744 \ubbf8\ub9ac \ud655\ubcf4\ud55c\ub2e4<\/td><\/tr><tr><td>\ud574\uc9c8 \ubb34\ub835<\/td><td>\uc870\uba85, \uc778\uc801, \ubcf5\uadc0 \ub3d9\uc120<\/td><td>\ud63c\uc790\ub77c\uba74 \ud48d\uacbd\ubcf4\ub2e4 \ubcf5\uadc0 \uc548\uc815\uc131\uc744 \uc6b0\uc120\ud55c\ub2e4<\/td><\/tr><\/tbody><\/table><\/figure>\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50\ub294 \ub9c8\uc744 \ud558\ub098\uc5d0 \uc9d1\uc911\ud560\uc218\ub85d \ub9ac\ub4ec\uc774 \uc88b\ub2e4<\/h2>\n\n\n\n<p>\ub3d9\uc120\uc740 \uc548\uc2dc \uc911\uc2ec\ubd80, \ud638\uc218\ubcc0, \uadfc\uad50 \ub9c8\uc744 \uc911 \ud558\ub098\uc758 \ubc29\ud5a5\uc73c\ub85c \uc815\ud558\ub294 \ud3b8\uc774 \uc88b\ub2e4. \uc5ec\ub7ec \ub9c8\uc744\uc744 \ud558\ub8e8\uc5d0 \ubb36\uc73c\uba74 \ud48d\uacbd\uc740 \ub298\uc5b4\ub098\uc9c0\ub9cc \uccb4\ub958\uac10\uc740 \uc624\ud788\ub824 \uc57d\ud574\uc9c8 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<p>\ud63c\uc790\uc77c \ub54c\ub294 \uc5ec\ub7ec \uad6c\uc5ed\uc744 \uc810\uc73c\ub85c \uc5f0\uacb0\ud558\ub294 \uc77c\uc815\uc774 \uc27d\uac8c \ud53c\ub85c\ud574\uc9c4\ub2e4. \uc5ed\uc774\ub098 \uc815\ub958\uc7a5, \uc219\uc18c, \uc2dd\uc0ac \uc9c0\uc810, \uc0b0\ucc45 \uad6c\uac04\uc744 \ud558\ub098\uc758 \ucd95\uc73c\ub85c \ubb36\uc73c\uba74 \uae38\uc744 \uc783\uc744 \uac00\ub2a5\uc131\uc774 \uc904\uace0 \uc911\uac04\uc5d0 \uc77c\uc815\uc744 \uc904\uc774\uae30\ub3c4 \uc27d\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50 \uc219\uc18c\ub294 \ubd84\uc704\uae30\ubcf4\ub2e4 \uc0dd\ud65c \ubc18\uacbd\uc774 \uba3c\uc800\ub2e4<\/h2>\n\n\n\n<p>1\ubc15\uc744 \ud55c\ub2e4\uba74 \uc548\uc2dc \uc911\uc2ec\ubd80\uc640 \ud638\uc218 \uc811\uadfc\uc131\uc774 \ubaa8\ub450 \uad1c\ucc2e\uc740 \uc704\uce58\uac00 \uc548\uc815\uc801\uc774\ub2e4. \uadfc\uad50 \ub9c8\uc744 \uc219\uc18c\ub294 \uc870\uc6a9\ud558\uc9c0\ub9cc \uc800\ub141 \uc2dd\uc0ac\uc640 \uc774\ub3d9 \uc120\ud0dd\uc9c0\uac00 \uc904 \uc218 \uc788\uc73c\ubbc0\ub85c \ud63c\uc790\ub77c\uba74 \uccb4\ud06c\uc778 \uc2dc\uac04\uacfc \uc8fc\ubcc0 \ud3b8\uc758\uc2dc\uc124\uc744 \uba3c\uc800 \ud655\uc778\ud574\uc57c \ud55c\ub2e4.<\/p>\n\n\n\n<p>\uc219\uc18c\ub97c \uc7a1\ub294\ub2e4\uba74 \uc911\uc2ec\ubd80\uc640 \uad50\ud1b5 \uac70\uc810 \uc0ac\uc774\uac00 \uac00\uc7a5 \ubb34\ub09c\ud558\ub2e4. \uc911\uc2ec\ubd80\uc5d0\uc11c \ub108\ubb34 \uba40\uba74 \ubc24 \ubcf5\uadc0\uac00 \ubd80\ub2f4\uc2a4\ub7fd\uace0, \uad00\uad11 \ub3d9\uc120 \ud55c\uac00\uc6b4\ub370\ub9cc \uace0\ub974\uba74 \uc2dd\uc0ac\uc640 \uc0dd\ud65c \ud3b8\uc758\uac00 \uc624\ud788\ub824 \ubd88\ud3b8\ud560 \uc218 \uc788\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\uc740 \uc774\ub3d9\ubcf4\ub2e4 \ud734\uc2dd \ubc00\ub3c4\ub97c \ucc59\uae34\ub2e4<\/h2>\n\n\n\n<p>\uc810\uc2ec\uc740 \ub9c8\uc744 \uc548\uc5d0\uc11c \ud574\uacb0\ud558\uace0 \uc800\ub141\uc740 \uc548\uc2dc \uc911\uc2ec\ubd80\ub85c \ub3cc\uc544\uc640 \uba39\ub294 \ubc29\uc2dd\uc774 \uac00\uc7a5 \uc548\uc804\ud558\ub2e4. \uc791\uc740 \ub9c8\uc744 \uc2dd\ub2f9\uc740 \uc601\uc5c5\uc77c\uacfc \ube0c\ub808\uc774\ud06c \ud0c0\uc784 \ubcc0\ub3d9\uc774 \uc788\uc73c\ubbc0\ub85c \ub2f9\uc77c \uc9c0\ub3c4 \uc815\ubcf4\ub9cc \ubbff\uae30\ubcf4\ub2e4 \uacf5\uc2dd \ucc44\ub110\uc744 \ud568\uaed8 \ubcf4\ub294 \uac83\uc774 \uc88b\ub2e4.<\/p>\n\n\n\n<p>\uc791\uc740 \ub3c4\uc2dc\uc5d0\uc11c\ub294 \uc2dd\ub2f9 \uc218\ubcf4\ub2e4 \uc601\uc5c5 \uc2dc\uac04 \ud655\uc778\uc774 \ub354 \uc911\uc694\ud558\ub2e4. \ud63c\uc790\ub77c\uba74 \uc608\uc57d\uc774 \ud544\uc694\ud55c \uace0\uae09 \uc2dd\ub2f9\ubcf4\ub2e4, \uc810\uc2ec\uacfc \uc800\ub141 \uc0ac\uc774\uc5d0 \uc26c\uc5b4\uac08 \uc218 \uc788\ub294 \uce74\ud398\ub098 \uac04\ub2e8\ud55c \uc2dd\uc0ac\ucc98\ub97c \ud655\ubcf4\ud558\ub294 \ucabd\uc774 \ud604\uc2e4\uc801\uc774\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\uc740 \uc774\ub3d9 \uc2dc\uac04\uc744 \uc904\uc77c\uc218\ub85d \ud6a8\uc728\uc801\uc774\ub2e4<\/h2>\n\n\n\n<p>\uc608\uc0b0\uc740 \uad50\ud1b5\uc218\ub2e8 \uc120\ud0dd\uc5d0 \ub530\ub77c \ub2ec\ub77c\uc9c4\ub2e4. \ubc84\uc2a4\ub97c \uc774\uc6a9\ud558\uba74 \ubd80\ub2f4\uc774 \ub0ae\uc9c0\ub9cc \uc2dc\uac04 \uc81c\uc57d\uc774 \uc0dd\uae30\uace0, \ud0dd\uc2dc\ub098 \ucc28\ub7c9\uc744 \uc4f0\uba74 \uc774\ub3d9\uc740 \ud3b8\ud574\uc9c0\uc9c0\ub9cc \ud558\ub8e8 \ube44\uc6a9\uc774 \ud06c\uac8c \uc624\ub978\ub2e4.<\/p>\n\n\n\n<p>\uc608\uc0b0\uc740 \uc785\uc7a5\ub8cc\ubcf4\ub2e4 \uad50\ud1b5\uacfc \uc219\ubc15\uc5d0\uc11c \ucc28\uc774\uac00 \ub09c\ub2e4. \ub2f9\uc77c\uce58\uae30\ub77c\uba74 \uc655\ubcf5 \uad50\ud1b5\ube44\uc640 \uc2dd\ube44 \uc911\uc2ec\uc73c\ub85c \uacc4\uc0b0\ud558\uace0, 1\ubc15\uc744 \ud55c\ub2e4\uba74 \uc219\uc18c \uc704\uce58\uac00 \uc774\ub3d9\ube44\uc640 \ud53c\ub85c\ub3c4\ub97c \ub3d9\uc2dc\uc5d0 \ubc14\uafbc\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\uc740 \uc870\uc6a9\ud55c \uc0dd\ud65c\uad8c \uc0b0\ucc45\uc744 \uc88b\uc544\ud560 \ub54c \ub9de\ub2e4<\/h2>\n\n\n\n<p>\ud63c\uc790 \uc870\uc6a9\ud788 \uac77\ub294 \uc2dc\uac04\uc744 \uc88b\uc544\ud558\uace0, \uc5ec\ud589\uc9c0\uc758 \uc0dd\ud65c\uac10\uc744 \uad00\ucc30\ud558\ub294 \ub370 \ub9cc\uc871\uc744 \ub290\ub07c\ub294 \uc0ac\ub78c\uc5d0\uac8c \ub9de\ub294\ub2e4. \uc548\uc2dc \uc911\uc2ec\ubd80\uc758 \ud654\ub824\ud568\ubcf4\ub2e4 \uc8fc\ubcc0 \ub9c8\uc744\uc758 \ub290\ub9b0 \ub9ac\ub4ec\uc744 \ubcf4\uace0 \uc2f6\uc740 \uc5ec\ud589\uc790\uc5d0\uac8c \ud2b9\ud788 \uc801\ud569\ud558\ub2e4.<\/p>\n\n\n\n<p>\ubc18\ub300\ub85c \uc9e7\uc740 \uc2dc\uac04\uc5d0 \ub300\ud45c \uba85\uc18c\ub97c \ub9ce\uc774 \ucc0d\uace0 \uc2f6\uc740 \uc5ec\ud589\uc790\ub77c\uba74 \ub9cc\uc871\ub3c4\uac00 \ub0ae\uc744 \uc218 \uc788\ub2e4. \ud504\ub791\uc2a4 \uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\ub294 \uc18d\ub3c4\ub97c \ub0ae\ucdb0\uc57c \uc7a5\uc810\uc774 \ubcf4\uc774\ub294 \ubaa9\uc801\uc9c0\uc774\ubbc0\ub85c, \uc77c\uc815\uc758 \uc131\uacf5 \uae30\uc900\uc744 \u201c\uc5bc\ub9c8\ub098 \ub9ce\uc774 \ubd24\ub294\uac00\u201d\uac00 \uc544\ub2c8\ub77c \u201c\ud63c\uc790 \ubb34\ub9ac \uc5c6\uc774 \uba38\ubb3c \uc218 \uc788\uc5c8\ub294\uac00\u201d\ub85c \uc7a1\ub294 \ud3b8\uc774 \ub0ab\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\uc740 \uba38\ubb34\ub294 \uc5ec\ud589\uc5d0 \ub354 \uac00\uae5d\ub2e4<\/h2>\n\n\n\n<p>\ud504\ub791\uc2a4 \uc548\uc2dc \uadfc\uad50 \ub9c8\uc744 \ud63c\uc790 \uc5ec\ud589: \uc0dd\ud65c\uad8c\ucc98\ub7fc \uba38\ubb34\ub294 \ud558\ub8e8 \uc124\uacc4\uc740 \ud63c\uc790 \uc5ec\ud589\uc790\uc5d0\uac8c \ud654\ub824\ud55c \uc131\ucde8\uac10\uc744 \uc8fc\ub294 \uc77c\uc815\uc740 \uc544\ub2c8\uc9c0\ub9cc, \uc774\ub3d9\uacfc \uccb4\ub958\uc758 \uade0\ud615\uc744 \uc5f0\uc2b5\ud558\uae30 \uc88b\uc740 \ubaa9\uc801\uc9c0\ub2e4. \uacf5\uc2dd \uad50\ud1b5 \uc815\ubcf4, \uc219\uc18c \uc704\uce58, \uc2dd\uc0ac \uac00\ub2a5 \uc2dc\uac04\ub9cc \uc0ac\uc804\uc5d0 \ud655\uc778\ud558\uba74 \ud558\ub8e8 \ub610\ub294 1\ubc15 \uc77c\uc815\uc73c\ub85c \ucda9\ubd84\ud788 \uc124\uacc4\ud560 \uc218 \uc788\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ud504\ub791\uc2a4 \uc548\uc2dc \uadfc\uad50 \ub9c8\uc744\uc744 \ud63c\uc790 